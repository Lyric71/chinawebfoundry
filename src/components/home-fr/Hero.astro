---
/**
 * Hero FR : hero sombre cinématographique avec maquettes UI flottantes en parallaxe,
 * dégradés mesh animés, typographie en dégradé, bandeau de confiance défilant et
 * indicateur de progression au scroll.
 *
 * Le header est superposé à cette section (transparent sur les pages hero).
 */
import Button from '../ui/Button.astro';

const trustBadges = [
  'Bureau à Shanghai',
  'Équipe chinoise sur place',
  'Licence ICP en règle',
  'Visibilité Baidu',
  'Pensés pour DeepSeek et Doubao',
  'Quinze ans à Shanghai',
  'WordPress et Astro',
  'Plumes chinoises maison',
  'Conformes 广告法',
  'UX rodée sur WeChat',
];
---

<section
  data-hero
  class="relative bg-[var(--color-surface-dark)] overflow-hidden min-h-[100vh] flex flex-col"
>
  <!-- ====== ARRIÈRE-PLAN ====== -->
  <!-- Image de skyline en fond -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-wordpress-china-skyline.webp"
      alt=""
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      decoding="async"
      data-hero-bg
    />
    <!-- Voiles dégradés superposés pour la profondeur et le contraste -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a0a0e]/95 via-[#0a0a0e]/80 to-[#0a0a0e]/40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0e]/70 via-transparent to-[#0a0a0e]/95"></div>
  </div>

  <!-- Orbes mesh animés (uniquement dans la famille orange) -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-[10%] -left-32 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/[0.18] blur-[140px] mesh-orb mesh-orb-1"></div>
    <div class="absolute bottom-[5%] -right-20 w-[500px] h-[500px] rounded-full bg-[#FF7E47]/[0.12] blur-[160px] mesh-orb mesh-orb-2"></div>
    <div class="absolute top-1/2 left-1/3 w-[400px] h-[400px] rounded-full bg-white/[0.04] blur-[140px] mesh-orb mesh-orb-3"></div>
  </div>

  <!-- Trame de points -->
  <div
    aria-hidden="true"
    class="absolute inset-0 [background-image:radial-gradient(rgba(255,255,255,0.08)_1px,transparent_1px)] [background-size:38px_38px] pointer-events-none"
  ></div>

  <!-- Idéogramme géant décoratif -->
  <span
    aria-hidden="true"
    class="absolute right-[-4rem] bottom-[-2rem] text-[26rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block"
    data-hero-glyph
  >中</span>

  <!-- Barre de statut en haut (indicateur live) -->
  <div class="relative z-30 mx-auto w-full max-w-[1400px] section-padding pt-24 lg:pt-28">
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/[0.04] backdrop-blur-md border border-white/10">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-brand-orange)] opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-brand-orange)]"></span>
        </span>
        <span class="text-[11px] font-mono uppercase tracking-[0.18em] text-white/70">En direct de Shanghai · 上海</span>
        <span class="text-white/30">·</span>
        <span class="text-[11px] font-mono text-white/55" data-hero-clock>--:--</span>
      </div>
    </div>
  </div>

  <!-- ====== GRILLE PRINCIPALE ====== -->
  <div class="relative z-20 mx-auto w-full max-w-[1400px] section-padding flex-1 flex items-center pt-12 pb-20 lg:pb-28">
    <div class="grid grid-cols-12 gap-8 lg:gap-12 w-full items-center">
      <!-- GAUCHE : titre, CTA, chiffres en direct -->
      <div class="col-span-12 lg:col-span-7" data-hero-text>
        <!-- Surtitre -->
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px w-10 bg-[var(--color-brand-orange)]"></div>
          <span class="text-xs lg:text-sm font-medium tracking-[0.18em] text-[var(--color-brand-orange)] uppercase">
            Agence web · Bureau à Shanghai
          </span>
        </div>

        <!-- Titre avec accent en dégradé -->
        <h1 class="text-[clamp(2.4rem,5.4vw,4.5rem)] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
          Un site pensé
          <span class="block mt-2">
            <span class="relative inline-block">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF9466] to-[var(--color-brand-orange)] bg-clip-text text-transparent">
                à Shanghai
              </span>
            </span>
          </span>
          <span class="block mt-2 text-white/95">pour le public chinois.</span>
        </h1>

        <p class="mt-7 text-base lg:text-xl text-white/65 leading-relaxed max-w-[640px]">
          En Chine, on lit autrement. On achète autrement. On cherche autrement. Nos sites s'adressent au public chinois dans sa langue, sur ses usages mobiles, sur ses moteurs : Baidu, DeepSeek, Doubao.
          <span class="text-white/85 font-medium">Direction à Shanghai, quinze ans sur le terrain.</span>
        </p>

        <!-- CTA -->
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <Button href="/fr/contact/" variant="primary" size="lg">Parlons-en</Button>
          <a
            href="/fr/china-site-scanner/"
            class="group inline-flex items-center gap-3 px-7 py-3 text-base font-medium font-[var(--font-button)] rounded-[var(--radius-pill)] border border-white/20 bg-white/[0.04] backdrop-blur-md text-white hover:bg-white/[0.10] hover:border-white/40 hover:-translate-y-0.5 hover:shadow-[0_8px_25px_rgba(255,255,255,0.10)] active:translate-y-0 no-underline transition-all duration-200"
          >
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-brand-orange)] opacity-60 animate-ping"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-brand-orange)]"></span>
            </span>
            <span>Diagnostic Chine offert</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Bandeau chiffres en direct -->
        <div class="mt-12 grid grid-cols-3 gap-6 max-w-xl">
          <div class="border-l-2 border-[var(--color-brand-orange)]/70 pl-4">
            <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white leading-none"><span data-counter data-counter-suffix="+">15</span></div>
            <div class="text-[10px] uppercase tracking-[0.18em] text-white/50 mt-2">Ans à Shanghai</div>
          </div>
          <div class="border-l-2 border-white/15 pl-4">
            <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white leading-none">SH</div>
            <div class="text-[10px] uppercase tracking-[0.18em] text-white/50 mt-2">Studio chinois</div>
          </div>
          <div class="border-l-2 border-white/15 pl-4">
            <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white leading-none"><span data-counter>10</span></div>
            <div class="text-[10px] uppercase tracking-[0.18em] text-white/50 mt-2">Métiers maison</div>
          </div>
        </div>
      </div>

      <!-- DROITE : maquettes UI flottantes -->
      <div class="hidden lg:block col-span-12 lg:col-span-5 relative h-[560px]" data-hero-mockups>
        <!-- Carte 1 : suivi de classement Baidu -->
        <div
          data-mockup="1"
          class="absolute top-0 right-0 w-[320px] rounded-2xl bg-gradient-to-br from-white/[0.08] via-white/[0.04] to-white/[0.02] backdrop-blur-xl border border-white/15 p-5 shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] mockup-float"
          style="animation-delay: 0s;"
        >
          <div class="flex items-center justify-between mb-4">
            <div class="inline-flex items-center gap-2">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-[#2932E1]/15 border border-[#2932E1]/30 text-[10px] font-bold text-[#7A82FF]">百</span>
              <span class="text-xs font-mono text-white/85">Rang sur Baidu</span>
            </div>
            <span class="inline-flex items-center gap-1 text-[10px] font-mono text-emerald-300">
              <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 4l8 10H4z"/></svg>
              +14
            </span>
          </div>
          <!-- Mini graphique en barres -->
          <div class="flex items-end gap-1.5 h-16 mb-3">
            <div class="flex-1 rounded-sm bg-white/15" style="height: 30%"></div>
            <div class="flex-1 rounded-sm bg-white/20" style="height: 45%"></div>
            <div class="flex-1 rounded-sm bg-white/25" style="height: 38%"></div>
            <div class="flex-1 rounded-sm bg-[var(--color-brand-orange)]/40" style="height: 60%"></div>
            <div class="flex-1 rounded-sm bg-[var(--color-brand-orange)]/60" style="height: 72%"></div>
            <div class="flex-1 rounded-sm bg-[var(--color-brand-orange)]/80" style="height: 85%"></div>
            <div class="flex-1 rounded-sm bg-[var(--color-brand-orange)]" style="height: 95%"></div>
          </div>
          <div class="flex items-baseline justify-between pt-3 border-t border-white/10">
            <div>
              <div class="text-2xl font-medium font-[var(--font-heading)] text-white leading-none">#3</div>
              <div class="text-[9px] uppercase tracking-wider text-white/45 mt-1">企业网站设计</div>
            </div>
            <div class="text-right">
              <div class="text-[10px] font-mono text-white/55">sur sept jours</div>
              <div class="text-[10px] font-mono text-emerald-300">↑ en hausse</div>
            </div>
          </div>
        </div>

        <!-- Carte 2 : licence ICP -->
        <div
          data-mockup="2"
          class="absolute top-[150px] left-0 w-[280px] rounded-2xl bg-gradient-to-br from-emerald-500/[0.10] via-white/[0.04] to-white/[0.02] backdrop-blur-xl border border-emerald-400/25 p-5 shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] mockup-float"
          style="animation-delay: 1.5s;"
        >
          <div class="flex items-center justify-between mb-4">
            <div class="inline-flex items-center gap-2">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-emerald-500/15 text-emerald-300">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-xs font-mono text-white/85">Licence ICP</span>
            </div>
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-emerald-500/15 border border-emerald-400/30">
              <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
              <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-300">Active</span>
            </span>
          </div>
          <div class="text-sm font-mono text-white mb-1">沪ICP备2024XXXXXX号</div>
          <div class="text-[10px] text-white/45">Dépôt chez Aliyun · valable jusqu'en 2027</div>
          <div class="mt-3 pt-3 border-t border-white/10 grid grid-cols-3 gap-2">
            <div>
              <div class="text-[9px] uppercase tracking-wider text-white/40">Province</div>
              <div class="text-xs font-mono text-white/85">Shanghai</div>
            </div>
            <div>
              <div class="text-[9px] uppercase tracking-wider text-white/40">Usage</div>
              <div class="text-xs font-mono text-white/85">B2B</div>
            </div>
            <div>
              <div class="text-[9px] uppercase tracking-wider text-white/40">Année</div>
              <div class="text-xs font-mono text-white/85">2024</div>
            </div>
          </div>
        </div>

        <!-- Carte 3 : performance -->
        <div
          data-mockup="3"
          class="absolute bottom-[140px] right-[20px] w-[260px] rounded-2xl bg-gradient-to-br from-white/[0.08] via-white/[0.04] to-white/[0.02] backdrop-blur-xl border border-white/15 p-5 shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] mockup-float"
          style="animation-delay: 0.7s;"
        >
          <div class="flex items-center justify-between mb-4">
            <div class="inline-flex items-center gap-2">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)]">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </span>
              <span class="text-xs font-mono text-white/85">Chargement · 上海 PVG</span>
            </div>
          </div>
          <div class="flex items-baseline gap-2 mb-3">
            <span class="text-3xl font-medium font-[var(--font-heading)] text-white leading-none">1,2</span>
            <span class="text-sm font-mono text-white/50">s</span>
          </div>
          <!-- Barre de progression -->
          <div class="h-1.5 w-full bg-white/10 rounded-full overflow-hidden mb-2">
            <div class="h-full w-[85%] bg-gradient-to-r from-emerald-400 to-emerald-500 rounded-full"></div>
          </div>
          <div class="flex items-center justify-between text-[10px] font-mono">
            <span class="text-emerald-300">Excellent</span>
            <span class="text-white/45">cible &lt; 2,5 s</span>
          </div>
        </div>

        <!-- Carte 4 : moteurs IA -->
        <div
          data-mockup="4"
          class="absolute bottom-0 left-[20px] w-[300px] rounded-2xl bg-gradient-to-br from-[#8b5cf6]/[0.12] via-white/[0.04] to-white/[0.02] backdrop-blur-xl border border-[#8b5cf6]/25 p-5 shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] mockup-float"
          style="animation-delay: 2.2s;"
        >
          <div class="flex items-center justify-between mb-4">
            <div class="inline-flex items-center gap-2">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-[#8b5cf6]/15 text-[#a78bfa]">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
              </span>
              <span class="text-xs font-mono text-white/85">Citations IA · CN</span>
            </div>
            <span class="text-[10px] font-mono text-white/45">sur trente jours</span>
          </div>
          <div class="space-y-2.5">
            <div class="flex items-center gap-3">
              <span class="text-[10px] font-mono text-white/60 w-16">DeepSeek</span>
              <div class="flex-1 h-1 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full w-[78%] bg-[var(--color-brand-orange)] rounded-full"></div>
              </div>
              <span class="text-[10px] font-mono text-white/85 w-8 text-right">78%</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] font-mono text-white/60 w-16">Doubao</span>
              <div class="flex-1 h-1 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full w-[64%] bg-[#a78bfa] rounded-full"></div>
              </div>
              <span class="text-[10px] font-mono text-white/85 w-8 text-right">64%</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] font-mono text-white/60 w-16">Kimi</span>
              <div class="flex-1 h-1 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full w-[55%] bg-[#7A82FF] rounded-full"></div>
              </div>
              <span class="text-[10px] font-mono text-white/85 w-8 text-right">55%</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] font-mono text-white/60 w-16">Baidu IA</span>
              <div class="flex-1 h-1 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full w-[82%] bg-emerald-400 rounded-full"></div>
              </div>
              <span class="text-[10px] font-mono text-white/85 w-8 text-right">82%</span>
            </div>
          </div>
        </div>

        <!-- Lignes décoratives reliant les cartes -->
        <svg aria-hidden="true" class="absolute inset-0 w-full h-full pointer-events-none opacity-30" viewBox="0 0 500 560" fill="none">
          <line x1="290" y1="100" x2="180" y2="200" stroke="url(#gradLine)" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="180" y1="280" x2="280" y2="380" stroke="url(#gradLine)" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="280" y1="380" x2="180" y2="480" stroke="url(#gradLine)" stroke-width="1" stroke-dasharray="4 4"/>
          <defs>
            <linearGradient id="gradLine" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#F25F29" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#F25F29" stop-opacity="0"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
    </div>
  </div>

  <!-- ====== BANDEAU DE CONFIANCE DÉFILANT ====== -->
  <div class="relative z-20 border-y border-white/10 bg-black/30 backdrop-blur-sm py-4 overflow-hidden">
    <div class="flex gap-12 animate-[marquee_55s_linear_infinite] whitespace-nowrap">
      {[...trustBadges, ...trustBadges, ...trustBadges].map((badge) => (
        <span class="inline-flex items-center gap-2.5 text-sm font-medium text-white/55 hover:text-[var(--color-brand-orange)] transition-colors">
          <svg class="w-3.5 h-3.5 text-[var(--color-brand-orange)]/80" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {badge}
          <span class="text-white/15 ml-2">·</span>
        </span>
      ))}
    </div>
    <!-- Fondus latéraux -->
    <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#0a0a0e] to-transparent pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#0a0a0e] to-transparent pointer-events-none"></div>
  </div>
</section>

<style>
  @keyframes meshDrift1 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(40px, -30px, 0) scale(1.08); }
  }
  @keyframes meshDrift2 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(-50px, 30px, 0) scale(1.1); }
  }
  @keyframes meshDrift3 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(30px, 40px, 0) scale(1.05); }
  }

  .mesh-orb-1 { animation: meshDrift1 18s ease-in-out infinite; }
  .mesh-orb-2 { animation: meshDrift2 22s ease-in-out infinite; }
  .mesh-orb-3 { animation: meshDrift3 16s ease-in-out infinite; }

  @keyframes mockupFloat {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -10px, 0); }
  }
  .mockup-float {
    animation: mockupFloat 6s ease-in-out infinite;
    will-change: transform;
  }

  /* Effet hover plus marqué sur les maquettes */
  [data-mockup] {
    transition: box-shadow 0.4s ease, border-color 0.4s ease;
  }
  [data-mockup]:hover {
    border-color: rgba(242, 95, 41, 0.4);
    box-shadow: 0 30px 70px -20px rgba(242, 95, 41, 0.25);
  }

  @media (prefers-reduced-motion: reduce) {
    .mesh-orb-1, .mesh-orb-2, .mesh-orb-3, .mockup-float {
      animation: none !important;
    }
  }
</style>

<script>
  function initHero() {
    const hero = document.querySelector<HTMLElement>('[data-hero]');
    if (!hero) return;

    // Parallaxe à la souris : l'image de fond et les cartes dérivent à l'inverse du curseur
    const bg = hero.querySelector<HTMLElement>('[data-hero-bg]');
    const mockups = Array.from(hero.querySelectorAll<HTMLElement>('[data-mockup]'));
    const glyph = hero.querySelector<HTMLElement>('[data-hero-glyph]');

    let raf = 0;
    let targetX = 0, targetY = 0;
    let currX = 0, currY = 0;

    function lerp(a: number, b: number, t: number) {
      return a + (b - a) * t;
    }

    function animate() {
      currX = lerp(currX, targetX, 0.06);
      currY = lerp(currY, targetY, 0.06);

      if (bg) {
        bg.style.transform = `scale(1.05) translate3d(${currX * -10}px, ${currY * -10}px, 0)`;
      }
      if (glyph) {
        glyph.style.transform = `translate3d(${currX * -20}px, ${currY * -15}px, 0)`;
      }
      mockups.forEach((card, i) => {
        const factor = (i + 1) * 6;
        card.style.setProperty('--mouse-tx', `${currX * factor}px`);
        card.style.setProperty('--mouse-ty', `${currY * factor}px`);
      });

      if (Math.abs(currX - targetX) > 0.001 || Math.abs(currY - targetY) > 0.001) {
        raf = requestAnimationFrame(animate);
      } else {
        raf = 0;
      }
    }

    function onMove(e: MouseEvent) {
      const rect = hero.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      targetX = (x - 0.5) * 2;
      targetY = (y - 0.5) * 2;
      if (!raf) raf = requestAnimationFrame(animate);
    }

    function onLeave() {
      targetX = 0;
      targetY = 0;
      if (!raf) raf = requestAnimationFrame(animate);
    }

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduceMotion) {
      hero.addEventListener('mousemove', onMove);
      hero.addEventListener('mouseleave', onLeave);
    }

    // Horloge Shanghai en direct (CST = UTC+8)
    const clock = hero.querySelector<HTMLElement>('[data-hero-clock]');
    if (clock) {
      function updateClock() {
        const now = new Date();
        const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
        const sh = new Date(utc + 3600000 * 8);
        const hh = String(sh.getHours()).padStart(2, '0');
        const mm = String(sh.getMinutes()).padStart(2, '0');
        if (clock) clock.textContent = `${hh}:${mm}`;
      }
      updateClock();
      setInterval(updateClock, 30000);
    }
  }

  initHero();
  document.addEventListener('astro:page-load', initHero);
  document.addEventListener('astro:after-swap', initHero);
</script>
