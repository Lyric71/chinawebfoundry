---
/**
 * Hero (FR) : fond photographique pleine largeur, titre à gauche,
 * rangée de badges de confiance, barre de progression en bas.
 *
 * Le header se superpose à cette section (transparent sur les pages hero).
 */
import Button from '../ui/Button.astro';

const badges = ['Bureau à Shanghai', 'Équipe chinoise native', 'Licence ICP', 'Prêt pour Baidu et l’IA'];
---

<section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
  <!-- ====== IMAGE DE FOND ====== -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-wordpress-china-skyline.webp"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
    <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-[#0f0f12]/60 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
  </div>

  <!-- ====== CONTENU ====== -->
  <div class="relative z-20 mx-auto w-full max-w-[1400px] section-padding pt-28 lg:pt-32 pb-10 lg:pb-12">
    <div class="max-w-[720px]">
      <div class="flex items-center gap-3 mb-5">
        <div class="h-px w-8 bg-[var(--color-brand-orange)]"></div>
        <span class="text-sm font-medium tracking-wider text-[var(--color-brand-orange)] uppercase">Agence web en Chine · Bureau à Shanghai</span>
      </div>

      <h1 class="text-[clamp(2.25rem,5vw,4rem)] font-medium font-[var(--font-heading)] text-white leading-[1.06]">
        Un site pour la Chine, ce n’est pas un site traduit.
      </h1>
      <p class="mt-5 text-base lg:text-lg text-white/65 leading-relaxed max-w-[620px]">
        Le public chinois ne lit pas, ne navigue pas et n’achète pas comme ailleurs. Nous bâtissons des sites qui lui parlent vraiment : contenu écrit en chinois, expérience locale, présence sur Baidu et sur les moteurs d’IA chinois. Vingt ans à Shanghai, plus de cinquante marques internationales lancées.
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="md">Échanger avec l’équipe</Button>
        <a
          href="/fr/china-site-scanner/"
          class="inline-flex items-center gap-3 px-7 py-2.5 text-base font-medium font-[var(--font-button)] rounded-[var(--radius-pill)] border border-white/30 text-white hover:bg-white/10 hover:border-white/50 hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,255,255,0.15)] active:translate-y-0 active:shadow-[0_2px_8px_rgba(255,255,255,0.1)] no-underline transition-all duration-200"
        >
          <span>Scanner mon site, gratuitement</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-10 lg:mt-14 flex flex-wrap items-center gap-3">
      {badges.map((badge) => (
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/[0.06] backdrop-blur-sm rounded-[var(--radius-pill)] text-sm text-white/70 font-medium border border-white/[0.06]">
          <svg class="w-4 h-4 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          {badge}
        </span>
      ))}
    </div>
  </div>

  <div class="relative z-20 h-[3px] bg-white/[0.06]">
    <div class="h-full w-1/3 bg-gradient-to-r from-[var(--color-brand-orange)] to-[var(--color-brand-orange)]/60"></div>
  </div>
</section>
