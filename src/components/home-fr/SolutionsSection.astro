    color: #ffffff;
    box-shadow: 0 4px 14px -4px rgba(15, 15, 18, 0.35);
  }
  .phase-tab.is-active span {
    opacity: 1;
    color: #ffffff;
  }

  /* CTA Commencer : orbes dérivants en arrière-plan */
  @keyframes gsDrift1 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(40px, -30px, 0) scale(1.08); }
  }
  @keyframes gsDrift2 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(-50px, 30px, 0) scale(1.1); }
  }
  .gs-orb-1 { animation: gsDrift1 18s ease-in-out infinite; }
  .gs-orb-2 { animation: gsDrift2 22s ease-in-out infinite; }

  /* Cartes UI flottantes sur la scène Commencer */
  @keyframes gsFloat {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -8px, 0); }
  }
  .gs-float-anim {
    animation: gsFloat 6s ease-in-out infinite;
    will-change: transform;
  }

  /* Cartes d'annotation : flottement dispersé + entrée subtile */
  @keyframes gsAnnoFloat {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -6px, 0); }
  }
  @keyframes gsAnnoEnter {
    0% { opacity: 0; transform: translate3d(0, 16px, 0) scale(0.96); }
    100% { opacity: 1; transform: translate3d(0, 0, 0) scale(1); }
  }
  .gs-anno-anim {
    opacity: 0;
    animation:
      gsAnnoEnter 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards,
      gsAnnoFloat 7s ease-in-out 1s infinite;
    animation-delay: var(--anno-delay, 0s), calc(var(--anno-delay, 0s) + 1s);
    will-change: transform;
  }

  /* Survol : lift + glow + bordure orange */
  [data-gs-anno] > div {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  [data-gs-anno]:hover > div {
    transform: translate3d(0, -4px, 0);
    box-shadow: 0 25px 50px -15px rgba(242, 95, 41, 0.35);
    border-color: rgba(242, 95, 41, 0.4);
  }

  /* Wrapper image : léger tilt au survol */
