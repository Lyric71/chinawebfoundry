---
import { getCollection } from 'astro:content';

const services = await getCollection('services-fr');
const byId = (id: string) => services.find((s) => s.id === id);

interface Choice {
  label: string;
  href: string;
}

interface ServiceItem {
  id: string;
  featured?: boolean;
  highlight?: string;
  choices?: Choice[];
}

interface Phase {
  n: string;
  label: string;
  cn: string;
  tagline: string;
  body: string;
  cols: string;
  items: ServiceItem[];
}

const phases: Phase[] = [
  {
    n: '01',
    label: 'Cadrage',
    cn: '策划',
    tagline: 'Le point de départ de toute mission',
    body: 'Avant qu\'une ligne de code ne soit écrite, nous mesurons l\'écart entre votre marque telle qu\'elle est et ce qui résonne réellement en Chine.',
    cols: 'lg:grid-cols-3',
    items: [
      { id: 'strategy-audit', featured: true, highlight: 'Porte d\'entrée la plus fréquente' },
      { id: 'china-migration' },
    ],
  },
  {
    n: '02',
    label: 'Construction',
    cn: '建造',
    tagline: 'Ce que nous posons sur la table',
    body: 'Contenu chinois, ergonomie chinoise, infrastructure chinoise. Fait sur place, fait pour durer.',
    cols: 'lg:grid-cols-2',
    items: [
      { id: 'chinese-content' },
      { id: 'ux-ui-design' },
      {
        id: 'technical-integration',
        choices: [
          { label: 'WordPress', href: '/fr/wordpress/' },
          { label: 'Astro', href: '/fr/astro/' },
        ],
      },
      { id: 'plugins-extensions' },
    ],
  },
  {
    n: '03',
    label: 'Croissance',
    cn: '增长',
    tagline: 'Comment vous restez visibles',
    body: 'Baidu et les nouveaux moteurs IA chinois choisissent qui le public chinois trouve en premier. Notre rôle : qu\'il vous trouve, vous.',
    cols: 'lg:grid-cols-2',
    items: [
      { id: 'baidu-seo' },
      { id: 'geo', highlight: 'Nouveauté 2026' },
    ],
  },
  {
    n: '04',
    label: 'Exploitation',
    cn: '运营',
    tagline: 'Comment le site reste en vie',
    body: 'Hébergement et maintenance pilotés depuis Shanghai. Votre équipe ne touche jamais à une console en chinois.',
    cols: 'lg:grid-cols-2',
    items: [
      { id: 'china-hosting' },
      { id: 'maintenance-support' },
    ],
  },
];

const totalServices = phases.reduce((acc, p) => acc + p.items.length, 0);

// Map des id de services vers des paths SVG inline (style Heroicons, stroke-current)
const iconMap: Record<string, string> = {
  'strategy-audit': 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2zM9 7h6',
  'china-migration': 'M13 5l7 7-7 7M5 5l7 7-7 7',
  'chinese-content': 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10',
  'ux-ui-design': 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
  'technical-integration': 'M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26',
  'plugins-extensions': 'M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.036 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z',
  'china-hosting': 'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z',
  'baidu-seo': 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z',
  'geo': 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z',
  'maintenance-support': 'M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z',
};
---

<!-- Nos services : bento par phase avec scrollspy + parallaxe -->
<section
  id="OurServices"
  data-services-section
  class="relative section-spacing bg-white overflow-hidden"
>
  <!-- Arrière-plan : trame de points + idéogramme décoratif + lueur douce -->
  <div
    aria-hidden="true"
    class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.035] pointer-events-none"
  ></div>
  <div
    aria-hidden="true"
    class="absolute -top-40 right-[8%] w-[520px] h-[520px] rounded-full bg-[var(--color-brand-orange)]/[0.06] blur-[140px] pointer-events-none"
    data-float="slow"
  ></div>
  <span
    aria-hidden="true"
    class="absolute right-[-3rem] top-[8%] text-[22rem] lg:text-[28rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.04] leading-none select-none pointer-events-none hidden md:block"
    data-parallax="0.12"
  >服务</span>

  <div class="relative mx-auto max-w-[1400px] section-padding">
    <!-- En-tête : grille asymétrique avec titre dégradé et rangée de chiffres animés -->
    <div class="grid grid-cols-12 gap-8 lg:gap-12 mb-14 lg:mb-20 items-end">
      <div class="col-span-12 lg:col-span-7" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)]">Nos services · 服务</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.04]">
          Dix services. Quatre phases.
          <span class="block">
            <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Une seule équipe, à Shanghai.</span>
          </span>
        </h2>
        <p class="mt-7 text-lg text-[var(--color-text-body)] leading-relaxed max-w-xl">
          Du cadrage à l'exploitation. Chaque étape de votre arrivée en Chine, prise en main par les mêmes interlocuteurs.
        </p>
      </div>

      <!-- Bandeau chiffres -->
      <div class="col-span-12 lg:col-span-5 grid grid-cols-3 gap-4" data-reveal data-reveal-delay="120">
        <div class="border-l-2 border-[var(--color-brand-orange)] pl-4">
          <div class="text-3xl lg:text-[42px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none"><span data-counter>{totalServices}</span></div>
          <div class="text-[10px] uppercase tracking-[0.16em] text-[var(--color-text-muted)] mt-2.5">Services</div>
        </div>
        <div class="border-l-2 border-[var(--color-text-card-blue)]/40 pl-4">
          <div class="text-3xl lg:text-[42px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none"><span data-counter data-counter-suffix="+">15</span></div>
          <div class="text-[10px] uppercase tracking-[0.16em] text-[var(--color-text-muted)] mt-2.5">Ans sur le terrain</div>
        </div>
        <div class="border-l-2 border-[var(--color-text-card-blue)]/40 pl-4">
          <div class="text-3xl lg:text-[42px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none">SH</div>
          <div class="text-[10px] uppercase tracking-[0.16em] text-[var(--color-text-muted)] mt-2.5">Studio à Shanghai</div>
        </div>
      </div>
    </div>

    <!-- Navigateur de phases : onglets scrollspy -->
    <div
      class="relative mb-12 lg:mb-16 -mx-4 lg:mx-0 px-4 lg:px-0"
      data-reveal
    >
      <div
        class="services-tabs flex items-center gap-2 overflow-x-auto scrollbar-hide rounded-2xl bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] p-2"
        role="tablist"
      >
        {phases.map((p) => (
          <a
            href={`#phase-${p.label.toLowerCase()}`}
            data-phase-tab={p.label.toLowerCase()}
            class="phase-tab relative flex-1 min-w-[150px] inline-flex items-center justify-center gap-3 px-4 py-3 rounded-xl text-sm font-medium font-[var(--font-button)] text-[var(--color-text-muted)] no-underline transition-all duration-300 whitespace-nowrap"
            role="tab"
          >
            <span class="font-semibold">{p.label}</span>
            <span class="text-xs opacity-60">{p.cn}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Rail de progression des phases (piloté par scroll) -->
    <div class="relative">
      <!-- Rail vertical (côté gauche, desktop seulement) -->
      <div
        aria-hidden="true"
        class="hidden lg:block absolute left-0 top-2 bottom-2 w-[2px] bg-[var(--color-surface-border)] rounded-full"
      ></div>
      <div
        aria-hidden="true"
        data-services-rail
        class="hidden lg:block absolute left-0 top-2 w-[2px] bg-gradient-to-b from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] rounded-full origin-top will-change-[height] transition-[height] duration-150 ease-out"
        style="height: 0;"
      ></div>

      <!-- Blocs de phase -->
      <div class="lg:pl-10 space-y-16 lg:space-y-24">
        {phases.map((phase) => (
          <div
            id={`phase-${phase.label.toLowerCase()}`}
            class="phase-block scroll-mt-32"
            data-phase-block={phase.label.toLowerCase()}
          >
            <!-- Bandeau d'en-tête de phase -->
            <div class="relative grid grid-cols-12 gap-6 mb-8 lg:mb-10 items-end" data-reveal>
              <!-- Marqueur de phase (ancré au rail) -->
              <span
                aria-hidden="true"
                class="hidden lg:block absolute -left-[42px] top-3 w-3 h-3 rounded-full bg-[var(--color-brand-orange)] ring-4 ring-white shadow-[0_0_0_2px_var(--color-brand-orange)]"
              ></span>

              <div class="col-span-12 lg:col-span-7">
                <div class="flex items-baseline gap-3 mb-1.5 flex-wrap">
                  <h3 class="text-2xl lg:text-[32px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none">{phase.label}</h3>
                  <span class="text-base font-medium text-[var(--color-text-muted)]">{phase.cn}</span>
                </div>
                <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-snug">{phase.tagline}</p>
              </div>
              <div class="col-span-12 lg:col-span-5">
                <p class="text-sm lg:text-[15px] text-[var(--color-text-muted)] italic leading-relaxed lg:text-right">{phase.body}</p>
              </div>
            </div>

            <!-- Bento des cartes de service -->
            <div class:list={['grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5', phase.cols]}>
              {phase.items.map((item, si) => {
                const service = byId(item.id);
                if (!service) return null;
                const iconPath = iconMap[item.id];

                if (item.featured) {
                  // Carte mise en avant (sombre) : occupe 2 col en lg
                  return (
                    <article
                      data-reveal
                      data-reveal-delay={String(si * 80)}
                      data-cursor-spotlight
                      class="md:col-span-2 lg:col-span-2 lg:row-span-1 group relative rounded-3xl bg-gradient-to-br from-[var(--color-text-dark)] via-[#1f1f24] to-[#0f0f12] text-white p-7 lg:p-9 overflow-hidden transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_30px_70px_-25px_rgba(15,15,18,0.5)]"
                    >
                      <span aria-hidden="true" class="absolute -right-12 -bottom-16 text-[14rem] font-medium font-[var(--font-heading)] text-white/[0.04] leading-none select-none pointer-events-none transition-transform duration-700 group-hover:scale-110 origin-bottom-right">{phase.cn}</span>
                      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"></div>

                      <a href={`/fr/services/${service.id}/`} class="relative no-underline block text-white">
                        <div class="flex items-center gap-2 mb-6">
                          <span class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)] border border-[var(--color-brand-orange)]/20">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                            </svg>
                          </span>
                          {item.highlight && (
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[var(--color-brand-orange)] text-white text-[10px] font-semibold uppercase tracking-[0.12em]">
                              <span class="w-1 h-1 rounded-full bg-white"></span>
                              {item.highlight}
                            </span>
                          )}
                        </div>

                        <h4 class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] leading-tight mb-3.5 text-white">{service.data.title}</h4>
                        <p class="text-base text-white/65 leading-relaxed mb-7 max-w-md">{service.data.description}</p>

                        <div class="inline-flex items-center gap-2 text-sm font-semibold font-[var(--font-button)] text-[var(--color-brand-orange)] transition-all duration-300 group-hover:gap-3.5">
                          Voir le détail · {service.data.shortTitle}
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.25" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                          </svg>
                        </div>
                      </a>
                    </article>
                  );
                }

                if (item.choices && item.choices.length > 0) {
                  // Carte CHOIX avec pastilles de stack
                  return (
                    <article
                      data-reveal
                      data-reveal-delay={String(si * 80)}
                      data-cursor-spotlight
                      class="group relative rounded-3xl bg-white border border-[var(--color-surface-border)] p-7 lg:p-8 overflow-hidden transition-all duration-300 hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_22px_45px_-20px_rgba(15,15,18,0.18)] hover:-translate-y-1"
                    >
                      <div class="relative">
                        <div class="flex items-center gap-2 mb-5">
                          <span class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-[var(--color-brand-orange)]/10 text-[var(--color-brand-orange)] transition-transform duration-300 group-hover:scale-105 group-hover:rotate-[-3deg]">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                            </svg>
                          </span>
                          <span class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-muted)]">Choix de la stack</span>
                        </div>
                        <h4 class="text-xl lg:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3">{service.data.title}</h4>
                        <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed mb-6">{service.data.description}</p>

                        <div class="flex flex-wrap items-center gap-2">
                          <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mr-1">Choisir entre</span>
                          {item.choices.map((choice) => (
                            <a
                              href={choice.href}
                              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-[var(--color-surface-border)] text-xs font-medium font-[var(--font-button)] text-[var(--color-text-dark)] no-underline transition-all duration-200 hover:border-[var(--color-brand-orange)] hover:text-[var(--color-brand-orange)] hover:-translate-y-0.5"
                            >
                              {choice.label}
                              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.25" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                              </svg>
                            </a>
                          ))}
                        </div>
                      </div>
                    </article>
                  );
                }

                // Carte STANDARD
                return (
                  <article
                    data-reveal
                    data-reveal-delay={String(si * 80)}
                    data-cursor-spotlight
                    class="group relative rounded-3xl bg-white border border-[var(--color-surface-border)] p-7 lg:p-8 overflow-hidden transition-all duration-300 hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_22px_45px_-20px_rgba(15,15,18,0.18)] hover:-translate-y-1"
                  >
                    <div class="relative h-full flex flex-col">
                      <div class="flex items-center justify-between mb-5">
                        <span class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-[var(--color-brand-orange)]/10 text-[var(--color-brand-orange)] transition-transform duration-300 group-hover:scale-105 group-hover:rotate-[-3deg]">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                          </svg>
                        </span>
                        {item.highlight && (
                          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[var(--color-brand-orange)]/10 text-[var(--color-brand-orange)] text-[10px] font-semibold uppercase tracking-[0.12em] border border-[var(--color-brand-orange)]/20">
                            <span class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]"></span>
                            {item.highlight}
                          </span>
                        )}
                      </div>
