</style>

<script>
  function initServicesPhaseUI() {
    const section = document.querySelector<HTMLElement>('[data-services-section]');
    if (!section) return;

    const tabs = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-phase-tab]'));
    const blocks = Array.from(document.querySelectorAll<HTMLElement>('[data-phase-block]'));
    const rail = document.querySelector<HTMLElement>('[data-services-rail]');

    if (!tabs.length || !blocks.length) return;

    // Scrollspy : surligne l'onglet actif selon le bloc visible
    const setActive = (name: string) => {
      tabs.forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.phaseTab === name);
      });
    };

    // Choisit le bloc dont le sommet est le plus proche (mais après) une ligne ~30% du haut
    const pickActive = () => {
      const focal = window.innerHeight * 0.3;
      let bestName = '';
      let bestDist = Infinity;
      blocks.forEach((b) => {
        const rect = b.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > window.innerHeight) return;
        const dist = Math.abs(rect.top - focal);
        if (dist < bestDist) {
          bestDist = dist;
          bestName = b.dataset.phaseBlock || '';
        }
      });
      if (bestName) setActive(bestName);
    };

    // Remplissage du rail : progression scroll-driven dans la section
    const updateRail = () => {
      if (!rail) return;
      const rect = section.getBoundingClientRect();
      const total = rect.height;
      const scrolled = Math.min(Math.max(-rect.top + window.innerHeight * 0.3, 0), total);
      const pct = total > 0 ? Math.min(1, scrolled / total) : 0;
      rail.style.height = `calc(${pct * 100}% - 16px)`;
    };

    let raf = 0;
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        pickActive();
        updateRail();
        raf = 0;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();

    // Scroll fluide pour les onglets (compense les headers sticky)
    tabs.forEach((tab) => {
      tab.addEventListener('click', (e) => {
        const href = tab.getAttribute('href');
        if (!href || !href.startsWith('#')) return;
        const target = document.getElementById(href.slice(1));
        if (!target) return;
        e.preventDefault();
        const top = target.getBoundingClientRect().top + window.scrollY - 100;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });
  }

  initServicesPhaseUI();
  document.addEventListener('astro:page-load', initServicesPhaseUI);
  document.addEventListener('astro:after-swap', initServicesPhaseUI);

  // Commencer : parallaxe souris sur les cartes flottantes + barre de progression
  function initGetStarted() {
    const stage = document.querySelector<HTMLElement>('[data-gs-stage]');
    if (!stage) return;

    const floats = Array.from(stage.querySelectorAll<HTMLElement>('[data-gs-float]'));
    const progress = stage.querySelector<HTMLElement>('[data-gs-progress]');
    const img = stage.querySelector<HTMLElement>('[data-gs-img]');

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reduce) {
      let raf = 0;
      let tx = 0, ty = 0, cx = 0, cy = 0;
      const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

      const tick = () => {
        cx = lerp(cx, tx, 0.08);
        cy = lerp(cy, ty, 0.08);
        // Léger décalage de l'image de fond ; les cartes gardent leur animation CSS
        if (img) img.style.transform = `scale(1.03) translate3d(${cx * -10}px, ${cy * -10}px, 0)`;
        if (Math.abs(cx - tx) > 0.001 || Math.abs(cy - ty) > 0.001) {
          raf = requestAnimationFrame(tick);
        } else {
          raf = 0;
        }
      };

      stage.addEventListener('mousemove', (e) => {
        const rect = stage.getBoundingClientRect();
        tx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
        ty = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
        if (!raf) raf = requestAnimationFrame(tick);
      });
      stage.addEventListener('mouseleave', () => {
        tx = 0; ty = 0;
        if (!raf) raf = requestAnimationFrame(tick);
      });
    }
    // référence des floats conservée pour usage futur
    void floats;

    // Anime la barre de progression du livrable à 100% une fois visible
    if (progress) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            requestAnimationFrame(() => {
              if (progress) progress.style.width = '100%';
            });
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.4 });
      io.observe(stage);
    }
  }

  initGetStarted();
  document.addEventListener('astro:page-load', initGetStarted);
  document.addEventListener('astro:after-swap', initGetStarted);
</script>
