---
/**
 * StatsSection : bandeau visuel riche de données combinant
 * - panneau métrique principal avec graphique animé
 * - capture d'écran de produit (tableau de bord analytics Chine)
 * - mini cartes statistiques avec anneaux de progression et barres de comparaison
 * - arrière-plan avec dégradés mesh, trame de points, idéogramme décoratif
 */

interface Industry {
  label: string;
  cn: string;
  pct: number;
}

const industries: Industry[] = [
  { label: 'Luxe et art de vivre', cn: '奢侈品', pct: 90 },
  { label: 'Industrie', cn: '工业', pct: 80 },
  { label: 'Sciences du vivant', cn: '生命科学', pct: 70 },
  { label: 'Pharmacie', cn: '医药', pct: 65 },
  { label: 'Services B2B', cn: 'B2B', pct: 75 },
];

const monthlyTrend = [38, 44, 41, 52, 60, 58, 67, 72, 78, 85, 88, 95];
const monthLabels = ['J','F','M','A','M','J','J','A','S','O','N','D'];
---

<section
  data-stats-section
  class="relative py-20 md:py-28 lg:py-32 overflow-hidden bg-[#0a0a0e]"
>
  <!-- Couches d'arrière-plan -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a2e]/60 via-[#0a0a0e] to-[#0f0f12]"></div>
    <div class="absolute inset-0 [background-image:radial-gradient(rgba(255,255,255,0.06)_1px,transparent_1px)] [background-size:38px_38px] opacity-50"></div>
    <div class="absolute -top-32 left-[12%] w-[520px] h-[520px] rounded-full bg-[var(--color-brand-orange)]/[0.10] blur-[150px]"></div>
    <div class="absolute -bottom-32 right-[10%] w-[480px] h-[480px] rounded-full bg-[#3b82f6]/[0.10] blur-[160px]"></div>
    <span class="absolute right-[-5rem] top-[15%] text-[24rem] lg:text-[28rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none hidden md:block" data-parallax="0.1">数据</span>
  </div>

  <div class="relative z-10 mx-auto max-w-[1400px] section-padding">
    <!-- Bandeau d'en-tête -->
    <div class="grid grid-cols-12 gap-8 mb-14 lg:mb-20 items-end">
      <div class="col-span-12 lg:col-span-7" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/15 border border-[var(--color-brand-orange)]/30 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)]">Les chiffres · 数据</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.06]">
          Quinze ans.
          <span class="block">
            <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF9466] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Équipe native.</span>
          </span>
          <span class="block text-white/95">Un bureau à Shanghai.</span>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-5" data-reveal data-reveal-delay="120">
        <p class="text-base lg:text-lg text-white/65 leading-relaxed">
          De vrais sites WordPress et Astro, de vraies positions sur Baidu, de vraies audiences chinoises. Suivis chaque semaine dans Baidu Tongji, restitués chaque mois.
        </p>
      </div>
    </div>

    <!-- Bento principal des chiffres -->
    <div class="grid grid-cols-12 gap-4 lg:gap-5 mb-5">
      <!-- Métrique principale : années + graphique -->
      <div
        class="col-span-12 md:col-span-6 lg:col-span-5 group relative rounded-3xl bg-gradient-to-br from-white/[0.05] via-white/[0.02] to-transparent border border-white/10 p-7 lg:p-8 overflow-hidden backdrop-blur-sm transition-all duration-300 hover:border-[var(--color-brand-orange)]/40"
        data-reveal
        data-cursor-spotlight
      >
        <span aria-hidden="true" class="absolute -right-12 -bottom-16 text-[16rem] font-medium font-[var(--font-heading)] text-white/[0.03] leading-none select-none">年</span>
        <div class="relative">
          <div class="flex items-center gap-2 mb-5">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l3-3 4 4 5-7"/></svg>
            </span>
            <span class="text-[10px] font-mono uppercase tracking-[0.16em] text-white/45">Ans sur le terrain</span>
          </div>
          <div class="flex items-baseline gap-2 mb-1">
            <span class="text-6xl lg:text-7xl font-medium font-[var(--font-heading)] text-white leading-none"><span data-counter data-counter-suffix="+">15</span></span>
            <span class="text-2xl text-white/55 font-medium">ans</span>
          </div>
          <p class="text-sm text-white/55 mb-6">Équipe dirigeante avec 15 ans de digital et de web en Chine.</p>

          <!-- Mini courbe / aire de tendance -->
          <div class="flex items-end gap-1 h-20 mt-6 mb-2">
            {monthlyTrend.map((v) => (
              <div class="flex-1 flex flex-col justify-end">
                <div class="w-full rounded-t bg-gradient-to-t from-[var(--color-brand-orange)] to-[#FF9466] transition-all duration-500 hover:opacity-100 opacity-80" style={`height: ${v}%`}></div>
              </div>
            ))}
          </div>
          <div class="flex justify-between text-[9px] font-mono text-white/35">
            {monthLabels.map((m) => (<span>{m}</span>))}
          </div>
          <div class="mt-4 pt-4 border-t border-white/10 flex items-center justify-between text-xs font-mono">
            <span class="text-white/55">Feuilles de route remises chaque mois</span>
            <span class="text-emerald-300 inline-flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 4l8 10H4z"/></svg>
              en hausse
            </span>
          </div>
        </div>
      </div>

      <!-- Vitesse du site : anneau de progression -->
      <div
        class="col-span-12 md:col-span-6 lg:col-span-3 group relative rounded-3xl bg-gradient-to-br from-white/[0.05] via-white/[0.02] to-transparent border border-white/10 p-7 lg:p-8 overflow-hidden backdrop-blur-sm transition-all duration-300 hover:border-[var(--color-brand-orange)]/40"
        data-reveal
        data-reveal-delay="80"
        data-cursor-spotlight
      >
        <div class="flex items-center gap-2 mb-5">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)]">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </span>
          <span class="text-[10px] font-mono uppercase tracking-[0.16em] text-white/45">Chargement médian, 上海</span>
        </div>

        <!-- Anneau de progression SVG -->
        <div class="relative w-full aspect-square max-w-[180px] mx-auto my-3">
          <svg class="w-full h-full -rotate-90" viewBox="0 0 120 120">
            <circle cx="60" cy="60" r="50" stroke="rgba(255,255,255,0.08)" stroke-width="8" fill="none"/>
            <circle
              cx="60" cy="60" r="50"
              stroke="url(#ringGrad)"
              stroke-width="8"
              fill="none"
              stroke-linecap="round"
              stroke-dasharray="314"
              stroke-dashoffset="63"
              data-progress-ring
              style="transition: stroke-dashoffset 1.6s cubic-bezier(0.22, 1, 0.36, 1);"
            />
            <defs>
              <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#F25F29"/>
                <stop offset="100%" stop-color="#FF9466"/>
              </linearGradient>
            </defs>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-4xl font-medium font-[var(--font-heading)] text-white leading-none">1,2<span class="text-2xl text-white/55">s</span></span>
            <span class="text-[10px] uppercase tracking-wider text-white/45 mt-1.5">Chargement de page</span>
          </div>
        </div>
        <p class="text-xs text-white/55 text-center mt-2">Temps de chargement médian sur les sites mis en ligne, mesuré depuis Shanghai.</p>
      </div>

      <!-- Répartition par secteurs : graphique en barres -->
      <div
        class="col-span-12 md:col-span-6 lg:col-span-4 group relative rounded-3xl bg-gradient-to-br from-white/[0.05] via-white/[0.02] to-transparent border border-white/10 p-7 lg:p-8 overflow-hidden backdrop-blur-sm transition-all duration-300 hover:border-emerald-400/40"
        data-reveal
        data-reveal-delay="160"
        data-cursor-spotlight
      >
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-emerald-500/15 text-emerald-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M9 17V9m4 8V5m4 12v-6"/></svg>
            </span>
            <span class="text-[10px] font-mono uppercase tracking-[0.16em] text-white/45">Secteurs servis</span>
          </div>
          <span class="text-[10px] font-mono text-white/35">profondeur · 5</span>
        </div>
        <div class="space-y-2.5">
          {industries.map((ind) => (
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-[11px] font-medium text-white/85">{ind.label}</span>
                <span class="text-[10px] font-mono text-white/45">{ind.cn}</span>
              </div>
              <div class="h-1.5 bg-white/[0.06] rounded-full overflow-hidden">
                <div
                  class="h-full bg-gradient-to-r from-emerald-400 to-emerald-300 rounded-full transition-all duration-1000 ease-out origin-left"
                  data-bar
                  data-bar-pct={ind.pct}
                  style="width: 0%"
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Deuxième ligne : métriques suivies + comparaison -->
    <div class="grid grid-cols-12 gap-4 lg:gap-5">
      <!-- Métriques Baidu Tongji suivies -->
      <div
        class="col-span-12 lg:col-span-7 relative rounded-3xl overflow-hidden border border-white/10 group bg-gradient-to-br from-white/[0.05] via-white/[0.02] to-transparent p-7 lg:p-8 backdrop-blur-sm transition-all duration-300 hover:border-[var(--color-brand-orange)]/40"
        data-reveal
        data-cursor-spotlight
      >
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF9466] to-[var(--color-brand-orange)]"></div>

        <div class="flex items-center justify-between mb-6">
          <div class="inline-flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[#2932E1]/15 border border-[#2932E1]/30 text-sm font-bold text-[#7A82FF]">百</span>
            <div>
              <div class="text-[10px] font-mono uppercase tracking-[0.16em] text-white/45">Baidu Tongji · 百度统计</div>
              <div class="text-sm font-medium text-white/85 mt-0.5">Ce que nous surveillons chaque semaine</div>
            </div>
          </div>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-500/15 border border-emerald-400/30">
            <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-300">En direct</span>
          </span>
        </div>

        <!-- Grille des paires de métriques -->
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="rounded-xl bg-white/[0.03] border border-white/5 p-4">
            <div class="text-[10px] font-mono uppercase tracking-wider text-white/45 mb-1">浏览量 PV</div>
            <div class="text-base font-medium text-white">Pages vues quotidiennes</div>
          </div>
          <div class="rounded-xl bg-white/[0.03] border border-white/5 p-4">
            <div class="text-[10px] font-mono uppercase tracking-wider text-white/45 mb-1">访客数 UV</div>
            <div class="text-base font-medium text-white">Visiteurs uniques quotidiens</div>
          </div>
          <div class="rounded-xl bg-white/[0.03] border border-white/5 p-4">
            <div class="text-[10px] font-mono uppercase tracking-wider text-white/45 mb-1">来源 Source</div>
            <div class="text-base font-medium text-white">Baidu, IA, direct, sites tiers</div>
          </div>
          <div class="rounded-xl bg-white/[0.03] border border-white/5 p-4">
            <div class="text-[10px] font-mono uppercase tracking-wider text-white/45 mb-1">关键词 Mots-clés</div>
            <div class="text-base font-medium text-white">Termes indexés et leur position</div>
          </div>
          <div class="rounded-xl bg-white/[0.03] border border-white/5 p-4">
            <div class="text-[10px] font-mono uppercase tracking-wider text-white/45 mb-1">跳出率 Rebond</div>
            <div class="text-base font-medium text-white">Par page d'arrivée, par segment</div>
          </div>
          <div class="rounded-xl bg-white/[0.03] border border-white/5 p-4">
            <div class="text-[10px] font-mono uppercase tracking-wider text-white/45 mb-1">地域 Région</div>
            <div class="text-base font-medium text-white">Répartition par ville, du tier 1 au tier 3</div>
          </div>
        </div>

        <p class="text-sm text-white/65 leading-relaxed pt-4 border-t border-white/10">
          Suivi chaque semaine dans Baidu Tongji. Restitué chaque mois, accompagné des prochaines actions concrètes pour le sprint à venir.
        </p>
      </div>

      <!-- Comparaison : traduit vs natif -->
      <div
        class="col-span-12 lg:col-span-5 group relative rounded-3xl bg-gradient-to-br from-white/[0.05] via-white/[0.02] to-transparent border border-white/10 p-7 lg:p-8 overflow-hidden backdrop-blur-sm transition-all duration-300 hover:border-[var(--color-brand-orange)]/40"
        data-reveal
        data-reveal-delay="120"
        data-cursor-spotlight
      >
        <div class="flex items-center gap-2 mb-6">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)]">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </span>
          <span class="text-[10px] font-mono uppercase tracking-[0.16em] text-white/45">Traduit vs natif</span>
        </div>

        <p class="text-sm text-white/65 leading-relaxed mb-6">Taux de rebond médian, sites de marques étrangères en Chine, sur les 90 premiers jours.</p>

        <!-- Ligne traduit -->
        <div class="mb-5">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-medium text-white/75 inline-flex items-center gap-1.5">
              <svg class="w-3 h-3 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
              Site traduit
            </span>
            <span class="text-sm font-medium font-[var(--font-heading)] text-red-300"><span data-counter data-counter-suffix="%">82</span></span>
          </div>
          <div class="h-2 bg-white/[0.06] rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-red-500 to-red-400 rounded-full transition-all duration-1000 ease-out" data-bar data-bar-pct="82" style="width: 0%"></div>
          </div>
        </div>

        <!-- Ligne natif -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-medium text-white/75 inline-flex items-center gap-1.5">
              <svg class="w-3 h-3 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Rédigé en interne par des natifs
            </span>
            <span class="text-sm font-medium font-[var(--font-heading)] text-emerald-300"><span data-counter data-counter-suffix="%">31</span></span>
          </div>
          <div class="h-2 bg-white/[0.06] rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full transition-all duration-1000 ease-out" data-bar data-bar-pct="31" style="width: 0%"></div>
          </div>
        </div>

        <div class="pt-5 border-t border-white/10 flex items-center justify-between">
          <span class="text-[11px] font-mono text-white/55">Écart</span>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-300">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7-7m0 0l-7 7m7-7v18"/></svg>
            <span>51 points gagnés en votre faveur</span>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initStatsBars() {
    const bars = document.querySelectorAll<HTMLElement>('[data-bar]');
    const ring = document.querySelector<SVGCircleElement>('[data-progress-ring]');

    if (!bars.length && !ring) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          if (el.dataset.bar !== undefined) {
            const pct = parseInt(el.dataset.barPct || '0', 10);
            requestAnimationFrame(() => {
              el.style.width = `${pct}%`;
            });
          }
          if (el.tagName === 'circle') {
            const circle = el as unknown as SVGCircleElement;
            const total = 314;
            const pct = 0.80;
            requestAnimationFrame(() => {
              circle.style.strokeDashoffset = String(total * (1 - pct));
            });
          }
          io.unobserve(el);
        });
      },
      { threshold: 0.4 }
    );

    bars.forEach((b) => io.observe(b));
    if (ring) io.observe(ring as unknown as Element);

    if (reduceMotion) {
      bars.forEach((b) => {
        const pct = parseInt(b.dataset.barPct || '0', 10);
        b.style.transition = 'none';
        b.style.width = `${pct}%`;
      });
      if (ring) {
        ring.style.strokeDashoffset = String(314 * (1 - 0.8));
      }
    }
  }

  initStatsBars();
  document.addEventListener('astro:page-load', initStatsBars);
  document.addEventListener('astro:after-swap', initStatsBars);
</script>
