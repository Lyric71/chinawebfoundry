---
/**
 * Nos cinq priorités : cartes empilées en trois colonnes.
 * Même structure que la section "Que rédiger · 写什么" de /fr/services/chinese-content/
 * - Colonne gauche (sombre) : grand idéogramme + label
 * - Colonne centrale (blanc) : titre + corps
 * - Colonne droite (surface claire) : CTA lien + ce qui est inclus
 */

interface Area {
  label: string;
  cn: string;
  title: string;
  body: string;
  link: { href: string; label: string };
  inside: string[];
}

const areas: Area[] = [
  {
    label: 'Contenu',
    cn: '内容',
    title: 'Un discours qui fait mouche',
    body: 'Nos plumes chinoises reprennent votre propos pour qu\'il sonne juste sur place. Cautions tierces, références reconnues, repères culturels : nous les disposons aux endroits où le lecteur chinois va instinctivement les chercher.',
    link: { href: '/fr/services/chinese-content/', label: 'Contenu chinois' },
    inside: ['Plumes maison', 'Voix de marque en chinois', 'Conformité au 广告法'],
  },
  {
    label: 'UX et UI',
    cn: '体验',
    title: 'Une ergonomie ajustée aux usages chinois',
    body: 'Pensée mobile d\'abord, éprouvée dans le navigateur intégré à WeChat, dessinée pour la façon dont l\'œil chinois balaie une page. QR codes, marqueurs de confiance, badges officiels : chaque élément trouve sa place là où le lecteur va le chercher.',
    link: { href: '/fr/services/ux-ui-design/', label: 'Design UX et UI' },
    inside: ['Mobile d\'abord', 'Éprouvé dans WeChat', 'Confiance posée d\'emblée'],
  },
  {
    label: 'Baidu',
    cn: '百度',
    title: 'Référencement sur Baidu',
    body: 'Baidu joue selon ses propres règles. Critères de classement particuliers, exigences techniques plus serrées que celles de Google. Nous posons les fondations qui lui permettent d\'explorer votre site, puis de le faire remonter dans ses résultats.',
    link: { href: '/fr/services/baidu-seo/', label: 'Référencement Baidu' },
    inside: ['Mots-clés en chinois', 'Console Baidu Webmaster', 'Construction de l\'autorité'],
  },
  {
    label: 'Recherche IA',
    cn: 'IA',
    title: 'Optimisation pour les moteurs IA chinois',
    body: 'Chez les Chinois de moins de 35 ans, la requête tapée recule. La question se pose désormais à DeepSeek, à Doubao, à Kimi, à Yuanbao, au Wenxin de Baidu. L\'IA répond. Le clic n\'a jamais lieu. Notre travail consiste à structurer votre site de telle sorte que ces moteurs citent votre marque dans leur réponse.',
    link: { href: '/fr/services/geo/', label: 'GEO Chine' },
    inside: ['DeepSeek et Doubao', 'Schema et llms.txt', 'Suivi des citations'],
  },
  {
    label: 'Infrastructure',
    cn: '基础',
    title: 'Hébergement et infrastructure en Chine',
    body: 'Hébergement rapide, licence ICP en bonne et due forme, chez Aliyun, Tencent Cloud ou Huawei Cloud. Nous portons toute la chaîne. Votre équipe n\'a jamais à ouvrir une console rédigée en chinois.',
    link: { href: '/fr/services/china-hosting/', label: 'Hébergement en Chine' },
    inside: ['Dépôt ICP', 'Aliyun ou Tencent Cloud', 'Performances supervisées'],
  },
];
---

<section class="relative section-spacing bg-gradient-to-b from-[var(--color-surface-light)] to-white overflow-hidden">
  <!-- Idéogramme flottant décoratif -->
  <span aria-hidden="true" class="absolute -top-24 right-[-2rem] text-[18rem] lg:text-[22rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.04] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.15">焦</span>

  <div class="relative mx-auto max-w-[1400px] section-padding">
    <!-- En-tête -->
    <div class="max-w-3xl mb-14 lg:mb-16" data-reveal>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
        <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">Nos cinq priorités · 焦点</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-5">
        Cinq écueils. Une équipe qui les connaît par cœur.
      </h2>
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
        Contenu, ergonomie, Baidu, intelligence artificielle, infrastructure. Voilà les cinq murs contre lesquels viennent buter les marques étrangères en Chine. Cinq terrains que nous arpentons depuis Shanghai.
      </p>
    </div>

    <!-- Empilement de cartes en trois colonnes -->
    <div class="space-y-5 lg:space-y-6">
      {areas.map((a, i) => (
        <article
          data-reveal
          data-reveal-delay={String(i * 60)}
          data-cursor-spotlight
          class:list={[
            'group relative grid grid-cols-1 lg:grid-cols-12 gap-0 rounded-3xl border border-[var(--color-surface-border)] bg-white overflow-hidden transition-all duration-500',
            'hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_30px_70px_-30px_rgba(15,15,18,0.18)] hover:-translate-y-1',
          ]}
        >
          <!-- Gauche : fond sombre avec idéogramme + label -->
          <div class="lg:col-span-3 relative p-7 lg:p-8 bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white overflow-hidden">
            <span aria-hidden="true" class="absolute right-[-1.5rem] bottom-[-3rem] text-[14rem] font-medium font-[var(--font-heading)] text-white/[0.04] leading-none select-none pointer-events-none transition-transform duration-700 group-hover:scale-110 origin-bottom-right">{a.cn}</span>
            <div class="relative">
              <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-2">{a.label}</div>
              <div class="text-5xl lg:text-6xl font-medium font-[var(--font-heading)] text-white leading-none mb-1.5">{a.cn}</div>
              <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)]/90 font-semibold">Priorité</div>
            </div>
          </div>

          <!-- Centre : titre + corps -->
          <div class="lg:col-span-6 p-7 lg:p-9 flex flex-col justify-center">
            <h3 class="text-2xl lg:text-[26px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4 transition-colors duration-300 group-hover:text-[var(--color-brand-orange)]">
              {a.title}
            </h3>
            <p class="text-[15px] lg:text-base text-[var(--color-text-body)] leading-relaxed">
              {a.body}
            </p>
          </div>

          <!-- Droite : ce qui est inclus + lien CTA -->
          <div class="lg:col-span-3 p-6 lg:p-7 bg-[var(--color-surface-light)] border-t lg:border-t-0 lg:border-l border-[var(--color-surface-border)] flex flex-col justify-between gap-5">
            <div>
              <div class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-muted)] mb-3">Au programme</div>
              <ul class="space-y-2">
                {a.inside.map((item) => (
                  <li class="flex items-start gap-2 text-[13px] text-[var(--color-text-dark)] leading-snug">
                    <svg class="w-3.5 h-3.5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <a
              href={a.link.href}
              class="inline-flex items-center gap-2 text-sm font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] no-underline transition-all duration-300 group-hover:gap-3.5"
            >
              {a.link.label}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.25" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
