---
/**
 * Témoignages : carrousel à rotation automatique.
 * Orange + sombre + clair seulement. Pas de dégradés multicolores.
 */
import { getCollection } from 'astro:content';

const testimonials = (await getCollection('testimonials-fr')).sort(
  (a, b) => a.data.order - b.data.order,
);

interface Item {
  name: string;
  initials: string;
  role: string;
  company: string;
  body: string;
  highlight: string;
  before: string;
  match: string;
  after: string;
  tags: string[];
}

const HIGHLIGHTS: Record<string, string> = {
  Bassetti: 'double culture',
  'Maison suisse de montres de luxe': 'six semaines',
  'Marque alimentaire américaine': 'sous la barre des deux secondes',
};

const TAGS: Record<string, string[]> = {
  Bassetti: ['Stratégie et audit', 'Migration WordPress', 'Référencement Baidu'],
  'Maison suisse de montres de luxe': ['Dépôt ICP', 'Hébergement en Chine', 'Indexation Baidu'],
  'Marque alimentaire américaine': ['Refonte des performances', 'Mise en place CDN', 'Migration'],
};

const items: Item[] = testimonials.map((t) => {
  const body = (t.body || '').trim();
  const highlight = HIGHLIGHTS[t.data.company] || '';
  const idx = highlight ? body.toLowerCase().indexOf(highlight.toLowerCase()) : -1;
  const initials = t.data.name
    .split(' ')
    .filter(Boolean)
    .map((s) => s[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();

  return {
    name: t.data.name,
    initials,
    role: t.data.role,
    company: t.data.company,
    body,
    highlight,
    before: idx === -1 ? body : body.slice(0, idx),
    match: idx === -1 ? '' : body.slice(idx, idx + highlight.length),
    after: idx === -1 ? '' : body.slice(idx + highlight.length),
    tags: TAGS[t.data.company] || [],
  };
});
---

<section
  data-testimonial-section
  class="relative py-24 md:py-32 lg:py-36 overflow-hidden bg-white"
>
  <!-- Arrière-plan discret -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 left-[12%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.05] blur-[140px]"></div>
    <div class="absolute -bottom-32 right-[8%] w-[420px] h-[420px] rounded-full bg-[var(--color-brand-orange)]/[0.04] blur-[140px]"></div>
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:34px_34px] opacity-[0.03]"></div>
  </div>
  <span aria-hidden="true" class="absolute right-[-3rem] top-[8%] text-[20rem] lg:text-[26rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.05] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.12">客户</span>

  <div class="relative z-10 mx-auto max-w-[1200px] section-padding">
    <!-- En-tête -->
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16" data-reveal>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
        <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)]">Ils en parlent · 客户评价</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
        Ils ont vraiment lancé leur marque sur le web chinois.
      </h2>
    </div>

    <!-- Carrousel -->
    <div class="relative" data-testimonial-carousel>
      <!-- Grand guillemet décoratif -->
      <span aria-hidden="true" class="absolute -top-12 -left-2 lg:-left-10 text-[10rem] lg:text-[14rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.10] leading-none select-none pointer-events-none">"</span>

      <!-- Conteneur des slides -->
      <div class="relative" data-slides-container>
        {items.map((t, i) => (
          <article
            data-slide-index={i}
            class:list={[
              'testimonial-slide',
              i === 0 ? '' : 'is-hidden',
            ]}
          >
            <div class="grid grid-cols-12 gap-8 lg:gap-12 items-center">
              <!-- Gauche : avatar + méta -->
              <div class="col-span-12 lg:col-span-4 flex flex-col items-center lg:items-start text-center lg:text-left">
                <div class="relative w-28 h-28 lg:w-32 lg:h-32 rounded-full bg-gradient-to-br from-[var(--color-brand-orange)] via-[#FF7E47] to-[#D94E1F] flex items-center justify-center shadow-[0_18px_40px_-10px_rgba(242,95,41,0.4)] mb-5">
                  <span class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] text-white tracking-wider">{t.initials}</span>
                  <span aria-hidden="true" class="absolute -inset-2 rounded-full border border-dashed border-[var(--color-brand-orange)]/30 animate-[spin_28s_linear_infinite]"></span>
                </div>

                <p class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)]">{t.name}</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">{t.role}</p>
                <p class="text-sm font-medium text-[var(--color-text-card-blue)] mt-1">{t.company}</p>

                {t.tags.length > 0 && (
                  <div class="mt-5 flex flex-wrap justify-center lg:justify-start gap-1.5">
                    {t.tags.map((tag) => (
                      <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-[var(--color-brand-orange)]/[0.08] border border-[var(--color-brand-orange)]/20 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              <!-- Droite : citation -->
              <div class="col-span-12 lg:col-span-8">
                <blockquote class="text-xl md:text-2xl lg:text-[28px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.35]">
                  {t.match
                    ? (
                        <>
                          {t.before}
                          <span class="relative inline-block">
                            <span class="relative z-10 text-[var(--color-brand-orange)] font-semibold">{t.match}</span>
                            <span aria-hidden="true" class="absolute left-0 right-0 bottom-1 h-2 lg:h-3 bg-[var(--color-brand-orange)]/15"></span>
                          </span>
                          {t.after}
                        </>
                      )
                    : t.body}
                </blockquote>

                <div class="mt-7 flex items-center gap-4 justify-center lg:justify-start">
                  <div class="flex items-center gap-0.5">
                    {[1,2,3,4,5].map(() => (
                      <svg class="w-4 h-4 text-[var(--color-brand-orange)]" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
                    ))}
                  </div>
                  <span class="text-xs font-medium text-[var(--color-text-muted)]">Témoignage vérifié</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Contrôles -->
      <div class="mt-10 lg:mt-14 flex items-center justify-between gap-6 flex-wrap">
        <!-- Points -->
        <div class="flex items-center gap-2.5">
          {items.map((_, i) => (
            <button
              type="button"
              data-dot-index={i}
              class:list={[
                'testimonial-dot block h-1.5 rounded-full transition-all duration-500',
                i === 0 ? 'w-12 bg-[var(--color-brand-orange)]' : 'w-6 bg-[var(--color-text-muted)]/25 hover:bg-[var(--color-text-muted)]/45',
              ]}
              aria-label={`Afficher le témoignage ${i + 1}`}
            ></button>
          ))}
        </div>

        <!-- Flèches + anneau de décompte -->
        <div class="flex items-center gap-3">
          <div class="relative w-9 h-9 hidden sm:block" aria-hidden="true">
            <svg class="w-full h-full -rotate-90" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="15" stroke="rgba(0,0,0,0.06)" stroke-width="2" fill="none"/>
              <circle
                data-rotate-progress
                cx="18" cy="18" r="15"
                stroke="var(--color-brand-orange)"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
                stroke-dasharray="94"
                stroke-dashoffset="94"
                style="transition: stroke-dashoffset 6s linear;"
              />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
            </span>
          </div>

          <button
            type="button"
            data-arrow="prev"
            class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-[var(--color-surface-border)] text-[var(--color-text-dark)] hover:border-[var(--color-brand-orange)] hover:text-[var(--color-brand-orange)] hover:bg-[var(--color-brand-orange)]/5 transition-all duration-200"
            aria-label="Témoignage précédent"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button
            type="button"
            data-arrow="next"
            class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-[var(--color-surface-border)] text-[var(--color-text-dark)] hover:border-[var(--color-brand-orange)] hover:text-[var(--color-brand-orange)] hover:bg-[var(--color-brand-orange)]/5 transition-all duration-200"
            aria-label="Témoignage suivant"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>

          <a
            href="/fr/work/"
            class="ml-2 inline-flex items-center gap-2 text-sm font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] no-underline hover:gap-3 transition-all duration-200"
          >
            Voir toutes nos références
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Slides : simple show/hide. Le slide actif s'affiche en flux normal,
     tous les autres sont retirés du layout. Pas d'absolu chaotique. */
  .testimonial-slide {
    display: block;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s cubic-bezier(0.22,1,0.36,1), transform 0.5s cubic-bezier(0.22,1,0.36,1);
  }
  .testimonial-slide.is-hidden {
    display: none;
  }
  .testimonial-slide.is-leaving {
    opacity: 0;
    transform: translateY(8px);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-slide { transition: none; }
  }
</style>

<script>
  function initTestimonialCarousel() {
    const root = document.querySelector<HTMLElement>('[data-testimonial-carousel]');
    if (!root) return;

    const slides = Array.from(root.querySelectorAll<HTMLElement>('.testimonial-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-dot-index]'));
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-arrow="prev"]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-arrow="next"]');
    const ringFg = root.querySelector<SVGCircleElement>('[data-rotate-progress]');

    if (!slides.length) return;

    const ROTATE_MS = 6000;
    const RING_LEN = 94;
    let active = 0;
    let timer: number | null = null;

    function applyDot(idx: number) {
      dots.forEach((d, i) => {
        const isActive = i === idx;
        d.classList.toggle('w-12', isActive);
        d.classList.toggle('bg-[var(--color-brand-orange)]', isActive);
        d.classList.toggle('w-6', !isActive);
        d.classList.toggle('bg-[var(--color-text-muted)]/25', !isActive);
      });
    }

    function show(targetIdx: number) {
      const next = ((targetIdx % slides.length) + slides.length) % slides.length;
      slides.forEach((s, i) => {
        if (i === next) {
          s.classList.remove('is-hidden');
        } else {
          s.classList.add('is-hidden');
        }
      });
      applyDot(next);
      active = next;
      restartRing();
    }

    function restartRing() {
      if (!ringFg) return;
      ringFg.style.transition = 'none';
      ringFg.style.strokeDashoffset = String(RING_LEN);
      void (ringFg as unknown as HTMLElement).getBoundingClientRect();
      requestAnimationFrame(() => {
        ringFg.style.transition = `stroke-dashoffset ${ROTATE_MS}ms linear`;
        ringFg.style.strokeDashoffset = '0';
      });
    }

    function start() {
      stop();
      timer = window.setInterval(() => show(active + 1), ROTATE_MS);
      restartRing();
    }
    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
      if (ringFg) {
        ringFg.style.transition = 'none';
        ringFg.style.strokeDashoffset = String(RING_LEN);
      }
    }

    dots.forEach((d, i) => d.addEventListener('click', () => { show(i); start(); }));
    prevBtn?.addEventListener('click', () => { show(active - 1); start(); });
    nextBtn?.addEventListener('click', () => { show(active + 1); start(); });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) start();
        else stop();
      });
    }, { threshold: 0.3 });
    io.observe(root);
  }

  initTestimonialCarousel();
  document.addEventListener('astro:page-load', initTestimonialCarousel);
  document.addEventListener('astro:after-swap', initTestimonialCarousel);
</script>
