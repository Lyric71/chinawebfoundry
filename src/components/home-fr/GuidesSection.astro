---
import { getCollection } from 'astro:content';
import Button from '../ui/Button.astro';

const guides = (await getCollection('guides-fr'))
  .filter((guide) => guide.data.published)
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 3);
---

<section class="py-14 md:py-28 lg:py-36 bg-[var(--color-surface-light)]">
  <div class="mx-auto max-w-[1400px] section-padding">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-14">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
          Le guide du web chinois
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
          Nos analyses les plus récentes
        </h2>
      </div>
      <div class="flex-shrink-0">
        <Button href="/fr/resources/china-web-guide/" variant="secondary" size="md">Parcourir le guide</Button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {guides.map((guide) => (
        <a
          href={`/fr/resources/china-web-guide/${guide.id}/`}
          class="group flex flex-col bg-white border border-[var(--color-surface-border)] rounded-2xl overflow-hidden no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
        >
          <div class="aspect-[16/9] bg-[var(--color-surface-light)] overflow-hidden">
            <img
              src={guide.data.visual}
              alt=""
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="flex flex-col flex-1 p-6 lg:p-7">
            <h3 class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-2">
              {guide.data.title}
            </h3>
            <p class="text-sm text-[var(--color-brand-orange)] font-medium mb-3 line-clamp-2">
              {guide.data.subtitle}
            </p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-6 flex-1">
              {guide.data.summary}
            </p>
            <span class="inline-flex items-center gap-2 text-sm font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] group-hover:gap-3 transition-all duration-200">
              Lire l’article
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
