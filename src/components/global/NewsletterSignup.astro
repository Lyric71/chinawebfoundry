---
---

<div>
  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)] mb-4">
    Stay Updated
  </h3>
  <p class="text-sm text-[var(--color-text-body)] mb-4">
    Get tips on running WordPress in China, delivered to your inbox.
  </p>
  <form class="flex gap-2" action="#" method="POST">
    <input
      type="email"
      name="email"
      placeholder="Your email"
      required
      class="flex-1 px-4 py-2 bg-[#1A1A1A] text-white rounded-[var(--radius-pill)] placeholder-[var(--color-text-muted)] text-sm border-0 focus:outline-2 focus:outline-[var(--color-brand-orange)]"
    />
    <button
      type="submit"
      class="px-5 py-2 bg-[var(--color-brand-orange)] text-white font-[var(--font-button)] font-medium text-sm rounded-[var(--radius-pill)] hover:bg-[var(--color-brand-orange-hover)] transition-colors cursor-pointer"
    >
      Sign Up Now
    </button>
  </form>
</div>
