---
import { getMainNav } from '../../i18n/navigation';
import { getLangFromUrl, localePath, useTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/ui';

interface Props {
  heroPage?: boolean;
  lang?: Locale;
}

const { heroPage = false, lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const mainNav = getMainNav(currentLang);
const currentPath = Astro.url.pathname;
---

<!-- Mobile menu button -->
<button
  id="mobile-menu-toggle"
  class:list={[
    'mobile-menu-btn md:hidden p-2.5 transition-colors',
    heroPage
      ? 'text-white hover:text-white/70'
      : 'text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)]',
  ]}
  aria-label="Toggle menu"
  aria-expanded="false"
  aria-controls="mobile-menu"
>
  <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
  <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- Mobile menu panel -->
<div
  id="mobile-menu"
  class="hidden fixed inset-0 top-[60px] z-[9999] bg-white md:hidden overflow-y-auto"
  aria-label="Mobile navigation"
>
  <nav class="flex flex-col px-6 py-8">
    {mainNav.map((item) => {
      const hasChildren = item.children && item.children.length > 0;
      const isActive = currentPath === item.href || (item.children && currentPath.startsWith(item.href));

      return hasChildren ? (
        <div class="border-b border-[var(--color-surface-border)]" data-mobile-accordion>
          <button
            type="button"
            class:list={[
              'flex items-center justify-between w-full py-4 text-lg font-medium bg-transparent border-none cursor-pointer text-left',
              isActive
                ? 'text-[var(--color-brand-orange)]'
                : 'text-[var(--color-text-body)]',
            ]}
            aria-expanded="false"
          >
            {item.label}
            <svg class="w-5 h-5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="hidden pb-4 pl-4" data-accordion-content>
            {(() => {
              const hasColumns = item.children?.some((c) => (c as any).column);
              if (!hasColumns) {
                return item.children?.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block py-2 text-base no-underline transition-colors',
                      currentPath === child.href
                        ? 'text-[var(--color-brand-orange)]'
                        : 'text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)]',
                    ]}
                  >
                    {child.label}
                    {child.description && (
                      <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{child.description}</span>
                    )}
                  </a>
                ));
              }
              const groups = [
                { key: 'plan', label: t('nav.plan'), filter: (c: any) => c.column === 'plan', techFilter: null },
                { key: 'build', label: t('nav.build'), filter: (c: any) => c.column === 'build' && !c.subColumn, techFilter: (c: any) => c.column === 'build' && c.subColumn === 'technology' },
                { key: 'grow', label: t('nav.grow'), filter: (c: any) => c.column === 'grow', techFilter: null },
              ];
              return groups.map((group) => {
                const items = item.children?.filter(group.filter) ?? [];
                const techItems = group.techFilter ? (item.children?.filter(group.techFilter) ?? []) : [];
                if (items.length === 0 && techItems.length === 0) return null;
                return (
                  <div class="mt-3 first:mt-0" data-mobile-sub-accordion>
                    <button
                      type="button"
                      class="flex items-center justify-between w-full py-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] bg-transparent border-none cursor-pointer text-left"
                      aria-expanded="false"
                    >
                      {group.label}
                      <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </button>
                    <div class="hidden pl-3" data-sub-accordion-content>
                      {items.map((child) => (
                        <a
                          href={child.href}
                          class:list={[
                            'block py-2 text-base no-underline transition-colors',
                            currentPath === child.href
                              ? 'text-[var(--color-brand-orange)]'
                              : 'text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)]',
                          ]}
                        >
                          {child.label}
                        </a>
                      ))}
                      {techItems.length > 0 && (
                        <>
                          <p class="mt-3 mb-1 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
                            {t('nav.technology')}
                          </p>
                          {techItems.map((child) => (
                            <a
                              href={child.href}
                              class:list={[
                                'block py-2 text-base no-underline transition-colors',
                                currentPath === child.href
                                  ? 'text-[var(--color-brand-orange)]'
                                  : 'text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)]',
                              ]}
                            >
                              {child.label}
                            </a>
                          ))}
                        </>
                      )}
                    </div>
                  </div>
                );
              });
            })()}
            {item.href === localePath('/services/', currentLang) && (
              <a
                href={localePath('/services/', currentLang)}
                class="block py-2 text-sm font-medium text-[var(--color-brand-orange)] no-underline mt-4 inline-flex items-center gap-1.5"
              >
                {t('nav.allServicesMobile')}
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
          </div>
        </div>
      ) : (
        <a
          href={item.href}
          class:list={[
            'block py-4 text-lg font-medium no-underline border-b border-[var(--color-surface-border)] transition-colors',
            isActive
              ? 'text-[var(--color-brand-orange)]'
              : 'text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)]',
          ]}
        >
          {item.label}
        </a>
      );
    })}

    <div class="mt-6 space-y-3">
      <a
        href={localePath('/china-site-scanner/', currentLang)}
        class="flex items-center justify-center gap-2 w-full px-6 py-3 text-base font-medium font-[var(--font-button)] rounded-[var(--radius-pill)] bg-[var(--color-brand-orange)] text-white hover:bg-[var(--color-brand-orange-hover)] no-underline transition-all duration-200"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        {t('nav.chinaSiteScanner')}
      </a>
      <a
        href={localePath('/contact/', currentLang)}
        class="flex items-center justify-center gap-2 w-full px-6 py-3 text-base font-medium font-[var(--font-button)] rounded-[var(--radius-pill)] border border-[var(--color-text-dark)] text-[var(--color-text-dark)] hover:bg-[var(--color-text-dark)] hover:text-white no-underline transition-all duration-200"
      >
        {t('nav.contact')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </nav>
</div>

<script>
  // Move menu panel out of header stacking context into body
  const menuPanel = document.getElementById('mobile-menu');
  if (menuPanel) {
    document.body.appendChild(menuPanel);
  }

  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const mainNavBar = document.getElementById('main-nav-bar');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');
  const header = document.getElementById('site-header');
  const isHeroPage = header?.dataset.heroPage === 'true';

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));

    if (isHeroPage) {
      if (!isOpen) {
        // Menu is opening: force white header background and dark icon
        mainNavBar?.classList.remove('bg-transparent', 'border-white/10');
        mainNavBar?.classList.add('bg-white/95', 'backdrop-blur-sm', 'border-[var(--color-surface-border)]');
        toggle.classList.remove('text-white', 'hover:text-white/70');
        toggle.classList.add('text-[var(--color-text-body)]', 'hover:text-[var(--color-brand-orange)]');
      } else {
        // Menu is closing: restore header based on scroll position
        if (window.scrollY <= 80) {
          mainNavBar?.classList.add('bg-transparent', 'border-white/10');
          mainNavBar?.classList.remove('bg-white/95', 'backdrop-blur-sm', 'border-[var(--color-surface-border)]');
          toggle.classList.add('text-white', 'hover:text-white/70');
          toggle.classList.remove('text-[var(--color-text-body)]', 'hover:text-[var(--color-brand-orange)]');
        }
      }
    }
  });

  // Accordion behaviour (top-level: Services, Resources)
  const accordions = document.querySelectorAll('[data-mobile-accordion]');
  accordions.forEach((accordion) => {
    const btn = accordion.querySelector(':scope > button');
    const content = accordion.querySelector(':scope > [data-accordion-content]');
    const chevron = btn?.querySelector(':scope > svg');

    btn?.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
      content?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });
  });

  // Sub-accordion behaviour (Plan / Build / Technology / Grow inside Services)
  const subAccordions = document.querySelectorAll('[data-mobile-sub-accordion]');
  subAccordions.forEach((accordion) => {
    const btn = accordion.querySelector(':scope > button');
    const content = accordion.querySelector(':scope > [data-sub-accordion-content]');
    const chevron = btn?.querySelector(':scope > svg');

    btn?.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
      content?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });
  });
</script>
