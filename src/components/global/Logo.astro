---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  href?: string;
}

const { size = 'md', href = '/' } = Astro.props;

const sizeClasses = {
  sm: 'w-9 h-9',
  md: 'w-12 h-12',
  lg: 'w-20 h-20',
};
---

<a href={href} class="inline-block no-underline hover:no-underline" aria-label="ChinaWebFoundry - Home">
  <img
    src="/Logo-ChinaWebFoundry-final.webp"
    alt="ChinaWebFoundry logo"
    class={sizeClasses[size]}
    width="62"
    height="62"
    loading="eager"
  />
</a>
