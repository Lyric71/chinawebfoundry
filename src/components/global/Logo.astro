---
interface Props {
  size?: 'sm' | 'md' | 'lg';
}

const { size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'w-10 h-10',
  md: 'w-[62px] h-[62px]',
  lg: 'w-20 h-20',
};
---

<a href="/" class="inline-block no-underline hover:no-underline" aria-label="ChinaWebFoundry - Home">
  <img
    src="/Logo-ChinaWebFoundry-final.png"
    alt="ChinaWebFoundry logo"
    class={sizeClasses[size]}
    width="62"
    height="62"
    loading="eager"
  />
</a>
