---
import { getLangFromUrl, switchLocalePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/ui';

interface Props {
  lang?: Locale;
  heroPage?: boolean;
}

const { lang, heroPage = false } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);

const locales: { code: Locale; label: string; aria: string }[] = [
  { code: 'en', label: 'EN', aria: 'English' },
  { code: 'fr', label: 'FR', aria: 'Français' },
  { code: 'es', label: 'ES', aria: 'Español' },
  { code: 'de', label: 'DE', aria: 'Deutsch' },
];
---

<div class="flex items-center gap-1 text-sm">
  {locales.map((loc, i) => {
    const isActive = loc.code === currentLang;
    return (
      <>
        {i > 0 && (
          <span class:list={[
            'lang-switch-sep text-xs',
            heroPage ? 'text-white/30' : 'text-[var(--color-text-muted)]',
          ]}>|</span>
        )}
        <a
          href={isActive ? Astro.url.pathname : switchLocalePath(Astro.url.pathname, loc.code)}
          class:list={[
            'lang-switch-link',
            isActive ? 'lang-switch-active' : 'lang-switch-inactive',
            'px-1.5 py-0.5 rounded no-underline transition-colors duration-200 font-medium',
            isActive
              ? heroPage
                ? 'text-white'
                : 'text-[var(--color-text-dark)]'
              : heroPage
                ? 'text-white/50 hover:text-white'
                : 'text-[var(--color-text-muted)] hover:text-[var(--color-text-dark)]',
          ]}
          aria-label={loc.aria}
          aria-current={isActive ? 'page' : undefined}
        >
          {loc.label}
        </a>
      </>
    );
  })}
</div>
