---
import Container from '../ui/Container.astro';
import Logo from './Logo.astro';
---

<footer class="border-t border-[var(--color-surface-border)] mt-16">
  <Container class="py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <!-- Column 1: Logo -->
      <div>
        <Logo size="md" />
        <p class="mt-4 text-sm text-[var(--color-text-body)]">
          Expert WordPress solutions for the Chinese market.
        </p>
      </div>

      <!-- Column 2: Links -->
      <div>
        <h3 class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-4">
          Links
        </h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/who-we-are/" class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline">Who We Are</a></li>
          <li><a href="/contact/" class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline">Contact</a></li>
          <li><a href="/privacy-policy/" class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline">Privacy Policy</a></li>
          <li><a href="/terms-of-service/" class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 pt-6 border-t border-[var(--color-surface-border)] text-center text-sm text-[var(--color-text-muted)]">
      &copy; ChinaWebFoundry {new Date().getFullYear()}
    </div>
  </Container>
</footer>
