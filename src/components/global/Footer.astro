---
import { getFooterNav, getLegalNav } from '../../i18n/navigation';
import { getLangFromUrl, localePath, useTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const footerNav = getFooterNav(currentLang);
const legalNav = getLegalNav(currentLang);
---

<!-- Footer: nav columns + social + legal -->
<footer class="bg-[var(--color-surface-light)] mt-0">
  <!-- Main footer content -->
  <div class="mx-auto max-w-[1400px] section-padding py-12 lg:py-16">
    <div class="grid grid-cols-6 sm:grid-cols-12 gap-y-10 gap-x-4 lg:gap-x-4 items-start">
      <!-- Manifesto + logo -->
      <div class="col-span-6 sm:col-span-12 lg:col-span-4">
        <a href={localePath('/', currentLang)} class="inline-block mb-5" aria-label="ChinaWebFoundry - Home">
          <img
            src="/Logo-ChinaWebFoundry-final.webp"
            alt="ChinaWebFoundry logo"
            class="w-9 h-9"
            width="62"
            height="62"
            loading="lazy"
          />
        </a>
        <p class="text-base text-[var(--color-text-body)] leading-relaxed max-w-sm">
          {t('footer.manifesto')}
        </p>
      </div>

      <!-- Services column -->
      <div class="col-span-3 sm:col-span-4 lg:col-span-3">
        <h4 class="text-sm font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-4">
          {t('footer.services')}
        </h4>
        <ul class="space-y-2.5 text-sm">
          {footerNav.services.map((item) => (
            <li>
              <a href={item.href} class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div class="col-span-3 sm:col-span-4 lg:col-span-2">
        <h4 class="text-sm font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-4">
          {t('footer.company')}
        </h4>
        <ul class="space-y-2.5 text-sm">
          {footerNav.company.map((item) => (
            <li>
              <a href={item.href} class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">
                {item.label}
              </a>
            </li>
          ))}
          {footerNav.resources.map((item) => (
            <li>
              <a href={item.href} class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href={localePath('/contact/', currentLang)} class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">
              {t('footer.contact')}
            </a>
          </li>
        </ul>
      </div>

      <!-- Social column -->
      <div class="col-span-6 sm:col-span-4 lg:col-span-3">
        <h4 class="text-sm font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-4">
          {t('footer.connect')}
        </h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href="mailto:hello@beyondbordergroup.com" class="text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)] no-underline transition-colors inline-flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              hello@beyondbordergroup.com
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Built with: tech logos row -->
  <div class="border-t border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding py-6">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8 text-sm text-[var(--color-text-muted)]">
        <span class="font-semibold uppercase tracking-wider text-xs text-[var(--color-text-dark)]">
          {t('footer.builtWith')}
        </span>
        <div class="flex items-center gap-8">
          <a
            href="https://wordpress.org"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WordPress"
            class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] no-underline transition-colors"
          >
            <svg class="h-7 w-7" viewBox="0 0 122.52 122.523" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <g fill="currentColor">
                <path d="m8.708 61.26c0 20.802 12.089 38.779 29.619 47.298l-25.069-68.686c-2.916 6.536-4.55 13.769-4.55 21.388z"/>
                <path d="m96.74 58.608c0-6.495-2.333-10.993-4.334-14.494-2.664-4.329-5.161-7.995-5.161-12.324 0-4.831 3.664-9.328 8.825-9.328.233 0 .454.029.681.042-9.35-8.566-21.807-13.796-35.489-13.796-18.36 0-34.513 9.42-43.91 23.688 1.233.037 2.395.063 3.382.063 5.497 0 14.006-.667 14.006-.667 2.833-.167 3.167 3.994.337 4.329 0 0-2.847.335-6.015.501l19.138 56.925 11.501-34.493-8.188-22.434c-2.83-.166-5.511-.501-5.511-.501-2.832-.166-2.5-4.496.332-4.329 0 0 8.679.667 13.843.667 5.496 0 14.006-.667 14.006-.667 2.835-.167 3.168 3.994.337 4.329 0 0-2.853.335-6.015.501l18.992 56.494 5.242-17.517c2.272-7.269 4.001-12.49 4.001-16.989z"/>
                <path d="m62.184 65.857-15.768 45.819c4.708 1.384 9.687 2.141 14.846 2.141 6.12 0 11.989-1.058 17.452-2.979-.141-.225-.269-.464-.374-.724z"/>
                <path d="m107.376 36.046c.226 1.674.354 3.471.354 5.404 0 5.333-.996 11.328-3.996 18.824l-16.053 46.413c15.624-9.111 26.133-26.038 26.133-45.426.001-9.137-2.333-17.729-6.438-25.215z"/>
                <path d="m61.262 0c-33.779 0-61.262 27.481-61.262 61.26 0 33.783 27.483 61.263 61.262 61.263 33.778 0 61.265-27.48 61.265-61.263-.001-33.779-27.487-61.26-61.265-61.26zm0 119.715c-32.23 0-58.453-26.223-58.453-58.455 0-32.23 26.222-58.451 58.453-58.451 32.229 0 58.45 26.221 58.45 58.451 0 32.232-26.221 58.455-58.45 58.455z"/>
              </g>
            </svg>
            <span class="text-base font-medium">WordPress</span>
          </a>
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Astro"
            class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] no-underline transition-colors"
          >
            <svg class="h-7 w-auto" viewBox="0 0 85 107" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path fill="currentColor" d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z"/>
              <path fill="currentColor" d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z"/>
            </svg>
            <span class="text-base font-medium">Astro</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Legal bar -->
  <div class="border-t border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding py-6">
      <div class="flex flex-col gap-4 text-sm text-[var(--color-text-muted)]">
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
          <span>Copyright {new Date().getFullYear()} - BeyondBorderGroup Ltd - Hong Kong</span>
          <span class="hidden sm:inline text-[var(--color-surface-border)]">|</span>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 sm:gap-x-4">
            <a href="https://beyondbordergroup.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">beyondbordergroup.com</a>
            <span class="text-[var(--color-surface-border)]">|</span>
            <a href="https://hubstudio.ai" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">hubstudio.ai</a>
            <span class="text-[var(--color-surface-border)]">|</span>
            <a href="https://nuvora.studio" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">nuvora.studio</a>
            <span class="text-[var(--color-surface-border)]">|</span>
            <a href="https://theredscroll.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">theredscroll.com</a>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
          {legalNav.map((item) => (
            <a href={item.href} class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] no-underline transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
