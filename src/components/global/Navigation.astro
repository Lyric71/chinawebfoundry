---
import { getMainNav } from '../../i18n/navigation';
import { getLangFromUrl, localePath, useTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/ui';

interface Props {
  class?: string;
  heroPage?: boolean;
  lang?: Locale;
}

const { class: className, heroPage = false, lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const mainNav = getMainNav(currentLang);
const currentPath = Astro.url.pathname;

const planServices = mainNav[0].children?.filter((s) => s.column === 'plan') ?? [];
const buildServices = mainNav[0].children?.filter((s) => s.column === 'build' && !s.subColumn) ?? [];
const buildTechnology = mainNav[0].children?.filter((s) => s.column === 'build' && s.subColumn === 'technology') ?? [];
const growServices = mainNav[0].children?.filter((s) => s.column === 'grow') ?? [];
---

<nav class:list={['hidden md:flex items-center gap-8', className]} aria-label="Main navigation">
  {mainNav.map((item) => {
    const isActive = currentPath === item.href || (item.children && currentPath.startsWith(item.href));
    const hasChildren = item.children && item.children.length > 0;
    const isServices = item.label === 'Services';

    return hasChildren ? (
      <div class="relative group" data-dropdown>
        <button
          type="button"
          class:list={[
            'flex items-center gap-1.5 text-sm font-normal no-underline transition-colors duration-200 bg-transparent border-none cursor-pointer',
            heroPage ? 'nav-link-hero' : '',
            isActive
              ? 'text-[var(--color-brand-orange)]'
              : heroPage
                ? 'text-white/90 hover:text-white'
                : 'text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)]',
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          {item.label}
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        {isServices ? (
          <div
            class="invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-200 absolute top-full left-1/2 -translate-x-1/2 pt-4 z-50"
            role="menu"
          >
            <div class="bg-white rounded-lg shadow-lg border border-[var(--color-surface-border)] p-8 w-[720px]">
              <div class="grid grid-cols-3 gap-8">
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t('nav.plan')}</h4>
                  <ul class="space-y-4" role="none">
                    {planServices.map((service) => (
                      <li role="none">
                        <a href={service.href} role="menuitem" class:list={['block no-underline', currentPath === service.href ? 'text-[var(--color-brand-orange)]' : 'text-[var(--color-text-dark)] hover:text-[var(--color-brand-orange)]']}>
                          <span class="text-sm font-medium">{service.label}</span>
                          {service.description && <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{service.description}</span>}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t('nav.build')}</h4>
                  <ul class="space-y-4" role="none">
                    {buildServices.map((service) => (
                      <li role="none">
                        <a href={service.href} role="menuitem" class:list={['block no-underline', currentPath === service.href ? 'text-[var(--color-brand-orange)]' : 'text-[var(--color-text-dark)] hover:text-[var(--color-brand-orange)]']}>
                          <span class="text-sm font-medium">{service.label}</span>
                          {service.description && <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{service.description}</span>}
                        </a>
                      </li>
                    ))}
                  </ul>
                  {buildTechnology.length > 0 && (
                    <>
                      <h5 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mt-6 mb-3">{t('nav.technology')}</h5>
                      <ul class="space-y-4" role="none">
                        {buildTechnology.map((service) => (
                          <li role="none">
                            <a href={service.href} role="menuitem" class:list={['block no-underline', currentPath === service.href ? 'text-[var(--color-brand-orange)]' : 'text-[var(--color-text-dark)] hover:text-[var(--color-brand-orange)]']}>
                              <span class="text-sm font-medium">{service.label}</span>
                              {service.description && <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{service.description}</span>}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </>
                  )}
                </div>
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t('nav.grow')}</h4>
                  <ul class="space-y-4" role="none">
                    {growServices.map((service) => (
                      <li role="none">
                        <a href={service.href} role="menuitem" class:list={['block no-underline', currentPath === service.href ? 'text-[var(--color-brand-orange)]' : 'text-[var(--color-text-dark)] hover:text-[var(--color-brand-orange)]']}>
                          <span class="text-sm font-medium">{service.label}</span>
                          {service.description && <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{service.description}</span>}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
              <div class="mt-6 pt-4 border-t border-[var(--color-surface-border)]">
                <a href={localePath('/services/', currentLang)} class="text-sm font-medium text-[var(--color-brand-orange)] hover:text-[var(--color-brand-orange-hover)] no-underline inline-flex items-center gap-1.5">
                  {t('nav.allServices')}
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ) : (
          <div
            class="invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-200 absolute top-full left-0 pt-4 z-50"
            role="menu"
          >
            <div class="bg-white rounded-lg shadow-lg border border-[var(--color-surface-border)] p-4 min-w-[220px]">
              <ul class="space-y-3" role="none">
                {item.children?.map((child) => (
                  <li role="none">
                    <a href={child.href} role="menuitem" class:list={['block no-underline', currentPath === child.href ? 'text-[var(--color-brand-orange)]' : 'text-[var(--color-text-dark)] hover:text-[var(--color-brand-orange)]']}>
                      <span class="text-sm font-medium">{child.label}</span>
                      {child.description && <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{child.description}</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        )}
      </div>
    ) : (
      <a
        href={item.href}
        class:list={[
          'text-sm font-normal no-underline transition-colors duration-200',
          heroPage ? 'nav-link-hero' : '',
          isActive
            ? 'text-[var(--color-brand-orange)]'
            : heroPage
              ? 'text-white/90 hover:text-white'
              : 'text-[var(--color-text-body)] hover:text-[var(--color-brand-orange)]',
        ]}
      >
        {item.label}
      </a>
    );
  })}
</nav>

<script>
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const dropdowns = document.querySelectorAll('[data-dropdown]');
      dropdowns.forEach((dropdown) => {
        const btn = dropdown.querySelector('button');
        btn?.setAttribute('aria-expanded', 'false');
      });
      (document.activeElement as HTMLElement)?.blur();
    }
  });

  const dropdowns = document.querySelectorAll('[data-dropdown]');
  dropdowns.forEach((dropdown) => {
    const btn = dropdown.querySelector('button');
    dropdown.addEventListener('mouseenter', () => btn?.setAttribute('aria-expanded', 'true'));
    dropdown.addEventListener('mouseleave', () => btn?.setAttribute('aria-expanded', 'false'));
  });
</script>
