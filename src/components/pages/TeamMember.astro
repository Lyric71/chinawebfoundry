---
interface Props {
  name: string;
  role: string;
  photo: string;
  bio: string;
}

const { name, role, photo, bio } = Astro.props;
---

<div class="flex flex-col sm:flex-row gap-6 items-start">
  <img
    src={photo}
    alt={`Photo of ${name}`}
    class="w-24 h-24 rounded-full object-cover flex-shrink-0"
    width="96"
    height="96"
    loading="lazy"
  />
  <div>
    <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)]">{name}</h3>
    <p class="text-sm text-[var(--color-brand-orange)] font-medium mb-2">{role}</p>
    <p class="text-base text-[var(--color-text-body)]">{bio}</p>
  </div>
</div>
