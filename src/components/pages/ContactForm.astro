---
import Button from '../ui/Button.astro';
---

<div class="max-w-3xl mx-auto">
  <!-- Header banner -->
  <div class="flex items-center gap-4 bg-[var(--color-surface-light)] rounded-t-xl px-6 py-5 border border-[var(--color-surface-border)]">
    <div class="flex-shrink-0 w-12 h-12 bg-[var(--color-text-card-blue)]/10 rounded-full flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--color-text-card-blue)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
    </div>
    <div>
      <h2 class="text-xl font-semibold text-[var(--color-text-dark)]">Tell us about your project</h2>
      <p class="text-sm text-[var(--color-text-muted)]">Fields marked * are required.</p>
    </div>
  </div>

  <!-- Form body -->
  <form action="#" method="POST" class="bg-white rounded-b-xl border border-t-0 border-[var(--color-surface-border)] px-6 py-8 space-y-6">
    <!-- Row 1: Name + Email -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Your name <span class="text-[var(--color-brand-orange)]">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Jane Smith"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
      <div>
        <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Your email <span class="text-[var(--color-brand-orange)]">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="jane@company.com"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
    </div>

    <!-- Row 2: Phone + Website -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="phone" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Your phone <span class="text-[var(--color-text-muted)] font-normal normal-case">(optional)</span>
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="+44 20 7946 0958"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
      <div>
        <label for="website" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Your website <span class="text-[var(--color-brand-orange)]">*</span>
        </label>
        <input
          type="url"
          id="website"
          name="website"
          required
          placeholder="https://yourcompany.com"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
    </div>

    <!-- Row 3: Company name -->
    <div>
      <label for="company" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
        Your company name <span class="text-[var(--color-brand-orange)]">*</span>
      </label>
      <input
        type="text"
        id="company"
        name="company"
        required
        placeholder="Acme Ltd"
        class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
      />
    </div>

    <!-- Row 4: Project description -->
    <div>
      <label for="project" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
        Your project <span class="text-[var(--color-brand-orange)]">*</span>
      </label>
      <textarea
        id="project"
        name="project"
        rows="5"
        required
        placeholder="Tell us about your project, goals, and timeline..."
        class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent resize-vertical"
      ></textarea>
    </div>

    <Button type="submit" variant="primary" size="lg" class="w-full">Send Message</Button>
  </form>
</div>
