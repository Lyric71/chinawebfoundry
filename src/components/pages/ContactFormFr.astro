---
import Button from '../ui/Button.astro';
---

<div class="max-w-3xl mx-auto">
  <!-- Header banner -->
  <div class="flex items-center gap-4 bg-[var(--color-surface-light)] rounded-t-xl px-6 py-5 border border-[var(--color-surface-border)]">
    <div class="flex-shrink-0 w-12 h-12 bg-[var(--color-text-card-blue)]/10 rounded-full flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--color-text-card-blue)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
    </div>
    <div>
      <h2 class="text-xl font-semibold text-[var(--color-text-dark)]">Décrivez-nous votre projet</h2>
      <p class="text-sm text-[var(--color-text-muted)]">Les champs marqués * sont obligatoires.</p>
    </div>
  </div>

  <!-- Form body -->
  <form id="contact-form" class="bg-white rounded-b-xl border border-t-0 border-[var(--color-surface-border)] px-6 py-8 space-y-6">
    <!-- Row 1: Name + Email -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Nom complet <span class="text-[var(--color-brand-orange)]">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Marie Dupont"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
      <div>
        <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Adresse e-mail <span class="text-[var(--color-brand-orange)]">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="marie@entreprise.fr"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
    </div>

    <!-- Row 2: Phone + Website -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="phone" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Téléphone <span class="text-[var(--color-text-muted)] font-normal normal-case">(facultatif)</span>
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="+33 1 23 45 67 89"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
      <div>
        <label for="website" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
          Site web actuel <span class="text-[var(--color-brand-orange)]">*</span>
        </label>
        <input
          type="url"
          id="website"
          name="website"
          required
          placeholder="https://votreentreprise.fr"
          class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
        />
      </div>
    </div>

    <!-- Row 3: Company name -->
    <div>
      <label for="company" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
        Entreprise <span class="text-[var(--color-brand-orange)]">*</span>
      </label>
      <input
        type="text"
        id="company"
        name="company"
        required
        placeholder="Dupont SAS"
        class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent"
      />
    </div>

    <!-- Row 4: Project description -->
    <div>
      <label for="project" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dark)] mb-2">
        Votre projet en quelques lignes <span class="text-[var(--color-brand-orange)]">*</span>
      </label>
      <textarea
        id="project"
        name="project"
        rows="5"
        required
        placeholder="Contexte, objectifs, calendrier souhaité..."
        class="w-full px-4 py-3 border border-[var(--color-surface-border)] rounded-lg text-[var(--color-text-body)] placeholder:text-[var(--color-text-muted)] focus:outline-2 focus:outline-[var(--color-brand-orange)] focus:border-transparent resize-vertical"
      ></textarea>
    </div>

    <!-- Honeypot field for spam protection -->
    <div class="hidden" aria-hidden="true">
      <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
    </div>

    <!-- Status message -->
    <div id="form-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <Button type="submit" variant="primary" size="lg" class="w-full">Envoyer</Button>
  </form>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check
    const honeypot = form.querySelector<HTMLInputElement>('input[name="website_url"]');
    if (honeypot && honeypot.value) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi en cours...';
    statusEl.classList.add('hidden');

    const data = {
      name: (form.querySelector('#name') as HTMLInputElement).value,
      email: (form.querySelector('#email') as HTMLInputElement).value,
      phone: (form.querySelector('#phone') as HTMLInputElement).value,
      website: (form.querySelector('#website') as HTMLInputElement).value,
      company: (form.querySelector('#company') as HTMLInputElement).value,
      project: (form.querySelector('#project') as HTMLTextAreaElement).value,
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok && result.success) {
        statusEl.textContent = 'Bien reçu. Nous revenons vers vous sous 24 heures.';
        statusEl.className = 'rounded-lg px-4 py-3 text-sm font-medium bg-green-50 text-green-800 border border-green-200';
        form.reset();
      } else {
        statusEl.textContent = result.error || 'Un problème est survenu. Merci de réessayer.';
        statusEl.className = 'rounded-lg px-4 py-3 text-sm font-medium bg-red-50 text-red-800 border border-red-200';
      }
    } catch {
      statusEl.textContent = 'Impossible de joindre le serveur. Vérifiez votre connexion et réessayez.';
      statusEl.className = 'rounded-lg px-4 py-3 text-sm font-medium bg-red-50 text-red-800 border border-red-200';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
