---
interface Props {
  question: string;
  id: string;
}

const { question, id } = Astro.props;
---

<div class="border-b border-[var(--color-surface-border)]" data-faq-item>
  <h3 class="flex">
    <button
      type="button"
      class="flex flex-1 items-center justify-between gap-4 py-5 text-left text-base sm:text-lg font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] transition-colors hover:text-[var(--color-text-body)]/60 cursor-pointer"
      aria-expanded="false"
      aria-controls={`faq-content-${id}`}
      data-faq-trigger
    >
      {question}
      <svg
        class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform duration-200"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
        data-faq-chevron
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
  </h3>
  <div
    id={`faq-content-${id}`}
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-200 ease-out"
    data-faq-content
    role="region"
  >
    <div class="overflow-hidden">
      <div class="pb-5 text-base text-[var(--color-text-body)] leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>
