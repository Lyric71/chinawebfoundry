---
interface Props {
  question: string;
  answer: string;
  id: string;
  searchKey: string;
}

const { question, answer, id, searchKey } = Astro.props;
---

<div
  class="faq-card group relative rounded-2xl bg-white border border-[var(--color-surface-border)]/70 transition-all duration-300 hover:border-[var(--color-brand-orange)]/40 hover:shadow-[0_8px_30px_rgba(33,33,33,0.08)] overflow-hidden"
  data-faq-item
  data-search={searchKey}
>
  <span class="absolute left-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-[var(--color-brand-orange)] to-[#FF8A4C] scale-y-0 origin-top transition-transform duration-300 group-data-[open=true]:scale-y-100"></span>

  <h3 class="flex">
    <button
      type="button"
      class="flex flex-1 items-start gap-4 px-5 sm:px-6 py-5 text-left cursor-pointer w-full"
      aria-expanded="false"
      aria-controls={`faq-content-${id}`}
      data-faq-trigger
    >
      <span class="mt-1 grid place-items-center w-7 h-7 rounded-full bg-[var(--color-surface-light)] text-[var(--color-text-muted)] shrink-0 transition-all duration-300 group-hover:bg-[var(--color-brand-orange)]/10 group-hover:text-[var(--color-brand-orange)] group-data-[open=true]:bg-[var(--color-brand-orange)] group-data-[open=true]:text-white" aria-hidden="true">
        <svg class="w-3.5 h-3.5 transition-transform duration-300 group-data-[open=true]:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12h14" />
        </svg>
      </span>
      <span class="flex-1 text-base sm:text-lg font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug transition-colors group-hover:text-[var(--color-brand-orange)]">
        {question}
      </span>
    </button>
  </h3>

  <div
    id={`faq-content-${id}`}
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out"
    data-faq-content
    role="region"
  >
    <div class="overflow-hidden">
      <div class="px-5 sm:px-6 pb-6 pl-[60px] sm:pl-[64px] text-[15px] sm:text-base text-[var(--color-text-body)] leading-relaxed opacity-0 -translate-y-1 transition-all duration-300 group-data-[open=true]:opacity-100 group-data-[open=true]:translate-y-0">
        <p>{answer}</p>
      </div>
    </div>
  </div>
</div>
