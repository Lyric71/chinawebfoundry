---
import Card from '../ui/Card.astro';

interface Props {
  title: string;
  subtitle: string;
  description: string;
}

const { title, subtitle, description } = Astro.props;
---

<Card hover padding="md">
  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)] mb-1">
    {title}
  </h3>
  <p class="text-sm font-medium text-[var(--color-text-dark)] mb-2">
    {subtitle}
  </p>
  <p class="text-sm text-[var(--color-text-body)]">
    {description}
  </p>
</Card>
