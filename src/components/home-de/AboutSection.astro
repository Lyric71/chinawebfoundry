---
import Button from '../ui/Button.astro';
---

<!-- Warum wir: iO-Stil-Layout mit Hintergrundkreis + Fotoraster -->
<section class="py-24 md:py-32 lg:py-40 overflow-hidden">
  <div class="mx-auto max-w-[1400px] section-padding">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 xl:gap-20">

      <!-- Links: Text in einem großen dekorativen Kreis -->
      <div class="relative lg:w-[50%] flex-shrink-0">
        {/* Großer Hintergrundkreis */}
        <div class="absolute inset-0 -left-4 sm:-left-16 -top-12 -bottom-12 bg-[var(--color-surface-light)] rounded-full scale-110 lg:scale-125 origin-center"></div>

        <div class="relative z-10 py-12 lg:py-16 pr-4 lg:pr-8">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Warum wir
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.12] mb-6">
            Ihr Markenteam hinter der Firewall
          </h2>
          <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed mb-4">
            Wer das chinesische Publikum erreichen will, braucht Mitarbeiter, die täglich in dessen Welt leben: chinesische Muttersprachler als Texter, Designer, die jede Website zuerst in WeChat öffnen, und SEO-Fachleute, die auf Baidu ranken statt auf Google.
          </p>
          <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed mb-10">
            Alle fest angestellt, unter einem Dach, in einem Büro in Shanghai. An der Spitze stehen Köpfe, die ausländische Marken seit 15 Jahren in China etablieren.
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <Button href="/de/ueber-uns/" variant="primary" size="md">Unsere Geschichte</Button>
            <Button href="/de/ressourcen/faq/" variant="secondary" size="md">FAQ lesen</Button>
          </div>
        </div>
      </div>

      <!-- Rechts: 2x2-Fotoraster mit abgerundeten Innenecken -->
      <div class="lg:w-[50%] flex-shrink-0">
        <div class="grid grid-cols-2 gap-3 lg:gap-4 about-photo-grid">
          {/* Oben links - Teamfoto */}
          <div class="aspect-square overflow-hidden about-img-tl">
            <img
              src="/images/team/team-photo.webp"
              alt="Das Team von ChinaWebFoundry in Shanghai"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          {/* Oben rechts - Zusammenarbeit */}
          <div class="aspect-square overflow-hidden about-img-tr">
            <img
              src="/images/who-we-are-collaboration.webp"
              alt="Das Team von ChinaWebFoundry bei der Arbeit in einem Studio in Shanghai"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          {/* Unten links - Büro */}
          <div class="aspect-square overflow-hidden about-img-bl">
            <img
              src="/images/hero-who-we-are-office.webp"
              alt="Das Büro von ChinaWebFoundry in Shanghai"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          {/* Unten rechts - Teamfoto (Detail) */}
          <div class="aspect-square overflow-hidden about-img-br">
            <img
              src="/images/team/team-photo.webp"
              alt="Die Redaktions- und Designteams von ChinaWebFoundry"
              class="w-full h-full object-cover object-right"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Jede Innenecke erhält einen großen Radius, um den Effekt zu erzeugen */
  .about-img-tl {
    border-radius: 8px 8px 50% 8px;
  }
  .about-img-tr {
    border-radius: 8px 8px 8px 50%;
  }
  .about-img-bl {
    border-radius: 8px 50% 8px 8px;
  }
  .about-img-br {
    border-radius: 8px 8px 8px 8px;
  }
</style>
