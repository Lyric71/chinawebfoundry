---
interface Props {
  hover?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { hover = false, padding = 'md', class: className } = Astro.props;

const paddingClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const hoverClasses = hover
  ? 'transition-all duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]'
  : '';
---

<div class:list={[
  'bg-[var(--color-surface-white)] border border-[var(--color-surface-border)] rounded-lg',
  paddingClasses[padding],
  hoverClasses,
  className,
]}>
  <slot />
</div>
