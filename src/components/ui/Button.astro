---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  arrow?: boolean;
}

const { variant = 'primary', size = 'md', href, type = 'button', class: className, arrow = true } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 font-[var(--font-button)] font-medium rounded-[var(--radius-pill)] transition-all duration-200 cursor-pointer no-underline hover:-translate-y-0.5 active:translate-y-0';

const variantClasses = {
  primary: 'bg-[var(--color-brand-orange)] text-white hover:bg-[var(--color-brand-orange-hover)] hover:shadow-[0_6px_20px_rgba(242,95,41,0.35)] active:bg-[var(--color-brand-orange-active)] active:shadow-[0_2px_8px_rgba(242,95,41,0.25)]',
  secondary: 'bg-transparent text-[var(--color-text-dark)] border border-[var(--color-text-dark)] hover:bg-[var(--color-text-dark)] hover:text-white hover:shadow-[0_6px_20px_rgba(33,33,33,0.2)] active:bg-[var(--color-text-near-black)] active:shadow-[0_2px_8px_rgba(33,33,33,0.15)]',
  ghost: 'bg-transparent text-[var(--color-brand-orange)] hover:underline hover:shadow-none',
};

const sizeClasses = {
  sm: 'px-5 py-2 text-sm',
  md: 'px-6 py-2.5 text-base',
  lg: 'px-8 py-3 text-lg',
};

const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className];
---

{href ? (
  <a href={href} class:list={classes}>
    <span><slot /></span>
    {arrow && (
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    )}
  </a>
) : (
  <button type={type} class:list={classes}>
    <span><slot /></span>
    {arrow && (
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    )}
  </button>
)}
