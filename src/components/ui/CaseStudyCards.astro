---
/**
 * CaseStudyCards - Adapted from shadcn casestudy-5 component.
 * Renders a featured card (full-width, 2-col on lg) + remaining items in a grid.
 * For 2 or fewer items, all go in the grid with no featured card.
 *
 * Reference: src/components/ui/casestudy-5.tsx (original React version)
 */

export interface CardItem {
  title: string;
  body?: string;
  details?: string;
  image?: string;
}

interface Props {
  items: CardItem[];
}

const { items } = Astro.props;

const showFeatured = items.length >= 3 && !!items[0].body;
const featuredItem = showFeatured ? items[0] : null;
const gridItems = showFeatured ? items.slice(1) : items;
const gridColClass =
  gridItems.length >= 3
    ? 'lg:grid-cols-3'
    : gridItems.length === 2
      ? 'lg:grid-cols-2'
      : '';
---

<div class="border border-[var(--color-surface-border)]">
  {/* Featured card: full-width with 2-col layout */}
  {featuredItem && (
    <div class="group grid gap-4 overflow-hidden px-6 transition-colors duration-500 ease-out hover:bg-[var(--color-surface-light)] lg:grid-cols-2 xl:px-16">
      <div class="flex flex-col justify-center gap-4 py-8 md:py-16">
        <h3 class="text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] sm:text-3xl sm:leading-10 text-balance">
          {featuredItem.title}
        </h3>
        <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
          {featuredItem.body}
        </p>
        {featuredItem.details && (
          <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
            {featuredItem.details}
          </p>
        )}
      </div>
      <div class="relative isolate py-8 md:py-16">
        <div class="relative isolate h-full border border-[var(--color-surface-border)] bg-white p-2 overflow-hidden">
          {featuredItem.image ? (
            <div class="h-full overflow-hidden">
              <img
                src={featuredItem.image}
                alt={featuredItem.title}
                class="aspect-[14/9] h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
          ) : (
            <div class="h-full min-h-[200px]">
              <div class="h-full w-full bg-[radial-gradient(var(--color-text-muted)_1px,transparent_1px)] [background-size:12px_12px] opacity-[0.08]"></div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-20 h-20 rounded-full bg-[var(--color-brand-orange)]/[0.07] flex items-center justify-center">
                <div class="w-10 h-10 rounded-full bg-[var(--color-brand-orange)]/[0.12]"></div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  {/* Grid cards */}
  <div class:list={['flex', featuredItem && 'border-t border-[var(--color-surface-border)]']}>
    <div class="hidden w-16 shrink-0 bg-[radial-gradient(var(--color-text-muted)_1px,transparent_1px)] [background-size:10px_10px] opacity-[0.08] xl:block"></div>
    <div class:list={['grid flex-1', gridColClass]}>
      {gridItems.map((item, idx) => (
        <div
          class:list={[
            'group flex flex-col gap-6 border-[var(--color-surface-border)] bg-white px-6 py-8 transition-colors duration-500 ease-out hover:bg-[var(--color-surface-light)] md:py-12 xl:px-8',
            idx === 0 ? 'xl:border-l' : 'border-t lg:border-t-0 lg:border-l',
            idx === gridItems.length - 1 && 'xl:border-r',
          ]}
        >
          {item.image && (
            <div class="overflow-hidden border border-[var(--color-surface-border)]">
              <img
                src={item.image}
                alt={item.title}
                class="aspect-[16/9] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}
          <div>
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4 sm:text-2xl">
              {item.title}
            </h3>
            {item.body && (
              <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                {item.body}
              </p>
            )}
            {item.details && (
              <p class="mt-3 text-[15px] text-[var(--color-text-body)] leading-relaxed">
                {item.details}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
    <div class="hidden w-16 shrink-0 bg-[radial-gradient(var(--color-text-muted)_1px,transparent_1px)] [background-size:10px_10px] opacity-[0.08] xl:block"></div>
  </div>
</div>
