---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  tag?: 'h1' | 'h2' | 'h3';
}

const { eyebrow, title, subtitle, align = 'center', tag: Tag = 'h2' } = Astro.props;

const alignClass = align === 'center' ? 'text-center' : 'text-left';
---

<div class:list={['mb-12', alignClass]}>
  {eyebrow && (
    <p class="text-sm font-medium uppercase tracking-wider text-[var(--color-brand-orange)] mb-2 font-[var(--font-heading)]">
      {eyebrow}
    </p>
  )}
  <Tag class="text-2xl md:text-[28px] lg:text-4xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
    {title}
  </Tag>
  {subtitle && (
    <p class="mt-4 text-base md:text-lg text-[var(--color-text-body)] max-w-2xl" class:list={[align === 'center' && 'mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
