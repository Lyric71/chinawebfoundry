---
import Button from '../ui/Button.astro';
import { trustPoints } from '../../data/trustPoints';
---

<!-- Trust / Why Us section -->
<section class="py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-[1400px] section-padding">
    <div class="io-grid items-start gap-y-16">
      <!-- Left: heading + description + CTA -->
      <div class="col-span-12 lg:col-span-5">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
          Why Us
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
          Why International Companies Trust Us for WordPress in China
        </h2>
        <p class="mt-8 text-lg text-[var(--color-text-body)] leading-relaxed">
          We are based in China and understand the technical and regulatory landscape from the inside. We don't just build WordPress sites &mdash; we make them work within China's unique internet ecosystem.
        </p>
        <div class="mt-10">
          <Button href="/who-we-are/" variant="primary" size="md">About our team</Button>
        </div>
      </div>

      <!-- Right: trust points -->
      <div class="col-span-12 lg:col-span-6 lg:col-start-7">
        <div class="divider-list border-t border-[var(--color-surface-border)]">
          {trustPoints.map((point) => (
            <div class="py-8">
              <h3 class="text-xl sm:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
                {point.title}
              </h3>
              <p class="mt-3 text-base text-[var(--color-text-body)] leading-relaxed">
                {point.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
