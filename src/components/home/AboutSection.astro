---
import Button from '../ui/Button.astro';
---

<!-- Why Us: iO-style layout with circle bg + photo grid -->
<section class="py-24 md:py-32 lg:py-40 overflow-hidden">
  <div class="mx-auto max-w-[1400px] section-padding">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 xl:gap-20">

      <!-- Left: Text inside a large decorative circle -->
      <div class="relative lg:w-[50%] flex-shrink-0">
        {/* Large circle background */}
        <div class="absolute inset-0 -left-4 sm:-left-16 -top-12 -bottom-12 bg-[var(--color-surface-light)] rounded-full scale-110 lg:scale-125 origin-center"></div>

        <div class="relative z-10 py-12 lg:py-16 pr-4 lg:pr-8">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Why us
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.12] mb-6">
            Your brand team. Inside the Firewall.
          </h2>
          <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed mb-4">
            To land with Chinese audiences you need people who live with that audience day to day. Native Chinese writers. Designers who open the site in WeChat first. SEO specialists who rank on Baidu.
          </p>
          <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed mb-10">
            All of them on staff, in one Shanghai office. A leadership team with 15+ years getting foreign brands to land properly in China.
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <Button href="/who-we-are/" variant="primary" size="md">Our story</Button>
            <Button href="/resources/faq/" variant="secondary" size="md">Read the FAQ</Button>
          </div>
        </div>
      </div>

      <!-- Right: 2x2 photo grid with circular inner corners -->
      <div class="lg:w-[50%] flex-shrink-0">
        <div class="grid grid-cols-2 gap-3 lg:gap-4 about-photo-grid">
          {/* Top left - team photo */}
          <div class="aspect-square overflow-hidden about-img-tl">
            <img
              src="/images/team/team-photo.webp"
              alt="The ChinaWebFoundry team in Shanghai"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          {/* Top right - collaboration */}
          <div class="aspect-square overflow-hidden about-img-tr">
            <img
              src="/images/who-we-are-collaboration.webp"
              alt="ChinaWebFoundry team collaborating in a Shanghai studio"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          {/* Bottom left - office */}
          <div class="aspect-square overflow-hidden about-img-bl">
            <img
              src="/images/hero-who-we-are-office.webp"
              alt="ChinaWebFoundry Shanghai office"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          {/* Bottom right - team photo (focused) */}
          <div class="aspect-square overflow-hidden about-img-br">
            <img
              src="/images/team/team-photo.webp"
              alt="ChinaWebFoundry editorial and design team"
              class="w-full h-full object-cover object-right"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Each inner corner gets a large circular radius to create the effect */
  .about-img-tl {
    border-radius: 8px 8px 50% 8px;
  }
  .about-img-tr {
    border-radius: 8px 8px 8px 50%;
  }
  .about-img-bl {
    border-radius: 8px 50% 8px 8px;
  }
  .about-img-br {
    border-radius: 8px 8px 8px 8px;
  }
</style>
