---
import { getCollection } from 'astro:content';
import Button from '../ui/Button.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

/** Map icon names from frontmatter to SVG paths */
const iconPaths: Record<string, string> = {
  'clipboard-check': 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  'arrow-right-circle': 'M12.75 15l3-3m0 0l-3-3m3 3h-7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  'palette': 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
  'plug': 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
  'languages': 'M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802',
  'search': 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z',
  'puzzle': 'M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.491 48.491 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.401.604-.401.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z',
  'server': 'M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z',
  'wrench': 'M11.42 15.17l-5.1 5.1a2.121 2.121 0 01-3-3l5.1-5.1m0 0L4.16 8.93a2.122 2.122 0 010-3l1.58-1.58a2.122 2.122 0 013 0l3.25 3.25a.75.75 0 001.06 0l5.09-5.09a2.121 2.121 0 013 3l-5.09 5.09a.75.75 0 000 1.06l3.25 3.25a2.122 2.122 0 010 3l-1.58 1.58a2.122 2.122 0 01-3 0L11.42 15.17z',
};

function getIconPath(name: string): string {
  return iconPaths[name] || iconPaths['wrench'];
}

/** Pre-compute grouped services in frontmatter to avoid JSX comparison issues */
const planServices = services.filter((s) => s.data.order === 1);
const buildServices = services.filter((s) => s.data.order >= 2 && s.data.order <= 5);
const growServices = services.filter((s) => s.data.order >= 6 && s.data.order <= 9);
---

<!-- Our Services: modern card layout with icons -->
<section id="OurServices" class="py-24 md:py-32 lg:py-40 bg-[var(--color-surface-light)]">
  <div class="mx-auto max-w-[1400px] section-padding">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16 lg:mb-20">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
          Our Services
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
          Complete WordPress Solutions for China
        </h2>
        <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed">
          From strategy to maintenance, we handle every aspect of your WordPress presence in China.
        </p>
      </div>
      <div class="flex-shrink-0">
        <Button href="/contact/" variant="primary" size="md">Get started</Button>
      </div>
    </div>

    <!-- Plan group -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)]">Plan</span>
        <div class="flex-1 h-px bg-[var(--color-surface-border)]"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {planServices.map((service) => (
          <a
            href={`/services/${service.id}/`}
            class="group relative flex items-start gap-5 p-6 rounded-2xl bg-white border border-[var(--color-surface-border)] hover:border-[var(--color-brand-orange)]/20 hover:shadow-[0_8px_30px_rgba(242,95,41,0.06)] no-underline transition-all duration-300"
          >
            <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-[var(--color-brand-orange)]/[0.08] group-hover:bg-[var(--color-brand-orange)]/[0.14] flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(service.data.icon)} />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] group-hover:text-[var(--color-brand-orange)] transition-colors leading-snug">
                {service.data.title}
              </h3>
              <p class="mt-1.5 text-sm text-[var(--color-text-body)] leading-relaxed line-clamp-2">
                {service.data.description}
              </p>
            </div>
            <div class="flex-shrink-0 mt-1 text-[var(--color-text-muted)] group-hover:text-[var(--color-brand-orange)] group-hover:translate-x-1 transition-all duration-200 opacity-0 group-hover:opacity-100">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Build group -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)]">Build</span>
        <div class="flex-1 h-px bg-[var(--color-surface-border)]"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {buildServices.map((service) => (
          <a
            href={`/services/${service.id}/`}
            class="group relative flex items-start gap-5 p-6 rounded-2xl bg-white border border-[var(--color-surface-border)] hover:border-[var(--color-brand-orange)]/20 hover:shadow-[0_8px_30px_rgba(242,95,41,0.06)] no-underline transition-all duration-300"
          >
            <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-[var(--color-brand-orange)]/[0.08] group-hover:bg-[var(--color-brand-orange)]/[0.14] flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(service.data.icon)} />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] group-hover:text-[var(--color-brand-orange)] transition-colors leading-snug">
                {service.data.title}
              </h3>
              <p class="mt-1.5 text-sm text-[var(--color-text-body)] leading-relaxed line-clamp-2">
                {service.data.description}
              </p>
            </div>
            <div class="flex-shrink-0 mt-1 text-[var(--color-text-muted)] group-hover:text-[var(--color-brand-orange)] group-hover:translate-x-1 transition-all duration-200 opacity-0 group-hover:opacity-100">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Grow group -->
    <div>
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)]">Grow</span>
        <div class="flex-1 h-px bg-[var(--color-surface-border)]"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {growServices.map((service) => (
          <a
            href={`/services/${service.id}/`}
            class="group relative flex items-start gap-5 p-6 rounded-2xl bg-white border border-[var(--color-surface-border)] hover:border-[var(--color-brand-orange)]/20 hover:shadow-[0_8px_30px_rgba(242,95,41,0.06)] no-underline transition-all duration-300"
          >
            <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-[var(--color-brand-orange)]/[0.08] group-hover:bg-[var(--color-brand-orange)]/[0.14] flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(service.data.icon)} />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] group-hover:text-[var(--color-brand-orange)] transition-colors leading-snug">
                {service.data.title}
              </h3>
              <p class="mt-1.5 text-sm text-[var(--color-text-body)] leading-relaxed line-clamp-2">
                {service.data.description}
              </p>
            </div>
            <div class="flex-shrink-0 mt-1 text-[var(--color-text-muted)] group-hover:text-[var(--color-brand-orange)] group-hover:translate-x-1 transition-all duration-200 opacity-0 group-hover:opacity-100">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
