<style>
  .scrollbar-hide {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .phase-tab.is-active {
    background-color: var(--color-text-dark);
    color: #ffffff;
    box-shadow: 0 4px 14px -4px rgba(15, 15, 18, 0.35);
  }
  .phase-tab.is-active span {
    opacity: 1;
    color: #ffffff;
  }
</style>

<script>
  function initServicesPhaseUI() {
    const section = document.querySelector<HTMLElement>('[data-services-section]');
    if (!section) return;

    const tabs = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-phase-tab]'));
    const blocks = Array.from(document.querySelectorAll<HTMLElement>('[data-phase-block]'));
    const rail = document.querySelector<HTMLElement>('[data-services-rail]');

    if (!tabs.length || !blocks.length) return;

    // Scrollspy: highlight active tab based on which phase block is in viewport
    const setActive = (name: string) => {
      tabs.forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.phaseTab === name);
      });
    };

    // Pick the block whose top is closest to (but past) a focal line ~30% from viewport top
    const pickActive = () => {
      const focal = window.innerHeight * 0.3;
      let best: { name: string; dist: number } | null = null;
      blocks.forEach((b) => {
        const rect = b.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > window.innerHeight) return;
        const dist = Math.abs(rect.top - focal);
        if (best === null || dist < best.dist) {
          best = { name: b.dataset.phaseBlock || '', dist };
        }
      });
      if (best) setActive(best.name);
    };

    // Rail fill: scroll-driven progress through the section
    const updateRail = () => {
      if (!rail) return;
      const rect = section.getBoundingClientRect();
      const total = rect.height;
      const scrolled = Math.min(Math.max(-rect.top + window.innerHeight * 0.3, 0), total);
      const pct = total > 0 ? Math.min(1, scrolled / total) : 0;
      rail.style.height = `calc(${pct * 100}% - 16px)`;
    };

    let raf = 0;
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        pickActive();
        updateRail();
        raf = 0;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();

    // Smooth scroll for tabs (compensate for any sticky headers)
    tabs.forEach((tab) => {
      tab.addEventListener('click', (e) => {
        const href = tab.getAttribute('href');
        if (!href || !href.startsWith('#')) return;
        const target = document.getElementById(href.slice(1));
        if (!target) return;
        e.preventDefault();
        const top = target.getBoundingClientRect().top + window.scrollY - 100;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });
  }

  initServicesPhaseUI();
  document.addEventListener('astro:page-load', initServicesPhaseUI);
  document.addEventListener('astro:after-swap', initServicesPhaseUI);
</script>