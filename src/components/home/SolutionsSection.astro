---
import { getCollection } from 'astro:content';
import Button from '../ui/Button.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<!-- Our Services: split layout 5+7 with divider list -->
<section id="OurServices" class="py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-[1400px] section-padding">
    <div class="io-grid items-start gap-y-16">
      <!-- Left column: eyebrow + heading + CTA (5 cols) -->
      <div class="col-span-12 lg:col-span-5 lg:sticky lg:top-24">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
          OUR SERVICES
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
          Shaping WordPress experiences for China
        </h2>
        <div class="mt-10">
          <Button href="/contact/" variant="primary" size="md">Discover our expertise</Button>
        </div>
      </div>

      <!-- Right column: service list with dividers + arrows (7 cols) -->
      <div class="col-span-12 lg:col-span-6 lg:col-start-7">
        <div class="divider-list border-t border-[var(--color-surface-border)]">
          {services.map((service) => (
            <a
              href={`/services/${service.id}/`}
              class="group flex items-start justify-between gap-8 py-8 no-underline transition-colors hover:no-underline"
            >
              <div class="flex-1">
                <h3 class="text-xl sm:text-2xl lg:text-[28px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug group-hover:text-[var(--color-brand-orange)] transition-colors">
                  {service.data.title}
                </h3>
                <p class="mt-3 text-base text-[var(--color-text-body)] leading-relaxed">
                  {service.data.description}
                </p>
              </div>
              <div class="flex-shrink-0 mt-2 text-[var(--color-text-muted)] group-hover:text-[var(--color-brand-orange)] group-hover:translate-x-1 transition-all duration-200">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
