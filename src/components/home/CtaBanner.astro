---
import Button from '../ui/Button.astro';

/**
 * Dark feature section (iO "How to put AI to work" pattern)
 * Dark bg with subtle visual, headline + check list left, description + CTA right
 */
const features = [
  'Replacing blocked Google services',
  'China CDN and hosting setup',
  'Baidu SEO and indexing',
  'ICP licence management',
  'Plugin compatibility testing',
  'Performance monitoring from China',
];
---

<section class="relative bg-[var(--color-surface-dark)] py-24 md:py-32 lg:py-40 overflow-hidden">
  <!-- Subtle background decoration -->
  <div class="absolute inset-0 opacity-[0.04]">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-white to-transparent"></div>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 rounded-full bg-[var(--color-brand-orange)]" style="filter: blur(120px);"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1400px] section-padding">
    <div class="io-grid items-start gap-y-16">
      <!-- Left column: headline + features (6 cols) -->
      <div class="col-span-12 lg:col-span-6">
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-white leading-[1.1] mb-12">
          How we optimise WordPress for the Chinese market
        </h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5">
          {features.map((feature) => (
            <li class="flex items-start gap-3 text-white/80 text-base leading-relaxed">
              <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>

      <!-- Right column: description + CTA (5 cols) -->
      <div class="col-span-12 lg:col-span-5 lg:col-start-8">
        <p class="text-lg text-white/60 leading-relaxed mb-5">
          Most WordPress sites aren't built with China in mind. Plugins rely on blocked services, hosting is overseas, and performance suffers behind the Great Firewall.
        </p>
        <p class="text-lg text-white/60 leading-relaxed mb-10">
          ChinaWebFoundry changes that. We audit, migrate, and optimise every layer of your WordPress site so it loads fast, ranks on Baidu, and stays compliant.
        </p>
        <Button href="/contact/" variant="primary" size="md">Get a free audit</Button>
      </div>
    </div>
  </div>
</section>
