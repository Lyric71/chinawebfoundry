---
import { getCollection, render } from 'astro:content';

const testimonials = (await getCollection('testimonials')).sort((a, b) => a.data.order - b.data.order);
---

<!-- Testimonials: dark section with decorative elements -->
<section class="relative bg-[var(--color-surface-dark)] py-24 md:py-32 lg:py-40 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12] via-[#1a1a2e] to-[#16213e]"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-white/[0.02] to-transparent"></div>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 rounded-full bg-[var(--color-brand-orange)] opacity-[0.03]" style="filter: blur(120px);"></div>
    <div class="absolute top-1/4 right-1/3 w-64 h-64 rounded-full bg-blue-500 opacity-[0.02]" style="filter: blur(80px);"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1400px] section-padding">
    <div class="io-grid items-start gap-y-16">
      <!-- Left: heading -->
      <div class="col-span-12 lg:col-span-5">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
          Success Stories
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-white leading-[1.1]">
          Every client arrives with the same challenge
        </h2>
        <p class="mt-6 text-lg text-white/50 leading-relaxed">
          A WordPress site that works everywhere except China. Our success stories are measured in one thing: your site loading fast, ranking on Baidu, and reaching Chinese audiences.
        </p>

        <!-- Decorative large quote mark -->
        <div class="hidden lg:block mt-12">
          <svg class="w-24 h-24 text-[var(--color-brand-orange)] opacity-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
          </svg>
        </div>
      </div>

      <!-- Right: testimonial cards -->
      <div class="col-span-12 lg:col-span-6 lg:col-start-7">
        <div class="space-y-6">
          {testimonials.map(async (testimonial) => {
            const { Content } = await render(testimonial);
            return (
              <div class="relative p-6 lg:p-8 rounded-2xl bg-white/[0.04] border border-white/[0.06] backdrop-blur-sm hover:bg-white/[0.06] transition-colors duration-300">
                <blockquote class="text-base lg:text-lg text-white/75 leading-relaxed italic">
                  <Content />
                </blockquote>
                <div class="mt-5 flex items-center gap-3">
                  {testimonial.data.photo && (
                    <img
                      src={testimonial.data.photo}
                      alt={`Photo of ${testimonial.data.name}`}
                      class="w-10 h-10 rounded-full object-cover ring-2 ring-white/10"
                      width="40"
                      height="40"
                      loading="lazy"
                    />
                  )}
                  <div>
                    <p class="text-sm font-medium text-white">{testimonial.data.name}</p>
                    <p class="text-sm text-white/40">{testimonial.data.role}, {testimonial.data.company}</p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>
