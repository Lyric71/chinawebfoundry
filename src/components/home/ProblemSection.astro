---
import { problems } from '../../data/problems';

/** SVG icon paths keyed by problem index */
const icons = [
  // Clock - load times
  'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  // Shield - firewall
  'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  // No-entry - Google blocked
  'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636',
  // Document - ICP
  'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  // Magnifying glass - Baidu SEO
  'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z',
  // Server - hosting
  'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z',
];
---

<!-- Problem section: icon card grid -->
<section class="py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-[1400px] section-padding">
    <!-- Section header -->
    <div class="max-w-2xl mb-16 lg:mb-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
        The Problem
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
        Your WordPress Site Is Invisible in China
      </h2>
      <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed">
        International WordPress sites face serious obstacles inside the Great Firewall. Here are the six most common problems our clients come to us with.
      </p>
    </div>

    <!-- Card grid: 2 cols on tablet, 3 on desktop -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {problems.map((problem, i) => (
        <div class="group relative p-8 rounded-2xl border border-[var(--color-surface-border)] bg-white hover:border-[var(--color-brand-orange)]/20 hover:shadow-[0_8px_30px_rgba(242,95,41,0.08)] transition-all duration-300">
          <!-- Icon -->
          <div class="mb-6">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-[var(--color-brand-orange)]/[0.08] group-hover:bg-[var(--color-brand-orange)]/[0.12] transition-colors">
              <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icons[i]} />
              </svg>
            </div>
          </div>

          <h3 class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-3">
            {problem.title}
          </h3>
          <p class="text-base text-[var(--color-text-body)] leading-relaxed">
            {problem.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Transition line -->
    <div class="mt-16 max-w-3xl mx-auto text-center">
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
        We solve every one of these problems. As a specialised WordPress China agency, we migrate, optimise, and maintain WordPress websites so they perform flawlessly inside the Great Firewall.
      </p>
    </div>
  </div>
</section>
