---
import { problems } from '../../data/problems';

const images = [
  '/images/problem-content-resonates.webp',
  '/images/problem-firewall-blocking.webp',
  '/images/problem-baidu-seo.webp',
  '/images/problem-slow-load-times.webp',
  '/images/problem-unreliable-hosting.webp',
];
---

<!-- Problem section: accordion + image layout -->
<section class="pt-24 md:pt-32 lg:pt-40 pb-16 md:pb-20 lg:pb-24">
  <div class="mx-auto max-w-[1400px] section-padding">
    <!-- Section header -->
    <div class="max-w-3xl mb-16 lg:mb-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
        The Real Problem
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
        Your Brand Doesn’t Land in China. And Translation Won’t Fix It.
      </h2>
      <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed">
        Most foreign brands launch in China by translating their global website. Six months later, bounce rates sit above 80% and the leads pipeline is empty. HQ rarely sees it coming.
      </p>
    </div>

    <!-- Accordion + image grid -->
    <div class="flex flex-col md:flex-row items-start gap-12 lg:gap-16">
      <!-- Left: accordion -->
      <div class="w-full md:w-1/2" id="problem-accordion">
        {problems.map((problem, i) => (
          <div
            class="problem-item border-b border-[var(--color-surface-border)]"
            data-index={i}
            data-image={images[i]}
          >
            <button
              type="button"
              class="flex w-full items-center justify-between py-5 text-left cursor-pointer bg-transparent border-none"
              aria-expanded="false"
            >
              <h3 class="text-lg lg:text-xl font-semibold font-[var(--font-heading)] transition-colors duration-200 text-[var(--color-text-muted)]">
                {problem.title}
              </h3>
              <svg
                class="w-5 h-5 flex-shrink-0 ml-4 transition-transform duration-200 text-[var(--color-text-muted)]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="problem-content overflow-hidden transition-all duration-300 max-h-0 opacity-0">
              <p class="pb-3 text-base text-[var(--color-text-body)] leading-relaxed">
                {problem.description}
              </p>
              {problem.citation && (
                <p class="pb-5 text-sm text-[var(--color-text-muted)] leading-relaxed border-l-2 border-[var(--color-brand-orange)] pl-4 italic">
                  {problem.citation}
                </p>
              )}
              <!-- Mobile-only image -->
              <div class="md:hidden mb-5">
                <img
                  src={images[i]}
                  alt={problem.title}
                  class="w-full h-auto rounded-xl object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Right: image (desktop only) -->
      <div class="hidden md:block w-1/2 sticky top-28">
        <div class="relative overflow-hidden rounded-2xl bg-[var(--color-surface-light)]">
          <img
            id="problem-image"
            src={images[0]}
            alt="Problem illustration"
            class="w-full aspect-[4/3] object-cover transition-opacity duration-300"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Parallax transition: problem to solution -->
<section class="parallax-section relative" style="padding: 12px;">
  <div class="relative h-[75vh]">
    <!-- Sticky image -->
    <div
      class="parallax-sticky sticky top-[12px] z-0 overflow-hidden rounded-3xl"
      style="height: calc(50vh - 24px);"
    >
      <img
        src="/images/parallax-solution-before-after.webp"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
      <div class="parallax-overlay absolute inset-0 bg-[#0f0f12]/70"></div>
    </div>

    <!-- Overlay text (scrolls over the sticky image) -->
    <div class="parallax-copy absolute left-0 top-0 flex h-[50vh] w-full flex-col items-center justify-center text-white px-6">
      <p class="mb-3 text-center text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] md:mb-4 md:text-base">
        The Solution
      </p>
      <p class="text-center text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-medium font-[var(--font-heading)] leading-[1.12] max-w-4xl">
        We solve every one of these problems.
      </p>
    </div>
  </div>

  <!-- Content below the sticky image -->
  <div class="mx-auto max-w-5xl grid grid-cols-1 md:grid-cols-12 gap-8 px-4 pb-16 pt-6">
    <div class="col-span-1 md:col-span-5">
      <h2 class="text-2xl sm:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
        A China web agency. In Shanghai. Strategic, not just technical.
      </h2>
    </div>
    <div class="col-span-1 md:col-span-7">
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-6">
        We build websites that land with Chinese audiences. In that order:
      </p>

      <!-- Priority stack -->
      <div class="mb-6 space-y-3">
        <div class="flex items-start gap-4 p-4 rounded-xl bg-[var(--color-surface-light)]">
          <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-brand-orange)]/10 text-[var(--color-brand-orange)] flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
          </span>
          <div>
            <p class="text-base font-semibold text-[var(--color-text-dark)]">Brand</p>
            <p class="text-base text-[var(--color-text-body)] leading-relaxed">Content that reads native, UX that feels local.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-[var(--color-surface-light)]">
          <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-brand-orange)]/10 text-[var(--color-brand-orange)] flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </span>
          <div>
            <p class="text-base font-semibold text-[var(--color-text-dark)]">Visibility</p>
            <p class="text-base text-[var(--color-text-body)] leading-relaxed">Baidu and the Chinese AI engines.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-[var(--color-surface-light)]">
          <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-brand-orange)]/10 text-[var(--color-brand-orange)] flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
          </span>
          <div>
            <p class="text-base font-semibold text-[var(--color-text-dark)]">Infrastructure</p>
            <p class="text-base text-[var(--color-text-body)] leading-relaxed">ICP, hosting and performance, in the background.</p>
          </div>
        </div>
      </div>

      <p class="text-base text-[var(--color-text-muted)] leading-relaxed mb-8 italic">
        Plus: we help you defend the localisation decisions back at HQ.
      </p>

      <!-- How a typical engagement runs -->
      <div class="mb-8 border-l-2 border-[var(--color-brand-orange)] pl-6 space-y-5">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-dark)]">
          How a typical engagement runs
        </p>
        <div>
          <p class="text-base text-[var(--color-text-dark)] font-semibold">Strategy and Audit, 1 to 2 weeks</p>
          <p class="text-base text-[var(--color-text-body)] leading-relaxed">We audit your site, brand and Chinese competition, then deliver a written roadmap before any code is touched.</p>
        </div>
        <div>
          <p class="text-base text-[var(--color-text-dark)] font-semibold">Build or migrate, 4 to 12 weeks</p>
          <p class="text-base text-[var(--color-text-body)] leading-relaxed">Localised content, ICP hosting, Baidu and AI search from day one.</p>
        </div>
        <div>
          <p class="text-base text-[var(--color-text-dark)] font-semibold">Grow, ongoing</p>
          <p class="text-base text-[var(--color-text-body)] leading-relaxed">Content, search and maintenance on a monthly retainer.</p>
        </div>
      </div>

      <a
        href="/contact/"
        class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-medium font-[var(--font-button)] rounded-[var(--radius-pill)] bg-[var(--color-brand-orange)] text-white no-underline transition-all duration-200 hover:bg-[var(--color-brand-orange-hover)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(242,95,41,0.3)]"
      >
        Talk to us
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  function initProblemAccordion() {
    const items = document.querySelectorAll<HTMLElement>('.problem-item');
    const image = document.getElementById('problem-image') as HTMLImageElement | null;
    if (!items.length) return;

    items.forEach((item) => {
      const btn = item.querySelector('button');
      const content = item.querySelector('.problem-content') as HTMLElement | null;
      const title = item.querySelector('h3');
      const chevron = item.querySelector('svg');

      btn?.addEventListener('click', () => {
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all
        items.forEach((other) => {
          const otherBtn = other.querySelector('button');
          const otherContent = other.querySelector('.problem-content') as HTMLElement | null;
          const otherTitle = other.querySelector('h3');
          const otherChevron = other.querySelector('svg');

          otherBtn?.setAttribute('aria-expanded', 'false');
          otherContent?.classList.remove('max-h-[800px]', 'opacity-100');
          otherContent?.classList.add('max-h-0', 'opacity-0');
          otherTitle?.classList.remove('text-[var(--color-text-dark)]');
          otherTitle?.classList.add('text-[var(--color-text-muted)]');
          otherChevron?.classList.remove('rotate-180', 'text-[var(--color-text-dark)]');
          otherChevron?.classList.add('text-[var(--color-text-muted)]');
        });

        // If it was closed, open this one
        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          content?.classList.remove('max-h-0', 'opacity-0');
          content?.classList.add('max-h-[800px]', 'opacity-100');
          title?.classList.remove('text-[var(--color-text-muted)]');
          title?.classList.add('text-[var(--color-text-dark)]');
          chevron?.classList.add('rotate-180', 'text-[var(--color-text-dark)]');
          chevron?.classList.remove('text-[var(--color-text-muted)]');

          // Update desktop image
          const newImage = item.dataset.image;
          if (image && newImage) {
            image.style.opacity = '0';
            setTimeout(() => {
              image.src = newImage;
              image.style.opacity = '1';
            }, 150);
          }
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initProblemAccordion);
  document.addEventListener('astro:page-load', initProblemAccordion);

  // Parallax scroll animation (disabled on mobile to avoid Safari jank)
  function initParallax() {
    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    if (isMobile) return;

    const section = document.querySelector('.parallax-section');
    const sticky = document.querySelector('.parallax-sticky') as HTMLElement | null;
    const overlay = document.querySelector('.parallax-overlay') as HTMLElement | null;
    const copy = document.querySelector('.parallax-copy') as HTMLElement | null;
    if (!section || !sticky || !overlay || !copy) return;

    function onScroll() {
      const rect = section!.getBoundingClientRect();
      const sectionHeight = section!.clientHeight;
      const viewportHeight = window.innerHeight;

      // Progress: 0 when section enters, 1 when section leaves
      const rawProgress = -rect.top / (sectionHeight - viewportHeight);
      const progress = Math.max(0, Math.min(1, rawProgress));

      // Scale the sticky image from 1 to 0.85 as you scroll past
      const scale = 1 - progress * 0.15;
      sticky!.style.transform = `scale(${scale})`;

      // Fade overlay from visible to transparent
      overlay!.style.opacity = String(1 - progress);

      // Text visible immediately, fades out as you scroll past
      let copyOpacity = 1;
      if (progress > 0.5) {
        copyOpacity = 1 - (progress - 0.5) / 0.5;
      }
      copy!.style.opacity = String(copyOpacity);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener('DOMContentLoaded', initParallax);
  document.addEventListener('astro:page-load', initParallax);
</script>
