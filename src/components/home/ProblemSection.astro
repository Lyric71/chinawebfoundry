---
/**
 * The Real Problem: light bento with images.
 * - Header band: eyebrow + headline + stat panel
 * - 5 problem cards in a bento (1 featured + 4 standard), each with an image
 * - Cursor spotlight + hover lift + decorative parallax glyph
 */
import { problems } from '../../data/problems';

const images = [
  '/images/problem-content-resonates.webp',
  '/images/problem-firewall-blocking.webp',
  '/images/problem-baidu-seo.webp',
  '/images/problem-slow-load-times.webp',
  '/images/problem-unreliable-hosting.webp',
];

const tags = ['Content', 'UX', 'Search', 'AI', 'Infra'];
---

<section
  data-problem-section
  class="relative overflow-hidden bg-white py-24 md:py-32 lg:py-40"
>
  <!-- Subtle background layers -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-b from-white via-[var(--color-surface-light)] to-white"></div>
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:34px_34px] opacity-[0.035]"></div>
    <div class="absolute -top-32 left-[8%] w-[520px] h-[520px] rounded-full bg-[var(--color-brand-orange)]/[0.06] blur-[150px]"></div>
    <div class="absolute -bottom-32 right-[5%] w-[480px] h-[480px] rounded-full bg-[var(--color-brand-orange)]/[0.05] blur-[160px]"></div>
  </div>
  <span aria-hidden="true" class="absolute right-[-4rem] top-[10%] text-[22rem] lg:text-[28rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.05] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.12">问题</span>

  <div class="relative z-10 mx-auto max-w-[1400px] section-padding">
    <!-- HEADER BAND -->
    <div class="grid grid-cols-12 gap-8 lg:gap-12 mb-14 lg:mb-20 items-end">
      <!-- Left: eyebrow + headline -->
      <div class="col-span-12 lg:col-span-7" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)]">The Real Problem · 真正的问题</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.04]">
          Your brand doesn't land in China.
          <span class="block mt-2">
            <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF9466] to-[var(--color-brand-orange)] bg-clip-text text-transparent">
              And translation won't fix it.
            </span>
          </span>
        </h2>
        <p class="mt-7 text-lg lg:text-xl text-[var(--color-text-body)] leading-relaxed max-w-2xl">
          Most foreign brands launch in China by translating their global website. Six months later, the leads pipeline is empty.
          <span class="text-[var(--color-text-dark)] font-medium">HQ rarely sees it coming.</span>
        </p>
      </div>

      <!-- Right: stat panel -->
      <div class="col-span-12 lg:col-span-5 lg:pl-10" data-reveal data-reveal-delay="120">
        <div class="relative rounded-3xl bg-white border border-[var(--color-surface-border)] p-7 lg:p-9 overflow-hidden shadow-[0_30px_60px_-30px_rgba(15,15,18,0.15)]">
          <span aria-hidden="true" class="absolute -right-8 -bottom-12 text-[14rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.06] leading-none select-none">82</span>
          <div class="relative">
            <div class="flex items-center gap-2 mb-4">
              <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[var(--color-brand-orange)]/10 text-[var(--color-brand-orange)]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181"/></svg>
              </span>
              <span class="text-[10px] font-mono uppercase tracking-[0.16em] text-[var(--color-text-muted)]">Bounce rate, first 90 days</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-7xl lg:text-[110px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none">
                <span data-counter data-counter-suffix="%">82</span>
              </span>
            </div>
            <p class="mt-4 text-sm text-[var(--color-text-body)] leading-relaxed">
              Median bounce rate of translated foreign brand sites in mainland China during the first ninety days after launch.
            </p>
            <p class="mt-3 text-[10px] font-mono uppercase tracking-wider text-[var(--color-text-muted)]">
              Source · Internal benchmark, 2023 to 2025
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- BENTO: 5 problem cards with images -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
      {problems.map((p, i) => {
        const img = images[i];
        const tag = tags[i];
        const isFeatured = i === 0;
        const cardClass = isFeatured
          ? 'md:col-span-2 lg:col-span-2 group relative rounded-3xl overflow-hidden transition-all duration-500 bg-white border border-[var(--color-surface-border)] hover:-translate-y-1.5 hover:border-[var(--color-brand-orange)]/40 hover:shadow-[0_30px_60px_-20px_rgba(15,15,18,0.18)]'
          : 'group relative rounded-3xl overflow-hidden transition-all duration-500 bg-white border border-[var(--color-surface-border)] hover:-translate-y-1 hover:border-[var(--color-brand-orange)]/40 hover:shadow-[0_22px_50px_-22px_rgba(15,15,18,0.15)]';

        return (
          <article
            data-reveal
            data-reveal-delay={String(i * 70)}
            data-cursor-spotlight
            class:list={[cardClass]}
          >
            <!-- Image: top of card with subtle gradient overlay -->
            <div class:list={['relative overflow-hidden', isFeatured ? 'aspect-[16/7]' : 'aspect-[16/9]']}>
              <img
                src={img}
                alt={p.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
                loading="lazy"
                decoding="async"
              />
              <!-- Bottom gradient for legibility of tag -->
              <div class="absolute inset-0 bg-gradient-to-t from-[#0f0f12]/60 via-transparent to-transparent"></div>
              <!-- Tag pill bottom-left -->
              <div class="absolute top-4 left-4 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/[0.10] backdrop-blur-md border border-white/20">
                <span class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]"></span>
                <span class="text-[10px] font-semibold uppercase tracking-[0.16em] text-white">{tag}</span>
              </div>
              <!-- Top accent bar (slides on hover) -->
              <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF9466] to-[var(--color-brand-orange)] origin-left scale-x-0 transition-transform duration-700 group-hover:scale-x-100 z-10"></div>
            </div>

            <!-- Body -->
            <div class="p-7 lg:p-8 flex flex-col">
              <h3 class:list={['font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3 transition-colors duration-300 group-hover:text-[var(--color-brand-orange)]', isFeatured ? 'text-2xl lg:text-3xl' : 'text-xl lg:text-2xl']}>
                {p.title}
              </h3>
              <p class:list={['text-[var(--color-text-body)] leading-relaxed', isFeatured ? 'text-base lg:text-lg' : 'text-[15px]']}>
                {p.description}
              </p>

              {p.citation && (
                <p class="mt-5 pt-5 border-t border-[var(--color-surface-border)] text-xs text-[var(--color-text-muted)] leading-relaxed italic">
                  {p.citation}
                </p>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>