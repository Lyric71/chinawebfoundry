---
/**
 * Stats / key figures section (iO pattern)
 * Circular image left + stat rows with dividers right
 */
const stats = [
  { number: '8+', description: 'years of WordPress expertise in China' },
  { number: '50+', description: 'WordPress sites launched behind the Great Firewall' },
  { number: '<3s', description: 'average load time from mainland China' },
  { number: '100%', description: 'ICP compliance rate across all client sites' },
  { number: '2', description: 'offices in Shanghai and London' },
];
---

<section class="section-spacing bg-[var(--color-surface-light)]">
  <div class="mx-auto max-w-[1400px] section-padding">
    <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-16">
      ChinaWebFoundry, strength in numbers
    </h2>

    <div class="io-grid items-start">
      <!-- Left: circular image (5 cols) -->
      <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 flex justify-center lg:justify-start">
        <div class="w-64 h-64 lg:w-80 lg:h-80 rounded-full overflow-hidden bg-gradient-to-br from-[var(--color-brand-orange)]/20 to-[var(--color-text-card-blue)]/20">
          <!-- Placeholder for team/office photo -->
          <div class="w-full h-full bg-[url('/images/placeholder-team.jpg')] bg-cover bg-center"></div>
        </div>
      </div>

      <!-- Right: stat rows with dividers (7 cols) -->
      <div class="col-span-12 lg:col-span-7">
        <div class="divider-list">
          {stats.map((stat) => (
            <div class="flex items-baseline gap-6 sm:gap-10 py-5">
              <span class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] flex-shrink-0 w-24 lg:w-28">
                {stat.number}
              </span>
              <span class="text-lg lg:text-xl text-[var(--color-text-dark)]">
                {stat.description}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
