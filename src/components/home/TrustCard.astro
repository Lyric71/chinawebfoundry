---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div>
  <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-2">
    {title}
  </h3>
  <p class="text-base text-[var(--color-text-body)]">
    {description}
  </p>
</div>
