---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
---

<section class="section-spacing bg-[var(--color-surface-light)]">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div>
        <h1 class="text-3xl sm:text-4xl lg:text-[48px] font-semibold font-[var(--font-heading)] text-[var(--color-brand-red)] leading-tight">
          Launch Your WordPress Website in China
          <span class="block mt-2">- That Actually Works!</span>
        </h1>
        <p class="mt-6 text-lg text-[var(--color-text-body)] max-w-lg">
          ChinaWebFoundry is a China-based WordPress agency. We migrate, host, and optimise WordPress sites for the Chinese market - fast, compliant, and Baidu-ready.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="#OurServices" variant="primary" size="lg">Our Services</Button>
          <Button href="/contact/" variant="secondary" size="lg">Contact Us</Button>
        </div>
      </div>

      <!-- Hero images placeholder -->
      <div class="flex gap-4 justify-center">
        <div class="w-40 h-56 bg-gradient-to-br from-[var(--color-brand-orange)] to-[var(--color-brand-red)] rounded-lg opacity-80"></div>
        <div class="w-40 h-56 bg-gradient-to-br from-[var(--color-brand-red)] to-[var(--color-brand-orange)] rounded-lg opacity-60 mt-8"></div>
        <div class="w-40 h-56 bg-gradient-to-br from-[var(--color-brand-orange)] to-[var(--color-brand-red)] rounded-lg opacity-40 mt-4 hidden sm:block"></div>
      </div>
    </div>
  </Container>
</section>
