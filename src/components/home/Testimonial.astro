---
/**
 * Testimonial: rich auto-rotating carousel with
 * - giant decorative quote glyph
 * - stylized initials avatar
 * - brand context tags
 * - dot navigation + manual previous/next
 * - subtle parallax background and gradient mesh
 */
import { getCollection } from 'astro:content';

const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => a.data.order - b.data.order,
);

const items = testimonials.map((t) => ({
  name: t.data.name,
  initials: t.data.name
    .split(' ')
    .filter(Boolean)
    .map((s) => s[0])
    .join('')
    .slice(0, 2)
    .toUpperCase(),
  role: t.data.role,
  company: t.data.company,
  body: t.body || '',
}));

// Map company to a complimentary brand tone for the avatar
const colorMap: Record<string, string> = {
  Bassetti: 'from-[#3b82f6] via-[#6366f1] to-[#8b5cf6]',
  'Luxury Swiss Watch Brand': 'from-amber-500 via-orange-500 to-red-500',
  'American Food Brand': 'from-emerald-500 via-teal-500 to-cyan-500',
};

// Brand context lines (what the engagement included)
const contextMap: Record<string, string[]> = {
  Bassetti: ['Strategy & Audit', 'WordPress migration', 'Baidu SEO'],
  'Luxury Swiss Watch Brand': ['ICP filing', 'China hosting', 'Baidu indexing'],
  'American Food Brand': ['Performance rebuild', 'CDN config', 'Migration'],
};

// Highlight quote phrase per testimonial (prefilled to be meaningful)
const highlightMap: Record<string, string> = {
  Bassetti: 'understood both worlds',
  'Luxury Swiss Watch Brand': 'within six weeks',
  'American Food Brand': 'under 2 seconds',
};
---

<section
  data-testimonial-section
  class="relative py-24 md:py-32 lg:py-36 overflow-hidden bg-gradient-to-b from-white via-[var(--color-surface-light)] to-white"
>
  <!-- Background decorative layers -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 left-[15%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.05] blur-[140px]"></div>
    <div class="absolute -bottom-32 right-[10%] w-[400px] h-[400px] rounded-full bg-[#3b82f6]/[0.05] blur-[140px]"></div>
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:34px_34px] opacity-[0.03]"></div>
  </div>
  <!-- Decorative giant Chinese glyph -->
  <span aria-hidden="true" class="absolute right-[-3rem] top-[8%] text-[20rem] lg:text-[26rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.05] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.12">客户</span>

  <div class="relative z-10 mx-auto max-w-[1200px] section-padding">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16" data-reveal>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
        <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)]">In their words · 客户评价</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
        From people whose brands actually went live in China.
      </h2>
    </div>

    <!-- Carousel container -->
    <div class="relative" data-testimonial-carousel>
      <!-- Massive decorative quote glyph -->
      <span aria-hidden="true" class="absolute -top-12 -left-4 lg:-left-12 text-[12rem] lg:text-[16rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.10] leading-none select-none pointer-events-none">"</span>

      <!-- Slides -->
      <div class="relative min-h-[420px] lg:min-h-[380px]">
        {items.map((t, i) => (
          <article
            class:list={[
              'testimonial-slide absolute inset-0 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]',
              i === 0 ? 'opacity-100 translate-y-0 is-active' : 'opacity-0 translate-y-6 pointer-events-none',
            ]}
            data-slide-index={i}
          >
            <div class="grid grid-cols-12 gap-8 lg:gap-12 items-center">
              <!-- Avatar + meta -->
              <div class="col-span-12 lg:col-span-4 flex flex-col items-center lg:items-start text-center lg:text-left">
                <!-- Stylized avatar -->
                <div class:list={['relative w-28 h-28 lg:w-36 lg:h-36 rounded-full bg-gradient-to-br', colorMap[t.company] || 'from-slate-500 to-slate-700', 'flex items-center justify-center shadow-[0_20px_50px_-12px_rgba(0,0,0,0.25)] mb-5']}>
                  <span class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] text-white tracking-wider">{t.initials}</span>
                  <!-- Decorative ring -->
                  <span aria-hidden="true" class="absolute -inset-2 rounded-full border-2 border-dashed border-[var(--color-brand-orange)]/30 animate-[spin_25s_linear_infinite]"></span>
                </div>

                <p class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)]">{t.name}</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">{t.role}</p>
                <p class="text-sm font-medium text-[var(--color-text-card-blue)] mt-1">{t.company}</p>

                <!-- Service tags -->
                {contextMap[t.company] && (
                  <div class="mt-5 flex flex-wrap justify-center lg:justify-start gap-1.5">
                    {contextMap[t.company].map((tag) => (
                      <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-[var(--color-brand-orange)]/8 border border-[var(--color-brand-orange)]/20 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              <!-- Quote -->
              <div class="col-span-12 lg:col-span-8">
                <blockquote class="text-xl md:text-2xl lg:text-[28px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.35]">
                  {highlightMap[t.company]
                    ? (() => {
                        const phrase = highlightMap[t.company];
                        const idx = t.body.toLowerCase().indexOf(phrase.toLowerCase());
                        if (idx === -1) return t.body;
                        const before = t.body.slice(0, idx);
                        const match = t.body.slice(idx, idx + phrase.length);
                        const after = t.body.slice(idx + phrase.length);
                        return (
                          <>
                            {before}
                            <span class="relative inline-block">
                              <span class="relative z-10 text-[var(--color-brand-orange)] font-semibold">{match}</span>
                              <span aria-hidden="true" class="absolute left-0 right-0 bottom-1 h-2 lg:h-3 bg-[var(--color-brand-orange)]/15 -z-0"></span>
                            </span>
                            {after}
                          </>
                        );
                      })()
                    : t.body}
                </blockquote>

                <div class="mt-8 flex items-center gap-4">
                  <!-- Star rating -->
                  <div class="flex items-center gap-0.5">
                    {[...Array(5)].map(() => (
                      <svg class="w-4 h-4 text-[var(--color-brand-orange)]" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
                    ))}
                  </div>
                  <span class="text-xs font-medium text-[var(--color-text-muted)]">Verified case study client</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Controls: dots + arrows -->
      <div class="mt-10 lg:mt-14 flex items-center justify-between gap-6 flex-wrap">
        <!-- Dot indicators -->
        <div class="flex items-center gap-2.5" role="tablist">
          {items.map((t, i) => (
            <button
              type="button"
              data-dot-index={i}
              class:list={[
                'testimonial-dot group relative flex items-center justify-center transition-all duration-300',
                i === 0 ? 'is-active' : '',
              ]}
              aria-label={`Show testimonial ${i + 1}`}
            >
              <span class="block h-1.5 w-8 rounded-full bg-[var(--color-text-muted)]/25 transition-all duration-500 group-[.is-active]:bg-[var(--color-brand-orange)] group-[.is-active]:w-14"></span>
              <span aria-hidden="true" class="absolute inset-0 rounded-full -m-1"></span>
            </button>
          ))}
        </div>

        <!-- Arrow controls + auto-rotate progress -->
        <div class="flex items-center gap-3">
          <!-- Progress ring around play indicator -->
          <div class="relative w-9 h-9">
            <svg class="w-full h-full -rotate-90" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="15" stroke="rgba(0,0,0,0.06)" stroke-width="2" fill="none"/>
              <circle
                data-rotate-progress
                cx="18" cy="18" r="15"
                stroke="var(--color-brand-orange)"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
                stroke-dasharray="94"
                stroke-dashoffset="94"
                style="transition: stroke-dashoffset 5s linear;"
              />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
            </span>
          </div>

          <button
            type="button"
            data-arrow="prev"
            class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-[var(--color-surface-border)] text-[var(--color-text-dark)] hover:border-[var(--color-brand-orange)] hover:text-[var(--color-brand-orange)] transition-all duration-200 hover:-translate-x-0.5"
            aria-label="Previous testimonial"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button
            type="button"
            data-arrow="next"
            class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-[var(--color-surface-border)] text-[var(--color-text-dark)] hover:border-[var(--color-brand-orange)] hover:text-[var(--color-brand-orange)] transition-all duration-200 hover:translate-x-0.5"
            aria-label="Next testimonial"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>

          <a
            href="/work/"
            class="ml-2 inline-flex items-center gap-2 text-sm font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] no-underline hover:gap-3 transition-all duration-200"
          >
            All case studies
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initTestimonialCarousel() {
    const root = document.querySelector<HTMLElement>('[data-testimonial-carousel]');
    if (!root) return;

    const slides = Array.from(root.querySelectorAll<HTMLElement>('.testimonial-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-dot-index]'));
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-arrow="prev"]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-arrow="next"]');
    const ringFg = root.querySelector<SVGCircleElement>('[data-rotate-progress]');

    if (!slides.length) return;

    const ROTATE_MS = 5000;
    const RING_LEN = 94;
    let active = 0;
    let timer: number | null = null;

    function show(idx: number) {
      const next = (idx + slides.length) % slides.length;
      slides.forEach((s, i) => {
        const isActive = i === next;
        s.classList.toggle('opacity-100', isActive);
        s.classList.toggle('translate-y-0', isActive);
        s.classList.toggle('is-active', isActive);
        s.classList.toggle('opacity-0', !isActive);
        s.classList.toggle('translate-y-6', !isActive);
        s.classList.toggle('pointer-events-none', !isActive);
      });
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === next);
      });
      active = next;
      restartRing();
    }

    function restartRing() {
      if (!ringFg) return;
      // Reset (instant), then animate
      ringFg.style.transition = 'none';
      ringFg.style.strokeDashoffset = String(RING_LEN);
      void (ringFg as unknown as HTMLElement).getBoundingClientRect();
      requestAnimationFrame(() => {
        ringFg.style.transition = `stroke-dashoffset ${ROTATE_MS}ms linear`;
        ringFg.style.strokeDashoffset = '0';
      });
    }

    function start() {
      stop();
      timer = window.setInterval(() => show(active + 1), ROTATE_MS);
      restartRing();
    }
    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
      if (ringFg) {
        ringFg.style.transition = 'none';
        ringFg.style.strokeDashoffset = String(RING_LEN);
      }
    }

    dots.forEach((d, i) => {
      d.addEventListener('click', () => {
        show(i);
        start();
      });
    });
    prevBtn?.addEventListener('click', () => {
      show(active - 1);
      start();
    });
    nextBtn?.addEventListener('click', () => {
      show(active + 1);
      start();
    });

    // Pause on hover
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    // Start auto-rotation only when in view
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) start();
        else stop();
      });
    }, { threshold: 0.3 });
    io.observe(root);
  }

  initTestimonialCarousel();
  document.addEventListener('astro:page-load', initTestimonialCarousel);
  document.addEventListener('astro:after-swap', initTestimonialCarousel);
</script>