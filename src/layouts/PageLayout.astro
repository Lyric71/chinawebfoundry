---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** When true, header overlays content (transparent bg), no spacer. Used for hero pages. */
  heroPage?: boolean;
}

const { title, description, canonical, ogImage, heroPage = false } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Header heroPage={heroPage} />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
