---
import PageLayout from './PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { getLangFromUrl, localePath, useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  metaTitle: string;
  metaDescription: string;
  lang?: Locale;
  /** Service slug (without locale prefix), used for the Service schema URL. */
  slug?: string;
}

const { title, description, metaTitle, metaDescription, lang, slug } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') || 'https://www.chinawebfoundry.com';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const homeUrl = `${siteOrigin}${localePath('/', currentLang)}`;
const servicesUrl = `${siteOrigin}${localePath('/services/', currentLang)}`;
const homeLabel = t('service.home');
const servicesLabel = currentLang === 'es' ? 'Servicios' : 'Services';
const inLanguageMap = { en: 'en-GB', fr: 'fr-FR', es: 'es-ES' } as const;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description,
  url: pageUrl,
  inLanguage: inLanguageMap[currentLang],
  provider: { '@id': `${siteOrigin}/#organization` },
  areaServed: { '@type': 'Country', name: 'China' },
  serviceType: title,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: homeUrl },
    { '@type': 'ListItem', position: 2, name: servicesLabel, item: servicesUrl },
    { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
  ],
};

const jsonLd = [serviceLd, breadcrumbLd];
// `slug` is informational for now; reserved for potential future use (e.g. linking related Service entries).
void slug;
---

<PageLayout title={metaTitle} description={metaDescription} lang={currentLang} jsonLd={jsonLd}>
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="section-padding pt-6">
    <Container>
      <ol class="flex items-center gap-2 text-sm text-[var(--color-text-muted)]">
        <li><a href={localePath('/', currentLang)} class="hover:text-[var(--color-brand-orange)]">{t('service.home')}</a></li>
        <li class="before:content-['/'] before:mx-2">{title}</li>
      </ol>
    </Container>
  </nav>

  <!-- Service Hero -->
  <section class="section-spacing">
    <Container>
      <SectionHeading tag="h1" title={title} subtitle={description} align="center" />
    </Container>
  </section>

  <!-- Service Content -->
  <section class="pb-16">
    <Container>
      <div class="prose prose-lg max-w-3xl mx-auto">
        <slot />
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <Container class="text-center">
      <h2 class="text-2xl md:text-[28px] font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-4">
        {t('service.readyToStart')}
      </h2>
      <p class="text-[var(--color-text-body)] mb-8 max-w-xl mx-auto">
        {t('service.letsDiscuss')}
      </p>
      <Button href={localePath('/contact/', currentLang)} variant="primary" size="lg">{t('nav.contactUs')}</Button>
    </Container>
  </section>
</PageLayout>
