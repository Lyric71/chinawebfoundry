---
import '../styles/global.css';
import { getLangFromUrl, getHreflangUrls, localePath } from '../i18n/utils';
import { buildBreadcrumbLd } from '../lib/seoSchema';
import type { Locale } from '../i18n/ui';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  lang?: Locale;
  /** Optional extra JSON-LD blocks (e.g. Service, Article, FAQPage) emitted in addition to the sitewide Organization + WebSite. */
  jsonLd?: Record<string, unknown>[];
  /** When set, emits a two-level BreadcrumbList (Home > breadcrumbName) for second-level pages that don't already build their own. */
  breadcrumbName?: string;
  /** Override the auto-computed hreflang URLs when locales use different slugs (e.g. /web-agency-china/ vs /fr/agence-web-chine/ vs /es/agencia-web-china/ vs /de/webagentur-china/). Pass absolute paths starting with /. */
  alternateUrls?: { en: string; fr: string; es?: string; de?: string };
}

const { title, description, canonical, ogImage = '/images/og-default.webp', lang, jsonLd = [], alternateUrls, breadcrumbName } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') || 'https://www.chinawebfoundry.com';
const autoHreflang = getHreflangUrls(Astro.url.pathname, siteOrigin);
const hreflang = {
  en: alternateUrls?.en ? `${siteOrigin}${alternateUrls.en}` : autoHreflang.en,
  fr: alternateUrls?.fr ? `${siteOrigin}${alternateUrls.fr}` : autoHreflang.fr,
  es: alternateUrls?.es ? `${siteOrigin}${alternateUrls.es}` : autoHreflang.es,
  de: alternateUrls?.de ? `${siteOrigin}${alternateUrls.de}` : autoHreflang.de,
};
const ogLocaleMap = { en: 'en_GB', fr: 'fr_FR', es: 'es_ES', de: 'de_DE' } as const;
const inLanguageMap = { en: 'en-GB', fr: 'fr-FR', es: 'es-ES', de: 'de-DE' } as const;
const ogLocale = ogLocaleMap[currentLang];
const ogLocaleAlternates = (['en', 'fr', 'es', 'de'] as const).filter((l) => l !== currentLang).map((l) => ogLocaleMap[l]);

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'ProfessionalService'],
  '@id': `${siteOrigin}/#organization`,
  name: 'ChinaWebFoundry',
  alternateName: 'China Web Foundry',
  url: `${siteOrigin}/`,
  logo: {
    '@type': 'ImageObject',
    '@id': `${siteOrigin}/#logo`,
    url: `${siteOrigin}/Logo-ChinaWebFoundry-final.webp`,
    contentUrl: `${siteOrigin}/Logo-ChinaWebFoundry-final.webp`,
    width: 160,
    height: 139,
    caption: 'ChinaWebFoundry',
  },
  description: 'Web agency based in Shanghai. We build and maintain websites for international brands operating in mainland China.',
  slogan: 'Web agency in China for international brands',
  priceRange: '$$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '19th Floor, Trinity Plaza, 868 Changshou Road',
    addressLocality: 'Shanghai',
    addressRegion: 'Putuo District',
    postalCode: '200060',
    addressCountry: 'CN',
  },
  areaServed: { '@type': 'Country', name: 'China' },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'hello@bearingbridge.com',
    url: `${siteOrigin}/contact/`,
    availableLanguage: ['English', 'French', 'Spanish', 'German', 'Chinese'],
    areaServed: 'CN',
  },
  knowsLanguage: ['en', 'fr', 'es', 'de', 'zh-CN'],
  founder: {
    '@type': 'Person',
    name: 'Cyril Drouin',
    jobTitle: 'Founder and CEO',
    sameAs: [
      'https://www.linkedin.com/in/cyril-d-68835729/',
      'https://cyrildrouin.substack.com/',
    ],
  },
  sameAs: [
    'https://www.linkedin.com/in/cyril-d-68835729/',
    'https://cyrildrouin.substack.com/',
    'https://bearingbridge.com',
  ],
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  url: `${siteOrigin}/`,
  name: 'ChinaWebFoundry',
  description: 'Web agency in China for international brands.',
  inLanguage: inLanguageMap[currentLang],
  publisher: { '@id': `${siteOrigin}/#organization` },
};

const homeLabelMap = { en: 'Home', fr: 'Accueil', es: 'Inicio', de: 'Startseite' } as const;
const breadcrumbLd = breadcrumbName
  ? [
      buildBreadcrumbLd([
        { name: homeLabelMap[currentLang], item: `${siteOrigin}${localePath('/', currentLang)}` },
        { name: breadcrumbName, item: canonicalURL },
      ]),
    ]
  : [];

const sitewideLd = [organizationLd, websiteLd, ...breadcrumbLd, ...jsonLd];
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={hreflang.en} />
    <link rel="alternate" hreflang="fr" href={hreflang.fr} />
    <link rel="alternate" hreflang="es" href={hreflang.es} />
    <link rel="alternate" hreflang="de" href={hreflang.de} />
    <link rel="alternate" hreflang="x-default" href={hreflang.en} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}
    <meta property="og:site_name" content="ChinaWebFoundry" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/poppins-500.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-500.woff2" as="font" type="font/woff2" crossorigin />

    <!-- JSON-LD: Organization + WebSite (sitewide) plus any per-page schema passed via jsonLd prop -->
    {sitewideLd.map((ld) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
