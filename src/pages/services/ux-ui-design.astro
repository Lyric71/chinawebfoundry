---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'UX/UI Design for WordPress in China | ChinaWebFoundry';
const metaDescription = 'We design WordPress sites that work for Chinese users. Culturally adapted, mobile-first, built by a China-based team with 20 years local experience.';

const stats = [
  { value: '70%+', label: 'Mobile traffic in China' },
  { value: '6', label: 'Browsers we QA on' },
  { value: 'WeChat', label: 'Native integration' },
  { value: 'ICP', label: 'Compliant by design' },
];

const services = [
  {
    title: 'UX research and user insights',
    body: 'We map how your audience actually moves through content in China, benchmark local and international competitors, and design journeys that begin where Chinese users begin: Douyin, WeChat, or Baidu.',
    icon: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607Z',
    tag: 'Research',
  },
  {
    title: 'Information architecture',
    body: 'Chinese audiences prefer denser pages. More links visible, more text, more options upfront. We structure content for the depth visitors expect, without making it unreadable for HQ.',
    icon: 'M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5',
    tag: 'IA',
  },
  {
    title: 'Visual design',
    body: 'Mobile-first layouts for the devices people in China actually use. Symbolic colour, typography that respects Chinese characters, and the trust signals (WeChat QR, ICP, business licence) Chinese consumers verify before they act.',
    icon: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
    tag: 'UI',
  },
  {
    title: 'Gutenberg-native design system',
    body: 'We design inside Gutenberg directly. Custom blocks your content team uses without a developer, components for visual consistency, templates non-technical staff can update themselves.',
    icon: 'M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3',
    tag: 'System',
  },
];

const processSteps = [
  { phase: '01', title: 'Discovery and briefing', body: 'Get aligned on brand guidelines, goals, and who you are trying to reach in China.' },
  { phase: '02', title: 'Research and benchmarking', body: 'Competitive landscape, local user patterns, design principles. The homework phase.' },
  { phase: '03', title: 'Wireframing', body: 'Page structure and user flows checked against how Chinese users expect sites to work. Cheaper to rework a wireframe than a polished mockup.' },
  { phase: '04', title: 'Visual design and iteration', body: 'High-fidelity mockups and feedback rounds until it works for your global brand and the Chinese market.' },
  { phase: '05', title: 'Design system and handoff', body: 'Components, style guidelines, and interaction specs packaged so your dev team can build without guessing.' },
  { phase: '06', title: 'QA and validation', body: 'We test on Chinese browsers and devices. A site that looks great in London can fall apart on UC Browser or QQ Browser, both still big in China.' },
];

const colours = [
  { name: 'Auspicious red', hex: '#E11D2E', meaning: 'Luck, energy, action' },
  { name: 'Brand orange', hex: '#F25F29', meaning: 'Vitality, accent' },
  { name: 'Trust green', hex: '#52C41A', meaning: 'Confirmation, WeChat' },
  { name: 'Ink', hex: '#1F1F1F', meaning: 'Headings, anchor' },
  { name: 'Cloud', hex: '#FAFAFA', meaning: 'Surface, never solo' },
];

const typeScale = [
  { label: 'H1', size: '32', cn: '中文标题', en: 'Display Headline' },
  { label: 'H2', size: '24', cn: '副标题', en: 'Section Subhead' },
  { label: 'Body', size: '16', cn: '正文段落', en: 'Body paragraph' },
  { label: 'Caption', size: '12', cn: '辅助说明', en: 'Caption / meta' },
];

const spacingTokens = [
  { name: '4 · XS', width: 'w-2' },
  { name: '8 · S', width: 'w-4' },
  { name: '16 · M', width: 'w-8' },
  { name: '24 · L', width: 'w-12' },
  { name: '32 · XL', width: 'w-16' },
  { name: '48 · 2XL', width: 'w-24' },
];

const intelligence = [
  {
    claim: 'Colour carries meaning',
    body: 'Red signals luck and energy. Gold conveys premium. White used solo carries funerary weight, so we pair it with strong accents.',
    visual: 'colour',
  },
  {
    claim: 'Density reads as trust',
    body: 'Dense above-the-fold layouts feel grounded to Chinese users. Whitespace-heavy designs can read as empty, unfinished, or evasive.',
    visual: 'density',
  },
  {
    claim: 'Trust lives at the edges',
    body: 'ICP filing number, business licence, official badges. Footer placement is conventional. Above-fold QR codes anchor credibility.',
    visual: 'trust',
  },
  {
    claim: 'WeChat is plumbing',
    body: 'QR codes, mini-program links, share endpoints, customer service handles. These are baseline infrastructure, not optional features.',
    visual: 'wechat',
  },
  {
    claim: 'Type carries weight',
    body: 'PingFang SC, Noto Sans SC or Source Han pair with Inter or system stacks. Character spacing and line height differ from Latin.',
    visual: 'type',
  },
  {
    claim: 'Bottom nav is the home button',
    body: 'Sticky bottom navigation is the home button of the Chinese mobile web. Five tap-targets, always visible, always thumbable.',
    visual: 'nav',
  },
];

const audiences = [
  { label: 'Starting from scratch', description: 'You\'re building a WordPress site for China and you want to get the design right from the start.', image: '/images/audiences/building-site-china-design.webp' },
  { label: 'Not performing', description: 'You already have a site live in China but it\'s not performing and you think the design might be the issue.', image: '/images/audiences/live-site-not-performing.webp' },
  { label: 'Campaign pages', description: 'Your marketing team needs pages targeting Chinese consumers that don\'t feel translated from English.', image: '/images/audiences/campaign-chinese-consumers.webp' },
  { label: 'Adapting global design', description: 'You\'ve got a solid global design system and you need someone who understands how to adapt it for China.', image: '/images/audiences/global-design-adapt-china.webp' },
];

const marqueeWords = [
  '移动优先', 'Mobile-first',
  '微信', 'WeChat',
  '百度', 'Baidu',
  '抖音', 'Douyin',
  '备案', 'ICP filing',
  'Gutenberg',
  '中文排版', 'CN typography',
  '信任信号', 'Trust signals',
  '色彩文化', 'Cultural colour',
  '密度优先', 'Density-first',
  'PingFang SC',
  'UC · QQ · Chrome',
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <!-- HERO: editorial split with phone mockup -->
  <section class="relative bg-[#0a0a0d] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px]"></div>
      <div class="absolute -bottom-40 right-1/3 w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/5 blur-[100px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(242,95,41,0.08),transparent_50%)]"></div>
      <!-- subtle grid overlay -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Breadcrumb" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">UX/UI Design</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 lg:pb-32">
        <!-- Text -->
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">UX / UI · 设计</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Design <span class="italic font-light text-white/80">for</span><br/>
            how Chinese users
            <span class="block mt-3 text-[var(--color-brand-orange)]">actually browse.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            WordPress experiences that feel native to users in China. Culturally relevant, mobile-first, shaped around the platforms that run China's internet.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/contact/" variant="primary" size="lg">Start your design project</Button>
            <a href="#what-we-offer" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              See the system
              <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <!-- Visual: artboard-framed phone mockup -->
        <div class="col-span-12 lg:col-span-5 mt-16 lg:mt-0">
          <div class="relative">
            <div class="absolute -inset-8 bg-[var(--color-brand-orange)]/15 rounded-[40px] blur-3xl -z-10"></div>

            <!-- Artboard label -->
            <div class="flex items-center justify-between mb-3 px-1">
              <div class="flex items-center gap-2 text-[11px] font-mono text-white/40">
                <span class="w-1.5 h-1.5 rounded-sm bg-[var(--color-brand-orange)]"></span>
                <span>home-mobile.fig</span>
              </div>
              <div class="text-[11px] font-mono text-white/30">375 × 812</div>
            </div>

            <div class="relative rounded-3xl overflow-hidden border border-white/10 bg-gradient-to-br from-white/[0.04] to-transparent">
              <img
                src="/images/ux-design-china-mobile-wordpress-mockup.webp"
                alt="A WordPress mobile homepage designed for Chinese users, with red accents, WeChat QR code, and ICP licence"
                class="w-full h-auto block"
                loading="eager"
                decoding="async"
              />
            </div>

            <!-- Floating chip: Mobile-first -->
            <div class="hidden sm:flex absolute -left-6 top-20 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <span class="w-2 h-2 rounded-full bg-green-400"></span>
              <span class="text-xs font-medium text-white">Mobile-first</span>
            </div>

            <!-- Floating chip: trust signals -->
            <div class="hidden sm:flex absolute -right-4 bottom-24 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <svg class="w-3.5 h-3.5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              <span class="text-xs font-medium text-white">WeChat + ICP</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VOCABULARY MARQUEE -->
  <section aria-hidden="true" class="bg-[#0a0a0d] border-y border-white/5 overflow-hidden py-5">
    <div class="marquee-mask">
      <div class="marquee-track flex items-center gap-10 whitespace-nowrap">
        {[...marqueeWords, ...marqueeWords].map((word, i) => (
          <div class="flex items-center gap-10 flex-shrink-0">
            <span class={`text-base font-medium ${i % 2 === 0 ? 'text-white/40' : 'text-white/70'}`}>{word}</span>
            <span class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]/60 flex-shrink-0"></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="bg-white border-b border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-[var(--color-surface-border)] py-10 lg:py-12 -mx-4 sm:-mx-6 lg:-mx-8">
        {stats.map((stat) => (
          <div class="px-4 sm:px-6 lg:px-8">
            <div class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] tracking-tight leading-none">
              {stat.value}
            </div>
            <div class="mt-3 text-sm text-[var(--color-text-muted)]">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-12 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            The problem
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] mb-8 tracking-tight">
            Why Western design<br/>
            <span class="text-[var(--color-text-muted)]">falls flat in China.</span>
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            A company gets their WordPress site converting back home, launches it in China, and bounce rates spike. The site looks fine technically, but something about it feels wrong to anyone browsing from Shanghai or Chengdu.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            Chinese internet users did not grow up on the same web. How they navigate, how much information they expect to see at once, all shaped by WeChat, Taobao, and Douyin.
          </p>
          <blockquote class="border-l-2 border-[var(--color-brand-orange)] pl-6 py-1">
            <p class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
              A design language that converts in Chicago does not automatically work in Chongqing.
            </p>
          </blockquote>
        </div>

        <div class="col-span-12 lg:col-span-6">
          <div class="relative">
            <div class="rounded-2xl overflow-hidden border border-[var(--color-surface-border)] shadow-xl shadow-black/5">
              <img
                src="/images/ux-design-china-vs-western-mobile-comparison.webp"
                alt="Two phones side by side, one showing a sparse Western-style site, the other a dense Chinese-style site with WeChat QR and trust signals"
                class="w-full h-auto block"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="mt-5 grid grid-cols-2 gap-4 text-center">
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Western-style</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Sparse, low engagement</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)] mb-1">China-native</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Dense, converts</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CHINA DESIGN INTELLIGENCE GRID -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-20">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Field knowledge
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] tracking-tight">
            Six things designing<br/>for China taught us.
          </h2>
        </div>
        <p class="text-base text-[var(--color-text-muted)] max-w-md font-mono uppercase tracking-wider text-xs">
          A.01 to A.06 / China UX heuristics
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {intelligence.map((card, idx) => (
          <article class="group relative rounded-2xl bg-white border border-[var(--color-surface-border)] overflow-hidden hover:border-[var(--color-brand-orange)]/40 hover:shadow-xl hover:shadow-black/5 transition-all duration-300">
            <!-- Visual artifact area -->
            <div class="relative h-44 bg-gradient-to-br from-[var(--color-surface-light)] to-white border-b border-[var(--color-surface-border)] overflow-hidden">
              <div class="absolute top-3 left-4 text-[11px] font-mono text-[var(--color-text-muted)] uppercase tracking-wider">
                A.0{idx + 1}
              </div>

              {card.visual === 'colour' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-end gap-1">
                    <div class="w-12 h-20 rounded-md bg-[#E11D2E] shadow-md"></div>
                    <div class="w-12 h-16 rounded-md bg-[#F25F29] shadow-md"></div>
                    <div class="w-12 h-12 rounded-md bg-[#D4AF37] shadow-md"></div>
                    <div class="w-12 h-8 rounded-md bg-[#52C41A] shadow-md"></div>
                  </div>
                </div>
              )}

              {card.visual === 'density' && (
                <div class="absolute inset-0 flex items-center justify-center px-8">
                  <div class="w-full max-w-[180px] space-y-1.5">
                    <div class="h-3 bg-[var(--color-brand-orange)]/80 rounded-sm"></div>
                    <div class="grid grid-cols-3 gap-1.5">
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm"></div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm w-3/4"></div>
                    <div class="grid grid-cols-2 gap-1.5">
                      <div class="h-6 bg-[var(--color-brand-orange)]/30 rounded-sm"></div>
                      <div class="h-6 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'trust' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-center gap-2.5">
                    <div class="px-3 py-2 rounded-md border border-[var(--color-surface-border)] bg-white text-[10px] font-mono text-[var(--color-text-body)]">
                      ICP 沪B2-2024<br/>0123456号
                    </div>
                    <div class="w-12 h-12 rounded-md bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center text-white text-[10px] font-bold">营业<br/>执照</div>
                    <div class="w-10 h-10 rounded-md bg-[#52C41A] flex items-center justify-center">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'wechat' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative w-24 h-24 bg-white rounded-xl border border-[var(--color-surface-border)] p-2">
                    <div class="grid grid-cols-7 gap-px h-full w-full">
                      {Array.from({ length: 49 }).map((_, i) => {
                        const filled = [0,1,2,3,5,6,8,12,14,15,18,20,22,24,28,29,30,32,34,36,40,42,43,44,46,47,48].includes(i);
                        return <div class={filled ? 'bg-[var(--color-text-dark)] rounded-[1px]' : ''}></div>;
                      })}
                    </div>
                    <div class="absolute -bottom-2 -right-2 w-7 h-7 rounded-full bg-[#52C41A] border-2 border-white flex items-center justify-center">
                      <span class="text-white text-[9px] font-bold">微信</span>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'type' && (
                <div class="absolute inset-0 flex items-center justify-center gap-3 px-6">
                  <span class="text-[80px] leading-none font-medium text-[var(--color-text-dark)]">中</span>
                  <div class="h-16 w-px bg-[var(--color-surface-border)]"></div>
                  <span class="text-[72px] leading-none font-light text-[var(--color-text-dark)] italic">Aa</span>
                </div>
              )}

              {card.visual === 'nav' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative w-20 h-32 rounded-xl border-2 border-[var(--color-text-dark)]/30 bg-white p-1.5 flex flex-col">
                    <div class="flex-1 space-y-1">
                      <div class="h-1.5 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-3 bg-[var(--color-text-dark)]/10 rounded-sm"></div>
                      <div class="h-1.5 bg-[var(--color-text-dark)]/15 rounded-sm w-3/4"></div>
                      <div class="h-3 bg-[var(--color-brand-orange)]/30 rounded-sm"></div>
                    </div>
                    <div class="mt-1 flex items-center justify-around bg-[var(--color-brand-orange)]/10 rounded-md px-1 py-1.5 border-t border-[var(--color-brand-orange)]/30">
                      {Array.from({ length: 5 }).map(() => (
                        <div class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]"></div>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </div>

            <!-- Body -->
            <div class="p-7">
              <h3 class="text-lg lg:text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3 tracking-tight">
                {card.claim}
              </h3>
              <p class="text-[14px] text-[var(--color-text-body)] leading-relaxed">
                {card.body}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE OFFER: bento -->
  <section id="what-we-offer" class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14 lg:mb-20">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          What we offer
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] tracking-tight">
