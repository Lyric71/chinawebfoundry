---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../components/pages/ScrollEffects.astro';

const metaTitle = "GEO China | AI Search Optimisation for Brands";
const metaDescription = "AI search optimisation for the China market. We make your brand the answer DeepSeek, Doubao, Kimi, Yuanbao, and Baidu AI cite and recommend.";

const engines = [
  {
    n: '01',
    cn: '深度',
    name: 'DeepSeek',
    enLabel: '深度求索',
    body: "Prefers structured, technically accurate content from official websites. If your site loads slowly inside China or depends on resources blocked by the Great Firewall (防火长城), DeepSeek likely never sees you.",
    tag: 'Long-form, structured',
    chips: ['JSON-LD', 'SSR', 'Speed', 'No blocked deps'],
  },
  {
    n: '02',
    cn: '豆包',
    name: 'Doubao',
    enLabel: '字节跳动',
    body: 'The ByteDance flagship, drawing heavily from its own ecosystem: Toutiao (今日头条), Douyin (抖音), Baijiahao (百家号). Optimising for Doubao means feeding the ByteDance content graph in parallel with your own site.',
    tag: 'ByteDance graph',
    chips: ['Toutiao', 'Douyin', 'Baijiahao', 'Syndication'],
  },
  {
    n: '03',
    cn: 'Kimi',
    name: 'Kimi',
    enLabel: 'Moonshot AI',
    body: 'Rewards long-form analysis. Comparison pieces, technical guides, multi-thousand-word reports with clean data tables. Short marketing copy gets ignored.',
    tag: 'Depth + tables',
    chips: ['Comparisons', 'Guides', 'Data tables', 'Long-form'],
  },
  {
    n: '04',
    cn: '元宝',
    name: 'Yuanbao',
    enLabel: '腾讯混元',
    body: "Tencent's gateway into the WeChat (微信) ecosystem, and the only assistant that can search WeChat Official Account (公众号) content.",
    tag: 'WeChat-aware',
    chips: ['公众号', '视频号', 'Mini Program', 'WeCom'],
  },
  {
    n: '05',
    cn: '文心',
    name: 'Baidu AI',
    enLabel: '文心一言',
    body: 'Powered by ERNIE (文心一言). Favours authoritative sources: Baidu Baike (百度百科), government portals, JSON-LD structured data, plus heavy lean on Baijiahao and Baidu Zhidao (百度知道) presence.',
    tag: 'Authority-led',
    chips: ['百度百科', '百度知道', 'JSON-LD', 'Baijiahao'],
  },
];

const services = [
  {
    n: '01',
    title: 'Visibility diagnosis',
    body: 'A structured query matrix of 80 to 150 questions across all five Chinese platforms, run on real devices in Shanghai, Beijing, and Shenzhen, on residential and corporate networks, not VPNs.',
    bullets: [
      'Citation rate: how often your brand appears in AI responses to relevant prompts.',
      'Brand recommendation rank: where you sit when the engine names options.',
      'Sentiment score: tone of the mention, neutral, positive, or critical.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Source-tier audit',
    body: 'AI engines reward verifiable evidence. Real patent numbers, third-party lab reports, published standards. We call this T1 content. Marketing copy with no proof is T3, ignored or flagged. We map every claim on your site and rebuild the weak ones with evidence the AI can validate.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Content cluster engineering',
    body: 'Single articles do not move the needle. We build clusters: a core pillar piece backed by FAQ pages, comparison guides, scenario walkthroughs, case studies. Whatever angle the user asks from, your site shows up.',
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Multi-platform distribution',
    body: 'AI engines cross-reference the same brand across trusted destinations. We syndicate into Baijiahao (百家号), Zhihu (知乎), the right industry portals, and where it makes sense, formal Baidu Baike (百度百科) entries.',
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Technical groundwork',
    body: "JSON-LD structured data, robots.txt for Baiduspider, Sogouspider, ByteSpider, XML sitemaps, canonical tags that don't split authority across language versions. Most international builds get this wrong.",
    tag: 'p.28',
  },
  {
    n: '06',
    title: 'Continuous monitoring',
    body: 'DeepSeek shipped four major revisions in 2025 alone. What worked in February stopped working by May. We track weekly and adjust before citation rates slip.',
    tag: 'p.34',
  },
];

const stages = [
  {
    n: '01',
    cn: '诊断',
    title: 'Visibility diagnosis',
    body: 'Run the query matrix across all five engines from real devices in Shanghai, Beijing, and Shenzhen. Output: a baseline citation report with named gaps per platform.',
    output: 'Citation baseline',
  },
  {
    n: '02',
    cn: '证据',
    title: 'Evidence + source audit',
    body: 'Map every claim on your site to T1, T2, or T3. Rebuild the weak ones with patents, lab reports, named experts, and structured data the engines can validate.',
    output: 'Evidence map',
  },
  {
    n: '03',
    cn: '内容',
    title: 'Cluster + write',
    body: 'Native Chinese pillar pieces, FAQs, comparison guides, scenario walkthroughs, case studies. Built so any angle of the user question lands on your site.',
    output: 'Cluster pages live',
  },
  {
    n: '04',
    cn: '分发',
    title: 'Syndicate + structure',
    body: '百家号, 知乎, 百度百科 (where ready), industry portals, plus JSON-LD, robots.txt, llms.txt, canonical, and sitemap work shipped together.',
    output: 'Cross-graph presence',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Monitor + iterate',
    body: 'Weekly query-matrix re-runs across all five engines. Adjust before model updates land as a citation drop. Monthly written report.',
    output: 'Weekly tracking',
  },
];

const evidenceTiers = [
  {
    label: 'T1',
    title: 'Hard evidence',
    body: 'Patent numbers, third-party lab reports, published standards, official government data.',
    weight: 100,
    color: 'green',
    examples: ['Patent CN10X', 'SGS report', 'GB/T standard', 'CNNIC data'],
  },
  {
    label: 'T2',
    title: 'Industry recognised',
    body: 'Trade press coverage, analyst reports, named expert opinion, industry awards.',
    weight: 60,
    color: 'amber',
    examples: ['36Kr', '艾瑞咨询', 'Named expert', 'Industry award'],
  },
  {
    label: 'T3',
    title: 'Marketing copy',
    body: 'Unsupported brand claims with no external proof. Ignored or flagged as low confidence.',
    weight: 15,
    color: 'red',
    examples: ['"Best in class"', '"Industry leading"', 'No source', 'Slogan only'],
  },
];

const stats = [
  { value: '600M+', label: 'Chinese AI users · 2026', sub: 'CNNIC count of generative AI users in China.' },
  { value: '20%+', label: 'Baidu SERPs with AI answers', sub: '文心X1 + DeepSeek now embedded in results.' },
  { value: '4', label: 'DeepSeek revisions in 2025', sub: 'What worked in February stopped working by May.' },
];

const audiences = [
  {
    label: 'Brands invisible on Chinese AI',
    description: "Companies whose name never comes up when buyers ask DeepSeek, Doubao, or Yuanbao for options in their category, while competitors get cited and linked.",
    image: '/images/audiences/audience-geo-invisible-on-ai.webp',
  },
  {
    label: 'International brands launching into China',
    description: 'Teams that want AI visibility designed into the launch from day one, not bolted on six months later when the traffic numbers look flat.',
    image: '/images/audiences/audience-geo-launching-china-market.webp',
  },
  {
    label: 'Brands with content but no evidence',
    description: 'Sites with thoughtful Chinese content that AI engines still ignore because the claims lack the verifiable sources, structured data, and third-party validation that earn citations.',
    image: '/images/audiences/audience-geo-content-without-evidence.webp',
  },
  {
    label: 'Brands watching organic traffic flatten',
    description: 'Marketing teams that have noticed Chinese organic traffic plateau as buyers shift to AI-first research, and want to be the answer rather than the link nobody clicks.',
    image: '/images/audiences/audience-geo-search-traffic-flat.webp',
  },
];

const marqueePhrases = [
  'GEO China',
  'DeepSeek', '深度求索',
  'Doubao', '豆包',
  'Kimi', '元宝',
  '文心一言',
  'Cited not bypassed',
  'T1 evidence',
  'JSON-LD',
  'llms.txt',
  '百家号 · 知乎 · 百度百科',
];

const faqs = [
  {
    id: 'difference-from-seo',
    question: 'How is GEO different from Baidu SEO?',
    answer: [
      "Overlapping but not the same. Baidu SEO optimises for the Baidu results page, where users still scan ten blue links and click. GEO optimises for AI assistants that read your content and decide whether to quote you in a single answer. Different ranking inputs, different content structure, different success metrics. Most of our clients run both as one engagement because the underlying content infrastructure overlaps heavily.",
    ],
  },
  {
    id: 'platforms-covered',
    question: 'Which Chinese AI platforms do you actually cover?',
    answer: [
      'DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝), and Baidu AI (powered by 文心一言). These are the five that move volume inside mainland China today. ChatGPT, Perplexity, Google AI Overviews, and Claude are not relevant here, since they have no meaningful reach behind the Great Firewall.',
    ],
  },
  {
    id: 'measurement',
    question: 'How do you measure success?',
    answer: [
      'Three numbers, tracked monthly. Citation rate: how often your brand appears in AI responses to a fixed query matrix. Brand recommendation rank: where you sit when the engine lists options. Sentiment: positive, neutral, or critical framing of the mention. Reporting comes as a written monthly summary, with a live dashboard alongside.',
    ],
  },
  {
    id: 'how-long',
    question: 'How long until we see citation lift?',
    answer: [
      'Audit and foundation: 4 to 6 weeks. Content build-out and syndication: three to four months. By month six most clients see real citation lift on at least two platforms. Full coverage typically lands between month 9 and 12. Anyone promising AI citation share in 30 days is selling you something else.',
    ],
  },
  {
    id: 'evidence-tiers',
    question: "What is T1, T2, T3 content and why does it matter?",
    answer: [
      'AI engines weight sources by how verifiable the claims are. T1 is content backed by hard evidence: patent numbers, third-party lab reports, published standards, official government data. T2 is industry-recognised but secondary: trade press, analyst reports, named expert opinion. T3 is marketing copy with no external proof, the kind AI engines either ignore or flag as low-confidence. We map every claim on your site to its tier and rebuild the weak ones.',
    ],
  },
  {
    id: 'translated-content',
    question: 'Can we just translate our English content?',
    answer: [
      "No. Translated content reads as foreign to Chinese AI engines, often loses the structural cues they rely on, and almost never matches how Chinese users actually phrase questions. We work with native Chinese editors who rewrite from the ground up, with the source claims and evidence intact.",
    ],
  },
  {
    id: 'syndication',
    question: 'Where do you syndicate the content?',
    answer: [
      'Baijiahao (百家号) for Baidu and Yuanbao reach, Zhihu (知乎) for technical and B2B credibility signals, Toutiao (今日头条) and Baijiahao for ByteDance and Doubao surfaces, and where it makes sense formal Baidu Baike (百度百科) entries. Industry-specific portals are added based on the vertical.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: 'What happens when the engines change their models?',
    answer: [
      'They change often. DeepSeek shipped four major revisions in 2025 alone. We monitor citation behaviour weekly across the same query matrix used at audit, and we adjust content, structured data, and syndication before the change shows up as a citation drop. Teams that do not watch this lose visibility without realising why.',
    ],
  },
  {
    id: 'cost',
    question: "What does a GEO China engagement cost?",
    answer: [
      'It depends on scope: how many product lines or service areas are in play, the depth of the existing content estate, the number of platforms you need full coverage on, and whether the engagement also covers Chinese content production and Baidu SEO. Tell us the scope and we send a real quote within two business days.',
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-geo-beijing-ai-research.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[#4D6BFE]/15 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">答</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Breadcrumb" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">GEO China</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">GEO China</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">5 engines, one programme</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Get cited
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">by Chinese</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">AI.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Generative Engine Optimisation for sites talking to the China market. We make your content the answer DeepSeek, Doubao, Kimi, Yuanbao, and Baidu AI trust enough to give back to users. <span class="text-white font-medium">One answer per question, your brand inside it.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter>5</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Engines covered</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">600M</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Chinese AI users</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">150</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Queries per audit</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/contact/" variant="primary" size="lg">Get an AI Visibility Audit</Button>
            <Button href="#engines" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">See the five engines</Button>
          </div>
        </div>

        <!-- Visual: layered DeepSeek mockup -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Back: "not cited" mock -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Not cited</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">competitor wins</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Citation rate: 0%
              </div>
            </div>

            <!-- Front: DeepSeek chat -->
            <div data-tilt class="relative bg-white rounded-2xl shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)] overflow-hidden">
              <div class="flex items-center gap-2.5 px-5 py-3 bg-white border-b border-gray-100">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#4D6BFE] to-[#3a55e8] flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm5.5 11.5c-1.4.4-2.9.5-4.4.3-.4 1.6-.4 3.3 0 4.9-1.4-.6-2.6-1.5-3.5-2.7-1.5.4-3 .5-4.5.4 1-1.5 2.4-2.6 4-3.3-.6-1.4-1-3-1-4.6 1.4.6 2.7 1.6 3.6 2.8 1.5-.5 3.1-.6 4.6-.4-.7 1.4-1.7 2.6-3 3.5.6.4 1.3.7 2 .9.6.6 1.4 1.5 2.2 2.2z"/>
                  </svg>
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="text-sm font-semibold text-gray-900">DeepSeek</span>
                  <span class="text-[10px] text-gray-400">深度求索</span>
                </div>
                <div class="ml-auto flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                  <span class="text-[10px] text-gray-400">在线</span>
                </div>
              </div>

              <div class="px-5 py-4 space-y-4 bg-white">
                <div class="flex justify-end">
                  <div class="max-w-[85%] bg-[#F4F5F7] rounded-2xl rounded-tr-sm px-3.5 py-2.5">
                    <p class="text-[12.5px] text-gray-900 leading-relaxed">推荐几家专门服务国际品牌的中国 WordPress 建站代理商</p>
                  </div>
                </div>

                <div class="flex items-center gap-1.5">
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#EEF2FF] text-[#4D6BFE] text-[10px] font-medium">
                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    深度思考 R1
                  </span>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#ECFDF5] text-emerald-600 text-[10px] font-medium">
                    联网搜索
                  </span>
                </div>

                <p class="text-[10.5px] text-gray-400">已搜索 14 个网页 · 用时 3.2 秒</p>

                <div>
                  <p class="text-[12.5px] text-gray-700 leading-relaxed mb-3">
                    根据近年公开资料,在中国市场长期专注 WordPress 建站、并具备国际化服务能力的代理商主要包括:
                  </p>
                  <div class="space-y-2.5">
                    <div class="flex gap-2">
                      <span class="text-[#F25F29] font-bold text-[12.5px] mt-0.5 leading-none">·</span>
                      <p class="text-[12.5px] text-gray-700 leading-relaxed">
                        <span class="font-semibold text-gray-900">ChinaWebFoundry</span><sup class="text-[#4D6BFE] text-[10px] ml-0.5">1</sup>:在华运营 20 年以上,专注国际品牌的中国 WordPress 建站、ICP 备案、Baidu SEO 与 AI 搜索优化。
                      </p>
                    </div>
                    <div class="flex gap-2">
                      <span class="text-gray-300 font-bold text-[12.5px] mt-0.5 leading-none">·</span>
                      <p class="text-[12.5px] text-gray-500 leading-relaxed">
                        <span class="font-medium text-gray-700">某沪上数字代理</span><sup class="text-[#4D6BFE] text-[10px] ml-0.5">2</sup>:本地团队为主,提供 WordPress 主题开发与境内托管服务。
                      </p>
                    </div>
                  </div>
                </div>

                <div class="pt-3 border-t border-gray-100">
                  <p class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 mb-2">引用来源 · 3</p>
                  <div class="space-y-1.5">
                    <div class="flex items-center gap-2 text-[11px]">
                      <span class="w-4 h-4 rounded bg-[#F25F29]/10 text-[#F25F29] text-[9px] flex items-center justify-center font-semibold flex-shrink-0">1</span>
                      <span class="text-gray-600 truncate">chinawebfoundry.com</span>
                    </div>
                    <div class="flex items-center gap-2 text-[11px]">
                      <span class="w-4 h-4 rounded bg-gray-100 text-gray-500 text-[9px] flex items-center justify-center font-semibold flex-shrink-0">2</span>
                      <span class="text-gray-400 truncate">zhihu.com/question/...</span>
                    </div>
                    <div class="flex items-center gap-2 text-[11px]">
                      <span class="w-4 h-4 rounded bg-gray-100 text-gray-500 text-[9px] flex items-center justify-center font-semibold flex-shrink-0">3</span>
                      <span class="text-gray-400 truncate">baijiahao.baidu.com/...</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/10 rounded-3xl blur-2xl -z-10"></div>
            <div class="absolute -inset-6 bg-[#4D6BFE]/10 rounded-3xl blur-3xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- WHY: dramatic statement -->
  <section class="relative section-spacing overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
