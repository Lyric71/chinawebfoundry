---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../components/pages/ScrollEffects.astro';

const metaTitle = "Baidu SEO | Rank on China's Real Search Engine | ChinaWebFoundry";
const metaDescription = "Baidu SEO from inside China. Baidu's own tools, real algorithm tracking (知心算法, 飓风算法 3.0), AI search optimisation on 文心X1 and DeepSeek.";

const whyDifferent = [
  {
    n: '01',
    cn: '算法',
    title: 'Baidu rewards different things',
    body: '知心算法 (Zhixin Algorithm) now recognises 200+ semantic relationships in Chinese queries. 飓风算法 3.0 penalises AI-generated low-quality content. Machine-translated English copy gets downranked fast.',
    tag: 'Ranking signals',
    chips: ['知心算法', '飓风算法 3.0', 'Original ZH', 'Semantic match'],
  },
  {
    n: '02',
    cn: '蜘蛛',
    title: "Baidu's crawler is different",
    body: "Baidu Spider's JavaScript rendering lags Google's by years, so client-side content is often invisible. Mobile-first crawl is mandatory, sub-3-second load is a hard requirement, HTTPS is a positive signal.",
    tag: 'Crawl + render',
    chips: ['Baiduspider', 'Mobile-first', 'SSR / static', 'HTTPS'],
  },
  {
    n: '03',
    cn: '主机',
    title: 'Hosting location is a ranking signal',
    body: "Sites without an ICP filing get penalised in Baidu's index. Mainland hosting outranks identical content in Hong Kong or abroad. Structural, not coincidental.",
    tag: 'Infrastructure',
    chips: ['ICP', 'Mainland host', 'Aliyun', 'Tencent Cloud'],
  },
  {
    n: '04',
    cn: '推送',
    title: 'The submission model is different',
    body: "Baidu doesn't find your content on its own. It expects you to push new URLs through 主动推送 (Active Push API) within minutes of publication. We wire the push into the CMS.",
    tag: 'Submission',
    chips: ['主动推送', '自动推送', 'Sitemap', '手工提交'],
  },
  {
    n: '05',
    cn: '关键词',
    title: 'Keyword research is in Chinese, from scratch',
    body: 'What Chinese users actually search has almost no overlap with translated English keywords. We use 百度指数 (Baidu Index) and 百度关键词规划师 (Baidu Keyword Planner) to build the keyword map.',
    tag: 'Discovery',
    chips: ['百度指数', '关键词规划师', '5118', 'Long-tail'],
  },
];

const services = [
  {
    n: '01',
    title: 'Technical SEO for Baidu',
    body: 'Site verification in 百度搜索资源平台. All four URL submission methods configured in priority order, plus 死链提交, 站点子链, and mobile-first crawl verification. Page speed benchmarked from inside China.',
    bullets: [
      '主动推送 (Active Push) API wired into the CMS for real-time submission.',
      '自动推送 (Auto Push) JS fallback for URLs that get visited before the CMS hook fires.',
      'Sitemap for the full index, refreshed automatically (50,000 URLs / 10MB max per file).',
      '手工提交 (Manual) as a last resort for high-value pages.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Native Chinese content, structured for Baidu',
    body: 'Baidu rewards 深度原创. 飓风算法 demotes thin or copied pages, and 飓风算法 3.0 targets AI-generated content without human editing. We write with native Chinese editors, long-form structure, Schema markup, and clean factual answers AI engines can cite.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'AI search optimisation (文心X1, DeepSeek, Doubao, Kimi)',
    body: "20%+ of Baidu's 2025 results contained AI-generated answers. Baidu now embeds 文心X1 and DeepSeek deep search in the main results page. We structure content so AI engines can read, understand, and cite your brand.",
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Authority on the Chinese web',
    body: "International backlinks don't carry weight on Baidu. The platforms that move rankings: 百度百科, 百度知道, 百度贴吧, 知乎, 百家号, 百度爱采购, plus industry B2B sites and WeChat / Weibo signals. We build presence and run the syndication pipeline.",
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Ongoing optimisation and algorithm response',
    body: "Baidu doesn't announce most updates, and the ones it does announce arrive in Chinese on the 百度搜索资源平台 blog. Twelve months of tracking 知心算法 expansions, 飓风算法 3.0, and the 文心X1 + DeepSeek integration. Each one changed what wins.",
    tag: 'p.30',
  },
];

const tools = [
  {
    name: '百度搜索资源平台',
    en: 'Baidu Search Resource Platform',
    cn: '资源',
    body: 'The official webmaster console: site verification, URL submission, sitemaps, indexation reports, mobile testing, broken-link reporting, the algorithm announcement feed.',
    feature: true,
    items: ['Site verification', 'URL push API', 'Sitemap', 'Index reports', 'Mobile test', '死链提交', 'Algo feed'],
  },
  {
    name: '百度统计',
    en: 'Baidu Tongji',
    cn: '统计',
    body: "Baidu's Google Analytics equivalent. Required for any serious China-side measurement.",
  },
  {
    name: '百度指数',
    en: 'Baidu Index & Keyword Planner',
    cn: '指数',
    body: 'Where native Chinese keyword research starts, not on translated English lists. Pairs with 百度关键词规划师.',
  },
  {
    name: '5118 · 爱站 · 站长之家',
    en: 'Third-party Chinese SEO tools',
    cn: '工具',
    body: 'Often deeper competitive intelligence and historical ranking data than the official ones.',
  },
  {
    name: 'Baidu Webmaster APIs',
    en: 'Active Push integration',
    cn: '接口',
    body: 'For 主动推送 we wire directly into the CMS rather than relying on dashboards.',
  },
];

const stages = [
  {
    n: '01',
    cn: '审计',
    title: 'Baidu audit',
    body: "We test from inside mainland China: indexation, crawl health on Baiduspider, content depth, ICP and hosting signals, plus current rank against 50 to 100 named keywords.",
    output: 'Audit report',
  },
  {
    n: '02',
    cn: '关键词',
    title: 'Keyword map',
    body: 'Native Chinese keyword research from 百度指数 and 关键词规划师. We build a keyword map with intent tags, search volume, and a content brief per cluster.',
    output: 'Keyword map + briefs',
  },
  {
    n: '03',
    cn: '部署',
    title: 'Technical deployment',
    body: 'Site verification, 主动推送 wired into the CMS, sitemaps, schema markup, mobile and speed fixes, llms.txt and AI-search structure shipped together.',
    output: 'Live indexation',
  },
  {
    n: '04',
    cn: '权威',
    title: 'Authority + content',
    body: 'Native ZH content, plus syndication on 百家号, 知乎, 百度知道, and the right industry portals. We layer in 百度百科 entries when the brand is ready.',
    output: 'Citations + ranking lift',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Monitor + iterate',
    body: "Weekly rank tracking, monthly written report, response to algorithm updates within the same week. Baidu changes; the team that doesn't watch it loses rankings without realising why.",
    output: 'Monthly written report',
  },
];

const stats = [
  { value: '24-72h', label: 'Index time via 主动推送', sub: 'New URLs in Baidu within hours, not weeks.' },
  { value: '11', label: 'Algo updates we tracked in 2025', sub: '知心算法, 飓风算法 3.0, 文心X1 integration.' },
  { value: '20%+', label: 'Baidu results with AI answers', sub: '文心X1 and DeepSeek now embedded in SERPs.' },
];

const audiences = [
  {
    label: 'Foreign brands invisible on Baidu',
    description: 'Companies with a Chinese site that gets less than fifty organic visits a month from Baidu, despite running paid ads on the same keywords.',
    image: '/images/audiences/no-organic-traffic-china.webp',
  },
  {
    label: 'Brands with old translated content',
    description: "Foreign sites where the Chinese pages are still translated from English and haven't been updated since launch.",
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Brands launching from zero',
    description: 'Companies that already know they need Baidu visibility from day one and want it set up properly during the build, not bolted on three months after launch.',
    image: '/images/audiences/launching-chinese-market.webp',
  },
  {
    label: 'Brands serious about AI search visibility',
    description: 'Companies that have noticed AI-generated answers showing up at the top of Baidu results and want to be cited rather than bypassed.',
    image: '/images/audiences/seo-pro-needs-baidu.webp',
  },
];

const marqueePhrases = [
  '百度', 'Baidu',
  '主动推送', 'Active Push',
  '知心算法', '飓风算法 3.0',
  '文心X1', 'DeepSeek',
  '百家号', '知乎', '百度百科',
  'ICP filed',
  'Mainland hosting',
  'AI-search ready',
];

const faqs = [
  {
    id: 'outside-china',
    question: 'Can we run Baidu SEO from outside China?',
    answer: [
      "Technically yes, with significant limitations. Baidu's verification flow expects Chinese phone numbers, the dashboard is in Chinese, support documentation isn't translated, and many of Baidu's tools rate-limit or block foreign IPs. Most foreign teams who try it abandon the effort within a quarter. We run it from Shanghai because that's where the work actually happens.",
    ],
  },
  {
    id: 'how-long',
    question: 'How long until we see results?',
    answer: [
      'Long-tail keyword movement in 6 to 10 weeks. Competitive head terms in 3 to 6 months minimum. Real organic traffic growth on a 6-to-12 month curve. Index inclusion of new content via 主动推送 in 24 to 72 hours.',
    ],
  },
  {
    id: 'no-icp',
    question: "What if our site doesn't have an ICP filing?",
    answer: [
      'It will rank, but with a measurable handicap. Baidu treats Hong Kong and offshore sites as foreign, crawls them less frequently, and ranks them lower than mainland-hosted alternatives. For brands serious about Baidu, an ICP filing on mainland hosting is the right call.',
    ],
  },
  {
    id: 'baidu-ads',
    question: 'Do you also run Baidu Ads (SEM) campaigns?',
    answer: [
      "No, we focus on organic Baidu SEO. Paid search is a different specialty run by different teams. We work alongside paid media partners and make sure the SEO content and the paid landing pages don't fight each other.",
    ],
  },
  {
    id: 'chinese-content',
    question: 'How does this connect with our Chinese content work?',
    answer: [
      'Tightly. Baidu SEO without native Chinese content is wasted effort. Most of our clients run both as one engagement, with our Chinese content team and Baidu SEO team working from the same keyword map and the same content architecture.',
    ],
  },
  {
    id: 'ai-search',
    question: 'What about AI search visibility on Doubao, Kimi, DeepSeek, 文心X1?',
    answer: [
      'Increasingly the same project. Baidu now embeds 文心X1 and DeepSeek deep search into 20%+ of its result pages. Structuring content for AI engines (clean factual answers, schema markup, llms.txt, semantic structure) overlaps heavily with structuring for Baidu. We do both as one piece of work.',
    ],
  },
  {
    id: 'links',
    question: 'Do you build links?',
    answer: [
      "We build authority through Chinese platforms (百度百科, 百度知道, 知乎, 百家号, 百度爱采购, industry B2B sites) where presence actually moves Baidu rankings. Buying generic backlinks from a Western link broker doesn't work and risks 飓风算法 penalties. Authority in China is earned on Chinese platforms or not at all.",
    ],
  },
  {
    id: 'measurement',
    question: 'How do you measure success?',
    answer: [
      'Index inclusion (number of pages Baidu has indexed), keyword rankings (position by query, tracked weekly), organic traffic from Baidu (via 百度统计), conversion attribution, and visibility share against three to five named competitors. Reporting is a monthly written summary, plus a live dashboard.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: 'What happens when Baidu changes its algorithm?',
    answer: [
      "We monitor 百度搜索资源平台 announcements weekly and react inside the same week when something material ships. Last twelve months we worked through 知心算法 expansions, 飓风算法 3.0 against AI content, the 文心X1 integration into search results, and several smaller shifts.",
    ],
  },
  {
    id: 'cost',
    question: "What's the cost?",
    answer: [
      'It depends on scope: site size, content volume, competitive intensity, and whether the engagement covers Chinese content production and AI search optimisation too. Tell us the scope and we send a real quote within two business days.',
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-search-results.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Breadcrumb" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Baidu SEO</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Baidu SEO</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Inside the Firewall, Shanghai</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Get found on
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">百度.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Where Chinese search starts.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Baidu has its own crawler, index, submission API and algorithm cycle, plus an AI search layer (文心X1, DeepSeek) writing over twenty percent of results. <span class="text-white font-medium">Run from Shanghai, on Baidu's own tools.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">20</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Years on Baidu</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">200</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">知心 relations tracked</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">72h</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Index via 主动推送</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/contact/" variant="primary" size="lg">Request a Baidu Audit</Button>
            <Button href="#what-we-do" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">See the workstreams</Button>
          </div>
        </div>

        <!-- Visual: layered Baidu console mockup -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Back card (faded, "no SEO") -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">No filing</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">site offshore</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Index: 4 / 312 pages
              </div>
            </div>

            <!-- Front: Baidu console card -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                </div>
                <span class="text-[10px] font-mono text-white/45 ml-2">百度搜索资源平台</span>
                <span class="ml-auto inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-green-500/15 border border-green-400/30">
                  <span class="w-1 h-1 rounded-full bg-green-400 animate-pulse"></span>
                  <span class="text-[9px] font-mono text-green-300 uppercase">Live</span>
                </span>
              </div>

              <div class="space-y-4">
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">主动推送 (Active Push)</span>
                    <span class="text-[10px] text-[var(--color-brand-orange)] font-mono">Wired in</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden shimmer-bar">
                    <div class="h-full w-full bg-gradient-to-r from-[var(--color-brand-orange)] to-[#FF8956] rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">Indexed pages</span>
                    <span class="text-[10px] text-white/55 font-mono"><span data-counter>342</span> / 412</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[83%] bg-gradient-to-r from-[var(--color-brand-orange)]/80 to-[var(--color-brand-orange)]/30 rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">知心算法 score</span>
                    <span class="text-[10px] text-white/55 font-mono">Strong</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[72%] bg-gradient-to-r from-[var(--color-brand-orange)]/60 to-transparent rounded-full"></div>
                  </div>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-white/10 grid grid-cols-3 gap-2">
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">ICP</div>
                  <div class="text-xs font-mono text-green-300">Filed</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">文心X1</div>
                  <div class="text-xs font-mono text-green-300">Cited</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">飓风 3.0</div>
                  <div class="text-xs font-mono text-green-300">Clear</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- WHY: dramatic statement -->
  <section class="relative section-spacing overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0" data-reveal="left">
          <div class="relative inline-flex items-baseline">
            <span class="text-[10rem] lg:text-[14rem] font-medium font-[var(--font-heading)] leading-none bg-gradient-to-br from-[var(--color-brand-orange)] via-[#FF7E47] to-[#D94E1F] bg-clip-text text-transparent" data-counter data-counter-suffix="%" data-counter-duration="1800">50</span>
          </div>
          <p class="mt-4 text-base text-[var(--color-text-muted)] max-w-sm">
            Of all Chinese search still goes through Baidu. Skip it and you skip half the country's discovery before AI even enters the picture.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-7" data-reveal="right">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)] mb-5">Why it matters</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15] mb-6">
            Your Google playbook doesn't transfer.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Different crawler, different submission API, different algorithm cycle, different definition of authority. Eleven Baidu algorithm shifts in 2025 alone, on top of two embedded AI engines now writing the answers.
          </p>
