---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../components/pages/ScrollEffects.astro';

const metaTitle = 'Chinese content · what to write, how to structure it · ChinaWebFoundry';
const metaDescription = "What to write and how to structure your China website. Native Chinese editors decide content, IA, and trust signals before any code gets written.";

// What to Write: 5 differences with paired "default vs reality" data
const differences = [
  {
    n: '01',
    cn: '信任',
    title: 'The trust signals are different',
    body: "Chinese readers scan a brand site for things foreign teams under-emphasise: founder credibility, year of founding, factory location, certifications, partnerships, awards, named clients, media coverage, team size. A clean 3-bullet hero reads as empty rather than sophisticated. The reader assumes the brand is small, new, or hiding something.",
    westernLabel: '3-bullet hero',
    westernSub: '"Build better. Faster. Together."',
    chineseLabel: 'Dense trust panel',
    chineseSub: 'Founded · Factory · Partners · Awards · Media',
  },
  {
    n: '02',
    cn: '决策',
    title: 'The decision frame is different',
    body: "Western messaging leads with aspiration. Chinese readers buy on a different sequence: practical proof first, credibility second, aspiration last. Same content, reordered, reads as a credible brand instead of a brochure.",
    westernLabel: 'Aspiration → proof',
    westernSub: 'Vision, then specs, then case studies',
    chineseLabel: 'Proof → credibility → aspiration',
    chineseSub: 'Specs first, partners next, vision last',
  },
  {
    n: '03',
    cn: '语言',
    title: 'The category language is different',
    body: "Translated SEO keywords almost always miss the phrases Chinese users actually search. We do the keyword research in Chinese, from scratch, before any copy gets written.",
    westernLabel: 'Translated keywords',
    westernSub: '"enterprise software solutions"',
    chineseLabel: 'Native search intent',
    chineseSub: '企业级软件 / SaaS服务 / 数字化解决方案',
  },
  {
    n: '04',
    cn: '形式',
    title: 'The format is different',
    body: "Long-form, dense, scrollable. Chinese product pages routinely run 3 to 5 times the length of their Western equivalents. Density reads as a trust signal in this market.",
    westernLabel: 'Minimal, whitespace-led',
    westernSub: 'One claim per scroll',
    chineseLabel: 'Long-form, dense',
    chineseSub: '3 to 5 times the length of the Western page',
  },
  {
    n: '05',
    cn: '法律',
    title: 'The legal language is different',
    body: "Chinese advertising law (广告法) regulates what foreign brands routinely say without thinking. Superlatives like \"best\" or \"first\" (最, 第一, 最佳) are restricted. Industry-specific claims (medical, financial, food, cosmetics) have their own separate rules. We write to compliance from the start.",
    westernLabel: 'Superlatives everywhere',
    westernSub: '"World-class. Best-in-class. First."',
    chineseLabel: '广告法-compliant claims',
    chineseSub: 'Specific, evidenced, audited language',
  },
];

// IA comparison data
const foreignIA = [
  { label: 'Home', primary: true },
  { label: 'About' },
  { label: 'Products' },
  { label: 'Resources' },
  { label: 'Contact' },
];

const chineseIA = [
  { label: '首页 / Home', primary: true },
  { label: 'Brand Story', highlight: true },
  { label: 'Honors & Awards 荣誉资质', highlight: true },
  { label: 'Company History 企业历程', highlight: true },
  { label: 'Industry / Solutions' },
  { label: 'Cases & Customers', highlight: true },
  { label: 'Products' },
  { label: 'Factory 生产基地', highlight: true },
  { label: 'Partners 合作伙伴', highlight: true },
  { label: 'News 新闻动态', highlight: true },
  { label: 'Contact' },
];

const structurePoints = [
  {
    n: '01',
    title: 'Page hierarchy that Chinese readers expect',
    body: "Foreign brand sites typically lead with Home, About, Products, Resources, Contact. Chinese brand sites often lead with brand credibility, then category education, then proof, then product. The order matches how Chinese readers actually move through a brand they don't yet trust.",
  },
  {
    n: '02',
    title: 'Trust pages most foreign brands forget',
    body: "Honors and Awards (荣誉资质). Company History (企业历程). Factory or Office (生产基地). Quality Certifications (质量认证). Major Partners (合作伙伴). Media Mentions (媒体报道). News (新闻动态). Standard on Chinese brand sites and routinely missing from foreign brand sites entering China. We design them in from day one.",
  },
  {
    n: '03',
    title: 'Baidu-friendly URL and content structure',
    body: "Baidu indexes structured, original, fresh content from a single primary domain. We design URL patterns Baidu can crawl, internal linking that distributes ranking equity, and a publishing cadence that signals the site is active.",
  },
  {
    n: '04',
    title: 'AI-search-friendly content structure',
    body: "Doubao, Kimi, DeepSeek, and Wenxin parse content differently from Baidu. They reward clean factual structure, schema markup, llms.txt files, and content that maps to how a user phrases a query out loud. We write with both ranking layers in mind. Brands setting this up properly in 2026 will be the ones cited by AI engines in 2027 and 2028.",
  },
  {
    n: '05',
    title: 'Editorial cadence baked into the structure',
    body: "A site that hasn't published anything in 6 months stops ranking on Baidu. The IA needs places where content can keep coming: a real news section, a knowledge base, an editorial blog, customer stories. We build those publishing surfaces from day one, even if the launch content is light.",
  },
];

const contentTypes = [
  {
    label: 'Core website content',
    cn: '官网内容',
    body: 'The brand spine.',
    items: ['Home', 'About', 'Brand Story', 'Founder Story', 'Team', 'History', 'Honors', 'Quality', 'Factory', 'Partners', 'Contact'],
    feature: true,
  },
  {
    label: 'Product and category content',
    cn: '产品内容',
    body: 'Long-form product pages, technical specifications, application scenarios.',
  },
  {
    label: 'Editorial and SEO content',
    cn: '内容运营',
    body: 'Blog articles, knowledge base, industry insights, how-to guides for Baidu and AI search visibility.',
  },
  {
    label: 'Trust and proof content',
    cn: '品牌背书',
    body: 'Case studies, customer stories, partner profiles, award announcements, media mentions.',
  },
  {
    label: 'Conversion content',
    cn: '转化页面',
    body: 'Landing pages for paid media, lead magnets, gated whitepapers, contact forms.',
  },
  {
    label: 'WeChat ecosystem content',
    cn: '微信生态',
    body: 'H5 mini-site copy, Mini Program content, Official Account article briefs.',
  },
];

const stages = [
  {
    n: '01',
    cn: '调研',
    title: 'Discovery and category research',
    body: "We audit 3 to 5 direct competitors end to end, plus the category conversation on Baidu, Zhihu (知乎), and relevant industry sites. Output: a written content strategy naming what your brand should say, what it shouldn't, and where the white space sits.",
    output: 'Content strategy doc',
  },
  {
    n: '02',
    cn: '架构',
    title: 'Information architecture',
    body: 'Site map and page hierarchy designed for Chinese readers, with the trust pages, editorial surfaces, and Baidu-friendly URL structure built in. Delivered as a written IA document so design and development know what they are building toward.',
    output: 'IA document + sitemap',
  },
  {
    n: '03',
    cn: '撰写',
    title: 'Native Chinese writing',
    body: 'Chinese editors writing in Mandarin to the strategy, in your brand voice rebuilt for Chinese readers.',
    output: 'Page-by-page drafts',
  },
  {
    n: '04',
    cn: '迭代',
    title: 'Editorial review and publishing',
    body: "Every piece passes through internal review for brand voice, factual accuracy, SEO structure, and 广告法 compliance. After publishing we track performance on Baidu and the AI engines and iterate on underperformers. Publish-and-forget doesn't rank in China.",
    output: 'Monthly performance + revisions',
  },
];

const audiences = [
  {
    label: 'Brands launching in China for the first time',
    description: 'Companies that need to make the foundational content decisions correctly: what to say, how to structure it, who to be in the Chinese market.',
    image: '/images/audiences/launching-chinese-website.webp',
  },
  {
    label: "Brands relaunching after a translation didn't work",
    description: "Foreign sites with translated content that's sat untouched for 2 or 3 years, watching Baidu rankings drift down. The fix is usually a content rebuild before any redesign.",
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Brands with a Chinese site but no editorial cadence',
    description: 'Companies that launched once, never built the publishing engine, and now wonder why their site has gone quiet on Baidu.',
    image: '/images/audiences/ongoing-chinese-editorial.webp',
  },
  {
    label: 'B2B brands with technical depth',
    description: 'Industrial, life sciences, pharma, B2B services that need long-form Chinese content with technical accuracy.',
    image: '/images/audiences/campaign-chinese-copy.webp',
  },
  {
    label: 'Luxury and brand-led businesses',
    description: 'Brands where the trust signals, founder story, heritage, and cultural fit decide whether the customer buys.',
    image: '/images/audiences/ecommerce-product-pages-china.webp',
  },
];

// Trust phrases for the marquee
const marqueePhrases = [
  '荣誉资质', 'Honors',
  '企业历程', 'History',
  '生产基地', 'Factory',
  '质量认证', 'Quality',
  '合作伙伴', 'Partners',
  '媒体报道', 'Media',
  '新闻动态', 'News',
  '广告法 compliant',
  'Baidu indexed',
  'AI-search ready',
];

const faqs = [
  {
    id: 'just-translate',
    question: "Can't we just translate our existing English content?",
    answer: [
      "You can, and a lot of foreign brands do. It almost never works. Translation produces words; building a brand in Chinese takes editorial judgement. Chinese readers can tell within a paragraph. Baidu can tell within a crawl. If you only have the budget for translation, our honest recommendation is to wait until you can afford to do this properly.",
    ],
  },
  {
    id: 'translation-vs-transcreation',
    question: "What's the difference between translation, transcreation, and what you do?",
    answer: [
      "Translation converts words from one language to another. Transcreation rewrites the message for the target culture while keeping the brand voice. What we do starts upstream of both. We decide what your brand should say to a Chinese audience in the first place, then we write that, in Chinese, from scratch.",
    ],
  },
  {
    id: 'rebuild-from-scratch',
    question: 'Do we need to rebuild our entire content from scratch?',
    answer: [
      "Not always. About a third of our engagements rebuild the core brand pages and product pages. Another third start fresh. The remaining third use parts of the existing content as raw material and rebuild around it. The Strategy and Audit decides which applies.",
    ],
  },
  {
    id: 'who-writes',
    question: 'Who actually writes the content?',
    answer: [
      "Native Chinese editors based in Shanghai. People whose first language is Mandarin and whose career has been writing commercial content. Senior writers, every piece, every time. Every page goes through editorial review before it reaches you.",
    ],
  },
  {
    id: 'brand-voice',
    question: 'Can you match our existing brand voice?',
    answer: [
      "Yes, but not by translating it. We work from your global brand guidelines and a sample of your best existing content, then rebuild the voice in Chinese using equivalent registers and rhetorical moves. The result feels like the same brand, in a different language.",
    ],
  },
  {
    id: 'design-development',
    question: 'Where does content sit relative to design and development?',
    answer: [
      "Upstream of both. The information architecture decides the design. We deliver the IA and content structure first, then design works against that, then development builds it. Reversing the order is one of the most common reasons foreign brand sites in China feel forced.",
    ],
  },
  {
    id: 'baidu-seo',
    question: 'How does this connect with Baidu SEO?',
    answer: [
      "Tightly. Baidu SEO done well starts with a Baidu keyword map researched in Chinese from scratch, then a content architecture that matches search intent, then content written around those topics. Our content team and our Baidu SEO team work as one. Most clients book both as a single engagement.",
    ],
  },
  {
    id: 'ai-search',
    question: 'What about AI search visibility on Doubao, Kimi, DeepSeek?',
    answer: [
      "We structure content for AI engines from the start. Clean factual answers, schema markup, llms.txt files, content that maps to how Chinese users phrase questions verbally. The brands setting this up properly in 2026 will be the ones cited by AI engines in 2027.",
    ],
  },
  {
    id: 'ongoing-publishing',
    question: 'Do you handle ongoing publishing or only launch content?',
    answer: [
      "Both, and we recommend the second. Launching with content and never updating the site is the single biggest reason foreign brands lose Baidu visibility over time. Most clients move from launch content to a fixed monthly editorial retainer.",
    ],
  },
  {
    id: 'cost',
    question: "What's the cost?",
    answer: [
      "It depends on scope: rebuild versus new, page count, editorial cadence, whether the engagement covers Baidu SEO and AI search optimisation too. Tell us the scope and we send a real quote within 2 business days.",
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-chinese-content.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <!-- Massive decorative Chinese character -->
    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">写</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Chinese Content</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text -->
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Chinese Content</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Native editors, Shanghai</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Content is the brand.
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Especially in</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">中文.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Translation gives you words. Building a brand in Chinese takes editorial judgement. We decide what your brand should say in Chinese, how the website should be structured around that, and we write it. <span class="text-white font-medium">Editors writing in Mandarin.</span>
          </p>

          <!-- Stat row -->
          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">15</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Years editorial</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">50</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Brands launched</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">SH</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Shanghai team</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/contact/" variant="primary" size="lg">Talk to our content team</Button>
            <Button href="#what-to-write" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">See how we write</Button>
          </div>
        </div>

        <!-- Visual: layered comparison mockup -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Translated card (back, faded) -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Translated</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">EN → ZH</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Baidu rank: drifting
              </div>
            </div>

            <!-- Native card (front, sharp) -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-green-500/15 border border-green-400/30">
                  <span class="w-1 h-1 rounded-full bg-green-400"></span>
                  <span class="text-[10px] font-mono text-green-300 uppercase tracking-wider">Native ZH</span>
                </span>
                <span class="ml-auto text-[10px] font-mono text-white/40">brand-cn.md</span>
              </div>

              <div class="space-y-3.5 font-[var(--font-heading)]">
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H1</span>
                  <span class="text-[15px] text-white font-medium">内容即品牌</span>
                </div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H2</span>
                  <span class="text-[13px] text-white/85">荣誉资质 · 企业历程 · 生产基地</span>
                </div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H2</span>
                  <span class="text-[13px] text-white/85">质量认证 · 合作伙伴 · 媒体报道</span>
                </div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">P</span>
                  <span class="text-[12px] text-white/55 leading-relaxed">由本地编辑撰写，符合广告法，面向 Baidu 与 AI 搜索优化。</span>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-white/10 grid grid-cols-3 gap-2">
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">Baidu</div>
                  <div class="text-xs font-mono text-green-300">Indexed</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">广告法</div>
                  <div class="text-xs font-mono text-green-300">Compliant</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">AI search</div>
                  <div class="text-xs font-mono text-green-300">Ready</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- bottom edge fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- WHY: dramatic statement section -->
  <section class="relative section-spacing overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <!-- Big number/visual -->
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0" data-reveal="left">
          <div class="relative inline-flex items-baseline">
            <span class="text-[10rem] lg:text-[14rem] font-medium font-[var(--font-heading)] leading-none bg-gradient-to-br from-[var(--color-brand-orange)] via-[#FF7E47] to-[#D94E1F] bg-clip-text text-transparent" data-counter data-counter-duration="1800">9</span>
            <span class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] ml-2">seconds</span>
          </div>
          <p class="mt-4 text-base text-[var(--color-text-muted)] max-w-sm">
            Median time a Chinese visitor spends on a translated foreign brand site before bouncing.
          </p>
        </div>

        <!-- Statement -->
        <div class="col-span-12 lg:col-span-7" data-reveal="right">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)] mb-5">Why it matters</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15] mb-6">
            The most important decision in the project.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            You can pick the right hosting, the right framework, the right ICP filing path. If the content doesn't land with Chinese readers, none of it matters. The page loads in under a second and visitors leave in nine because nothing on it speaks to them.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            We treat content as the upstream decision. Before design, before development, before templates, we figure out what the website should actually say.
          </p>

          <!-- Order pills -->
          <div class="flex flex-wrap items-center gap-2.5">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-brand-orange)] text-white text-sm font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
              Content
            </span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
