---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'China hosting | Fast, ICP-licensed, managed';
const metaDescription = 'Hosting that actually works in mainland China. ICP filing handled, CDN configured, monitored from Shanghai. WordPress, Astro, or headless.';

const proofStats = [
  { value: '0.8', suffix: 's', label: 'Median load time on a mainland Chinese server', sub: 'Mid-range Chinese phone, Shanghai connection' },
  { value: '99.97', suffix: '%', label: 'Uptime across the sites we currently host', sub: 'Rolling 30-day average' },
  { value: '100', suffix: '%', label: 'ICP filing success rate so far', sub: 'Every application has eventually gone through' },
  { value: '20', suffix: '+', label: 'Years on the ground in Shanghai', sub: 'Same team, same city, since 2005' },
];

const sectionLinks = [
  { id: 'problem', label: 'The problem' },
  { id: 'options', label: 'Hosting options' },
  { id: 'included', label: 'What\'s included' },
  { id: 'icp', label: 'ICP licence' },
  { id: 'compliance', label: 'Data compliance' },
  { id: 'timeline', label: 'Timeline' },
  { id: 'performance', label: 'Performance' },
  { id: 'faq', label: 'FAQ' },
];

const hostingOptions = [
  {
    id: 'mainland',
    name: 'Mainland China',
    tag: 'ICP Required',
    tagline: 'Servers in Beijing, Shanghai, Shenzhen or Guangzhou.',
    headline: 'The real deal. Sub-second loads, full Baidu boost.',
    body: 'Your site lives on servers inside mainland China. We use Aliyun, Tencent Cloud or Huawei Cloud, depending on the project. We have been working with all three for years now, so we know exactly what we are getting from each one of them.',
    detail: 'Load times come in under one second. Baidu gives a noticeable ranking boost to sites that hold an ICP licence on local servers, which matters a lot if organic search is part of your China strategy. We handle the full ICP filing too. Honestly, that is where most foreign companies hit a wall without someone in-country helping them through it.',
    fit: 'Brands committed to the Chinese market, anyone serious about Baidu SEO, e-commerce, sites capturing Chinese user data.',
    image: '/images/hosting-china-cdn-map.webp',
    imageAlt: 'A stylised map of mainland China with glowing data center nodes in Beijing, Shanghai, Shenzhen and Guangzhou connected by a CDN mesh',
    accent: 'orange',
    metrics: [
      { label: 'Load time', value: '< 1s' },
      { label: 'ICP', value: 'Required' },
      { label: 'Baidu boost', value: 'Big' },
      { label: 'Time to live', value: '6 to 10 wks' },
    ],
  },
  {
    id: 'hong-kong',
    name: 'Hong Kong',
    tag: 'No ICP Needed',
    tagline: 'Online quickly, no government filing required.',
    headline: 'A bridge to the mainland. Fast to launch.',
    body: 'Don\'t have an ICP licence yet? Hong Kong gets you online faster. No filing required. With the right CDN and caching setup, you are looking at 2 to 4 second load times in mainland China. Compared to serving the site from Frankfurt or Virginia, that\'s night and day.',
    detail: 'We use this as a bridge solution pretty often, while clients wait on their ICP filing or while they are still deciding whether to commit to a mainland presence. Some of our long-running clients have stayed on Hong Kong for years and never felt the need to move.',
    fit: 'Quick launches, interim solutions, projects that can\'t get an ICP yet, brands testing the Chinese market before committing.',
    image: '/images/hosting-hong-kong-bridge.webp',
    imageAlt: 'Hong Kong skyline at blue hour from across Victoria Harbour with neon orange light trails crossing the water toward mainland China',
    accent: 'sky',
    metrics: [
      { label: 'Load time', value: '2 to 4s' },
      { label: 'ICP', value: 'Not required' },
      { label: 'Baidu boost', value: 'Minimal' },
      { label: 'Time to live', value: '2 to 3 wks' },
    ],
  },
  {
    id: 'dual-stack',
    name: 'Dual-Stack',
    tag: 'Global + China',
    tagline: 'Mainland for China visitors. Existing global stack for everyone else.',
    headline: 'One brand, two architectures, both fast.',
    body: 'Some clients can\'t just optimise for China and forget about the rest of the world. They need the site working everywhere. For those situations we build a split: visitors from inside China hit a mainland Chinese server, everyone else goes to your existing global setup.',
    detail: 'DNS takes care of the routing automatically. One backend powers both sides, content syncs across the two. The China site has its own ICP filing, the global site keeps running wherever it already lives. We handle both sides as one engagement so the editorial team only has one workflow.',
    fit: 'Global brands with a serious China audience, multinational e-commerce, sites where neither China nor the rest of the world can be deprioritised.',
    image: '/images/hosting-dual-stack-globe.webp',
    imageAlt: 'Isometric 3D illustration of a globe with two server clusters glowing (orange over China and cyan over the West) with routing paths splitting traffic by geography',
    accent: 'emerald',
    metrics: [
      { label: 'Load time', value: '< 1s in CN' },
      { label: 'ICP', value: 'Required (CN)' },
      { label: 'Baidu boost', value: 'Big' },
      { label: 'Time to live', value: '8 to 12 wks' },
    ],
  },
];

const includedItems = [
  {
    icon: 'server',
    title: 'Server setup and optimisation',
    body: 'Hosting tuned for your stack, with China-compatible SSL, server-level firewalls and DDoS protection configured for how things actually work behind the Firewall.',
  },
  {
    icon: 'cdn',
    title: 'China CDN configured',
    body: 'Aliyun or Tencent Cloud CDN hooked up. Your assets get served from nodes near your users in Shanghai or Chengdu instead of from across the Pacific.',
  },
  {
    icon: 'monitor',
    title: 'Monitoring from inside China',
    body: 'Most tools check from outside the Firewall, so dashboards lie. We monitor from inside China. Sounds like a detail, changes everything.',
  },
  {
    icon: 'backup',
    title: 'Daily backups and recovery plan',
    body: 'Automated daily, stored off-site, point-in-time recovery, disaster plan documented. Because stuff does break sometimes.',
  },
  {
    icon: 'document',
    title: 'ICP filing handled end to end',
    body: 'Paperwork, submissions, back-and-forth with the provincial authority. You never log into a Chinese hosting panel or read forms in Chinese.',
  },
  {
    icon: 'wrench',
    title: 'Ongoing maintenance',
    body: 'Server patches, security updates and scaling on our end so the site keeps performing without you having to think about it.',
  },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Informational sites',
    timing: '20+ working days',
    body: 'Company website, blog, brochure site, anything that doesn\'t involve transactions. The most common filing for foreign brands launching in China.',
    docs: ['Business registration', 'Domain certificate', 'Site administrator ID', 'Chinese-registered entity'],
  },
  {
    code: '经营许可证',
    name: 'ICP Commercial Licence',
    type: 'Commercial activity',
    timing: '2 to 3 months',
    body: 'For sites handling transactions, e-commerce, paid services, anything commercial. Longer process, more documentation, deeper scrutiny from the provincial authority.',
    docs: ['Everything in Bei\'an', 'Business scope review', 'Capital verification', 'Commercial purpose statement'],
  },
];

const complianceLaws = [
  {
    abbr: 'PIPL',
    name: 'Personal Information Protection Law',
    body: 'Governs how personal data on Chinese residents must be handled, stored and transferred. The closest Chinese parallel to GDPR.',
  },
  {
    abbr: 'CSL',
    name: 'Cybersecurity Law',
    body: 'Foundational data law since 2017. Sets the rules for network operators, critical infrastructure, and data localisation requirements.',
  },
  {
    abbr: 'DSL',
    name: 'Data Security Law',
    body: 'Classifies data by sensitivity and requires categorised protection. Affects how Chinese user data is stored and moved across borders.',
  },
];

const timelines = [
  {
    label: 'Hong Kong',
    title: 'Hong Kong launch',
    duration: '2 to 3 weeks',
    accent: 'sky',
    phases: [
      { name: 'Setup', width: '40%' },
      { name: 'Configure', width: '40%' },
      { name: 'Go live', width: '20%' },
    ],
    note: 'No ICP filing needed. The fastest path online for the Chinese market.',
  },
  {
    label: 'Mainland China',
    title: 'Mainland China launch',
    duration: '6 to 10 weeks',
    accent: 'orange',
    phases: [
      { name: 'ICP filing', width: '50%' },
      { name: 'Build (parallel)', width: '35%' },
      { name: 'Cutover', width: '15%' },
    ],
    note: 'ICP runs on the critical path. We start the filing on day one and run the rest of the build in parallel.',
  },
  {
    label: 'Dual-Stack',
    title: 'Dual-stack launch',
    duration: '8 to 12 weeks',
    accent: 'emerald',
    phases: [
      { name: 'Architecture', width: '25%' },
      { name: 'CN side + ICP', width: '45%' },
      { name: 'Routing + cutover', width: '30%' },
    ],
    note: 'Depends on how the global site is currently set up. The mainland Chinese half drives the timeline.',
  },
];

const performanceRows = [
  { location: 'US or Europe', loadTime: 8, loadLabel: '8 to 15+ seconds', icp: 'No', baiduBoost: 'None', highlight: false },
  { location: 'Hong Kong', loadTime: 2.5, loadLabel: '2 to 4 seconds', icp: 'No', baiduBoost: 'Minimal', highlight: false },
  { location: 'Mainland China', loadTime: 0.8, loadLabel: 'Under 1 second', icp: 'Yes', baiduBoost: 'Big', highlight: true },
];

const audiences = [
  { label: 'Building for China', description: 'International companies launching a brand new site for the Chinese market.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Slow from mainland', description: 'Businesses with an existing site that is painfully slow for anyone visiting from inside China.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'ICP first-timers', description: 'Teams dealing with the ICP filing for the first time and finding it confusing or stalled.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'Compliant e-commerce', description: 'Brands that need fast hosting which is also compliant with Chinese regulations and the local payment ecosystem.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];

const faqs = [
  {
    id: 'mainland-or-hk',
    question: 'Do we have to use mainland hosting, or can we just stay in Hong Kong?',
    answer: 'You can stay in Hong Kong, especially for an interim launch. But Baidu treats Hong Kong sites as foreign and the ranking penalty is real. For brands serious about the Chinese market long-term, mainland hosting with an ICP filing is the right call.',
  },
  {
    id: 'aliyun-overseas',
    question: 'Do we need an ICP if we host on Aliyun\'s overseas region?',
    answer: 'Yes, if you want the site on Aliyun\'s mainland servers. Aliyun also runs servers in Hong Kong and Singapore which don\'t require an ICP, but you lose the mainland performance and the Baidu boost.',
  },
  {
    id: 'cost',
    question: 'How much does China hosting cost?',
    answer: 'It varies by traffic, storage, and the level of management we run on top. Most marketing sites land in a predictable monthly range that is actually lower than equivalent Western managed WordPress hosting. Tell us the scope and we send a real quote within two business days.',
  },
  {
    id: 'add-china',
    question: 'Can we keep our existing global hosting and just add China?',
    answer: 'Yes, this is the dual-stack setup. Your global site stays where it is, the China visitors get routed to a mainland Chinese server, and the two share editorial workflows where it makes sense.',
  },
  {
    id: 'providers',
    question: 'What providers do you actually use?',
    answer: 'Aliyun, Tencent Cloud and Huawei Cloud are our three. Aliyun is usually the default for marketing sites, Tencent Cloud is strong for sites that integrate deeply with WeChat, and Huawei Cloud comes up more often for clients who already use Huawei elsewhere in their infrastructure.',
  },
  {
    id: 'icp-rejection',
    question: 'What happens if the ICP application is rejected?',
    answer: 'It happens, especially for first-time foreign filings. Usually it is a documentation issue or something missing from the business registration. We handle the resubmission. Every ICP we have ever submitted has eventually gone through.',
  },
  {
    id: 'astro-headless',
    question: 'Can we host an Astro or headless site in China?',
    answer: 'Yes. The build runs outside China on a CI pipeline, the static output gets pushed to a mainland Chinese server, and the site loads as fast as anything we have shipped. We do this regularly with Astro and with headless WordPress setups.',
  },
  {
    id: 'data-privacy',
    question: 'Is mainland hosting compliant with Chinese data privacy laws?',
    answer: 'For sites that collect data from Chinese users, yes. Mainland hosting on a properly configured Aliyun or Tencent Cloud account is the cleanest path to compliance with PIPL, the Cybersecurity Law and the Data Security Law. We configure the architecture so personal data stays in country.',
  },
  {
    id: 'hosting-panel',
    question: 'Do we have to deal with the Chinese hosting panel ourselves?',
    answer: 'No. We run the hosting account, the ICP filing and the day-to-day server work. You don\'t log into anything in Chinese, you don\'t read forms you can\'t understand. You just get a working site and a monthly report.',
  },
  {
    id: 'scaling',
    question: 'What happens when traffic spikes or the site grows?',
    answer: 'We scale the hosting up. Aliyun, Tencent and Huawei all support flexible scaling on the plans we use. We handle the resizing, the load balancing and any architecture changes the site needs to keep up.',
  },
];

const accentMap: Record<string, { dot: string; bg: string; text: string; border: string; bar: string }> = {
  orange: {
    dot: 'bg-[var(--color-brand-orange)]',
    bg: 'bg-[var(--color-brand-orange)]/10',
    text: 'text-[var(--color-brand-orange)]',
    border: 'border-[var(--color-brand-orange)]/25',
    bar: 'bg-[var(--color-brand-orange)]',
  },
  sky: {
    dot: 'bg-sky-500',
    bg: 'bg-sky-500/10',
    text: 'text-sky-600',
    border: 'border-sky-500/25',
    bar: 'bg-sky-500',
  },
  emerald: {
    dot: 'bg-emerald-500',
    bg: 'bg-emerald-500/10',
    text: 'text-emerald-600',
    border: 'border-emerald-500/25',
    bar: 'bg-emerald-500',
  },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-hosting.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/95 via-[#0f0f12]/75 to-[#0f0f12]/35"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Breadcrumb" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">China Hosting</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">China Hosting · 中国主机</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-white leading-[1.05] tracking-tight">
            Hosting that actually works
            <span class="block mt-2 text-[var(--color-brand-orange)]">in mainland China.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            We set up and manage hosting built for the Chinese internet. Fast load times, ICP filing handled end to end, CDN configured, monitored from inside China. Whatever stack your site runs on.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-[560px] leading-relaxed">
            15+ years on the ground in Shanghai. 100% ICP success rate so far.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/contact/" variant="primary" size="lg">Explore hosting options</Button>
            <a href="#options" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              Compare the three setups
              <span class="inline-block transition-transform group-hover:translate-y-0.5">↓</span>
            </a>
          </div>
        </div>

        <!-- Visual: server status card -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">hosting-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Server location</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Shanghai</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Load time (China)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">0.8s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[8%] h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Uptime (30d)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">99.97%</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP status</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Active</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">CDN nodes</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">24 active</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/8 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
        {proofStats.map((stat, i) => (
          <div class:list={[
            'flex flex-col gap-3',
            i > 0 ? 'lg:pl-8 lg:border-l lg:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-5xl lg:text-[60px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div>
              <p class="text-sm lg:text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-xs lg:text-sm text-[var(--color-text-muted)]">
                {stat.sub}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STICKY SUB-NAV: jump to section -->
  <nav aria-label="Page sections" class="sticky top-[64px] lg:top-[72px] z-30 bg-white/85 backdrop-blur-md border-b border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="overflow-x-auto -mx-1">
        <ul class="flex items-center gap-1 py-3 px-1 whitespace-nowrap">
          {sectionLinks.map((link) => (
            <li>
              <a href={`#${link.id}`} class="inline-flex items-center px-3 py-1.5 text-xs lg:text-[13px] font-medium text-[var(--color-text-body)] rounded-full hover:bg-[var(--color-surface-light)] hover:text-[var(--color-brand-orange)] transition-colors no-underline">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </nav>

  <!-- PROBLEM -->
  <section id="problem" class="section-spacing scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            The problem
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Your website probably doesn't load in China.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Try pulling your site up from Shanghai sometime. Most international sites take ten or fifteen seconds. Sometimes the page just never appears.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            That's the Great Firewall: throttled traffic, blocked CDNs, Google Fonts that won't resolve. After twenty years inside China, it's still the most common problem we see. Great in New York, broken in Beijing.
          </p>
        </div>

        <!-- Visual: side-by-side phone load comparison -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-12 lg:mt-0">
          <div class="relative">
            <div class="absolute -inset-6 bg-[var(--color-brand-orange)]/8 rounded-[40px] blur-3xl -z-10"></div>

            <div class="grid grid-cols-2 gap-3 lg:gap-4">
              <!-- US/EU phone -->
              <div class="relative bg-white border border-[var(--color-surface-border)] rounded-2xl p-5 lg:p-6 overflow-hidden">
                <div class="flex items-center gap-2 mb-4">
                  <span class="inline-block w-2 h-2 rounded-full bg-red-500"></span>
                  <span class="text-[11px] font-mono uppercase tracking-wider text-[var(--color-text-muted)]">US / EU</span>
                </div>
                <!-- Phone mockup -->
                <div class="relative mx-auto w-full max-w-[140px] aspect-[9/16] bg-[var(--color-surface-light)] rounded-[18px] border border-[var(--color-surface-border)] overflow-hidden">
                  <div class="absolute inset-0 flex flex-col items-center justify-center p-3">
                    <svg class="w-8 h-8 text-red-400 animate-spin" style="animation-duration: 2s;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v2m0 12v2m8-8h-2M6 12H4m13.66-5.66l-1.42 1.42M7.76 16.24l-1.42 1.42m11.32 0l-1.42-1.42M7.76 7.76L6.34 6.34"/>
                    </svg>
                    <p class="mt-2 text-[10px] font-mono text-[var(--color-text-muted)] text-center">loading...</p>
                  </div>
                </div>
                <div class="mt-4 text-center">
                  <p class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-red-500 tabular-nums leading-none">12.4s</p>
                  <p class="mt-1 text-[11px] text-[var(--color-text-muted)]">median load</p>
                </div>
              </div>

              <!-- China phone -->
              <div class="relative bg-white border border-[var(--color-brand-orange)]/30 rounded-2xl p-5 lg:p-6 overflow-hidden lg:translate-y-6 shadow-[0_20px_40px_-20px_rgba(242,95,41,0.3)]">
                <div class="flex items-center gap-2 mb-4">
                  <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
