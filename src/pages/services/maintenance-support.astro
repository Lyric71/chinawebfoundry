---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Maintenance & Support | Run Your China Site Right';
const metaDescription = 'Ongoing content updates, SEO and GEO follow-up, technical maintenance and hosting for your China site. One team. From inside the Firewall.';

const includedItems = [
  {
    title: 'Content updates',
    body: 'Two to four new pieces per month for active clients: typically one long-form Baidu-friendly article (1,500 to 2,500 Chinese characters), one case study or product update, and one or two short news posts. All written in real Chinese by native speakers, not translated from English drafts. We syndicate the strongest pieces to Baijiahao (百家号), Zhihu (知乎), and Sohu Hao (搜狐号), which AI engines treat as verification signals when deciding what to cite. More frequency around campaign windows: 双11, 618, Chinese New Year (春节).',
  },
  {
    title: 'Baidu SEO follow-up',
    body: "Monthly ranking report covering your top 30 to 50 keywords, indexing check on 100+ priority URLs through Baidu Ziyuan (百度站长资源), and two to three technical SEO fixes per month based on what the data shows. We push new content into Baidu's submission tools the day it goes live, fix crawl errors as they appear, and rebuild whatever drops out of the index. When Baidu adjusts its algorithm (eleven times in 2025, by our count) we adapt within the week, not the quarter.",
  },
  {
    title: 'GEO follow-up',
    body: 'Weekly visibility checks across DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝), and Baidu AI (百度AI), running a fixed 40-question query matrix per client covering brand, category, scenario, and competitor questions. Reports show citation rate, recommendation rank, and sentiment score, with a list of content adjustments to push that month. When a model update changes who gets cited (DeepSeek shipped four major revisions in 2025) we adjust before competitors notice.',
  },
  {
    title: 'Technical maintenance',
    body: 'WordPress core, plugin, and theme updates tested on staging before going live. Daily off-site backups retained 30 days. Security scanning via Wordfence or Sucuri running 24/7. Uptime checks every 5 minutes from servers physically inside China. Quarterly database cleanup. SSL renewals on China-compatible certificates from Aliyun (阿里云) or local CAs. The standard stuff, but verified from inside the Firewall, not from a Virginia datacenter.',
  },
  {
    title: 'The China layer',
    body: 'We watch Great Firewall behaviour in real time. When a CDN, font library, or external API gets blocked, we swap in a China-friendly replacement, average response time 14 minutes from detection to deploy. We re-test WeChat (微信) login, Alipay (支付宝), WeChat Pay (微信支付), and analytics (Baidu Tongji or 51la) after every update cycle. Most international agencies cannot see any of this without a VPN.',
  },
  {
    title: 'Hosting',
    body: "ICP-licensed (ICP备案) servers on Aliyun, Tencent Cloud (腾讯云), or Huawei Cloud (华为云), managed end to end. Performance tuning when traffic spikes. Bei'an (备案) renewals tracked through the MIIT console so nothing lapses. 99.9% uptime SLA with documented response times: 30 minutes for critical incidents, 4 hours for standard tickets.",
  },
  {
    title: 'Break-fix',
    body: 'When something breaks, our team in China picks it up immediately. Bug fixes, plugin conflicts, security incidents, payment gateway errors with Alipay or WeChat Pay. If a site gets hacked: isolate, clean, restore, harden, post-mortem within 48 hours.',
  },
];

const insightItems = [
  "China's digital environment moves faster than the West. Baidu's algorithm changed eleven times in 2025. DeepSeek shipped four major model revisions. Doubao reworked its content ingestion at least monthly.",
  'Sites that launch right and sit untouched for a year almost always end up invisible by month nine. The decay is gradual, and then sudden.',
  'The reverse is also true. Sites that publish steady fresh content, watch their AI citations weekly, and keep the technical stack clean tend to compound. Rankings climb, AI mentions grow, the cost of staying visible drops.',
  'International agencies cannot see most of this work without a VPN. From an office in London or Chicago, everything looks fine right up until it does not.',
];

const audiences = [
  {
    label: 'No local team',
    description: 'Companies with a live China site and no local team to run it, who need expert support without building one from scratch.',
    image: '/images/audiences/wordpress-china-no-local-team.webp',
  },
  {
    label: 'Marketing first',
    description: "Marketing departments who'd rather work on campaigns than chase broken plugins across nine time zones.",
    image: '/images/audiences/marketing-not-debugging.webp',
  },
  {
    label: 'IT without a China hire',
    description: "IT teams that need China expertise but can't justify a full-time hire on the org chart.",
    image: '/images/audiences/it-team-china-expertise.webp',
  },
  {
    label: 'Ecommerce in China',
    description: 'Ecommerce businesses on WooCommerce or Shopify with Chinese payment gateways and local fulfilment.',
    image: '/images/audiences/woocommerce-china-payments.webp',
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-maintenance-beijing-team-office.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/95 via-[#0f0f12]/75 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Maintenance & Support</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text -->
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Maintenance & Support
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            A live China site needs someone
            <span class="block mt-2 text-[var(--color-brand-orange)]">watching it from the inside.</span>
          </h1>
          <p class="mt-8 text-lg text-white/70 max-w-xl leading-relaxed">
            Ongoing content, SEO and GEO follow-up, technical maintenance, hosting. All handled by a team that operates behind the Great Firewall every day.
          </p>
          <p class="mt-5 text-sm text-white/50 max-w-xl leading-relaxed">
            One team. One bill. No finger-pointing across nine time zones.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Talk to Our Team</Button>
          </div>
        </div>

        <!-- Visual: maintenance status card -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">site-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Firewall watch</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Clear</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Content cadence</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">3 / mo</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Baidu index</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Healthy</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">AI citations (wk)</span>
                  <span class="text-sm font-semibold text-[var(--color-brand-orange)] font-mono">+12%</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-1">
                  <span class="text-sm text-white/50">Uptime (30d)</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">99.98%</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Backups</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Current</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">ICP 备案</span>
                  <span class="text-sm font-semibold text-white/70 font-mono">Renewed 2027</span>
                </div>
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTRODUCTION -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            The reality
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Launching is the easy part.
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            A China site is not something you launch and walk away from. Baidu drops rankings for sites that stop publishing. AI engines like DeepSeek and Doubao update their crawling logic every few weeks. A Google Font your developer left in the theme gets blocked on a random Tuesday and the homepage breaks for every visitor in Shanghai (上海), Shenzhen (深圳), and Beijing (北京). From your office in London or Chicago, everything looks fine.
          </p>
          <p class="mt-5 text-lg text-[var(--color-text-body)] leading-relaxed">
            This is what we run after launch. Content, search, technical, infrastructure. One team, one bill, no finger-pointing across time zones.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IS INSIDE THE SERVICE -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <!-- Left: sticky heading -->
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            What's included
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            What's actually inside the service
          </h2>
          <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed">
            Seven workstreams, run in parallel. The first three keep the site visible. The next three keep it standing. The last one catches what neither can.
          </p>
        </div>

        <!-- Right: items -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {includedItems.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY IT MATTERS -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Why it has to be ongoing
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Untouched sites go invisible.
          </h2>
          <p class="mt-6 text-base text-white/60 leading-relaxed">
            Maintained sites compound. The gap between the two opens fast.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            {insightItems.map((item) => (
              <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
                <p class="text-base text-white/70 leading-relaxed">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO IS THIS FOR -->
  <WhoIsThisFor heading="Who reaches out to us" audiences={audiences} background="light" />

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Get started
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        You did the hard part. Don't let it slip.
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Tell us where you are. We come back with a plan covering content cadence, SEO and GEO action items, technical maintenance, and hosting. Monthly retainers from US$ 1,200, scoped to what your site actually needs.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact/" variant="primary" size="lg">Request a Custom Proposal</Button>
        <Button href="/services/china-hosting/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Explore Hosting Options</Button>
      </div>
    </div>
  </section>

</PageLayout>
