---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';

const metaTitle = 'WordPress Maintenance & Support in China | Agency';
const metaDescription = 'China-based WordPress maintenance: firewall monitoring, Baidu SEO upkeep, security, backups, and fast support from a team operating inside China.';

const includedItems = [
  {
    title: 'Preventive Maintenance',
    body: 'WordPress core, plugin and theme updates, tested on staging before anything goes live. Daily backups stored off-site. Security scanning running 24/7. Uptime checks every five minutes from servers physically in China. Database cleanup on a regular schedule. SSL monitoring and renewals for China-compatible setups.',
    note: 'Any decent agency offers some version of this. The difference is we verify everything from behind the firewall, not from a datacenter in Virginia.',
  },
  {
    title: 'The China Layer',
    body: 'We monitor Great Firewall behaviour in real time. When a CDN or font library or API gets blocked, we catch it and swap in a China-friendly replacement before your analytics show the damage. We track Baidu\'s ranking signals and adjust technical SEO when things shift. After every update cycle, we check your China integrations manually. WeChat login, Alipay, local analytics. Making sure nothing\'s quietly broken.',
    note: 'Your agency back home literally cannot do this part. They\'d need a VPN just to see the problem exists.',
  },
  {
    title: 'Break-Fix',
    body: 'When stuff breaks, our China team picks it up immediately. No waiting half a day for someone on the other side of the planet to check their inbox. Bug fixes, plugin conflicts, security incidents, WooCommerce payment issues with Alipay or WeChat Pay.',
    note: 'If your site gets hacked: isolate, clean, restore, harden. Then a proper post-mortem so it doesn\'t happen twice.',
  },
  {
    title: 'Site Growth',
    body: 'New pages, design changes, feature requests, Baidu SEO adjustments, new integrations. Handled within your monthly support hours. We base recommendations on actual performance data from Chinese users, not best practices articles written by someone who\'s never dealt with Baidu firsthand.',
    note: '',
  },
];

const insightItems = [
  'A single blocked resource on the firewall can break your layout for every visitor in China. From your office in London or Chicago, everything looks fine. You won\'t know until someone tells you.',
  'Baidu rewards sites that stay technically healthy. Skip maintenance for a couple months and your rankings will reflect it. Getting them back takes way longer than keeping them would have.',
  'WordPress on Chinese hosting faces security threats with regional patterns. Attack vectors your Western security plugins weren\'t really built for.',
  'Your IT team can run diagnostics from anywhere. They still can\'t see what a user in Guangzhou actually experiences. We can. Because we\'re here.',
];

const audiences = [
  'Companies with a WordPress site live in China who need expert support without building a local team.',
  'Marketing departments who\'d rather work on campaigns than debug plugin conflicts across nine time zones.',
  'IT teams that need China WordPress experience but can\'t justify a full-time hire.',
  'Ecommerce businesses running WooCommerce with Chinese payment gateways and local fulfilment.',
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <!-- Hero: full-bleed dark -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-maintenance-support.png" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="pt-8 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Maintenance & Support</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text: 7 cols -->
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Maintenance & Support
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Your WordPress Site in China Needs Someone
            <span class="block mt-2 text-[var(--color-brand-orange)]">Watching It From the Inside</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Ongoing maintenance and support from a team that actually operates behind the Great Firewall. We catch the problems your global IT team can't see.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Talk to Our Team</Button>
          </div>
        </div>

        <!-- Visual: maintenance status card -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">maintenance-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Firewall status</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Clear</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Last update check</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">2h ago</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Security scan</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Passed</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Uptime (30d)</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">99.98%</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Backups</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Current</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Baidu index</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Healthy</span>
                </div>
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            A Google Font gets blocked. Your homepage breaks. Nobody in your office knows.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            We see this more often than we'd like. A Google Font gets blocked by the firewall on some random Tuesday. Your homepage turns into a mess for every visitor in Shanghai, Shenzhen, Beijing. Your team in New York? No clue. From their end, everything loads fine.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            This isn't a scare tactic. It just happens. WordPress in China needs constant attention from someone who can see what your Chinese visitors actually see. The Great Firewall doesn't warn you before it blocks something. Baidu shuffles its algorithm and your rankings dip before anyone notices.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            A plugin update that worked fine on US hosting? Might cause a totally different issue on Chinese servers. Our team works from China. We test from Chinese networks. When something breaks at 3am your time, we're already on it.
          </p>
        </div>

        <!-- Visual: firewall alert card -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-surface-light)] to-white border border-[var(--color-surface-border)]">
            <div class="absolute inset-6 flex flex-col justify-center gap-6">
              <!-- Blocked resource -->
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-red-50 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">fonts.googleapis.com</div>
                  <div class="w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden">
                    <div class="w-full h-full bg-red-400 rounded-full"></div>
                  </div>
                  <div class="text-xs text-red-500 mt-1 font-medium">Blocked by Great Firewall</div>
                </div>
              </div>
              <!-- Detected & resolved -->
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">Self-hosted replacement</div>
                  <div class="w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden">
                    <div class="w-[12%] h-full bg-green-500 rounded-full"></div>
                  </div>
                  <div class="text-xs text-green-600 mt-1 font-medium">Swapped in 14 minutes</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included: sticky heading + list -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <!-- Left: sticky heading -->
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            What's Included
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            What we actually do for your site
          </h2>
          <p class="mt-6 text-base text-[var(--color-text-body)] leading-relaxed">
            This is where most WordPress maintenance companies just... can't help you. We cover the basics and the China-specific work that nobody else can.
          </p>
        </div>

        <!-- Right: items -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {includedItems.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                  {item.note && (
                    <p class="mt-3 text-sm text-[var(--color-text-muted)] italic leading-relaxed">
                      {item.note}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Matters: dark section -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Why This Matters
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            More than you think
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            {insightItems.map((item) => (
              <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
                <p class="text-base text-white/70 leading-relaxed">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Who Is This For -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Who Is This For?
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Who reaches out to us for maintenance
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-5">
            {audiences.map((item) => (
              <div class="flex items-start gap-5 bg-white rounded-xl px-6 py-5 border border-[var(--color-surface-border)]">
                <span class="inline-block mt-1 w-2 h-2 rounded-full bg-[var(--color-brand-orange)] flex-shrink-0"></span>
                <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Get Started
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        You already did the hard part. Don't let it fall apart now.
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        You already did the work of launching a WordPress site for China. Don't let it fall apart because nobody's watching from the inside. Pick a plan, or just tell us what you need.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact/" variant="primary" size="lg">Request a Custom Proposal</Button>
        <Button href="/services/china-hosting/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Explore Hosting Options</Button>
      </div>
    </div>
  </section>

</PageLayout>
