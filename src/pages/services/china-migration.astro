---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';

const metaTitle = 'WordPress Migration to China | ChinaWebFoundry';
const metaDescription = 'Move your WordPress site into China or migrate from any CMS to a WordPress setup built for the mainland. Zero downtime, zero data loss, fully compliant.';

const scenarios = [
  {
    title: 'WordPress to China-Optimised WordPress',
    body: 'Your WordPress site runs fine pretty much everywhere. But behind the Great Firewall it loads slow, throws errors, or just straight up breaks. We move it onto China-compliant hosting, replace blocked resources one by one, and get the performance to where it needs to be. Your global site stays exactly as-is.',
  },
  {
    title: 'Other CMS to WordPress for China',
    body: 'Drupal, Sitecore, Adobe Experience Manager, Webflow, Shopify -- or something custom that was built ten years ago and nobody wants to touch anymore. Full content transfer into WordPress, rebuilt for China from the ground up. URL mapping, SEO preservation, and redesign where the original layout just doesn\'t translate for a Chinese audience.',
  },
  {
    title: 'Global Site to Dual-Stack Setup',
    body: 'Some companies need a global site and a separate China version running at the same time. We build dual-stack architecture so both versions share content management workflows, but each delivers what its specific audience actually needs. One team manages content. Two very different markets get served the right way.',
  },
];

const processSteps = [
  {
    title: 'Discovery and Assessment',
    body: 'Everything kicks off with an audit. Platform, content volume, third-party integrations, technical architecture. We go through all of it and flag anything that\'s blocked, incompatible, or non-compliant. This part happens before anyone touches code.',
  },
  {
    title: 'Migration Architecture',
    body: 'The blueprint. China hosting environment, CDN strategy, DNS configuration, content structure. The entire thing gets designed around mainland performance from day one -- not patched together after the fact.',
  },
  {
    title: 'Content and Data Transfer',
    body: 'All your content comes over. Pages, posts, media files, metadata, custom fields, user data, product catalogs if you\'re running e-commerce. We map URL structures carefully so you don\'t lose the SEO equity you spent years building up.',
  },
  {
    title: 'Integration Replacement',
    body: 'Google Analytics replaced with Baidu Analytics. YouTube embeds swapped for Youku or Bilibili. Facebook tracking pixels become WeChat or Weibo. Every single third-party dependency gets checked. If it\'s blocked in China, we find what works locally and wire it in.',
  },
  {
    title: 'China-Specific Optimisation',
    body: 'Blocked fonts, blocked CDNs, all of it gets replaced. SSL configured for China compatibility. Assets optimised for local network conditions. Baidu-friendly technical SEO gets layered in throughout.',
  },
  {
    title: 'Testing from Inside China',
    body: 'Real testing from real connections inside mainland China. Not proxied through Hong Kong. We test load speeds, functionality, cross-browser compatibility -- including QQ Browser and UC Browser -- plus mobile performance on actual Chinese devices.',
  },
  {
    title: 'Zero-Downtime Launch',
    body: 'Cutover is planned down to the hour. Zero downtime. DNS propagation managed carefully. Real-time monitoring runs through the entire transition window until everything is confirmed stable.',
  },
  {
    title: 'Post-Migration Support',
    body: 'Performance monitoring, issue resolution, ongoing tweaks and adjustments. Most problems tend to surface in the first two or three weeks, and we\'re around for all of it.',
  },
];

const migrationItems = [
  { label: 'Pages and Posts', body: 'Content, formatting, media embeds, metadata' },
  { label: 'Media Library', body: 'Images, videos, documents, all re-optimised for delivery inside China' },
  { label: 'SEO Data', body: 'Meta titles, descriptions, URLs, redirects, sitemaps' },
  { label: 'Custom Fields and Taxonomies', body: 'ACF, custom post types, categories, tags' },
  { label: 'E-Commerce Data', body: 'Products, orders, customer records (WooCommerce)' },
  { label: 'User Accounts', body: 'Roles, profiles, and permissions' },
  { label: 'Integrations', body: 'CRM, analytics, marketing tools -- adapted or replaced' },
  { label: 'Design and Branding', body: 'Visual identity stays intact, with adjustments for Chinese UX where it makes sense' },
];

const challenges = [
  {
    title: 'The Great Firewall',
    body: 'Blocks Google services, most Western CDNs, social media platforms, and a long list of external resources your site almost certainly depends on. Every dependency has to be checked and swapped out. This is something our team deals with on a daily basis from China.',
  },
  {
    title: 'ICP Licence Requirements',
    body: 'Your website has to sit on government-approved infrastructure with proper domain registration and filing. We walk clients through the entire process because honestly, it\'s pretty confusing if you haven\'t been through it before.',
  },
  {
    title: 'Data Localisation Laws',
    body: 'Under China\'s Cybersecurity Law and PIPL, certain user data must be stored within mainland China. Your architecture needs to account for this from the very beginning, not three months after you\'ve launched.',
  },
  {
    title: 'Performance Standards',
    body: 'Users expect pages to load fast and Baidu penalises slow sites harder than Google does. Our infrastructure team on the ground makes sure your migrated site actually hits those benchmarks.',
  },
];

const audiences = [
  {
    label: 'Multinational companies',
    body: 'Entering or expanding their WordPress presence in China.',
  },
  {
    label: 'E-commerce brands',
    body: 'Launching a China-ready online store built on WordPress.',
  },
  {
    label: 'Media and publishing',
    body: 'Organisations who need to reach Chinese audiences properly.',
  },
  {
    label: 'Agencies',
    body: 'Handling WordPress migrations to China on behalf of their own clients.',
  },
];
---

<PageLayout title={metaTitle} description={metaDescription}>

  <!-- Hero: full-bleed dark -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-migration.png" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="pt-8 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">China Migration</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text: 7 cols -->
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            WordPress Migration
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            WordPress Migration to China,
            <span class="block mt-2 text-[var(--color-brand-orange)]">Done Right.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Move your WordPress site into China or switch from any CMS to a WordPress setup built for the mainland. Zero downtime, zero data loss, fully compliant.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Discuss Your Migration Project</Button>
          </div>
        </div>

        <!-- Visual: 5 cols, migration flow placeholder -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">migration-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Content transfer</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100%</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Blocked resources</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">0 / 47</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">China load time</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">2.1s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[15%] h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP compliance</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Filed</span>
                </div>
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Moving a website into China is nothing like a normal migration
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            The Great Firewall blocks half the services your site relies on. Hosting has to comply with ICP licensing rules -- something most Western development teams haven't even encountered before. Chinese users are notoriously impatient with slow pages. And if Baidu can't properly crawl your site, you're essentially invisible.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            We deal with all of this, every week, from our office in China. Whether you're already running WordPress or migrating off a totally different CMS, the goal is the same: a site that genuinely works on the mainland. Not "sort of works." Not "works behind a VPN." A site that loads fast, passes compliance, and actually reaches the people you're trying to reach.
          </p>
        </div>

        <!-- Visual: migration flow illustration -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-surface-light)] to-white border border-[var(--color-surface-border)]">
            <div class="absolute inset-6 flex flex-col justify-center gap-4">
              <!-- Source -->
              <div class="flex items-center gap-3">
                <div class="w-16 h-16 rounded-xl bg-[var(--color-surface-border)]/60 flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" /></svg>
                </div>
                <div>
                  <div class="h-3 w-24 bg-[var(--color-surface-border)] rounded mb-2"></div>
                  <div class="h-2 w-16 bg-[var(--color-surface-border)]/60 rounded"></div>
                </div>
              </div>
              <!-- Arrow -->
              <div class="flex justify-center">
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
              </div>
              <!-- Destination -->
              <div class="flex items-center gap-3">
                <div class="w-16 h-16 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div>
                  <div class="h-3 w-28 bg-[var(--color-brand-orange)]/20 rounded mb-2"></div>
                  <div class="h-2 w-20 bg-[var(--color-brand-orange)]/10 rounded"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Migration Scenarios: tall accent-border cards -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Migration Scenarios
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Three paths into China
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
          Every migration starts differently. Here's how we handle each one.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {scenarios.map((item) => (
          <div class="relative bg-white rounded-2xl p-8 lg:p-10 border border-[var(--color-surface-border)] overflow-hidden">
            <!-- Thick top accent bar -->
            <div class="absolute top-0 left-0 right-0 h-1 bg-[var(--color-brand-orange)]"></div>
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4">
              {item.title}
            </h3>
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
              {item.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section: numbered steps -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <!-- Left: sticky heading -->
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            How We Run a Migration
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Eight steps to a working site in China
          </h2>
          <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
            Every step is designed around mainland performance and compliance from day one.
          </p>
        </div>

        <!-- Right: process items -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {processSteps.map((step) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {step.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {step.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Gets Migrated: two-column divider list -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            What Gets Migrated
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Nothing gets left behind
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12">
            {migrationItems.map((item, i) => (
              <div class:list={[
                'py-6',
                i < migrationItems.length - 2 ? 'border-b border-white/10' : '',
                i === migrationItems.length - 2 ? 'border-b border-white/10 sm:border-b-0' : '',
              ]}>
                <div>
                  <div>
                    <h3 class="text-base font-semibold font-[var(--font-heading)] text-white mb-1">
                      {item.label}
                    </h3>
                    <p class="text-sm text-white/50 leading-relaxed">
                      {item.body}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why China Migration Is Different: stacked blockquote rows -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Why It's Different
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Why WordPress migration to China is different
        </h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-0 divider-list">
        {challenges.map((item) => (
          <div class="flex gap-6 lg:gap-10 py-8 lg:py-10 items-start">
            <div class="hidden sm:block w-1 flex-shrink-0 self-stretch rounded-full bg-[var(--color-brand-orange)]/20"></div>
            <div class="flex-1">
              <h3 class="text-xl lg:text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3">
                {item.title}
              </h3>
              <p class="text-base text-[var(--color-text-body)] leading-relaxed max-w-2xl">
                {item.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who Is This For: horizontal pill tags -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Who Is This For?
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Built for teams moving to China
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-5">
            {audiences.map((item) => (
              <div class="flex items-start gap-5 bg-white rounded-xl px-6 py-5 border border-[var(--color-surface-border)]">
                <span class="inline-block mt-1 w-2 h-2 rounded-full bg-[var(--color-brand-orange)] flex-shrink-0"></span>
                <div>
                  <span class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)]">{item.label}</span>
                  <span class="text-[var(--color-text-muted)] mx-2">/</span>
                  <span class="text-[15px] text-[var(--color-text-body)]">{item.body}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Start Your Migration
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Thinking about moving your WordPress site to China?
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Every migration project looks different. Tell us what you're working with right now, what you need to achieve, and when it needs to happen. Our team in China will figure out the right approach with you.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact/" variant="primary" size="lg">Start Your Migration Assessment</Button>
        <Button href="/#OurServices" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">View Our Services</Button>
      </div>
    </div>
  </section>

</PageLayout>
