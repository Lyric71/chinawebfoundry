---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import CaseStudyCards from '../../components/ui/CaseStudyCards.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'China Migration | Content, UX, Hosting Rebuilt | ChinaWebFoundry';
const metaDescription = 'Move your website into China the right way. Content, UX, and hosting rebuilt for Chinese audiences. ICP licensed, Baidu ready. Shanghai team.';

const layers = [
  {
    label: 'Content',
    title: 'Content Rewritten for Chinese Audiences',
    body: 'Translation alone is not migration. Native Chinese writers rewrite your messaging for Chinese readers: trust signals, founder credibility, certifications, partnerships, awards, the kind of social proof Chinese audiences look for first. Page hierarchy gets reordered when needed. Where the original copy doesn’t land culturally, we replace it rather than translate it.',
  },
  {
    label: 'UX',
    title: 'UX Redesigned for Chinese Habits',
    body: 'Chinese users don’t scan a page the way Western users do. Mobile-first, denser information, WeChat browser tested, trust placement in the local order. We redesign the parts that need redesigning and keep the brand identity intact across both versions of the site.',
  },
  {
    label: 'Hosting',
    title: 'Hosting and Infrastructure Moved Onto China',
    body: 'ICP filing handled end to end. Hosting on Aliyun, Tencent Cloud or Huawei Cloud, on the technology stack that fits the project. Blocked dependencies replaced one by one. CDN configured for mainland delivery. Baidu webmaster tools wired in from day one.',
  },
];

const scenarios = [
  {
    title: 'Migrating Your Existing Site',
    body: 'Your global site runs fine outside China. Behind the Firewall it loads slow, breaks layouts, or just refuses to work properly. We rebuild it for the Chinese market: content rewritten, UX adjusted, hosting moved onto a compliant mainland server. Your global site stays exactly as it is. WordPress, headless or whatever stack you happen to run. Typical timeline: 6 to 10 weeks.',
    image: '/images/migration-wordpress-china-optimised.webp',
  },
  {
    title: 'Switching CMS as Part of the Move',
    body: 'Drupal, Sitecore, Adobe Experience Manager, Webflow, Shopify, WordPress or something custom that nobody at HQ wants to maintain anymore. We move you onto a CMS that fits your team and the Chinese market, and we use the migration window as the moment to fix the things that were already broken on the old site, before adding everything China-specific on top. Typical timeline: 8 to 14 weeks.',
    image: '/images/migration-cms-to-wordpress-china.webp',
  },
  {
    title: 'Running Two Sites in Parallel',
    body: 'Some companies need a global site and a separate China site, running independently but sharing editorial workflows. We build both ends of that setup. One team manages the content pipeline, two very different audiences each get a site that was actually made for them. Typical timeline: 10 to 16 weeks.',
    image: '/images/migration-dual-stack-global-china.webp',
  },
];

const phases = [
  {
    label: 'Phase 1',
    title: 'Discover',
    steps: [
      {
        title: 'Discovery and Audit',
        body: 'Everything starts with a written audit. Current site, content volume, brand positioning, integrations, technical architecture, search visibility and what Chinese audiences in your category actually expect. We flag what works, what doesn’t, and what has to be rebuilt rather than carried over. Two to three weeks.',
      },
      {
        title: 'Migration Architecture',
        body: 'The plan. China hosting environment, CDN strategy, DNS, content structure, redirect map. Designed around Chinese performance and Chinese user habits from day one rather than patched together at the end. One week.',
      },
    ],
  },
  {
    label: 'Phase 2',
    title: 'Build',
    steps: [
      {
        title: 'Content Rewrite and Transfer',
        body: 'Pages, posts, media, metadata, custom fields, product catalogues. Everything moves. Native Chinese writers rewrite the copy that needs rewriting, transcreate where transcreation is the right call, and preserve the SEO equity you spent years building. URL mapping done by hand for anything that matters.',
      },
      {
        title: 'UX and UI Localisation',
        body: 'We review every page template against the way Chinese users actually scan a page, then adjust where the original layout doesn’t hold up. Trust signals get repositioned, information density is raised where it makes sense, and mobile-first behaviour is checked inside the WeChat in-app browser specifically. The brand identity stays, the interface gets localised.',
      },
      {
        title: 'Integration Replacement',
        body: 'Google Analytics swapped for Baidu Tongji. YouTube embeds replaced with Youku or Bilibili. Facebook tracking pixels replaced with WeChat or Weibo equivalents. Every third-party dependency gets checked. If it’s blocked or slow in China, we wire in a local replacement.',
      },
      {
        title: 'Performance and Technical Optimisation',
        body: 'Blocked fonts and CDNs replaced. SSL configured for China compatibility. Assets re-optimised for mainland network conditions. Baidu-friendly technical SEO layered through the build.',
      },
    ],
  },
  {
    label: 'Phase 3',
    title: 'Launch',
    steps: [
      {
        title: 'Testing From Inside China',
        body: 'Real testing on real connections in mainland China. Not proxied through Hong Kong, not routed via VPN. We check load speed, functionality, cross-browser behaviour including QQ Browser and UC Browser, and how the site actually performs on the kind of mid-range Android handset most of your audience is reading on.',
      },
      {
        title: 'Zero-Downtime Cutover',
        body: 'The launch is planned to the hour. DNS propagation managed carefully. Real-time monitoring across the transition window until everything is confirmed stable. We keep a rollback path open for forty-eight hours, just in case. Most issues surface in the first two to three weeks after launch and we are on call for all of it.',
      },
    ],
  },
];

const migrationItems = [
  { label: 'Pages and Posts', body: 'Content, formatting, media embeds, metadata.' },
  { label: 'Media Library', body: 'Images, videos, documents, re-optimised for delivery inside China.' },
  { label: 'SEO Data', body: 'Meta titles, descriptions, URLs, redirects, sitemaps.' },
  { label: 'Custom Fields and Taxonomies', body: 'Custom post types, categories, tags, structured data.' },
  { label: 'E-Commerce Data', body: 'Products, orders, customer records, payment configuration.' },
  { label: 'User Accounts', body: 'Roles, profiles and permissions.' },
  { label: 'Integrations', body: 'CRM, analytics, marketing tools, adapted or replaced for the China stack.' },
  { label: 'Design and Branding', body: 'Visual identity stays intact. UX adjusted where Chinese habits demand it.' },
];

const challenges = [
  {
    title: 'Legacy URLs and SEO Equity',
    body: 'You spent years building rankings on your global site. A bad migration loses all of it overnight. We do URL mapping by hand for any page that matters, set proper 301s, and preserve as much organic visibility as we can carry across.',
  },
  {
    title: 'The Great Firewall Layer',
    body: 'Blocks Google services, most Western CDNs, several social platforms and a long list of external dependencies your site almost certainly relies on. Every single one has to be replaced.',
  },
  {
    title: 'ICP Licensing',
    body: 'Hosting on a Chinese server requires a government filing called an ICP, or Bei’an. Application is in Chinese, rules vary by province and processing typically runs twenty working days at minimum. We handle the filing for you.',
  },
  {
    title: 'Data Localisation Laws',
    body: 'Under China’s Cybersecurity Law and PIPL, certain user data has to be stored on mainland servers. Architecture has to account for this from day one, not three months after launch.',
  },
];

const audiences = [
  { label: 'International brands entering China', description: 'Companies launching their first proper China presence after years of running a translated global site.', image: '/images/audiences/multinational-china-entry.webp' },
  { label: 'Brands relaunching a site that didn’t land', description: 'The original China site is live but it never performed. Bounce rate is high, leads are flat, HQ is asking why. The migration is really a relaunch.', image: '/images/audiences/agency-migration-clients.webp' },
  { label: 'E-commerce brands', description: 'Launching a China-ready store with the right payment, logistics and customer service integrations from day one.', image: '/images/audiences/ecommerce-china-store.webp' },
  { label: 'Media and publishing', description: 'Organisations that need to reach Chinese audiences properly, not through a translated mirror.', image: '/images/audiences/media-publishing-china.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <!-- Hero: full-bleed dark -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-migration.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">China Migration</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text: 7 cols -->
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            China Migration
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Move Your Website Into China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Properly.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            A real China migration isn’t a copy-paste behind the Firewall. It’s a relaunch. We move your content, your design and your hosting into China together, so the site that goes live actually works for Chinese audiences.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            Twenty years on the ground in Shanghai. Fifty-plus international brands migrated, none broken on the way in.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Discuss Your Migration</Button>
          </div>
        </div>

        <!-- Visual: 5 cols, migration status panel -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">migration-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Content localised</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100%</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Blocked resources</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">0 / 47</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">China load time</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">2.1s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[15%] h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP compliance</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Filed</span>
                </div>
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-7">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Most “China migrations” only solve the easy problem.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            You move the files, you change the host, you get an ICP filing. The site loads. The bounce rate stays at 80%.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            The hard part of a China migration isn’t the infrastructure, it’s everything Chinese users actually see and read once the site opens. The headline that worked in Munich. The page layout that converted in Boston. The trust signals your global team is proud of. None of that automatically translates.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            A proper migration into China runs on three layers at once: content rewritten for Chinese audiences, UX redesigned for Chinese browsing habits, and hosting moved onto compliant Chinese servers. We handle them together as one project, out of Shanghai.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Layers -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          The Three Layers of a Real Migration
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Content. UX. Hosting. All in one project.
        </h2>
      </div>

      <div class="space-y-4 lg:space-y-6">
        {layers.map((layer) => (
          <article class="bg-white rounded-2xl p-8 lg:p-10 border border-[var(--color-surface-border)] grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10">
            <div class="lg:col-span-3">
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-2">
                {layer.label}
              </p>
              <h3 class="text-xl lg:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
                {layer.title}
              </h3>
            </div>
            <div class="lg:col-span-9">
              <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed">
                {layer.body}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Migration Scenarios -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Migration Scenarios
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Three paths into China
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
          Every migration starts from a different place. Here is how we usually approach each one.
        </p>
      </div>

      <CaseStudyCards items={scenarios} />
    </div>
  </section>

  <!-- Process: phased -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <!-- Left: sticky heading -->
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            How We Run It
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Three phases. Eight steps. One launch.
          </h2>
          <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
            Designed around Chinese performance and Chinese user habits from day one, not patched together at the end.
          </p>
        </div>

        <!-- Right: phased steps -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7 space-y-12">
          {phases.map((phase) => (
            <div>
              <div class="flex items-baseline gap-3 mb-6 pb-3 border-b border-[var(--color-surface-border)]">
                <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">
                  {phase.label}
                </span>
                <h3 class="text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
                  {phase.title}
                </h3>
              </div>
              <div class="space-y-6">
                {phase.steps.map((step) => (
                  <div class="flex gap-5">
                    <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                    <div class="flex-1">
                      <h4 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                        {step.title}
                      </h4>
                      <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                        {step.body}
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Operational Checklist -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Operational Checklist
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Nothing important gets left behind.
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12">
            {migrationItems.map((item, i) => (
              <div class:list={[
                'py-6',
                i < migrationItems.length - 2 ? 'border-b border-white/10' : '',
                i === migrationItems.length - 2 ? 'border-b border-white/10 sm:border-b-0' : '',
              ]}>
                <h3 class="text-base font-semibold font-[var(--font-heading)] text-white mb-1">
                  {item.label}
                </h3>
                <p class="text-sm text-white/50 leading-relaxed">
                  {item.body}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Different -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Why It Is Different
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          A China migration is not a normal migration.
        </h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-0 divider-list">
        {challenges.map((item) => (
          <div class="flex gap-6 lg:gap-10 py-8 lg:py-10 items-start">
            <div class="hidden sm:block w-1 flex-shrink-0 self-stretch rounded-full bg-[var(--color-brand-orange)]/20"></div>
            <div class="flex-1">
              <h3 class="text-xl lg:text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3">
                {item.title}
              </h3>
              <p class="text-base text-[var(--color-text-body)] leading-relaxed max-w-2xl">
                {item.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Built for brands moving into China" audiences={audiences} background="light" />

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Start Your Migration
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Thinking about moving your site into China?
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Tell us where the site lives today, what it does for your brand, and what it needs to do for Chinese audiences. We come back within two business days with a written assessment: scope, timeline, and a clear view of what a proper migration looks like for your project. No charge, no commitment.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact/" variant="primary" size="lg">Start Your Migration Assessment</Button>
        <Button href="/#OurServices" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">View Our Services</Button>
      </div>
    </div>
  </section>

</PageLayout>
