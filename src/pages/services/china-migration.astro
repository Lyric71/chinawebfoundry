---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import WhoIsThisFor from '../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'China Migration | Content, UX, Hosting Rebuilt | ChinaWebFoundry';
const metaDescription = 'Move your website into China the right way. Content, UX, and hosting rebuilt for Chinese audiences. ICP licensed, Baidu ready. Shanghai team.';

const layers = [
  {
    label: 'Content',
    title: 'Content rewritten for Chinese audiences',
    body: 'Native Chinese writers rewrite your messaging with the trust signals, credibility markers and social proof Chinese audiences look for first.',
    iconPath: 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10',
  },
  {
    label: 'UX',
    title: 'UX redesigned for Chinese habits',
    body: 'Chinese users scan a page differently. Mobile-first, denser information, WeChat browser tested, trust placed in the local order, brand identity intact.',
    iconPath: 'M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3',
  },
  {
    label: 'Hosting',
    title: 'Hosting and infrastructure moved onto China',
    body: 'ICP filing handled end to end. Hosting on Aliyun, Tencent or Huawei Cloud, with blocked dependencies replaced and Baidu webmaster tools wired in from day one.',
    iconPath: 'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z',
  },
];

interface Scenario {
  timeline: string;
  title: string;
  lead: string;
  body: string;
  fit: string[];
  diagram: 'single' | 'swap' | 'parallel';
}

const scenarios: Scenario[] = [
  {
    timeline: '6 to 10 weeks',
    title: 'Migrating your existing site',
    lead: 'One global site, rebuilt for the Chinese market.',
    body: 'Content rewritten, UX adjusted, hosting moved onto a compliant mainland server. Your global site stays exactly as it is, on any stack you run.',
    fit: [
      'You already have a global site that performs',
      'You want one China presence that finally lands',
      'WordPress, headless or any other stack',
    ],
    diagram: 'single',
  },
  {
    timeline: '8 to 14 weeks',
    title: 'Switching CMS as part of the move',
    lead: 'Replace the platform and move into China in one window.',
    body: 'We use the migration as the moment to fix what was already broken on the old site, before adding everything China-specific on top. Drupal, Sitecore, AEM, Webflow, Shopify or custom.',
    fit: [
      'Your current CMS is painful to maintain',
      'You want the rebuild and the China move handled together',
      'You were rebuilding anyway',
    ],
    diagram: 'swap',
  },
  {
    timeline: '10 to 16 weeks',
    title: 'Running two sites in parallel',
    lead: 'A global site and a China site, sharing one editorial pipeline.',
    body: 'One team manages the content workflow. Two very different audiences each get a site that was actually made for them.',
    fit: [
      'Your global brand and China brand live differently',
      'You want full control on both sides',
      'You can resource both teams',
    ],
    diagram: 'parallel',
  },
];

const phases = [
  {
    label: 'Phase 1',
    title: 'Discover',
    steps: [
      {
        title: 'Discovery and audit',
        body: 'A written audit of your site, brand, category and Chinese competition. We flag what to keep, what to rebuild. Two to three weeks.',
      },
      {
        title: 'Migration architecture',
        body: 'Hosting, CDN, DNS, content structure, redirect map. Designed around Chinese performance from day one. One week.',
      },
    ],
  },
  {
    label: 'Phase 2',
    title: 'Build',
    steps: [
      {
        title: 'Content rewrite and transfer',
        body: 'Native Chinese writers rewrite the copy that needs it, transcreate the rest, and preserve SEO equity through hand-mapped URLs.',
      },
      {
        title: 'UX and UI localisation',
        body: 'Templates reviewed against Chinese reading habits and adjusted where they fall short. Brand identity stays, interface gets localised.',
      },
      {
        title: 'Integration replacement',
        body: 'Google Analytics, YouTube, Facebook pixels swapped for Baidu Tongji, Youku or Bilibili, WeChat or Weibo equivalents. Every dependency checked.',
      },
      {
        title: 'Performance and technical optimisation',
        body: 'Blocked fonts and CDNs replaced. SSL set for China. Assets tuned for mainland networks. Baidu-friendly SEO layered in.',
      },
    ],
  },
  {
    label: 'Phase 3',
    title: 'Launch',
    steps: [
      {
        title: 'Testing from inside China',
        body: 'Real connections, not VPN. Load speed, functionality, QQ and UC Browser, mid-range Android. The way your audience actually reads.',
      },
      {
        title: 'Zero-downtime cutover',
        body: 'Launch planned to the hour. DNS managed live, rollback path open for 48 hours. We are on call through the first weeks.',
      },
    ],
  },
];

const migrationItems = [
  {
    label: 'Pages and posts',
    body: 'Content, formatting, media embeds, metadata.',
    iconPath: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    label: 'Media library',
    body: 'Images, videos, documents, re-optimised for delivery inside China.',
    iconPath: 'M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z',
  },
  {
    label: 'SEO data',
    body: 'Meta titles, descriptions, URLs, redirects, sitemaps.',
    iconPath: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z',
  },
  {
    label: 'Custom fields and taxonomies',
    body: 'Custom post types, categories, tags, structured data.',
    iconPath: 'M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5l-3.9 19.5m-2.1-19.5l-3.9 19.5',
  },
  {
    label: 'E-commerce data',
    body: 'Products, orders, customer records, payment configuration.',
    iconPath: 'M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z',
  },
  {
    label: 'User accounts',
    body: 'Roles, profiles and permissions.',
    iconPath: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  },
  {
    label: 'Integrations',
    body: 'CRM, analytics, marketing tools, adapted or replaced for the China stack.',
    iconPath: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
  },
  {
    label: 'Design and branding',
    body: 'Visual identity stays intact. UX adjusted where Chinese habits demand it.',
    iconPath: 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.385m3.42 3.41a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.41a6.776 6.776 0 00-3.42-3.41',
  },
];

const challenges = [
  {
    title: 'Legacy URLs and SEO equity',
    body: 'You spent years building rankings on your global site. A bad migration loses all of it overnight. We do URL mapping by hand for any page that matters, set proper 301s, and preserve as much organic visibility as we can carry across.',
    iconPath: 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
  },
  {
    title: 'The Great Firewall layer',
    body: 'Blocks Google services, most Western CDNs, several social platforms and a long list of external dependencies your site almost certainly relies on. Every single one has to be replaced.',
    iconPath: 'M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z',
  },
  {
    title: 'ICP licensing',
    body: 'Hosting on a Chinese server requires a government filing called an ICP, or Bei’an. Application is in Chinese, rules vary by province and processing typically runs twenty working days at minimum. We handle the filing for you.',
    iconPath: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    title: 'Data localisation laws',
    body: 'Under China’s Cybersecurity Law and PIPL, certain user data has to be stored on mainland servers. Architecture has to account for this from day one, three months after launch is too late.',
    iconPath: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
  },
];

const audiences = [
  { label: 'International brands entering China', description: 'Companies launching their first proper China presence after years of running a translated global site.', image: '/images/audiences/multinational-china-entry.webp' },
  { label: 'Brands relaunching a site that didn’t land', description: 'The original China site is live but it never performed. Bounce rate is high, leads are flat, HQ is asking why. The migration is really a relaunch.', image: '/images/audiences/agency-migration-clients.webp' },
  { label: 'E-commerce brands', description: 'Launching a China-ready store with the right payment, logistics and customer service integrations from day one.', image: '/images/audiences/ecommerce-china-store.webp' },
  { label: 'Media and publishing', description: 'Organisations that need to reach Chinese audiences properly, not through a translated mirror.', image: '/images/audiences/media-publishing-china.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <!-- Hero: full-bleed dark -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-migration.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">China Migration</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text: 7 cols -->
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            China Migration
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Move your website into China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Properly.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            A real China migration is a relaunch. We move your content, your design and your hosting into China together, so the site that goes live actually works for Chinese audiences.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            Twenty years on the ground in Shanghai. Fifty-plus international brands migrated, none broken on the way in.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Discuss your migration</Button>
          </div>
        </div>

        <!-- Visual: 5 cols, migration status panel -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">migration-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Content localised</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100%</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Blocked resources</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">0 / 47</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">China load time</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">2.1s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[15%] h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP compliance</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Filed</span>
                </div>
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center gap-y-12">
        <div class="col-span-12 lg:col-span-6">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Most “China migrations” only solve the easy problem.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            You move the files, change the host, file the ICP. The site loads. The bounce rate stays at 80%.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            The hard part is everything Chinese users actually see once the page opens: the Munich headline, the Boston layout, the trust signals your global team is proud of. None of it automatically translates.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            A real migration runs on three layers at once. Content. UX. Hosting. One project, out of Shanghai.
          </p>
        </div>

        <!-- Visual: phone in hand, scrolling past -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative">
            <div class="relative overflow-hidden rounded-2xl aspect-[4/5] lg:aspect-[5/6] bg-[var(--color-surface-light)]">
              <img
                src="/images/migration-easy-problem.webp"
                alt="A Chinese reader scrolling past a website that loads but doesn’t land"
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
            <!-- Decorative accent -->
            <div class="absolute -inset-3 bg-[var(--color-brand-orange)]/[0.04] rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Layers -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          The three layers of a real migration
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Content. UX. Hosting. All in one project.
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6">
        {layers.map((layer) => (
          <article class="bg-white rounded-2xl p-8 lg:p-10 border border-[var(--color-surface-border)] flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-orange)]/10 flex items-center justify-center mb-6 flex-shrink-0">
              <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={layer.iconPath} />
              </svg>
            </div>
            <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-2">
              {layer.label}
            </p>
            <h3 class="text-xl lg:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-4">
              {layer.title}
            </h3>
            <p class="text-base text-[var(--color-text-body)] leading-relaxed">
              {layer.body}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Migration Scenarios -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Migration scenarios
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Three paths into China
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
          Every migration starts from a different place. Here is how we usually approach each one.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
        {scenarios.map((scenario) => (
          <article class="group relative flex flex-col p-7 lg:p-8 bg-white rounded-2xl border border-[var(--color-surface-border)] hover:border-[var(--color-brand-orange)]/40 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(15,15,18,0.06)] transition-all duration-300">
            <!-- Diagram -->
            <div class="mb-6 h-16 flex items-center" aria-hidden="true">
              {scenario.diagram === 'single' && (
                <div class="flex items-center gap-2">
                  <span class="px-3 py-1.5 rounded-md bg-[var(--color-surface-light)] text-xs font-medium font-[var(--font-button)] text-[var(--color-text-muted)] border border-[var(--color-surface-border)]">Global site</span>
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  <span class="px-3 py-1.5 rounded-md bg-[var(--color-brand-orange)]/10 text-xs font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] border border-[var(--color-brand-orange)]/20">中国</span>
                </div>
              )}
              {scenario.diagram === 'swap' && (
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="px-3 py-1.5 rounded-md bg-[var(--color-surface-light)] text-xs font-medium font-[var(--font-button)] text-[var(--color-text-muted)] border border-[var(--color-surface-border)] line-through decoration-[var(--color-text-muted)]/40">Old CMS</span>
                  <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  <span class="px-3 py-1.5 rounded-md bg-[var(--color-surface-light)] text-xs font-medium font-[var(--font-button)] text-[var(--color-text-dark)] border border-[var(--color-surface-border)]">New CMS</span>
                  <svg class="w-4 h-4 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  <span class="px-3 py-1.5 rounded-md bg-[var(--color-brand-orange)]/10 text-xs font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] border border-[var(--color-brand-orange)]/20">中国</span>
                </div>
              )}
              {scenario.diagram === 'parallel' && (
                <div class="flex flex-col gap-1.5">
                  <div class="flex items-center gap-2">
                    <span class="px-3 py-1.5 rounded-md bg-[var(--color-surface-light)] text-xs font-medium font-[var(--font-button)] text-[var(--color-text-dark)] border border-[var(--color-surface-border)]">Global site</span>
                    <span class="text-[var(--color-text-muted)] text-sm">·</span>
                    <span class="px-3 py-1.5 rounded-md bg-[var(--color-brand-orange)]/10 text-xs font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] border border-[var(--color-brand-orange)]/20">中国</span>
                  </div>
                  <span class="text-[11px] uppercase tracking-wider text-[var(--color-text-muted)] font-medium">One editorial pipeline</span>
                </div>
              )}
            </div>

            <!-- Timeline pill -->
            <div class="inline-flex items-center gap-1.5 self-start mb-4 px-3 py-1 rounded-full bg-[var(--color-surface-light)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {scenario.timeline}
            </div>

            <h3 class="text-xl lg:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-2">
              {scenario.title}
            </h3>
            <p class="text-base font-semibold text-[var(--color-text-dark)] leading-snug mb-3">
              {scenario.lead}
            </p>
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed mb-6">
              {scenario.body}
            </p>

            <div class="mt-auto pt-5 border-t border-[var(--color-surface-border)]">
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Right for you if</p>
              <ul class="space-y-2">
                {scenario.fit.map((point) => (
                  <li class="flex items-start gap-2.5 text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    <svg class="flex-shrink-0 w-4 h-4 mt-1 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Process: phased -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <!-- Left: sticky heading -->
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            How we run it
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Three phases. Eight steps. One launch.
          </h2>
          <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
            Designed around Chinese performance and Chinese user habits from day one, not patched together at the end.
          </p>
        </div>

        <!-- Right: phased steps with vertical timeline -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7 relative">
          <!-- Vertical line -->
          <div class="absolute left-[14px] top-3 bottom-3 w-px bg-[var(--color-surface-border)]" aria-hidden="true"></div>

          <div class="space-y-14">
            {phases.map((phase) => (
              <div class="relative">
                <!-- Phase header with marker on the line -->
                <div class="flex items-center gap-5 mb-6">
                  <div class="relative z-10 flex-shrink-0 w-[30px] h-[30px] rounded-full bg-[var(--color-brand-orange)] ring-8 ring-white flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <div class="flex items-baseline gap-3">
                    <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">
                      {phase.label}
                    </span>
                    <h3 class="text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
                      {phase.title}
                    </h3>
                  </div>
                </div>

                <!-- Steps under the phase, indented past the line -->
                <div class="pl-[50px] space-y-5">
                  {phase.steps.map((step) => (
                    <div class="bg-white rounded-xl p-5 border border-[var(--color-surface-border)]">
                      <h4 class="text-base lg:text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                        {step.title}
                      </h4>
                      <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                        {step.body}
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Operational Checklist -->
  <section class="relative section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="pointer-events-none absolute -top-40 -right-40 w-[640px] h-[640px] rounded-full bg-[var(--color-brand-orange)]/[0.08] blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-48 -left-40 w-[520px] h-[520px] rounded-full bg-[var(--color-brand-orange)]/[0.05] blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Hero row: heading + feature visual -->
      <div class="grid grid-cols-12 gap-6 lg:gap-8 items-stretch mb-10 lg:mb-14">
        <div class="col-span-12 lg:col-span-5 flex flex-col">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Operational checklist
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.05] mb-6">
            Nothing important gets left behind.
          </h2>
          <p class="text-lg text-white/65 leading-relaxed mb-8">
            A migration is dozens of small things going right at the same time. These are the eight areas we move, rebuild and verify on every project.
          </p>

          <div class="mt-auto inline-flex items-center gap-5 self-start px-5 py-4 rounded-xl bg-white/[0.04] border border-white/10 backdrop-blur-md">
            <div class="flex items-baseline gap-1 font-[var(--font-heading)]">
              <span class="text-4xl font-medium text-white leading-none tracking-tight">08</span>
              <span class="text-xl font-medium text-white/30 leading-none">/08</span>
            </div>
            <div class="h-10 w-px bg-white/10"></div>
            <p class="text-xs uppercase tracking-wider text-white/55 leading-snug">
              Areas covered<br />on every project
            </p>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-7">
          <div class="relative rounded-2xl overflow-hidden border border-white/10 bg-[var(--color-surface-dark)] aspect-[16/10] lg:aspect-auto lg:h-full lg:min-h-[380px]">
            <img
              src="/images/migration-pipeline-architecture.webp"
              alt="Modules of a website moving through the migration pipeline"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-[var(--color-surface-dark)]/40 via-transparent to-transparent"></div>
            <div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-white/5 rounded-2xl"></div>
            <div class="absolute top-5 right-5 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-surface-dark)]/70 backdrop-blur-md border border-white/10">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-brand-orange)] opacity-60 animate-ping"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-brand-orange)]"></span>
              </span>
              <span class="text-[11px] font-mono uppercase tracking-wider text-white/80">Migration in flight</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Items grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
        {migrationItems.map((item, i) => (
          <article class="group relative flex flex-col h-full p-6 lg:p-7 rounded-2xl bg-white/[0.04] border border-white/10 backdrop-blur-md transition-all duration-300 hover:bg-white/[0.07] hover:border-[var(--color-brand-orange)]/30 hover:-translate-y-0.5">
            <div class="flex items-start justify-between mb-6">
              <div class="w-11 h-11 rounded-xl bg-[var(--color-brand-orange)]/15 border border-[var(--color-brand-orange)]/25 flex items-center justify-center">
                <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.iconPath} />
                </svg>
              </div>
              <span class="font-mono text-xs text-white/35 tracking-[0.18em] mt-1.5">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <h3 class="text-base lg:text-[17px] font-semibold font-[var(--font-heading)] text-white mb-2 leading-snug">
              {item.label}
            </h3>
            <p class="text-sm text-white/55 leading-relaxed">
              {item.body}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Different -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Why it is different
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          A China migration plays by different rules.
        </h2>
      </div>

      <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
        {challenges.map((item) => (
          <div class="flex gap-5 p-6 lg:p-8 rounded-2xl bg-[var(--color-surface-light)] border border-[var(--color-surface-border)]">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[var(--color-brand-orange)]/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.iconPath} />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-lg lg:text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                {item.title}
              </h3>
              <p class="text-base text-[var(--color-text-body)] leading-relaxed">
                {item.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Built for brands moving into China" audiences={audiences} background="light" />

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-16 sm:py-20 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Start your migration
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Thinking about moving your site into China?
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Tell us where the site lives today, what it does for your brand, and what it needs to do for Chinese audiences. We come back within two business days with a written assessment: scope, timeline, and a clear view of what a proper migration looks like for your project. No charge, no commitment.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact/" variant="primary" size="lg">Start your migration assessment</Button>
        <Button href="/#OurServices" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">View our services</Button>
      </div>
    </div>
  </section>

</PageLayout>
