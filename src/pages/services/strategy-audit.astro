---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';

const metaTitle = 'WordPress China Strategy & Audit | ChinaWebFoundry';
const metaDescription = 'Get a full audit of your WordPress site for China readiness. We identify blockers, plan your ICP licence, and deliver a prioritised roadmap.';

const auditItems = [
  {
    title: 'Speed testing from inside China',
    body: 'Real browser sessions from four major cities. Most sites take over 15 seconds. Some never finish loading.',
    icon: 'speed',
  },
  {
    title: 'Blocked resource scan',
    body: 'Every plugin, font, script, and API call checked against the Great Firewall. We flag what\u2019s blocked and what\u2019s degraded.',
    icon: 'shield',
  },
  {
    title: 'Compliance review',
    body: 'SSL, data handling, and hosting measured against the Cybersecurity Law, PIPL, and Data Security Law.',
    icon: 'compliance',
  },
  {
    title: 'Chinese user experience',
    body: 'Your site on a Xiaomi phone with QQ Browser. Language rendering, navigation, mobile responsiveness.',
    icon: 'mobile',
  },
  {
    title: 'Baidu SEO health check',
    body: 'Indexation, sitemaps, Baidu Webmaster Tools compatibility, and search intent alignment. Google rankings mean nothing here.',
    icon: 'search',
  },
  {
    title: 'Infrastructure review',
    body: 'Hosting, DNS, CDN, and database performance. Will your WordPress stack actually work in a China environment?',
    icon: 'server',
  },
];

const roadmapItems = [
  {
    title: 'Market entry approach',
    body: 'Mainland hosting, Hong Kong with CDN, or WeChat/Xiaohongshu? We map every option with honest tradeoffs.',
  },
  {
    title: 'ICP licence path',
    body: 'Filing type, entity structure, provider eligibility, and realistic timelines. Getting this wrong costs months.',
  },
  {
    title: 'Technical architecture',
    body: 'Hosting, CDN, DNS for Chinese resolvers, and a WordPress stack tested under real China conditions.',
  },
  {
    title: 'Content & Baidu SEO',
    body: 'What to publish first, how to structure it for Baidu Spider, and mobile-first indexing rules.',
  },
  {
    title: 'Plugin swap list',
    body: 'Google Analytics to Baidu Tongji. Maps to Amap. reCAPTCHA to Tencent Captcha. Plus CRM/ERP mapping.',
  },
  {
    title: 'Timeline & budget',
    body: 'Phased milestones built around real timelines, not wishful thinking.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Kickoff Call',
    body: 'Your goals, audience, WordPress setup, ICP status, and previous China attempts.',
  },
  {
    number: '02',
    title: 'Testing from China',
    body: 'Real browsers, real cities, real network conditions. Benchmarked against competitors.',
  },
  {
    number: '03',
    title: 'Building the Plan',
    body: 'Specific recommendations with risk flags, compliance steps, and budget ranges.',
  },
  {
    number: '04',
    title: 'Walkthrough',
    body: 'Video call to review findings and align on next steps before anything gets built.',
  },
];

const audiences = [
  {
    label: 'First-time China entry',
    body: 'Need your WordPress site to actually work behind the Great Firewall.',
    icon: 'rocket',
  },
  {
    label: 'Underperforming in China',
    body: 'Slow loads, poor Baidu visibility, or things breaking in mainland browsers.',
    icon: 'chart',
  },
  {
    label: 'Campaign teams',
    body: 'Need a fast, compliant landing experience for Chinese audiences.',
    icon: 'target',
  },
  {
    label: 'Technical leadership',
    body: 'Need a clear assessment of ICP, MIIT, and infrastructure requirements.',
    icon: 'code',
  },
  {
    label: 'E-commerce & B2B',
    body: 'Losing Chinese customers because checkout flows break behind the Firewall.',
    icon: 'cart',
  },
];
---

<PageLayout title={metaTitle} description={metaDescription}>

  <!-- Hero: full-bleed dark with image placeholder -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <div class="w-full h-full bg-gradient-to-br from-[#1C1C1C] via-[#2a1a14] to-[#1C1C1C]"></div>
    </div>

    <!-- Subtle grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><rect width=%2260%22 height=%2260%22 fill=%22none%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="pt-8 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Strategy &amp; Audit</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text: 7 cols -->
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Every project starts here
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Enter China with Confidence.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Start with Strategy.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            We test your WordPress site against China's real technical constraints and map out exactly what it takes to perform behind the Great Firewall.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Schedule a Discovery Call</Button>
          </div>
        </div>

        <!-- Visual: 5 cols, audit report placeholder -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <!-- Floating audit card mock -->
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">audit-report.pdf</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Load time (Shanghai)</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">18.4s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[92%] h-full bg-gradient-to-r from-red-500 to-red-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Blocked resources</span>
                  <span class="text-sm font-semibold text-orange-400 font-mono">23 / 47</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[49%] h-full bg-gradient-to-r from-orange-500 to-orange-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Baidu indexation</span>
                  <span class="text-sm font-semibold text-yellow-400 font-mono">0 pages</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[3%] h-full bg-gradient-to-r from-yellow-500 to-yellow-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP compliance</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">Not filed</span>
                </div>
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction: split layout with image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Most WordPress sites break behind the Great Firewall
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Google Fonts won't render, reCAPTCHA spins forever, YouTube embeds go blank. We test from Beijing, Shanghai, Shenzhen, and Chengdu on real browsers, then build a roadmap: what to fix, what to replace, what to build new.
          </p>
        </div>

        <!-- Visual: broken website illustration -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-surface-light)] to-white border border-[var(--color-surface-border)]">
            <!-- Placeholder: broken site mockup -->
            <div class="absolute inset-6 flex flex-col gap-3">
              <div class="h-4 w-32 bg-[var(--color-surface-border)] rounded"></div>
              <div class="flex gap-3 mt-2">
                <div class="h-3 w-16 bg-[var(--color-surface-border)] rounded"></div>
                <div class="h-3 w-16 bg-[var(--color-surface-border)] rounded"></div>
                <div class="h-3 w-16 bg-[var(--color-surface-border)] rounded"></div>
              </div>
              <div class="flex-1 mt-4 grid grid-cols-2 gap-3">
                <div class="bg-[var(--color-surface-border)]/50 rounded-lg flex items-center justify-center">
                  <svg class="w-8 h-8 text-red-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="bg-[var(--color-surface-border)]/50 rounded-lg flex items-center justify-center">
                  <svg class="w-8 h-8 text-red-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                </div>
                <div class="col-span-2 bg-[var(--color-surface-border)]/50 rounded-lg flex items-center justify-center gap-2">
                  <svg class="w-6 h-6 text-orange-400/60 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                  <span class="text-sm text-[var(--color-text-muted)]">Loading...</span>
                </div>
              </div>
            </div>
            <!-- "Blocked" stamp -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-[-12deg]">
              <div class="border-4 border-red-400/30 rounded-lg px-6 py-2">
                <span class="text-2xl font-bold text-red-400/30 font-[var(--font-heading)] tracking-wider">BLOCKED</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Audit Section: card grid -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          The Audit
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          WordPress Audit for China Readiness
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
          We quantify what each issue costs you in speed, Baidu rankings, and conversions.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {auditItems.map((item) => (
          <div class="bg-white border border-[var(--color-surface-border)] rounded-xl p-7 transition-all duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center mb-5">
              {item.icon === 'speed' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
              )}
              {item.icon === 'shield' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              )}
              {item.icon === 'compliance' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              )}
              {item.icon === 'mobile' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
              )}
              {item.icon === 'search' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              )}
              {item.icon === 'server' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
              )}
            </div>
            <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3">
              {item.title}
            </h3>
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
              {item.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Roadmap Section: numbered list with image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <!-- Left: sticky heading + placeholder visual -->
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            The Roadmap
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Strategic Roadmap
          </h2>
          <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            The audit shows you where things stand. The roadmap is what to do about it.
          </p>

          <!-- Roadmap visual placeholder -->
          <div class="hidden lg:block relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-brand-orange)]/10 to-[var(--color-text-card-blue)]/10 border border-[var(--color-surface-border)]">
            <div class="absolute inset-6 flex flex-col justify-between">
              <div>
                <div class="h-3 w-24 bg-[var(--color-brand-orange)]/20 rounded mb-3"></div>
                <div class="h-2 w-40 bg-[var(--color-surface-border)] rounded mb-2"></div>
                <div class="h-2 w-32 bg-[var(--color-surface-border)] rounded"></div>
              </div>
              <!-- Timeline bars -->
              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  <span class="text-[10px] text-[var(--color-text-muted)] w-14 flex-shrink-0">Phase 1</span>
                  <div class="h-5 flex-1 bg-[var(--color-brand-orange)]/20 rounded-md"></div>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-[10px] text-[var(--color-text-muted)] w-14 flex-shrink-0">Phase 2</span>
                  <div class="h-5 w-[70%] bg-[var(--color-text-card-blue)]/15 rounded-md ml-[15%]"></div>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-[10px] text-[var(--color-text-muted)] w-14 flex-shrink-0">Phase 3</span>
                  <div class="h-5 w-[50%] bg-[var(--color-brand-orange)]/15 rounded-md ml-[40%]"></div>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-[10px] text-[var(--color-text-muted)] w-14 flex-shrink-0">ICP Filing</span>
                  <div class="h-5 w-[45%] bg-green-500/15 rounded-md"></div>
                </div>
              </div>
              <div class="flex justify-between text-[10px] text-[var(--color-text-muted)]">
                <span>Week 1</span><span>Week 4</span><span>Week 8</span><span>Week 12</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: roadmap items with numbering -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {roadmapItems.map((item, i) => (
              <div class="flex gap-5">
                <!-- Number circle -->
                <div class="flex-shrink-0 w-10 h-10 rounded-full border-2 border-[var(--color-brand-orange)] flex items-center justify-center">
                  <span class="text-sm font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)]">{i + 1}</span>
                </div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section: horizontal timeline -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          How We Work
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
          From discovery to delivery
        </h2>
      </div>

      <!-- Process grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        <!-- Connecting line (desktop only) -->
        <div class="hidden lg:block absolute top-[2.25rem] left-[10%] right-[10%] h-px bg-white/10"></div>

        {processSteps.map((step) => (
          <div class="relative text-center">
            <!-- Step number badge -->
            <div class="relative z-10 w-[4.5rem] h-[4.5rem] mx-auto mb-6 rounded-2xl bg-white/[0.06] border border-white/10 flex items-center justify-center">
              <span class="text-2xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]">
                {step.number}
              </span>
            </div>
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-white mb-3">
              {step.title}
            </h3>
            <p class="text-[15px] text-white/60 leading-relaxed">
              {step.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Start Here: blockquote highlight -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <!-- Left: heading + visual -->
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Why Start Here?
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-8">
            Skip strategy, pay later
          </h2>

          <!-- Before/After visual -->
          <div class="hidden lg:flex gap-4">
            <div class="flex-1 bg-red-50 border border-red-200/60 rounded-xl p-5">
              <div class="flex items-center gap-2 mb-3">
                <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span class="text-sm font-semibold font-[var(--font-heading)] text-red-500">Without audit</span>
              </div>
              <ul class="space-y-2 text-sm text-red-600/80">
                <li>18s+ load times</li>
                <li>23 blocked resources</li>
                <li>Failed ICP filing</li>
                <li>4 months wasted</li>
              </ul>
            </div>
            <div class="flex-1 bg-green-50 border border-green-200/60 rounded-xl p-5">
              <div class="flex items-center gap-2 mb-3">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm font-semibold font-[var(--font-heading)] text-green-600">With audit</span>
              </div>
              <ul class="space-y-2 text-sm text-green-700/80">
                <li>&lt;3s load times</li>
                <li>0 blocked resources</li>
                <li>ICP filed in parallel</li>
                <li>Launch on schedule</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Right: content -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <blockquote class="relative bg-[var(--color-surface-light)] rounded-2xl p-6 lg:p-8 mb-8">
            <svg class="absolute top-4 left-5 w-10 h-10 text-[var(--color-brand-orange)]/15" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" /></svg>
            <p class="text-base text-[var(--color-text-body)] leading-relaxed relative z-10">
              A client spent four months rebuilding their WordPress site for China. Then they found out their hosting provider didn't support ICP filing. Four months, gone. Another company launched a site that loaded in 23 seconds from Shanghai because the theme pulled 14 Google-hosted resources on every page.
            </p>
          </blockquote>

          <p class="text-base text-[var(--color-text-body)] leading-relaxed mb-5">
            Start ICP filing during the strategy phase and development runs in parallel with compliance instead of after it. Every recommendation connects to something measurable: Baidu ranking targets, load time benchmarks, conversion rates. Numbers, not promises.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who Is This For: icon cards -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Who Is This For?
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Built for teams serious about China
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {audiences.map((item, i) => (
          <div class:list={[
            'bg-white border border-[var(--color-surface-border)] rounded-xl p-7',
            i === audiences.length - 1 ? 'sm:col-span-2 lg:col-span-1' : '',
          ]}>
            <div class="w-10 h-10 rounded-lg bg-[var(--color-text-card-blue)]/10 flex items-center justify-center mb-4">
              {item.icon === 'rocket' && (
                <svg class="w-5 h-5 text-[var(--color-text-card-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.63 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-6.233 0c-1.045 1.045-1.636 3.858-1.636 3.858s2.813-.591 3.858-1.636a4.493 4.493 0 000-2.222" /></svg>
              )}
              {item.icon === 'chart' && (
                <svg class="w-5 h-5 text-[var(--color-text-card-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
              )}
              {item.icon === 'target' && (
                <svg class="w-5 h-5 text-[var(--color-text-card-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
              )}
              {item.icon === 'code' && (
                <svg class="w-5 h-5 text-[var(--color-text-card-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>
              )}
              {item.icon === 'cart' && (
                <svg class="w-5 h-5 text-[var(--color-text-card-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" /></svg>
              )}
            </div>
            <h3 class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-2">
              {item.label}
            </h3>
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
              {item.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <!-- Subtle gradient accent -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Get Started
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Ready to find out how your site performs in China?
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        We test from inside mainland China and deliver a plan you can act on.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/contact/" variant="primary" size="lg">Schedule a Discovery Call</Button>
        <Button href="/contact/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Download Our China Market Guide</Button>
      </div>
    </div>
  </section>

</PageLayout>
