---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQItem from '../components/pages/FAQItem.astro';
import ScrollEffects from '../components/global/ScrollEffects.astro';

const metaTitle = 'WeChat for China | Mini Programs and H5 Sites | ChinaWebFoundry';
const metaDescription = 'We build WeChat Mini Programs and H5 mini-sites for foreign brands in China. Strategy, registration, development, launch from Shanghai.';

const dayMoments = [
  { time: '07:30', icon: 'qr', label: 'Morning coffee', body: 'Scan the bakery QR, pay with WeChat Pay, points credited automatically.' },
  { time: '10:00', icon: 'card', label: 'Loyalty tier', body: 'Tap the brand membership card before the second coffee. Tier check, free upgrade.' },
  { time: '12:30', icon: 'cart', label: 'Lunch order', body: 'Mini Program of the noodle place down the street. Pre-ordered, ready on arrival.' },
  { time: '15:00', icon: 'shield', label: 'Service request', body: 'Warranty status on a kitchen appliance. Brand Mini Program. No login needed.' },
  { time: '19:00', icon: 'bag', label: 'Evening shopping', body: 'Skincare brand Mini Program. Saved cart, WeChat Pay, ready in order history.' },
  { time: '21:30', icon: 'video', label: 'Channels livestream', body: 'A favourite presenter on Channels. Tap a product, buy, no checkout interruption.' },
];

const compareRows = [
  { label: 'Lives where', mp: 'Inside WeChat, like a native app', h5: 'In WeChat\'s in-app browser, also outside' },
  { label: 'WeChat Pay', mp: 'Yes, full integration', h5: 'Limited, requires Official Account binding' },
  { label: 'Native APIs', mp: 'Camera, location, scan, login', h5: 'Browser-only' },
  { label: 'Build time', mp: '10 to 14 weeks', h5: '4 to 6 weeks' },
  { label: 'Best for', mp: 'Membership, e-commerce, service', h5: 'Campaigns, brochures, lead capture' },
];

const useCases = [
  {
    icon: 'badge',
    title: 'Membership and loyalty',
    body: 'The most common use case for foreign brands. The Mini Program holds the card, tracks points, delivers personalised rewards. Starbucks China runs its entire membership this way.',
