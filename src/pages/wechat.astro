  {
    icon: 'calendar',
    title: 'Booking, events, content',
    cn: '预订与内容',
    body: 'DerbySoft and Tongcheng for hotels (Club Med used DerbySoft for direct-booking growth). Damai, Huodongxing, Yoopay for ticketing. Channels and WeChat Live for livestream. Audemars Piguet uses booking-inside-Mini Program for clienteling.',
    items: [
      { en: 'DerbySoft', cn: '' },
