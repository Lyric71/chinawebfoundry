const saasCategories = [
  {
    icon: 'cart',
    title: 'E-commerce SaaS',
    cn: '电商 SaaS',
    body: 'Storefronts, catalogues, WeChat Pay, group buying (拼团), flash sales (秒杀), vouchers (优惠券). Established players from CNY 6,800/year; newer no-code platforms from CNY 1,000 to 2,000.',
    items: [
      { en: 'Youzan', cn: '有赞' },
      { en: 'Weimob', cn: '微盟' },
