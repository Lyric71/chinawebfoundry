const handleSteps = [
  {
    icon: 'badge',
    title: 'Account registration and verification',
    body: 'Through your WFOE, a local partner, or a service-account-only setup. Documentation, fees, identity checks, the Tencent back-and-forth.',
  },
  {
    icon: 'shield',
    title: 'MIIT Mini Program filing (小程序备案)',
    body: 'Mandatory since 2023. Chinese business licence, ICP-filed domain, category approvals. We handle the 24-hour SMS window that trips up first-time filings.',
  },
  {
    icon: 'server',
    title: 'ICP filing for the supporting domain',
    body: 'Required for Mini Programs with a backend. Aliyun, Tencent Cloud, or Huawei Cloud, depending on your stack.',
  },
  {
    icon: 'card',
    title: 'WeChat Pay integration',
    body: 'Merchant account, certificate generation, API, test cycle, end to end. The piece that breaks most often without local presence.',
  },
  {
    icon: 'lock',
    title: 'Privacy compliance (用户隐私保护指引)',
    body: 'Policy, in-app consent UI, audit-ready against WeChat\'s guidelines. So the Mini Program passes review the first time.',
