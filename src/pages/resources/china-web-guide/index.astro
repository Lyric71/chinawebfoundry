---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';

const guides = (await getCollection('guides'))
  .filter((guide) => guide.data.published)
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="China Web Guide | ChinaWebFoundry"
  description="Practical articles on running a website in China. ICP licences, Great Firewall, Baidu SEO, hosting, and more."
  heroPage={true}
>
  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12] via-[#1a1a2e] to-[#0f0f12]"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-32">
      <div class="io-grid items-start gap-y-10">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            China Web Guide
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.08]">
            What You Need to Know<br />About the Web in China
          </h1>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 lg:pt-10">
          <p class="text-lg text-white/60 leading-relaxed">
            Practical, no-fluff articles covering the realities of running a website behind the Great Firewall.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-20 md:py-28 lg:py-36">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {guides.map((guide) => (
          <a
            href={`/resources/china-web-guide/${guide.id}/`}
            class="group flex flex-col bg-white border border-[var(--color-surface-border)] rounded-2xl overflow-hidden no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
          >
            <div class="aspect-[16/9] bg-[var(--color-surface-light)] overflow-hidden">
              <img
                src={guide.data.visual}
                alt=""
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="flex flex-col flex-1 p-6 lg:p-7">
              <h2 class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-2">
                {guide.data.title}
              </h2>
              <p class="text-sm text-[var(--color-brand-orange)] font-medium mb-3">
                {guide.data.subtitle}
              </p>
              <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-6 flex-1">
                {guide.data.summary}
              </p>
              <span class="inline-flex items-center gap-2 text-sm font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] group-hover:gap-3 transition-all duration-200">
                Read article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-[1400px] section-padding text-center">
      <h2 class="text-3xl sm:text-4xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
        Need Help With Your China Web Strategy?
      </h2>
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed max-w-2xl mx-auto mb-10">
        These guides cover the basics. If you need hands-on help getting your WordPress site working in China, we are here for that.
      </p>
      <Button href="/contact/" variant="primary" size="lg">Talk to Us</Button>
    </div>
  </section>
</PageLayout>
