---
import { getCollection, getEntry, render } from 'astro:content';
import GuideLayout from '../../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides
    .filter((guide) => guide.data.published)
    .map((guide) => ({
      params: { slug: guide.id },
      props: { guide },
    }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const tocItems = headings.filter((h) => h.depth === 2);

// Look up the author from the team collection (defaults to cyril-drouin via schema).
const teamEntry = await getEntry('team', guide.data.author);
const author = teamEntry
  ? {
      name: teamEntry.data.name,
      role: teamEntry.data.role,
      url: teamEntry.data.linkedin,
      bio: teamEntry.data.bio,
    }
  : undefined;
---

<GuideLayout
  title={guide.data.title}
  subtitle={guide.data.subtitle}
  summary={guide.data.summary}
  visual={guide.data.visual}
  tocItems={tocItems}
  author={author}
  publishedAt={guide.data.publishedAt}
  updatedAt={guide.data.updatedAt}
>
  <Content />
</GuideLayout>
