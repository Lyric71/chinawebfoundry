---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'Astro in China | Statische Websites für langsame Mobilfunknetze';
const metaDescription = 'Astro führt schnell zu einer Marketing-Website in Festlandchina. Wann es WordPress überlegen ist und welche Anpassungen es hinter der Großen Firewall tragfähig machen.';

const stats = [
  { value: 100, suffix: '', label: 'Lighthouse-Score, den eine typische Astro-Website ohne manuelle Feinarbeit erreicht', source: 'Sitepins, Astro in 2026' },
  { value: 60, suffix: '%', label: 'der Astro-Websites erreichen bei den Core Web Vitals die Bewertung „Good“', source: 'Bei WordPress sind es 38 %' },
  { value: 50, suffix: '%', label: 'kürzerer LCP gegenüber einer vergleichbaren WordPress-Website auf demselben chinesischen Host', source: 'Messungen von ChinaWebFoundry' },
];

const useCases = [
  {
    icon: 'rocket',
    title: 'Marketing- und Markenwebsites',
    body: 'Markenauftritte, Produktseiten, Landingpages und Kampagnen-Microsites verlangen erstklassige Ladezeiten, während sich ihr Inhalt höchstens wöchentlich ändert. Genau für diesen Zuschnitt wurde Astro entwickelt, und genau hier tritt der Geschwindigkeitsvorsprung am deutlichsten zutage.',
    span: 'feature',
    badges: ['Markenwebsites', 'Landingpages', 'Microsites'],
  },
  {
    icon: 'book',
    title: 'Dokumentation und Wissensbibliotheken',
    body: 'Mit Starlight, dem hauseigenen Dokumentations-Framework von Astro, steht eines der besten Werkzeuge des gesamten Ökosystems bereit. Bei technischer Dokumentation, Wissensdatenbanken und Ressourcenzentren in China lädt der Inhalt zügig, und die Navigation bleibt durchweg übersichtlich.',
    span: 'normal',
  },
  {
    icon: 'pen',
    title: 'Redaktionelle Websites und Blogs',
    body: 'Content Collections liefern typsicheres Markdown und MDX, das bereits zur Build-Zeit validiert wird. Der Arbeitsablauf läuft schneller als alles, was wir von WordPress kennen, und das Ergebnis fällt in den chinesischen Mobilfunknetzen spürbar leichter aus.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Mehrsprachige Marketing-Websites',
    body: 'Astro bringt das i18n-Routing von Haus aus mit, sodass sich Chinesisch ohne Umstände neben Englisch, Französisch, Deutsch oder Japanisch betreiben lässt. Wir haben bereits Astro-Websites mit zehn und mehr Sprachen ausgeliefert, ohne dass der Betrieb dabei ins Stocken geriet.',
    span: 'normal',
  },
  {
    icon: 'zap',
    title: 'Websites, bei denen die Core Web Vitals über das Budget entscheiden',
    body: 'Wenn der Erfolg bezahlter Werbung an der Ladegeschwindigkeit der Landingpage hängt oder Ihre Sichtbarkeit davon abhängt, dass Baidu den Inhalt sauber indexiert, führt Astro Sie mit dem geringsten Widerstand ans Ziel. Auf einem chinesischen Mittelklasse-Telefon sind Ladezeiten unter einer Sekunde realistisch.',
    span: 'normal',
  },
  {
    icon: 'shield',
    title: 'Websites mit hohem Sicherheitsanspruch',
    body: 'Statisches HTML kennt keine Datenbank, die sich kompromittieren ließe, kein PHP, das sich ausnutzen ließe, und keinen Admin-Login, den ein Angreifer durchprobieren könnte. Für Marken, die bereits einmal gehackt wurden, sowie für regulierte Branchen, in denen IT-Sicherheit den Vorstand beschäftigt, fällt die geringere Angriffsfläche als gewichtiges Argument ins Gewicht.',
    span: 'wide',
    badges: ['Keine Datenbank', 'Kein PHP-Runtime', 'Kein Admin-Login', 'Statische Auslieferung'],
  },
];

const pickAstro = [
  'Die Website lebt in erster Linie von Inhalt und Kommunikation',
  'Die Ladegeschwindigkeit gilt als harte, messbare Vorgabe',
  'Das Team kommt mit einem entwicklergeführten Ablauf zurecht, oder Sie binden ein Headless-CMS an',
  'Sie möchten die Betriebs- und Hostingkosten langfristig senken',
  'Sicherheit und eine geringe Angriffsfläche wiegen schwerer als redaktionelle Beweglichkeit',
];

const pickWordPress = [
  'Ihr Redaktionsteam muss täglich veröffentlichen, ohne dafür einen Entwickler hinzuziehen zu müssen',
  'Sie betreiben über WooCommerce einen Shop mit Hunderten oder Tausenden Produkten',
  'Sie sind auf bestimmte WordPress-Plugins angewiesen (Mitgliederbereich, LMS, Marketing-Automation)',
  'Das Marketingteam arbeitet mit Elementor oder Divi und wird davon nicht abrücken',
  'Das Projekt ist stark interaktiv ausgelegt (eingeloggte Dashboards, Echtzeitfunktionen)',
];

const changeGroups = [
  {
    label: 'Frontend',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Schriften',
        body: 'Astro-Starter beziehen ihre Schriften häufig von Google Fonts. Wir deaktivieren den Loader und hosten die Schriften selbst, oder wir ersetzen sie durch China-taugliche Varianten, die lateinische und CJK-Glyphen in einer einzigen Datei vereinen.',
      },
      {
        icon: 'palette',
        title: 'Externe Assets und Bilder',
        body: 'Manche Astro-Themes greifen für Icons oder Bibliotheken auf westliche CDNs wie jsDelivr oder unpkg zurück. Wir leiten alles über ein chinesisches CDN um oder bündeln die Assets direkt in den Build. Die Bilder liefern wir in modernen Formaten aus Aliyun OSS oder Tencent COS aus.',
      },
      {
        icon: 'blocks',
        title: 'Skripte von Drittanbietern',
        body: 'Alles, was einen blockierten Dienst kontaktiert, entfernen oder ersetzen wir. Für Karten, Schriften, Analytics, Captchas und Einbettungen finden wir jeweils einen China-tauglichen Ersatz, und zwar bereits während des Builds, bevor das statische Ergebnis überhaupt ausgeliefert wird.',
      },
    ],
  },
  {
    label: 'Integrationen & CMS',
    accent: 'orange',
    items: [
      {
        icon: 'plug',
        title: 'Headless-CMS, wo es gebraucht wird',
        body: 'Benötigt das Redaktionsteam eine visuelle Oberfläche, binden wir Storyblok, Sanity, Decap oder ein headless betriebenes WordPress an. Das CMS liegt außerhalb Chinas, der Inhalt wird zur Build-Zeit synchronisiert, und die statische Website liegt auf einem Server im Festland.',
      },
      {
        icon: 'card',
        title: 'Formulare und Widgets',
        body: 'Formulare laufen als Astro Islands. An die Stelle von Google reCAPTCHA tritt ein chinesisches Captcha, Google Maps weicht Baidu Map oder Amap. So bleiben die interaktiven Bestandteile funktionsfähig, ohne von blockierten Diensten abhängig zu sein.',
      },
      {
        icon: 'chart',
        title: 'Analytics',
        body: 'Vercel Analytics oder Plausible weicht Baidu Tongji oder einem selbst gehosteten Werkzeug. Ihr Team behält die gewohnten Auswertungen, ohne dass Messdaten an blockierten Endpunkten hängen bleiben.',
      },
    ],
  },
  {
    label: 'Hosting & Build',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hosting',
        body: 'Die Website läuft auf Servern in Festlandchina, mit gültiger ICP-Registrierung auf der Domain. Als Anbieter kommen Aliyun, Tencent Cloud oder Huawei Cloud infrage, davorgeschaltet ein chinesisches CDN. Das eigene CDN von Cloudflare arbeitet auf dem Festland nicht zuverlässig, weshalb wir dort nicht darauf deployen.',
      },
      {
        icon: 'refresh',
        title: 'Build-Pipeline',
        body: 'Der Build läuft außerhalb Chinas auf einer CI-Pipeline wie GitHub Actions oder GitLab CI, das statische Ergebnis wird anschließend auf den chinesischen Host übertragen. Nach einem Push auf main aktualisiert sich die Website binnen weniger Minuten.',
      },
      {
        icon: 'shield',
        title: 'Sicherheitslage',
        body: 'Eine statische Website kommt ohne Datenbank, ohne PHP-Runtime und ohne Admin-Login aus. Die Sicherheitsarbeit verlagert sich damit auf die Build-Pipeline und den Edge der chinesischen Cloud, anstatt sich an einem Runtime abzuarbeiten, das Woche für Woche Patches verlangt.',
      },
    ],
  },
  {
    label: 'Performance & SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'Statisches HTML auf einem CDN im Festland ist nur schwer zu übertreffen. Wir streben einen ersten sichtbaren Seiteninhalt unter einer Sekunde auf einem chinesischen Mittelklasse-Telefon an, und in den meisten Fällen erreichen wir diesen Wert.',
      },
      {
        icon: 'search',
        title: 'Baidu und KI-Suche',
        body: 'Baidu crawlt nach anderen Regeln als Google. Deshalb richten wir die Metadaten sauber ein, melden die Website in den Baidu Webmaster Tools an und strukturieren sie so, dass Doubao, Kimi, DeepSeek und Wenxin sie lesen und zitieren können. Da der Inhalt als reine Dateien in Git liegt, lassen sich strukturierte Daten und die llms.txt mühelos erzeugen.',
      },
    ],
  },
];

const fitBuckets = [
  {
    eyebrow: 'Astro passt',
    title: 'Marketing-Websites mit leichter Interaktivität',
    body: 'Eine Marketing-Website mit einer kleinen Produktvitrine, einem Kontaktformular oder einigen interaktiven Widgets entspricht genau dem Zuschnitt, für den Astro entwickelt wurde: statische Seiten, kurze Ladezeiten und JavaScript ausschließlich an den Stellen, an denen es unverzichtbar ist.',
  },
  {
    eyebrow: 'WordPress passt besser',
    title: 'E-Commerce und tägliche Redaktion',
    body: 'Sobald ein nicht technisches Team Tausende Produkte täglich pflegt, tiefe Plugin-Abhängigkeiten bestehen oder das Marketing mit einem Page-Builder arbeitet, bleibt WooCommerce auf WordPress in den meisten Fällen die richtige Wahl.',
  },
  {
    eyebrow: 'Ein ganz anderes Werkzeug',
    title: 'App-ähnliche Anwendungen',
    body: 'Eingeloggte Dashboards, Zusammenarbeit in Echtzeit und soziale Bereiche ähneln eher einer Anwendung als einer Website. Jenseits dieser Schwelle ist Next.js oder Remix die bessere Grundlage als Astro.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hosting' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hosting' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hosting' },
  { name: 'Baidu', cn: '百度', role: 'Suche & SEO' },
  { name: 'WeChat', cn: '微信', role: 'Login & Messaging' },
  { name: 'Alipay', cn: '支付宝', role: 'Zahlungen' },
];

const faqs = [
  {
    id: 'astro-icp',
    question: 'Braucht unsere Astro-Website eine ICP-Lizenz, um in China zu funktionieren?',
    answer: 'Wird sie in Festlandchina gehostet, dann ja. Bei einem Hosting in Hongkong oder bei Cloudflare entfällt die Pflicht zwar, doch die Website lädt für Nutzer auf dem Festland messbar langsamer, und Baidu behandelt sie als ausländisches Angebot. Für Marken, die den chinesischen Markt ernsthaft erschließen wollen, rechtfertigt das Ergebnis den Aufwand der ICP-Registrierung.',
  },
  {
    id: 'astro-marketing-team',
    question: 'Kann unser Marketingteam die Website weiterhin selbst aktualisieren?',
    answer: 'Das hängt davon ab, wie wir die Website aufsetzen. Auf Basis von Markdown und Content Collections laufen Inhaltsänderungen über Git und setzen einen Entwickler oder einen technisch versierten Nutzer voraus. Mit einem angebundenen Headless-CMS wie Storyblok, Sanity oder Decap erhält das Redaktionsteam dagegen eine visuelle Oberfläche und pflegt die Website, ohne den Code anzufassen. Welches Modell wir wählen, richtet sich danach, wie das Team tatsächlich arbeitet.',
  },
  {
    id: 'astro-vs-wp-speed',
    question: 'Ist Astro in China wirklich schneller als WordPress?',
    answer: 'Die Messwerte belegen es. Astro liefert statisches HTML mit nahezu keinem JavaScript aus, was die übertragene Datenmenge senkt, das Parsen beschleunigt und die Zahl der Roundtrips zum Server verringert. Im Vergleich zu einer ähnlichen WordPress-Website auf demselben chinesischen Host haben wir einen um 40 bis 60 Prozent kürzeren Largest Contentful Paint gemessen.',
  },
  {
    id: 'astro-headless-cms',
    question: 'Lässt sich ein Headless-CMS mit Astro nutzen?',
    answer: 'Ja, das zählt zu den stärksten Mustern von Astro. Wir haben bereits Websites mit Storyblok, Sanity, Decap und headless betriebenem WordPress ausgeliefert. Das CMS liegt außerhalb Chinas, wo die Redaktion ohne VPN-Hürden arbeiten kann, das statische Frontend liegt auf einem Server im Festland, und der Inhalt wird zur Build-Zeit synchronisiert. So behält das Redaktionsteam die gewohnte Oberfläche, während das chinesische Publikum eine schnelle Website erhält.',
  },
  {
    id: 'astro-ecommerce',
    question: 'Eignet sich Astro für E-Commerce?',
    answer: 'Für kleine bis mittlere Sortimente unter fünfhundert Produkten verträgt sich Astro gut mit Headless-Commerce: Shopify Storefront, Snipcart oder Stripe Checkout decken die internationalen Zahlungen ab, eigene Integrationen für Alipay und WeChat Pay die der chinesischen Verbraucher. Für umfangreichen E-Commerce mit Tausenden Produkten und einem nicht technischen Team, das den Lagerbestand täglich pflegt, bleibt WooCommerce auf WordPress in den meisten Fällen die richtige Wahl.',
  },
  {
    id: 'astro-multilingual',
    question: 'Wie geht Astro mit mehrsprachigen Inhalten für China um?',
    answer: 'Astro bringt das i18n-Routing von Haus aus mit, sodass sich Chinesisch sauber und strukturiert neben Englisch, Französisch oder jeder weiteren Sprache führen lässt. URLs, hreflang-Tags und sprachspezifische Sitemaps funktionieren ohne Zusatzaufwand. Wir haben bereits Astro-Websites mit zehn und mehr Sprachen ausgeliefert.',
  },
  {
    id: 'astro-migrate-wp',
    question: 'Können wir unsere bestehende WordPress-Website auf Astro migrieren?',
    answer: 'Ja, und das gehört zu unseren regelmäßigen Aufgaben. Der Inhalt wird aus WordPress exportiert, in Astro Content Collections neu strukturiert oder über ein Headless-CMS geführt, und das Design für den neuen Stack neu aufgebaut. Der übliche Zeitrahmen liegt bei vier bis acht Wochen. Das Ergebnis ist eine schnellere Website mit niedrigeren Betriebskosten; die gewohnte WordPress-Admin-Oberfläche entfällt allerdings, sofern wir sie nicht als Headless-Backend weiterführen.',
  },
  {
    id: 'astro-hosting',
    question: 'Welches Hosting nutzen Sie für Astro in China?',
    answer: 'Je nach Projekt hosten wir auf Aliyun, Tencent Cloud oder Huawei Cloud. Der Build läuft außerhalb Chinas auf einer CI-Pipeline, das statische Ergebnis wird auf den chinesischen Host übertragen, davorgeschaltet ein CDN im Festland. Wir übernehmen das Hostingkonto, die ICP-Registrierung und die Deployment-Pipeline, damit sich Ihr Team zu keinem Zeitpunkt selbst in ein chinesisches Hosting-Panel einloggen muss.',
  },
  {
    id: 'astro-maintenance',
    question: 'Wie viel Pflege braucht eine Astro-Website?',
    answer: 'Deutlich weniger als eine WordPress-Website. Es entfallen die Datenbank-Sicherung, das Aktuellhalten der Plugins, die PHP-Upgrades und die Sicherheitspatches, die im Wochentakt eintreffen. Das Framework selbst wird einige Male im Jahr aktualisiert, die Abhängigkeiten verlangen hin und wieder eine Durchsicht, mehr fällt nicht an. Für die meisten Marketing-Websites genügt eine vierteljährliche Wartungsrunde.',
  },
  {
    id: 'astro-cloudflare',
    question: 'Was bedeutet die Übernahme von Astro durch Cloudflare für China?',
    answer: 'In der Sache ändert sich für China wenig. Mit dem stärkeren Engagement von Cloudflare steht hinter Astro nun ein Infrastrukturkonzern, der mit dreißig Milliarden Dollar bewertet wird, was Kunden ein belastbares Signal für die langfristige Tragfähigkeit gibt. Das Framework selbst bleibt MIT-lizenziert und überall deploybar, auch bei chinesischen Cloud-Anbietern. Das eigene CDN von Cloudflare arbeitet auf dem Festland zwar nicht zuverlässig, doch Astro-Websites lassen sich weiterhin ohne Funktionseinbußen auf Aliyun oder Tencent Cloud betreiben.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de">

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-astro-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrumennavigation" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Astro</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <!-- Astro logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--color-brand-orange)] to-[#EF4444] flex items-center justify-center shadow-[0_8px_30px_rgba(242,95,41,0.4)]">
              <svg class="h-8 w-auto text-white" viewBox="0 0 85 107" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Astro logo">
                <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z"/>
                <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-[var(--color-brand-orange)] ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/25">
              <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">Framework · Astro</span>
            </div>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Astro in China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Auf Geschwindigkeit ausgelegt.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Das Frontend-Framework für inhaltsgetriebene Websites liefert vorrangig statisches HTML aus, kommt mit einem Minimum an JavaScript aus und schont die langsamen Mobilfunknetze, über die ein Großteil Chinas surft.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            Seit Januar 2026 steht Cloudflare hinter dem Projekt. Da wir Astro ebenso routiniert umsetzen wie WordPress, können wir Ihnen offen sagen, welcher Stack zu welchem Vorhaben passt.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/de/kontakt/" variant="primary" size="lg">Mit unserem Team sprechen</Button>
            <Button href="/de/wordpress/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">WordPress für China</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">astro-china-build</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Lighthouse</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100 / 100</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">JS ausgeliefert</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">~0 KB</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Edge</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aliyun</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP-Registrierung</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Eingereicht</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
