---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'Astro in China | Statische Websites für langsame Mobilfunknetze';
const metaDescription = 'Astro ist der schnellste Weg zu einer Marketing-Website in Festlandchina. Was Astro ist, wann es WordPress schlägt und welche Anpassungen es hinter der Großen Firewall tragfähig machen.';

const stats = [
  { value: 100, suffix: '', label: 'Lighthouse-Score auf einer typischen Astro-Website, ganz ohne manuelle Feinarbeit', source: 'Sitepins, Astro in 2026' },
  { value: 60, suffix: '%', label: 'der Astro-Websites erreichen bei den Core Web Vitals die Schwelle „Good“', source: 'Bei WordPress sind es 38 %' },
  { value: 50, suffix: '%', label: 'schnellerer LCP gegenüber einer vergleichbaren WordPress-Website, gleicher chinesischer Host', source: 'Messungen von ChinaWebFoundry' },
];

const useCases = [
  {
    icon: 'rocket',
    title: 'Marketing- und Markenwebsites',
    body: 'Markenauftritte, Produktseiten, Landingpages, Kampagnen-Microsites. Die Ladezeit muss erstklassig sein, der Inhalt ändert sich wöchentlich oder seltener. Genau dafür wurde Astro gebaut, und genau hier zeigt sich der Geschwindigkeitsvorsprung am deutlichsten.',
    span: 'feature',
    badges: ['Markenwebsites', 'Landingpages', 'Microsites'],
  },
  {
    icon: 'book',
    title: 'Dokumentation und Wissensbibliotheken',
    body: 'Starlight, das hauseigene Dokumentations-Framework von Astro, ist das Beste, was das Ökosystem zu bieten hat. Für technische Dokumentation, Wissensdatenbanken und Ressourcenzentren in China lädt der Inhalt schnell und bleibt die Navigation übersichtlich.',
    span: 'normal',
  },
  {
    icon: 'pen',
    title: 'Redaktionelle Websites und Blogs',
    body: 'Content Collections liefern typsicheres Markdown und MDX mit Validierung schon zur Build-Zeit. Der Arbeitsablauf läuft schneller als alles, was wir auf WordPress kennen, und das Ergebnis fällt auf chinesischen Mobilfunknetzen deutlich leichter aus.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Mehrsprachige Marketing-Websites',
    body: 'Astro bringt i18n-Routing von Haus aus mit. Chinesisch neben Englisch, Französisch, Deutsch oder Japanisch zu betreiben, ist unkompliziert. Wir haben Astro-Websites mit zehn oder mehr Sprachen ausgeliefert, ohne dass etwas hakte.',
    span: 'normal',
  },
  {
    icon: 'zap',
    title: 'Websites, bei denen die Core Web Vitals das Budget bestimmen',
    body: 'Wenn bezahlte Werbung von der Ladegeschwindigkeit der Landingpage abhängt oder Ihr SEO darauf beruht, dass Baidu Ihren Inhalt sauber indexiert, bringt Astro Sie mit dem geringsten Widerstand ans Ziel. Ladezeiten unter einer Sekunde auf einem chinesischen Mittelklasse-Telefon.',
    span: 'normal',
  },
  {
    icon: 'shield',
    title: 'Websites mit hohem Sicherheitsanspruch',
    body: 'Statisches HTML hat keine Datenbank, die angreifbar wäre, kein PHP, das sich ausnutzen ließe, und keinen Admin-Login, der sich durchprobieren ließe. Für Marken, die schon einmal gehackt wurden, oder für regulierte Branchen, in denen Sicherheit eine Sache des Vorstands ist, zählt die kleinere Angriffsfläche als echtes Argument.',
    span: 'wide',
    badges: ['Keine Datenbank', 'Kein PHP-Runtime', 'Kein Admin-Login', 'Statische Auslieferung'],
  },
];

const pickAstro = [
  'Die Website lebt vor allem von Inhalt und Kommunikation',
  'Die Ladegeschwindigkeit ist eine harte, messbare Vorgabe',
  'Das Team kommt mit einem entwicklergeführten Ablauf zurecht, oder Sie binden ein Headless-CMS an',
  'Sie wollen die Betriebs- und Hostingkosten auf lange Sicht senken',
  'Sicherheit und eine kleine Angriffsfläche wiegen schwerer als redaktionelle Beweglichkeit',
];

const pickWordPress = [
  'Ihr Redaktionsteam muss täglich veröffentlichen, ohne einen Entwickler zu rufen',
  'Sie betreiben E-Commerce mit Hunderten oder Tausenden Produkten über WooCommerce',
  'Sie hängen an bestimmten WordPress-Plugins (Mitgliederbereich, LMS, Marketing-Automation)',
  'Das Marketingteam arbeitet mit Elementor oder Divi und wird nicht wechseln',
  'Das Projekt ist stark interaktiv (eingeloggte Dashboards, Echtzeitfunktionen)',
];

const changeGroups = [
  {
    label: 'Frontend',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Schriften',
        body: 'Astro-Starter holen ihre Schriften oft von Google Fonts. Wir schalten den Loader ab und hosten die Schriften selbst, oder wir tauschen sie gegen China-taugliche Varianten, die lateinische und CJK-Glyphen in einer einzigen Datei mitbringen.',
      },
      {
        icon: 'palette',
        title: 'Externe Assets und Bilder',
        body: 'Manche Astro-Themes verweisen für Icons oder Bibliotheken auf westliche CDNs (jsDelivr, unpkg). Wir leiten alles über ein chinesisches CDN um oder bündeln die Assets in den Build. Bilder werden aus Aliyun OSS oder Tencent COS in modernen Formaten ausgeliefert.',
      },
      {
        icon: 'blocks',
        title: 'Skripte von Drittanbietern',
        body: 'Alles, was einen blockierten Dienst anpingt, fliegt raus oder wird ersetzt. Karten, Schriften, Analytics, Captchas und Einbettungen bekommen jeweils einen China-tauglichen Ersatz, schon während des Builds, bevor das statische Ergebnis überhaupt ausgeliefert wird.',
      },
    ],
  },
  {
    label: 'Integrationen & CMS',
    accent: 'orange',
    items: [
      {
        icon: 'plug',
        title: 'Headless-CMS, wo es nötig ist',
        body: 'Wenn das Redaktionsteam eine visuelle Oberfläche braucht, binden wir Storyblok, Sanity, Decap oder ein headless betriebenes WordPress an. Das CMS liegt außerhalb Chinas, der Inhalt synchronisiert sich zur Build-Zeit, und die statische Website liegt auf einem Server im Festland.',
      },
      {
        icon: 'card',
        title: 'Formulare und Widgets',
        body: 'Formulare laufen als Astro Islands. Aus Google reCAPTCHA wird ein chinesisches Captcha. Aus Google Maps wird Baidu Map oder Amap. Die interaktiven Teile funktionieren weiter, ohne externe Abhängigkeiten.',
      },
      {
        icon: 'chart',
        title: 'Analytics',
        body: 'Vercel Analytics oder Plausible weicht Baidu Tongji oder einem selbst gehosteten Werkzeug. Dieselben Dashboards, die Ihr Team braucht, keine blockierten Endpunkte.',
      },
    ],
  },
  {
    label: 'Hosting & Build',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hosting',
        body: 'Server in Festlandchina, gültige ICP-Registrierung auf der Domain. Aliyun, Tencent Cloud oder Huawei Cloud, davor ein chinesisches CDN. Das eigene CDN von Cloudflare läuft auf dem Festland nicht gut, deshalb deployen wir dort nicht.',
      },
      {
        icon: 'refresh',
        title: 'Build-Pipeline',
        body: 'Der Build läuft außerhalb Chinas auf einer CI-Pipeline (GitHub Actions, GitLab CI). Das statische Ergebnis wird auf den chinesischen Host geschoben. Ein Push auf main, und die Website aktualisiert sich binnen weniger Minuten.',
      },
      {
        icon: 'shield',
        title: 'Sicherheitslage',
        body: 'Keine Datenbank, kein PHP-Runtime, kein Admin-Login. Die Sicherheitsarbeit verlagert sich auf die Build-Pipeline und den Edge der chinesischen Cloud, statt auf ein Runtime, das jede Woche gepatcht werden will.',
      },
    ],
  },
  {
    label: 'Performance & SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'Statisches HTML auf einem CDN im Festland ist schwer zu schlagen. Wir zielen auf einen ersten sichtbaren Seiteninhalt unter einer Sekunde auf einem chinesischen Mittelklasse-Telefon, und meistens treffen wir das.',
      },
      {
        icon: 'search',
        title: 'Baidu und KI-Suche',
        body: 'Baidu crawlt nach anderen Regeln als Google. Deshalb stellen wir die Metadaten sauber ein, richten die Baidu Webmaster Tools ein und strukturieren die Website so, dass Doubao, Kimi, DeepSeek und Wenxin sie lesen und zitieren können. Reine Dateien in Git machen strukturierte Daten und die llms.txt leicht erzeugbar.',
      },
    ],
  },
];

const fitBuckets = [
  {
    eyebrow: 'Astro passt',
    title: 'Marketing-Websites mit leichter Interaktivität',
    body: 'Eine Marketing-Website mit einer kleinen Produktvitrine, einem Kontaktformular oder ein paar interaktiven Widgets ist genau das, wofür Astro gebaut wurde. Statische Seiten, schnelle Ladezeiten, JavaScript nur dort, wo es sein muss.',
  },
  {
    eyebrow: 'WordPress passt besser',
    title: 'E-Commerce und tägliche Redaktion',
    body: 'Tausende Produkte, die ein nicht technisches Team täglich pflegt, tiefe Plugin-Abhängigkeiten, Marketingteams, die mit einem Page-Builder arbeiten. Hier ist WooCommerce auf WordPress meist immer noch die richtige Wahl.',
  },
  {
    eyebrow: 'Ein ganz anderes Werkzeug',
    title: 'App-ähnliche Erlebnisse',
    body: 'Eingeloggte Dashboards, Zusammenarbeit in Echtzeit, soziale Bereiche, alles, was eher einer Anwendung als einer Website gleicht. Jenseits dieses Punktes passt Next.js oder Remix besser als Astro.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hosting' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hosting' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hosting' },
  { name: 'Baidu', cn: '百度', role: 'Suche & SEO' },
  { name: 'WeChat', cn: '微信', role: 'Login & Messaging' },
  { name: 'Alipay', cn: '支付宝', role: 'Zahlungen' },
];

const faqs = [
  {
    id: 'astro-icp',
    question: 'Braucht unsere Astro-Website eine ICP-Lizenz, um in China zu funktionieren?',
    answer: 'Wenn sie in Festlandchina gehostet wird, ja. Hosten Sie in Hongkong oder bei Cloudflare, dann nicht, aber die Website ist für Nutzer auf dem Festland messbar langsamer, und Baidu behandelt sie als ausländisch. Für Marken, die es mit dem chinesischen Markt ernst meinen, lohnt die ICP-Registrierung den Aufwand.',
  },
  {
    id: 'astro-marketing-team',
    question: 'Kann unser Marketingteam die Website weiterhin selbst aktualisieren?',
    answer: 'Das hängt davon ab, wie wir sie aufsetzen. Mit Markdown und Content Collections laufen Inhaltsänderungen über Git und brauchen einen Entwickler oder einen technisch versierten Nutzer. Mit angebundenem Headless-CMS (Storyblok, Sanity, Decap) bekommt das Redaktionsteam eine visuelle Oberfläche und aktualisiert die Website, ohne den Code anzufassen. Wir wählen das Modell nach der Art, wie das Team tatsächlich arbeitet.',
  },
  {
    id: 'astro-vs-wp-speed',
    question: 'Ist Astro in China wirklich schneller als WordPress?',
    answer: 'In nackten Zahlen, ja. Astro liefert statisches HTML mit nahezu null JavaScript aus, was die übertragene Datenmenge senkt, das Parsen beschleunigt und die Roundtrips zum Server verringert. Wir haben einen 40 bis 60 Prozent schnelleren Largest Contentful Paint auf Astro gemessen, verglichen mit einer ähnlichen WordPress-Website auf demselben chinesischen Host.',
  },
  {
    id: 'astro-headless-cms',
    question: 'Lässt sich ein Headless-CMS mit Astro nutzen?',
    answer: 'Ja, das ist eines der stärksten Muster von Astro. Wir haben Websites mit Storyblok, Sanity, Decap und headless betriebenem WordPress ausgeliefert. Das CMS liegt außerhalb Chinas, wo Redakteure ohne VPN-Probleme frei arbeiten, das statische Frontend liegt auf einem Server im Festland, der Inhalt synchronisiert sich zur Build-Zeit. Das Redaktionsteam behält die Oberfläche, die es kennt, und das chinesische Publikum bekommt eine schnelle Website.',
  },
  {
    id: 'astro-ecommerce',
    question: 'Was ist mit E-Commerce auf Astro?',
    answer: 'Für kleine bis mittlere Sortimente (unter fünfhundert Produkte) verträgt sich Astro gut mit Headless-Commerce: Shopify Storefront, Snipcart oder Stripe Checkout für internationale Zahlungen, dazu eigene Integrationen für Alipay und WeChat Pay für chinesische Verbraucher. Für großen E-Commerce mit Tausenden Produkten und einem nicht technischen Team, das den Lagerbestand täglich pflegt, ist WooCommerce auf WordPress meist immer noch die richtige Wahl.',
  },
  {
    id: 'astro-multilingual',
    question: 'Wie geht Astro mit mehrsprachigen Inhalten für China um?',
    answer: 'Astro bringt i18n-Routing von Haus aus mit, was Chinesisch neben Englisch, Französisch oder jeder anderen Sprache sauber und strukturiert macht. URLs, hreflang-Tags und sprachspezifische Sitemaps funktionieren sofort. Wir haben Astro-Websites mit zehn oder mehr Sprachen ausgeliefert.',
  },
  {
    id: 'astro-migrate-wp',
    question: 'Können wir unsere bestehende WordPress-Website auf Astro migrieren?',
    answer: 'Ja, und das machen wir regelmäßig. Der Inhalt wird aus WordPress exportiert, in Astro Content Collections neu strukturiert oder über ein Headless-CMS geführt, und das Design für den neuen Stack neu aufgebaut. Der übliche Zeitrahmen liegt bei vier bis acht Wochen. Das Ergebnis ist eine schnellere Website mit niedrigeren Betriebskosten, aber die WordPress-Admin-Oberfläche fällt weg, sofern wir sie nicht als Headless-Backend behalten.',
  },
  {
    id: 'astro-hosting',
    question: 'Welches Hosting nutzen Sie für Astro in China?',
    answer: 'Wir hosten je nach Projekt auf Aliyun, Tencent Cloud oder Huawei Cloud. Der Build läuft außerhalb Chinas auf einer CI-Pipeline, das statische Ergebnis wird auf den chinesischen Host geschoben, davor ein CDN im Festland. Wir kümmern uns um das Hostingkonto, die ICP-Registrierung und die Deployment-Pipeline, damit sich Ihr Team nie selbst in ein chinesisches Hosting-Panel einloggen muss.',
  },
  {
    id: 'astro-maintenance',
    question: 'Wie viel Pflege braucht eine Astro-Website?',
    answer: 'Weniger als eine WordPress-Website, und zwar deutlich. Es gibt keine Datenbank, die gesichert werden muss, keine Plugins, die aktuell zu halten sind, keine PHP-Versionen, die ein Upgrade brauchen, keine Sicherheitspatches, die alle zwei Wochen eintreffen. Das Framework selbst wird ein paar Mal im Jahr aktualisiert, die Abhängigkeiten verlangen hin und wieder eine Durchsicht, und das war es ungefähr. Für die meisten Marketing-Websites genügt eine vierteljährliche Wartungsrunde.',
  },
  {
    id: 'astro-cloudflare',
    question: 'Was ist mit der Übernahme von Astro durch Cloudflare? Ändert das etwas für China?',
    answer: 'Es ändert etwas, und es ändert nichts. Das tiefere Engagement von Cloudflare bedeutet, dass hinter Astro nun ein Infrastrukturkonzern mit dreißig Milliarden Dollar Bewertung steht, ein echtes Vertrauenssignal für Kunden, die sich um die langfristige Tragfähigkeit sorgen. Das Framework selbst bleibt MIT-lizenziert und überall deploybar, auch bei chinesischen Cloud-Anbietern. Das eigene CDN von Cloudflare läuft auf dem Festland nicht gut, doch Astro-Websites lassen sich weiterhin auf Aliyun oder Tencent Cloud deployen, ohne dass eine Funktion verloren geht.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de">

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-astro-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrumennavigation" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Astro</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <!-- Astro logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--color-brand-orange)] to-[#EF4444] flex items-center justify-center shadow-[0_8px_30px_rgba(242,95,41,0.4)]">
              <svg class="h-8 w-auto text-white" viewBox="0 0 85 107" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Astro logo">
                <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z"/>
                <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-[var(--color-brand-orange)] ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/25">
              <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">Framework · Astro</span>
            </div>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Astro in China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Auf Tempo gebaut.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Das moderne Frontend-Framework für inhaltsgetriebene Websites. Statisch zuerst, JavaScript nahe null und besonders schonend zu langsamen chinesischen Mobilfunknetzen.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            Seit Januar 2026 von Cloudflare getragen. Wir bauen Astro genauso wie WordPress, deshalb können wir offen sagen, was wann passt.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/de/kontakt/" variant="primary" size="lg">Mit unserem Team sprechen</Button>
            <Button href="/de/wordpress/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">WordPress für China</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">astro-china-build</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Lighthouse</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100 / 100</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">JS ausgeliefert</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">~0 KB</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Edge</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aliyun</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP-Registrierung</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Eingereicht</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
