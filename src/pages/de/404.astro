---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
---

<PageLayout
  title="Seite nicht gefunden | ChinaWebFoundry"
  description="Diese Seite existiert nicht mehr oder wurde verschoben. Gehen Sie zurück zur Startseite oder entdecken Sie, wie wir internationale Marken in China sichtbar machen."
  lang="de"
>
  <section class="section-spacing">
    <Container class="text-center">
      <h1 class="text-6xl font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)] mb-4">404</h1>
      <p class="text-xl text-[var(--color-text-dark)] font-[var(--font-heading)] mb-2">Seite nicht gefunden</p>
      <p class="text-[var(--color-text-body)] mb-8">Diese Adresse führt ins Leere. Womöglich wurde sie verlegt oder ist nicht mehr verfügbar.</p>
      <Button href="/de/" variant="primary" size="lg">Zurück zur Startseite</Button>
    </Container>
  </section>
</PageLayout>
