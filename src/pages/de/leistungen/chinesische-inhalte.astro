---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'chinese-content'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

// Was zu schreiben ist: 5 Unterschiede mit gepaarten "Standard vs. Realität"-Daten
const differences = [
  {
    n: '01',
    cn: '信任',
    title: 'Die Vertrauenssignale sind andere',
