  {
    label: 'Vertrauens- und Beleginhalte',
    cn: '品牌背书',
    body: 'Fallstudien, Kundengeschichten, Partnerprofile, Ankündigungen von Auszeichnungen, Medienerwähnungen.',
  },
  {
    label: 'Conversion-Inhalte',
    cn: '转化页面',
    body: 'Landingpages für bezahlte Medien, Lead-Magnete, geschützte Whitepaper, Kontaktformulare.',
  },
  {
    label: 'Inhalte für das WeChat-Ökosystem',
    cn: '微信生态',
    body: 'Texte für H5-Mini-Sites, Mini-Programm-Inhalte, Briefings für Artikel von Offiziellen Accounts.',
  },
];

const stages = [
  {
    n: '01',
    cn: '调研',
    title: 'Discovery und Kategorierecherche',
    body: 'Wir prüfen 3 bis 5 direkte Wettbewerber von Anfang bis Ende und verfolgen das Kategoriegespräch auf Baidu, Zhihu (知乎) und einschlägigen Branchenseiten. Daraus entsteht eine schriftliche Content-Strategie, die benennt, was Ihre Marke sagen sollte, was sie auslassen sollte und wo der freie Raum liegt.',
    output: 'Content-Strategie-Dokument',
  },
  {
    n: '02',
    cn: '架构',
    title: 'Informationsarchitektur',
    body: 'Wir entwerfen Sitemap und Seitenhierarchie für chinesische Leser und bauen dabei die Vertrauensseiten, die redaktionellen Flächen und die Baidu-freundliche URL-Struktur ein. Geliefert wird das Ganze als schriftliches IA-Dokument, damit Design und Entwicklung wissen, worauf sie hinarbeiten.',
    output: 'IA-Dokument + Sitemap',
  },
  {
    n: '03',
    cn: '撰写',
