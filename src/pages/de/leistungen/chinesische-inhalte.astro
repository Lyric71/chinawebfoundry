const audiences = [
  {
    label: 'Marken, die zum ersten Mal in China starten',
    description: 'Unternehmen, die die grundlegenden Content-Entscheidungen richtig treffen müssen: was zu sagen ist, wie es zu strukturieren ist, wer man im chinesischen Markt ist.',
