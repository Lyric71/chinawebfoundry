    westernLabel: 'Hero mit 3 Stichpunkten',
    westernSub: '"Build better. Faster. Together."',
    chineseLabel: 'Dichtes Vertrauenspanel',
    chineseSub: 'Gegründet · Werk · Partner · Auszeichnungen · Medien',
