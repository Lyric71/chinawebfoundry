---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';

// Phasen und Servicedaten aus den einzelnen Serviceseiten
const phases = [
  {
    id: 'plan',
    label: 'Planen',
    cn: '策略',
    title: 'Erst entscheiden, was gebaut wird, dann bauen',
    blurb: 'Wir prüfen Ihren Bestand und ermitteln, was Ihr chinesisches Publikum tatsächlich benötigt. Das Ergebnis ist ein Fahrplan, der Sie in der richtigen Reihenfolge zu einer tragfähigen China-Präsenz führt.',
  },
  {
    id: 'build',
    label: 'Bauen',
    cn: '搭建',
    title: 'Die Technik neu aufsetzen, für das Leben hinter der Firewall',
    blurb: 'Migration, Design, technische Integration und eigene Plugins: Jede Schicht entsteht neu und durchläuft Tests über echte Verbindungen aus China.',
  },
  {
    id: 'host',
    label: 'Hosten',
    cn: '主机',
    title: 'Hosting, das auf dem chinesischen Festland wirklich funktioniert',
    blurb: 'Ladezeiten unter einer Sekunde auf Shanghaier Smartphones, eine ICP-Registrierung von Anfang bis Ende in unserer Hand und die Wahl zwischen Festland, Hongkong und Dual-Stack.',
  },
  {
    id: 'grow',
    label: 'Wachsen',
    cn: '增长',
    title: 'Auf Baidu gefunden, von chinesischen KI-Systemen zitiert',
    blurb: 'Muttersprachliche chinesische Inhalte, ein von China aus gesteuertes Baidu-SEO und Sichtbarkeit in den KI-Suchen DeepSeek, Doubao, Kimi, Yuanbao und Baidu AI.',
  },
  {
    id: 'run',
    label: 'Betreiben',
    cn: '维护',
    title: 'Jede Woche jemand, der von innen mitschaut',
    blurb: 'Redaktioneller Takt, SEO- und GEO-Nachverfolgung, technische Wartung und Hosting, betreut von einem Team mit einer Rechnung, überwacht aus Shanghai.',
  },
];

// Vorzeige-Service: Strategie und Audit
const strategy = {
  title: 'Strategie und Audit',
  cn: '策略',
  tagline: 'Ein schriftlicher Fahrplan, den Sie zu jeder Agentur mitnehmen können.',
  description: 'Wir rufen Ihre Website über echte Browser in Peking, Shanghai und Shenzhen auf und sehen, was tatsächlich geschieht. Markenpositionierung, Sichtbarkeit in der Suche, Technologie-Stack, WeChat-Präsenz und Compliance: Wir erfassen jeden dieser Punkte und erstellen den Fahrplan, der Sie in der richtigen Reihenfolge zum Start führt.',
  link: '/de/leistungen/strategie-audit/',
  cta: 'Mit der Strategie beginnen',
  deliverables: [
    'China-Readiness-Diagnose über Inhalte, UX, Suche, Performance und Compliance',
    'Strategische Positionierung, abgestimmt auf chinesische Vertrauenssignale',
    'Technologiearchitektur: WordPress oder Astro, Mini-Programm oder H5, Dual-Stack',
    'Sequenzierter Fahrplan, ICP-Registrierung auf dem kritischen Pfad eingeplant',
  ],
  stats: [
    { value: '15+', label: 'Jahre in Shanghai' },
    { value: '50+', label: 'Marken gestartet' },
    { value: '3-4 Wo.', label: 'bis zur Lieferung' },
  ],
};

// Services der Phase Bauen
const buildServices = [
  {
    title: 'China-Migration',
    cn: '迁移',
    tagline: 'Eine echte China-Migration ist ein Neustart.',
    description: 'Wir verlagern Inhalte, Nutzerführung und Hosting im Verbund. Die Vertrauenssignale werden neu formuliert, das Layout auf chinesische Lesegewohnheiten umgestellt und die Infrastruktur auf Festlandserver verlegt, während der ICP-Antrag parallel läuft.',
    link: '/de/leistungen/china-migration/',
    cta: 'Über Ihre Migration sprechen',
    icon: 'migration',
    deliverables: [
      'Inhalte von muttersprachlichen Redakteuren auf Chinesisch neu geschrieben',
      'UX überarbeitet für dichtere Seiten und den WeChat-Browser',
      'Umstellung ohne Ausfallzeit, Rückweg innerhalb von 48 Stunden',
      'URL-Mapping und 301-Weiterleitungen, damit die SEO-Autorität erhalten bleibt',
    ],
    stats: [
      { value: '50+', label: 'Marken migriert' },
      { value: '6-10 Wo.', label: 'typischer Zeitraum' },
    ],
  },
  {
    title: 'UX/UI-Design',
    cn: '设计',
    tagline: 'Design für die Art, wie Chinesen tatsächlich navigieren.',
    description: 'Mobile zuerst, dichte Layouts, abgestimmt auf die Bediengewohnheiten, die chinesische Nutzer aus WeChat, Taobao und Douyin mitbringen. Sehr luftige Designs wirken auf dieses Publikum leer. Vertrauenssignale gehören oberhalb der Falzlinie.',
    link: '/de/leistungen/ux-ui-design/',
    cta: 'Ihr Designprojekt starten',
    icon: 'design',
    deliverables: [
      'Nutzerforschung zu den Einstiegswegen über Douyin, WeChat und Baidu',
      'Informationsarchitektur, gebaut für dichtere Seiten',
      'WeChat-QR, ICP und Gewerbelizenz über der Falzlinie platziert',
      'QA über UC Browser, QQ Browser und Chrome',
    ],
    stats: [
      { value: '70%+', label: 'mobiler Traffic in China' },
      { value: '6', label: 'Browser nativ geprüft' },
    ],
  },
  {
    title: 'Technische Integration',
    cn: '技术',
    tagline: '2 Sekunden im Westen werden zu 15 in Shenzhen.',
    description: 'Serverkonfiguration, Theme-Bereinigung, Austausch blockierter Abhängigkeiten sowie die Anbindung von WeChat Pay, Alipay und Baidu Tongji: Der gesamte Stack entsteht neu und wird über echte chinesische Netze in Shanghai und Shenzhen geprüft.',
    link: '/de/leistungen/technische-integration/',
    cta: 'Technische Beratung vereinbaren',
    icon: 'technical',
    deliverables: [
      'Aliyun-, Tencent- oder Huawei-Tuning je nach Anbieter',
      'WeChat Pay, Alipay, WeChat-Login, Baidu Tongji integriert',
      'Google Fonts ersetzt, jQuery umgeleitet, blockierte APIs ausgetauscht',
      'Architektur nach PIPL und Cybersicherheitsgesetz ab dem ersten Tag',
    ],
    stats: [
      { value: '47', label: 'blockierte Ressourcen pro Website' },
      { value: '2,1 s', label: 'Ladezeit nach den Korrekturen' },
    ],
  },
  {
    title: 'Plugins und Erweiterungen',
    cn: '插件',
    tagline: 'WordPress-Plugins, gebaut für die Firewall.',
    description: 'Rund 40 % der gängigen WordPress-Plugins sind von Google abhängig und hinter der Firewall durchgängig blockiert. Wir entwickeln die Erweiterungen, die laufen, und ertüchtigen jene, die sich retten lassen.',
    link: '/de/leistungen/plugins-erweiterungen/',
    cta: 'Plugin-Beratung anfragen',
    icon: 'plugins',
    deliverables: [
      'WeChat-OAuth, Brücken zu Mini-Programmen, Verknüpfung mit Offiziellen Accounts',
      'Alipay, WeChat Pay, UnionPay als WooCommerce-Erweiterungen',
      'Baidu-Sitemap, Push-API und Werkzeuge für Meta-Tags',
      'Eigene Gutenberg-Blöcke: WeChat-QR, Baidu-Karten, Bilibili',
    ],
    stats: [
      { value: '60 %', label: 'der Plugins direkt reparierbar' },
      { value: 'UC', label: 'Browser-QA inbegriffen' },
    ],
  },
];

// Phase Hosten: Vorzeige-Hostingkarte
const hosting = {
  title: 'China-Hosting',
  cn: '主机',
  tagline: 'ICP-lizenziert, schnell und durchgehend betreut.',
  description: 'Ihre Website lädt in China vermutlich nur schwer. Ladezeiten von 10 bis 15 Sekunden sind bei internationalen Seiten der Normalfall, verursacht durch gedrosselten Traffic, blockierte CDNs und Google Fonts, die sich nicht auflösen lassen. Wir setzen deshalb auf der Infrastrukturebene an.',
  link: '/de/leistungen/china-hosting/',
  cta: 'Hosting-Optionen ansehen',
  options: [
    {
      name: 'Chinesisches Festland',
      timeframe: '6-10 Wochen',
      bullets: ['Ladezeiten unter 1 s auf chinesischen Smartphones', 'Voraussetzung für den Baidu-Schub', 'ICP-Lizenz von Anfang bis Ende übernommen'],
    },
    {
      name: 'Hongkong',
      timeframe: '2-3 Wochen',
      bullets: ['2 bis 4 s Ladezeit vom Festland', 'Kein ICP nötig', 'Schneller Start, geringer Baidu-Schub'],
    },
    {
      name: 'Dual-Stack',
      timeframe: '8-12 Wochen',
      bullets: ['Weltweit und China parallel', 'Eine einzige redaktionelle Pipeline', 'Geo-Routing am Edge'],
    },
  ],
  stats: [
    { value: '0,8 s', label: 'mittlere Ladezeit auf dem Festland' },
    { value: '99,97 %', label: 'Verfügbarkeit, 30 Tage rollierend' },
    { value: '100 %', label: 'Erfolgsquote bei der ICP-Registrierung' },
  ],
};

// Services der Phase Wachsen
const growServices = [
  {
    title: 'Chinesische Inhalte',
    cn: '内容',
    tagline: 'Redakteure, die auf Chinesisch und in Ihrer Markenstimme schreiben.',
    description: 'Muttersprachliche chinesische Autoren bringen Ihre Botschaften in jene Reihenfolge, nach der chinesische Leser tatsächlich entscheiden: zuerst der Beleg, dann die Glaubwürdigkeit und zuletzt der eigentliche Anspruch.',
    link: '/de/leistungen/chinesische-inhalte/',
    cta: 'Mit dem Content-Team sprechen',
    icon: 'content',
    deliverables: [
      'Content-Strategie auf Basis eines Audits von Baidu, Zhihu und Branche',
      'Vertrauensseiten, die westliche Sites übersehen: 荣誉资质, 企业历程, 生产基地',
      'Muttersprachliches Schreiben auf Chinesisch in Ihrer Markenstimme',
      'Aussagen nach 广告法 für Medizin, Finanzen, Lebensmittel und Kosmetik',
    ],
    stats: [
      { value: '9 s', label: 'bevor übersetzte Texte abprallen' },
      { value: '50+', label: 'Marken gestartet' },
    ],
  },
  {
    title: 'Baidu-SEO',
    cn: '百度',
    tagline: 'Baidu hat einen eigenen Crawler, eine eigene API und einen eigenen Algorithmus-Zyklus.',
    description: 'Wir betreiben Baidu-SEO direkt aus China, mit den hauseigenen Werkzeugen von Baidu und Fachleuten, die 百度搜索资源平台 Woche für Woche verfolgen.',
    link: '/de/leistungen/baidu-seo/',
    cta: 'Baidu-Audit anfragen',
    icon: 'seo',
    deliverables: [
      '主动推送-API direkt ins CMS eingebunden für die Einreichung in Echtzeit',
      'Muttersprachliche chinesische Keyword-Recherche aus dem Baidu Index',
      'Autoritätsarbeit auf 百度百科, 百度知道 und 百家号',
      'Wöchentliches Tracking der Updates von 知心算法 und 飓风算法',
    ],
    stats: [
      { value: '24-72 h', label: 'Indexierung über 主动推送' },
      { value: '6-10 Wo.', label: 'Bewegung im Long Tail' },
    ],
  },
  {
    title: 'GEO China',
    cn: '智搜',
    tagline: 'Von KI-Suchmaschinen zitiert werden.',
    description: 'Generative Engine Optimization für DeepSeek, Doubao, Kimi, Yuanbao und Baidu AI. Fünf Engines folgen fünf eigenen Regelwerken, und Ihre Website muss vor jedem einzelnen bestehen.',
    link: '/de/leistungen/geo/',
    cta: 'KI-Sichtbarkeitsaudit anfordern',
    icon: 'ai',
    deliverables: [
      'Fragenmatrix mit 80 bis 150 Fragen, auf echten Geräten in drei Städten getestet',
      'Quellenstufen-Audit T1 / T2 / T3 gegen die Ranking-Signale der KI',
      'Pfeilerinhalte mit FAQ-, Vergleichs- und Szenario-Clustern',
      'Verbreitung über Baijiahao, Zhihu, Toutiao und Baidu Baike',
    ],
    stats: [
      { value: '600 Mio.+', label: 'chinesische KI-Nutzer' },
      { value: '6 Mon.', label: 'bis zum Zitations-Anstieg' },
    ],
  },
];

// Phase Betreiben: Vorzeige-Wartungskarte
const maintenance = {
  title: 'Wartung und Support',
  cn: '维护',
  tagline: 'Eine laufende China-Website braucht jemanden, der von innen mitschaut.',
  description: 'Der Start ist der leichtere Teil. Baidu lässt Seiten im Ranking fallen, sobald sie nicht mehr veröffentlichen, DeepSeek und Doubao ändern ihre Crawling-Logik im Abstand weniger Wochen, und eine im Theme übersehene Google Font kann am Dienstag plötzlich blockiert sein. Von London oder Chicago aus betrachtet wirkt unterdessen alles in bester Ordnung.',
  link: '/de/leistungen/wartung-support/',
  cta: 'Individuelles Angebot anfragen',
  deliverables: [
    '2 bis 4 Inhalte pro Monat, verbreitet über Baijiahao und Zhihu',
    'Monatliche Baidu-Ranking-Berichte zu den 30 bis 50 wichtigsten Keywords',
    'Wöchentliche GEO-Sichtbarkeitsprüfungen über DeepSeek, Doubao, Kimi, Yuanbao, Baidu AI',
    'Core-, Plugin- und Theme-Updates, zuerst auf Staging getestet',
    'Erkennung von Firewall-Blockaden: CDN-, Schrift- und API-Ausfälle in rund 14 Minuten behoben',
    'Reaktion auf Hacks: isolieren, säubern, wiederherstellen, härten, Post-mortem in 48 h',
  ],
  stats: [
    { value: '11', label: 'Baidu-Algo-Änderungen in 2025' },
    { value: '14 Min.', label: 'von Blockade bis Behebung im Schnitt' },
    { value: '99,9 %', label: 'Verfügbarkeits-SLA' },
  ],
};
---

<PageLayout
  title="Web-Services in China für internationale Marken | ChinaWebFoundry"
  description="Alles, was eine internationale Marke braucht, um eine Website in China aufzubauen, zu starten und wachsen zu lassen. Von der Strategie bis zur Wartung, geliefert von einem festen Senior-Team in Shanghai seit 2005."
  heroPage={true}
  lang="de"
>
  <!-- ============== HERO ============== -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <video
        class="absolute inset-0 w-full h-full object-cover"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        poster="/images/hero-services.webp"
        aria-hidden="true"
      >
        <source src="/images/Video/great-wall-services-bg.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/92 via-[#0f0f12]/75 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-28 lg:pb-32">
      <div class="io-grid items-end gap-y-10">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-5">
            Unsere Leistungen
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.06]">
            Eine China-Präsenz,<br />durchgängig aufgebaut.
          </h1>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9">
          <p class="text-lg text-white/65 leading-relaxed">
            Eine in China ansässige Agentur, die jede Ebene abdeckt, damit Ihre Website hinter der Großen Firewall startet, läuft und sichtbar bleibt, unabhängig davon, auf welchem Stack Sie arbeiten.
          </p>
          <div class="mt-7">
            <Button href="/de/kontakt/" variant="primary" size="md">Sagen Sie uns, was Sie brauchen</Button>
          </div>
        </div>
      </div>
    </div>

    <!-- Navigationspillen nach Phase -->
    <div class="relative border-t border-white/10 bg-[#0f0f12]/60 backdrop-blur-sm">
      <div class="mx-auto max-w-[1400px] section-padding py-5">
        <nav class="flex flex-wrap items-center gap-x-2 gap-y-2 justify-center lg:justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-white/40 mr-2 hidden lg:inline">
            Zu einer Phase springen
          </span>
          <div class="flex flex-wrap gap-2">
            {phases.map((phase) => (
              <a
                href={`#${phase.id}`}
                class="group inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/15 text-white/80 hover:border-[var(--color-brand-orange)] hover:text-white hover:bg-[var(--color-brand-orange)]/10 transition-all duration-200 text-sm font-medium font-[var(--font-button)] no-underline"
              >
                <span class="text-[var(--color-brand-orange)] text-xs font-normal">{phase.cn}</span>
                <span>{phase.label}</span>
              </a>
            ))}
          </div>
        </nav>
      </div>
    </div>
  </section>

  <!-- ============== INTRO ============== -->
  <section class="py-20 md:py-24 lg:py-28">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid gap-y-8">
        <div class="col-span-12 lg:col-span-5">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-4">
            Was wir tun
          </p>
          <h2 class="text-3xl lg:text-[40px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15]">
            Die meisten ausländischen Websites sind in China kaputt.
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-6">
            Blockierte Abhängigkeiten, Seiten, die nie vollständig laden, ein Baidu, das nichts indexieren kann, KI-Assistenten, die Ihre Konkurrenz statt Ihrer Marke zitieren: Diese Probleme beheben wir seit über 15 Jahren von China aus, verteilt auf 10 ineinandergreifende Leistungen.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Wir haben diese Leistungen in 5 Phasen der Zusammenarbeit gebündelt, sodass Sie das Passende finden, ohne sich durch 10 Broschüren arbeiten zu müssen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== PHASE PLAN ============== -->
  <section id="plan" class="bg-[var(--color-surface-light)] py-20 md:py-24 lg:py-28 scroll-mt-20">
    <div class="mx-auto max-w-[1400px] section-padding">
      <!-- Phasenkopf -->
      <div class="flex items-baseline gap-4 mb-12 lg:mb-14 pb-6 border-b border-[var(--color-surface-border)]">
        <span class="text-2xl lg:text-3xl font-light text-[var(--color-brand-orange)] font-[var(--font-heading)]">{phases[0].cn}</span>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Phase eins</p>
        <h2 class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
          {phases[0].label}
        </h2>
      </div>

      <!-- Vorzeigekarte Strategie -->
      <a
        href={strategy.link}
        class="group block bg-white border border-[var(--color-surface-border)] rounded-3xl overflow-hidden no-underline transition-all duration-300 hover:shadow-[0_20px_50px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
      >
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-0">
          <!-- Links: Text -->
          <div class="lg:col-span-7 p-8 md:p-10 lg:p-14">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-xl font-light text-[var(--color-brand-orange)]">{strategy.cn}</span>
              <span class="h-px w-12 bg-[var(--color-brand-orange)]"></span>
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)]">
                {strategy.tagline}
              </p>
            </div>
            <h3 class="text-3xl lg:text-[40px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-5">
              {strategy.title}
            </h3>
            <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
              {strategy.description}
            </p>

            <!-- Leistungen -->
            <ul class="space-y-3 mb-8">
              {strategy.deliverables.map((item) => (
                <li class="flex gap-3 text-[15px] text-[var(--color-text-body)]">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <span class="inline-flex items-center gap-2 text-base font-medium font-[var(--font-button)] text-[var(--color-brand-orange-text)] group-hover:gap-3 transition-all duration-200">
              {strategy.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>

          <!-- Rechts: Zahlenpanel -->
          <div class="lg:col-span-5 bg-[var(--color-surface-dark)] p-8 md:p-10 lg:p-14 flex flex-col justify-center">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-orange)] mb-8">
              In Zahlen
            </p>
            <div class="space-y-8">
              {strategy.stats.map((stat) => (
                <div class="border-b border-white/10 pb-6 last:border-0 last:pb-0">
                  <p class="text-4xl lg:text-5xl font-medium font-[var(--font-heading)] text-white mb-1">{stat.value}</p>
                  <p class="text-sm text-white/55">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============== PHASE BUILD ============== -->
  <section id="build" class="py-20 md:py-24 lg:py-28 scroll-mt-20">
    <div class="mx-auto max-w-[1400px] section-padding">
      <!-- Phasenkopf -->
      <div class="flex items-baseline gap-4 mb-12 lg:mb-14 pb-6 border-b border-[var(--color-surface-border)]">
        <span class="text-2xl lg:text-3xl font-light text-[var(--color-brand-orange)] font-[var(--font-heading)]">{phases[1].cn}</span>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Phase zwei</p>
        <h2 class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
          {phases[1].label}
        </h2>
      </div>

      <!-- 2x2-Raster der Bau-Services -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7">
        {buildServices.map((service) => (
          <a
            href={service.link}
            class="group flex flex-col bg-white border border-[var(--color-surface-border)] rounded-2xl p-7 lg:p-9 no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
          >
            <div class="flex items-start justify-between mb-6">
