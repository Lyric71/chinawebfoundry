---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'china-migration'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const layers = [
  {
    label: 'Inhalte',
    title: 'Inhalte für chinesische Zielgruppen neu geschrieben',
    body: 'Muttersprachliche chinesische Autoren schreiben Ihre Botschaft neu, mit den Vertrauenssignalen und Belegen, nach denen chinesische Nutzer zuerst suchen.',
    iconPath: 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10',
  },
  {
    label: 'UX',
    title: 'UX für chinesische Gewohnheiten überarbeitet',
    body: 'Chinesische Nutzer überfliegen eine Seite anders. Wir gestalten fürs Handy zuerst, verdichten die Information und prüfen im WeChat-Browser. Die Vertrauenssignale stehen dort, wo chinesische Nutzer sie erwarten; an der Markenidentität ändern wir nichts.',
    iconPath: 'M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3',
  },
  {
    label: 'Hosting',
    title: 'Hosting und Infrastruktur nach China verlegt',
    body: 'Wir übernehmen die ICP-Registrierung von Anfang bis Ende und verlegen das Hosting auf Aliyun, Tencent oder Huawei Cloud. Blockierte Abhängigkeiten werden ersetzt, und die Baidu-Webmaster-Tools sind vom ersten Tag an eingebunden.',
    iconPath: 'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z',
  },
];

interface Scenario {
  timeline: string;
  title: string;
  lead: string;
  body: string;
  fit: string[];
  diagram: 'single' | 'swap' | 'parallel';
}

const scenarios: Scenario[] = [
  {
    timeline: '6 bis 10 Wochen',
    title: 'Ihre bestehende Website migrieren',
    lead: 'Ihre globale Website wird für den chinesischen Markt neu gebaut.',
    body: 'Wir schreiben die Inhalte neu, passen die UX an und verlegen das Hosting auf einen konformen Festland-Server. Ihre globale Website bleibt unverändert, auf welchem Stack auch immer Sie sie betreiben.',
    fit: [
      'Sie betreiben bereits eine globale Website, die funktioniert',
      'Sie wollen eine China-Präsenz, die endlich ankommt',
      'WordPress, Headless oder jeder andere Stack',
    ],
    diagram: 'single',
  },
  {
    timeline: '8 bis 14 Wochen',
    title: 'CMS-Wechsel als Teil des Umzugs',
    lead: 'Die Plattform wird ersetzt und der Umzug nach China in einem Zug erledigt.',
    body: 'Wir nehmen die Migration zum Anlass, das zu beheben, was auf der alten Website ohnehin nicht funktionierte, bevor die China-Anforderungen hinzukommen. Als Ausgangsplattform kommen Drupal, Sitecore, AEM, Webflow, Shopify oder eine Eigenentwicklung infrage.',
    fit: [
      'Ihr aktuelles CMS ist mühsam zu warten',
      'Sie wollen den Neubau und den China-Umzug gemeinsam erledigt haben',
      'Ein Neubau stand bei Ihnen ohnehin an',
    ],
    diagram: 'swap',
  },
  {
    timeline: '10 bis 16 Wochen',
    title: 'Zwei Websites parallel betreiben',
    lead: 'Eine globale Website und eine China-Website teilen sich eine redaktionelle Pipeline.',
    body: 'Ein Team steuert den redaktionellen Ablauf. Zwei sehr unterschiedliche Zielgruppen bekommen jeweils eine Website, die tatsächlich für sie gemacht ist.',
    fit: [
      'Ihre globale Marke und Ihre China-Marke leben unterschiedlich',
      'Sie wollen auf beiden Seiten die volle Kontrolle',
      'Sie können beide Teams ausstatten',
    ],
    diagram: 'parallel',
  },
];

const phases = [
  {
    label: 'Phase 1',
    title: 'Entdecken',
    steps: [
      {
        title: 'Analyse und Audit',
        body: 'Wir prüfen Website, Marke, Kategorie und die chinesische Konkurrenz in einem schriftlichen Audit und halten fest, was bleibt und was neu gebaut wird. Das dauert zwei bis drei Wochen.',
      },
      {
        title: 'Migrationsarchitektur',
        body: 'Hosting, CDN, DNS, Inhaltsstruktur und Weiterleitungen planen wir von Tag eins an für die Geschwindigkeit in China. Das dauert eine Woche.',
      },
    ],
  },
  {
    label: 'Phase 2',
    title: 'Bauen',
    steps: [
      {
        title: 'Inhalte neu schreiben und übertragen',
        body: 'Muttersprachliche chinesische Autoren schreiben die Texte neu, wo es nötig ist, übertragen den Rest sinngemäß und sichern die SEO-Autorität über von Hand zugeordnete URLs.',
      },
      {
        title: 'UX- und UI-Lokalisierung',
        body: 'Wir prüfen die Templates gegen chinesische Lesegewohnheiten und passen sie an, wo sie zu kurz greifen. Die Markenidentität bleibt, die Oberfläche wird lokalisiert.',
      },
      {
        title: 'Austausch von Integrationen',
        body: 'Wir tauschen Google Analytics, YouTube und Facebook-Pixel gegen Baidu Tongji, Youku oder Bilibili sowie WeChat- oder Weibo-Pendants aus und prüfen dabei jede einzelne Abhängigkeit.',
      },
      {
        title: 'Performance- und technische Optimierung',
        body: 'Wir ersetzen blockierte Schriften und CDNs, richten ein in China gültiges SSL-Zertifikat ein, stimmen alle Dateien auf die Festland-Netze ab und richten ein Baidu-freundliches SEO ein.',
      },
    ],
  },
  {
    label: 'Phase 3',
    title: 'Starten',
    steps: [
      {
        title: 'Tests aus China heraus',
        body: 'Wir testen über echte Verbindungen aus China, nicht über ein VPN: Ladegeschwindigkeit, Funktionalität, QQ- und UC-Browser sowie Mittelklasse-Android-Geräte, also genau die Bedingungen, unter denen Ihre Zielgruppe die Seite tatsächlich liest.',
      },
      {
        title: 'Umstellung ohne Ausfallzeit',
        body: 'Der Start ist auf die Stunde geplant. Das DNS wird live gesteuert, der Rückweg bleibt 48 Stunden offen, und wir bleiben durch die ersten Wochen hindurch erreichbar.',
      },
    ],
  },
];

