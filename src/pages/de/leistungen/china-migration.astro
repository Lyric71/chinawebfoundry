const audiences = [
  { label: 'Internationale Marken, die nach China kommen', description: 'Unternehmen, die ihre erste echte China-Präsenz starten, nachdem sie jahrelang eine übersetzte globale Website betrieben haben.', image: '/images/audiences/multinational-china-entry.webp' },
  { label: 'Marken, die eine Website neu starten, die nicht ankam', description: 'Die ursprüngliche China-Website ist live, hat aber nie funktioniert. Die Absprungrate ist hoch, die Leads bleiben aus, und die Zentrale fragt nach den Gründen. Diese Migration ist in Wahrheit ein Neustart.', image: '/images/audiences/agency-migration-clients.webp' },
  { label: 'E-Commerce-Marken', description: 'Marken, die einen China-fertigen Shop starten, mit den richtigen Integrationen für Zahlung, Logistik und Kundenservice ab dem ersten Tag.', image: '/images/audiences/ecommerce-china-store.webp' },
  { label: 'Medien und Verlage', description: 'Organisationen, die chinesische Zielgruppen richtig erreichen müssen, nicht über einen übersetzten Spiegel.', image: '/images/audiences/media-publishing-china.webp' },
