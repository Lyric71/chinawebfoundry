---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'geo'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const engines = [
  {
    n: '01',
    cn: '深度',
    name: 'DeepSeek',
    enLabel: '深度求索',
    body: 'Bevorzugt strukturierte, technisch einwandfreie Inhalte von offiziellen Websites. Lädt Ihre Seite aus China heraus langsam oder stützt sie sich auf Ressourcen, die die Große Firewall (防火长城) blockiert, sieht DeepSeek Sie schlicht nicht.',
    tag: 'Langform, strukturiert',
    chips: ['JSON-LD', 'SSR', 'Geschwindigkeit', 'Keine blockierten Abhängigkeiten'],
  },
  {
    n: '02',
    cn: '豆包',
    name: 'Doubao',
    enLabel: '字节跳动',
    body: 'Das Flaggschiff von ByteDance, das sich stark aus dem eigenen Ökosystem speist: Toutiao (今日头条), Douyin (抖音), Baijiahao (百家号). Für Doubao zu optimieren heißt, den ByteDance-Graphen parallel zu Ihrer Website zu füttern.',
    tag: 'ByteDance-Graph',
    chips: ['Toutiao', 'Douyin', 'Baijiahao', 'Verbreitung'],
  },
  {
    n: '03',
    cn: 'Kimi',
    name: 'Kimi',
    enLabel: 'Moonshot AI',
    body: 'Belohnt lange Analysen. Vergleiche, technische Leitfäden, Berichte über mehrere tausend Wörter mit sauberen Datentabellen. Kurze Marketingtexte bleiben unbeachtet.',
    tag: 'Tiefe und Tabellen',
    chips: ['Vergleiche', 'Leitfäden', 'Datentabellen', 'Langform'],
  },
  {
    n: '04',
    cn: '元宝',
    name: 'Yuanbao',
    enLabel: '腾讯混元',
    body: 'Das Tor von Tencent in das WeChat-Ökosystem (微信), und der einzige Assistent, der die Inhalte von WeChat Official Accounts (公众号) durchsuchen kann.',
    tag: 'WeChat-bewusst',
    chips: ['公众号', '视频号', 'Mini-Programm', 'WeCom'],
  },
  {
    n: '05',
    cn: '文心',
    name: 'Baidu AI',
    enLabel: '文心一言',
    body: 'Angetrieben von ERNIE (文心一言). Bevorzugt Quellen mit Autorität: Baidu Baike (百度百科), Behördenportale, JSON-LD-strukturierte Daten, dazu eine starke Stütze auf der Präsenz in Baijiahao und Baidu Zhidao (百度知道).',
    tag: 'Autoritätsgeführt',
    chips: ['百度百科', '百度知道', 'JSON-LD', 'Baijiahao'],
  },
];

const services = [
  {
    n: '01',
    title: 'Sichtbarkeitsdiagnose',
    body: 'Eine strukturierte Matrix aus 80 bis 150 Fragen über alle fünf chinesischen Plattformen, ausgeführt auf echten Geräten in Shanghai, Peking und Shenzhen, in Privat- und Firmennetzen, nie über VPN.',
    bullets: [
      'Zitationsrate: wie oft Ihre Marke in KI-Antworten auf relevante Fragen auftaucht.',
      'Empfehlungsrang: wo Sie stehen, wenn die Engine Optionen nennt.',
      'Sentiment: der Ton der Erwähnung, neutral, positiv oder kritisch.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Audit der Quellenstufen',
    body: 'KI-Engines belohnen überprüfbare Belege. Echte Patentnummern, Prüfberichte unabhängiger Labore, veröffentlichte Normen. Wir nennen das T1-Inhalte. Marketingtext ohne Beleg ist T3, wird ignoriert oder markiert. Wir erfassen jede Aussage auf Ihrer Website und bauen die schwachen mit Belegen neu auf, die die KI prüfen kann.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Aufbau von Content-Clustern',
    body: 'Einzelne Artikel bewegen nichts. Wir bauen Cluster: ein zentraler Pfeilertext, gestützt durch FAQ-Seiten, Vergleichsleitfäden, Szenario-Durchläufe, Fallstudien. Aus welchem Blickwinkel der Nutzer auch fragt, Ihre Website taucht auf.',
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Verbreitung über mehrere Plattformen',
    body: 'KI-Engines gleichen dieselbe Marke über vertrauenswürdige Ziele hinweg ab. Wir verbreiten auf Baijiahao (百家号), Zhihu (知乎), den passenden Branchenportalen und, wo es sinnvoll ist, in offiziellen Baidu-Baike-Einträgen (百度百科).',
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Technisches Fundament',
    body: 'JSON-LD-strukturierte Daten, robots.txt für Baiduspider, Sogouspider, ByteSpider, XML-Sitemaps, Canonical-Tags, die die Autorität nicht über die Sprachversionen verteilen. Die meisten internationalen Builds machen genau hier Fehler.',
    tag: 'p.28',
  },
  {
    n: '06',
    title: 'Laufende Überwachung',
    body: 'DeepSeek hat allein 2025 vier größere Überarbeitungen ausgeliefert. Was im Februar funktionierte, funktionierte im Mai nicht mehr. Wir verfolgen das wöchentlich und steuern nach, bevor die Zitationsraten abrutschen.',
    tag: 'p.34',
  },
];

const stages = [
  {
    n: '01',
    cn: '诊断',
    title: 'Sichtbarkeitsdiagnose',
    body: 'Wir führen die Fragenmatrix über alle fünf Engines auf echten Geräten in Shanghai, Peking und Shenzhen aus. Ergebnis: ein Basisbericht zur Zitation mit benannten Lücken je Plattform.',
    output: 'Zitations-Basislinie',
  },
  {
    n: '02',
    cn: '证据',
    title: 'Audit von Belegen und Quellen',
    body: 'Wir ordnen jede Aussage auf Ihrer Website T1, T2 oder T3 zu. Die schwachen bauen wir mit Patenten, Laborberichten, namentlich genannten Fachleuten und strukturierten Daten neu auf, die die Engines prüfen können.',
    output: 'Beleg-Karte',
  },
  {
    n: '03',
    cn: '内容',
    title: 'Cluster und Texte',
    body: 'Muttersprachliche chinesische Pfeilertexte, FAQs, Vergleichsleitfäden, Szenario-Durchläufe, Fallstudien. So gebaut, dass jeder Blickwinkel der Nutzerfrage auf Ihrer Website landet.',
    output: 'Cluster-Seiten live',
  },
  {
    n: '04',
    cn: '分发',
    title: 'Verbreiten und strukturieren',
    body: '百家号, 知乎, 百度百科 (wo reif), Branchenportale, dazu JSON-LD, robots.txt, llms.txt, Canonical und Sitemap-Arbeit gemeinsam ausgeliefert.',
    output: 'Präsenz über alle Graphen',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Überwachen und nachsteuern',
    body: 'Wöchentliche Neudurchläufe der Fragenmatrix über alle fünf Engines. Nachsteuern, bevor Modell-Updates als Zitationsabfall ankommen. Monatlicher schriftlicher Bericht.',
    output: 'Wöchentliches Tracking',
  },
];

const evidenceTiers = [
  {
    label: 'T1',
    title: 'Harte Belege',
    body: 'Patentnummern, Prüfberichte unabhängiger Labore, veröffentlichte Normen, offizielle Behördendaten.',
    weight: 100,
    color: 'green',
    examples: ['Patent CN10X', 'SGS-Bericht', 'GB/T-Norm', 'CNNIC-Daten'],
  },
  {
    label: 'T2',
    title: 'Von der Branche anerkannt',
    body: 'Berichterstattung der Fachpresse, Analystenberichte, namentlich genannte Fachmeinung, Branchenpreise.',
    weight: 60,
    color: 'amber',
    examples: ['36Kr', '艾瑞咨询', 'Genannte Fachperson', 'Branchenpreis'],
  },
  {
    label: 'T3',
    title: 'Marketingtext',
    body: 'Unbelegte Markenaussagen ohne externen Beweis. Werden ignoriert oder als unsicher markiert.',
    weight: 15,
    color: 'red',
    examples: ['"Best in class"', '"Marktführend"', 'Keine Quelle', 'Nur Slogan'],
  },
];

const stats = [
  { value: '600 Mio.+', label: 'KI-Nutzer in China · 2026', sub: 'CNNIC-Zählung der Nutzer generativer KI in China.' },
  { value: '20%+', label: 'Baidu-SERPs mit KI-Antworten', sub: '文心X1 und DeepSeek sind jetzt in den Ergebnissen eingebettet.' },
  { value: '4', label: 'DeepSeek-Überarbeitungen 2025', sub: 'Was im Februar funktionierte, funktionierte im Mai nicht mehr.' },
];

const audiences = [
  {
    label: 'Marken, die auf chinesischer KI unsichtbar sind',
    description: 'Unternehmen, deren Name nie fällt, wenn Käufer DeepSeek, Doubao oder Yuanbao nach Optionen in ihrer Kategorie fragen, während Wettbewerber zitiert und verlinkt werden.',
    image: '/images/audiences/audience-geo-invisible-on-ai.webp',
  },
  {
    label: 'Internationale Marken, die nach China starten',
    description: 'Teams, die KI-Sichtbarkeit von Tag eins in den Start einplanen wollen, statt sie sechs Monate später nachzurüsten, wenn die Traffic-Zahlen flach aussehen.',
    image: '/images/audiences/audience-geo-launching-china-market.webp',
  },
  {
    label: 'Marken mit Inhalten, aber ohne Belege',
    description: 'Websites mit durchdachten chinesischen Inhalten, die KI-Engines trotzdem ignorieren, weil den Aussagen die überprüfbaren Quellen, strukturierten Daten und die Bestätigung durch Dritte fehlen, die Zitate verdienen.',
    image: '/images/audiences/audience-geo-content-without-evidence.webp',
  },
  {
    label: 'Marken, deren organischer Traffic abflacht',
    description: 'Marketing-Teams, die bemerkt haben, dass der chinesische organische Traffic stagniert, weil Käufer auf KI-gestützte Recherche umsteigen, und die jetzt die Antwort sein wollen, nicht der Link, den niemand anklickt.',
    image: '/images/audiences/audience-geo-search-traffic-flat.webp',
  },
];

const marqueePhrases = [
  'GEO China',
  'DeepSeek', '深度求索',
  'Doubao', '豆包',
  'Kimi', '元宝',
  '文心一言',
  'Von KI zitiert',
  'T1-Belege',
  'JSON-LD',
  'llms.txt',
  '百家号 · 知乎 · 百度百科',
];

const faqs = [
  {
    id: 'difference-from-seo',
    question: 'Worin unterscheidet sich GEO von Baidu-SEO?',
    answer: [
      'Es überschneidet sich, ist aber nicht dasselbe. Baidu-SEO optimiert für die Baidu-Ergebnisseite, wo Nutzer noch zehn blaue Links überfliegen und klicken. GEO optimiert für KI-Assistenten, die Ihre Inhalte lesen und entscheiden, ob sie Sie in einer einzigen Antwort zitieren. Andere Ranking-Faktoren, andere Content-Struktur, andere Erfolgskennzahlen. Die meisten unserer Kunden betreiben beides als ein Mandat, weil die zugrunde liegende Content-Infrastruktur sich stark überschneidet.',
    ],
  },
  {
    id: 'platforms-covered',
    question: 'Welche chinesischen KI-Plattformen decken Sie tatsächlich ab?',
    answer: [
      'DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝) und Baidu AI (angetrieben von 文心一言). Das sind die fünf, die heute auf dem chinesischen Festland Volumen bewegen. ChatGPT, Perplexity, Google AI Overviews und Claude sind hier nicht relevant, da sie hinter der Großen Firewall keine nennenswerte Reichweite haben.',
    ],
  },
  {
    id: 'measurement',
    question: 'Wie messen Sie den Erfolg?',
    answer: [
      'Drei Zahlen, monatlich verfolgt. Zitationsrate: wie oft Ihre Marke in KI-Antworten auf eine feste Fragenmatrix auftaucht. Empfehlungsrang: wo Sie stehen, wenn die Engine Optionen auflistet. Sentiment: positive, neutrale oder kritische Einordnung der Erwähnung. Die Berichterstattung kommt als monatliche schriftliche Zusammenfassung, daneben ein Live-Dashboard.',
    ],
  },
  {
    id: 'how-long',
    question: 'Wie lange dauert es bis zum Zitations-Anstieg?',
    answer: [
      'Audit und Fundament: 4 bis 6 Wochen. Content-Ausbau und Verbreitung: drei bis vier Monate. Bis zum sechsten Monat sehen die meisten Kunden einen echten Zitations-Anstieg auf mindestens zwei Plattformen. Volle Abdeckung stellt sich in der Regel zwischen Monat 9 und 12 ein. Wer einen KI-Zitationsanteil in 30 Tagen verspricht, verkauft Ihnen etwas anderes.',
    ],
  },
  {
    id: 'evidence-tiers',
    question: 'Was sind T1-, T2-, T3-Inhalte und warum zählt das?',
    answer: [
      'KI-Engines gewichten Quellen danach, wie überprüfbar die Aussagen sind. T1 sind Inhalte, die durch harte Belege gestützt sind: Patentnummern, Prüfberichte unabhängiger Labore, veröffentlichte Normen, offizielle Behördendaten. T2 ist von der Branche anerkannt, aber sekundär: Fachpresse, Analystenberichte, namentlich genannte Fachmeinung. T3 ist Marketingtext ohne externen Beweis, die Sorte, die KI-Engines entweder ignorieren oder als unsicher markieren. Wir ordnen jede Aussage auf Ihrer Website ihrer Stufe zu und bauen die schwachen neu auf.',
    ],
  },
  {
    id: 'translated-content',
    question: 'Können wir nicht einfach unsere englischen Inhalte übersetzen?',
    answer: [
      'Nein. Übersetzte Inhalte wirken für chinesische KI-Engines fremd, verlieren oft die strukturellen Anhaltspunkte, auf die sie sich stützen, und treffen fast nie, wie chinesische Nutzer ihre Fragen tatsächlich formulieren. Wir arbeiten mit muttersprachlichen chinesischen Redakteuren, die von Grund auf neu schreiben, mit den Quellaussagen und Belegen intakt.',
    ],
  },
  {
    id: 'syndication',
    question: 'Wo verbreiten Sie die Inhalte?',
    answer: [
      'Baijiahao (百家号) für die Reichweite bei Baidu und Yuanbao, Zhihu (知乎) für Glaubwürdigkeitssignale im technischen und B2B-Bereich, Toutiao (今日头条) und Baijiahao für die ByteDance- und Doubao-Oberflächen und, wo es sinnvoll ist, offizielle Baidu-Baike-Einträge (百度百科). Branchenspezifische Portale kommen je nach Vertical hinzu.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: 'Was passiert, wenn die Engines ihre Modelle ändern?',
    answer: [
      'Das tun sie oft. DeepSeek hat allein 2025 vier größere Überarbeitungen ausgeliefert. Wir überwachen das Zitationsverhalten wöchentlich über dieselbe Fragenmatrix, die wir im Audit verwendet haben, und steuern Inhalte, strukturierte Daten und Verbreitung nach, bevor sich die Änderung als Zitationsabfall zeigt. Teams, die das nicht im Blick haben, verlieren Sichtbarkeit, ohne den Grund zu kennen.',
    ],
  },
  {
    id: 'cost',
    question: 'Was kostet ein GEO-China-Mandat?',
    answer: [
      'Das hängt vom Umfang ab: wie viele Produktlinien oder Servicebereiche im Spiel sind, die Tiefe des bestehenden Content-Bestands, die Zahl der Plattformen, auf denen Sie volle Abdeckung brauchen, und ob das Mandat auch die Produktion chinesischer Inhalte und Baidu-SEO umfasst. Beschreiben Sie uns den Umfang, und wir senden innerhalb von zwei Werktagen ein verbindliches Angebot.',
    ],
  },
];

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-geo-beijing-ai-research.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[#4D6BFE]/15 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">答</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrümel" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/de/leistungen/" class="hover:text-white/70 transition-colors no-underline">Leistungen</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">GEO China</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">GEO China</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">5 Engines, ein Programm</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Von chinesischer
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">KI zitiert</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">werden.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Generative Engine Optimization für Websites, die mit dem chinesischen Markt sprechen. Wir machen Ihren Inhalt zu der Antwort, der DeepSeek, Doubao, Kimi, Yuanbao und Baidu AI genug vertrauen, um sie an die Nutzer zurückzugeben. <span class="text-white font-medium">Eine Antwort pro Frage, Ihre Marke darin.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter>5</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Engines abgedeckt</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">600M</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">KI-Nutzer in China</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">150</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Fragen pro Audit</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/de/kontakt/" variant="primary" size="lg">KI-Sichtbarkeitsaudit anfordern</Button>
            <Button href="#engines" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Die fünf Engines ansehen</Button>
          </div>
        </div>

        <!-- Visual: geschichtetes DeepSeek-Mockup -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Hinten: "nicht zitiert"-Mock -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Nicht zitiert</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">Wettbewerber gewinnt</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Zitationsrate: 0%
              </div>
            </div>

            <!-- Vorne: DeepSeek-Chat -->
            <div data-tilt class="relative bg-white rounded-2xl shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)] overflow-hidden">
              <div class="flex items-center gap-2.5 px-5 py-3 bg-white border-b border-gray-100">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#4D6BFE] to-[#3a55e8] flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm5.5 11.5c-1.4.4-2.9.5-4.4.3-.4 1.6-.4 3.3 0 4.9-1.4-.6-2.6-1.5-3.5-2.7-1.5.4-3 .5-4.5.4 1-1.5 2.4-2.6 4-3.3-.6-1.4-1-3-1-4.6 1.4.6 2.7 1.6 3.6 2.8 1.5-.5 3.1-.6 4.6-.4-.7 1.4-1.7 2.6-3 3.5.6.4 1.3.7 2 .9.6.6 1.4 1.5 2.2 2.2z"/>
                  </svg>
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="text-sm font-semibold text-gray-900">DeepSeek</span>
                  <span class="text-[10px] text-gray-400">深度求索</span>
                </div>
                <div class="ml-auto flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
