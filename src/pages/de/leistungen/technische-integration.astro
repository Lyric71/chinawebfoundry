---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import CaseStudyCards from '../../../components/ui/CaseStudyCards.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'technical-integration'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const serverItems = [
  {
    title: 'Feinabstimmung des Cloud-Anbieters',
    body: 'Chinesische Cloud-Anbieter folgen jeweils eigenen Regeln. Alibaba Cloud behandelt die Datenbankkonfiguration anders als Tencent Cloud, und Huawei Cloud hat eigene Vorgaben zu PHP-Einstellungen und Dateispeicher. Wir haben mit allen dreien gearbeitet und stimmen WordPress auf den Anbieter ab, für den Sie sich entscheiden.',
  },
  {
    title: 'SSL-Zertifikate',
    body: 'Manche westlichen Zertifizierungsstellen werden von chinesischen Browsern nicht anerkannt. Der Besucher öffnet Ihre Seite, erhält sofort eine Sicherheitswarnung und ist damit verloren. Wir richten Zertifikate über Anbieter ein, denen in China tatsächlich vertraut wird.',
  },
  {
    title: 'Multisite und Mehrsprachigkeit',
    body: 'Wenn Sie eine China-Seite brauchen, die neben Ihrer globalen Website läuft, richten wir Multisite- und mehrsprachige Setups ein. Entscheidend ist dabei, dass beide synchron bleiben, ohne sich drei Monate später als Mühsal zu erweisen.',
  },
];

const themeFixItems = [
  'Google Fonts durch selbstgehostete Schriften ersetzt',
  'jQuery und JavaScript-Bibliotheken von westlichen CDNs auf in China gehostete Alternativen umgestellt',
  'YouTube-Player, Facebook-Buttons und Instagram-Widgets entfernt und ersetzt',
  'Kaputte Bilder und fehlende Stylesheets behoben',
  'Externe API-Aufrufe umgeleitet oder für den China-Zugang neu aufgebaut',
  'Das gesamte Frontend vor dem Start aus China heraus getestet',
];

const customPlugins = [
  {
    title: 'Zahlungs-Gateways',
    body: 'WeChat Pay hat getrennte Integrationswege für das mobile Web, für In-App-Zahlungen und für Mini Programs. Ist die Einrichtung fehlerhaft, scheitert die Transaktion ohne jede Fehlermeldung, und der Nutzer sieht schlicht nichts geschehen. Wir bauen Plugins für Alipay, WeChat Pay und UnionPay, die zuverlässig funktionieren.',
  },
  {
    title: 'WeChat-Anmeldung und -Teilen',
    body: 'Wir bauen WeChat-Anmeldebuttons, das Teilen an offizielle Konten und die QR-Code-Erzeugung, also die soziale Schicht, die chinesische Nutzer von jeder ernstzunehmenden Unternehmensseite erwarten.',
  },
  {
    title: 'Baidu Tongji Analytics',
    body: 'Wir binden Ihre Website vollständig an die Analyseplattform von Baidu an. Für das vollständige Reporting verlangt Baidu allerdings eine verifizierte ICP-Lizenz, ein Detail, das Agenturen ohne Sitz in China gern unerwähnt lassen.',
  },
  {
    title: 'SMS-Verifizierung',
    body: 'Wir richten die Verifizierung chinesischer Telefonnummern für die Kontoanmeldung, für Bezahlvorgänge und für Formulareingaben ein, ausgelegt auf die Zusammenarbeit mit lokalen SMS-Anbietern.',
  },
];

const performanceItems = [
  'Ressourcen auf lokalen Edge-Servern über Alibaba CDN oder Tencent CDN ausgespielt',
  'Caching-Schicht mit Redis oder Varnish, eigens für Ihre Hosting-Umgebung konfiguriert',
  'Bilder komprimiert für die Netzbedingungen, in denen Ihre Nutzer tatsächlich unterwegs sind',
  'Datenbankabfragen bereinigt, damit der Server schneller antwortet',
  'Getestet von echten Standorten in China, nicht über ein VPN',
];

const platformItems = [
  {
    title: 'Zahlungen',
    body: 'Alipay und WeChat Pay wickeln die meisten Transaktionen ab. Kreditkarten spielen bei chinesischen Verbrauchern kaum eine Rolle. Wir binden beide ein, dazu UnionPay. Haben Sie keine chinesische Rechtseinheit, richten wir grenzüberschreitende Zahlungen ein, damit Sie Renminbi annehmen und in Ihrer Währung abrechnen können.',
  },
  {
    title: 'Soziales',
    body: 'WeChat ist hier zugleich Browser, Geldbörse, App Store und Inhaltsplattform. Wir binden Ihre WordPress-Seite an offizielle Konten, Mini Programs, Weibo, Douyin und RED an.',
  },
  {
    title: 'Reichweitenmessung',
    body: 'Google Analytics lädt in China überhaupt nicht. Wir setzen Baidu Tongji als zentralen Tracker ein und ergänzen ein WeChat-Monitoring für sozialen Traffic und Conversion-Pfade, das abbildet, wie chinesische Nutzer sich tatsächlich durch eine Seite bewegen.',
  },
  {
    title: 'Unternehmenswerkzeuge',
    body: 'Setzen Sie Salesforce, SAP, HubSpot oder Odoo weltweit ein? Wir bauen die API-Verbindungen und die Datensynchronisation, damit Ihre Produktkataloge und Kundendaten auf beiden Seiten übereinstimmen und niemand zwischen Systemen kopieren muss.',
  },
];

const processSteps = [
  {
    title: 'Technisches Audit',
    body: 'Wir gehen Ihr aktuelles WordPress-Setup durch und dokumentieren jedes Plugin, jede Abhängigkeit und jeden externen Dienst, mit dem die Seite kommuniziert. Ziel ist es, herauszufinden, was in China bricht.',
  },
  {
    title: 'Umsetzung in Schichten',
    body: 'Wir arbeiten Schicht für Schicht: Serverkonfiguration, Theme-Bereinigung, Plugin-Ersatz oder Maßanfertigungen, Performance und Plattform-Integrationen, eine nach der anderen.',
  },
  {
    title: 'Tests aus China',
    body: 'Alles wird vor dem Livegang von innerhalb Chinas getestet, in echten chinesischen Netzen statt über ein VPN in Kalifornien.',
  },
  {
    title: 'Übergabe',
    body: 'Sie erhalten die vollständige Dokumentation, und Ihr Team übernimmt von dort. Alles ist dokumentiert und nach WordPress-Standards gebaut, sodass es bei Bedarf auch ein anderes Team warten kann.',
  },
];
const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de" jsonLd={pageLd}>

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-technical-integration.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrümelnavigation" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/de/leistungen/" class="hover:text-white/70 transition-colors no-underline">Leistungen</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Technische Integration</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Technische Integration
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Ihr gesamter WordPress-Stack,
            <span class="block mt-2 text-[var(--color-brand-orange)]">neu gebaut für China</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Serverinfrastruktur, Theme- und Plugin-Korrekturen, chinesische Zahlungen, soziale Plattformen und Anbindungen an Unternehmenswerkzeuge: alles neu gebaut für einen Markt, in dem die gewohnten Annahmen auseinanderfallen.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/de/kontakt/" variant="primary" size="lg">Technische Beratung vereinbaren</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">integration-check</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Google Fonts</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">Gesperrt</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Westliches CDN</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">Gesperrt</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Stripe / PayPal</span>
                  <span class="text-sm font-semibold text-yellow-400 font-mono">Unbrauchbar</span>
                </div>
                <div class="w-full h-px bg-white/10 my-1"></div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Alibaba Cloud</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Konfiguriert</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">WeChat Pay</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Integriert</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Baidu Tongji</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aktiv</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-8">
          Aus zwei Sekunden Ladezeit im Westen werden fünfzehn in Shenzhen
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
          Ihre WordPress-Seite läuft in New York, und sie läuft in London. Öffnen Sie sie über eine Verbindung aus Shanghai, sieht die Lage anders aus: Themes ziehen Schriften von Google-Servern, die China sperrt, Plugins senden API-Aufrufe, die hinter der Großen Firewall verenden, und JavaScript-Bibliotheken versuchen von CDNs zu laden, auf die das Land keinen Zugriff hat.
        </p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
          Die meisten Unternehmen erfahren davon erst nach dem Start, und das führt selten zu einem angenehmen Gespräch im eigenen Team.
        </p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Auch ein bloßer Wechsel zu einem chinesischen Hoster löst das Problem nicht von selbst. Die gesamte Seite braucht Arbeit: die Serverkonfiguration, die Theme-Abhängigkeiten und die Art, wie der Bezahlvorgang Zahlungen abwickelt.
        </p>
      </div>
    </div>
  </section>

  <!-- WordPress Core and Server Setup -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            WordPress-Kern und Serverkonfiguration
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Das Fundament muss zuerst stimmen
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {serverItems.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Theme and Plugin Overhaul -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Themes und Plugins, neu aufgesetzt
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Genau hier scheitern die meisten Seiten
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Themes und Plugins setzen voraus, dass das offene Internet für jeden zugänglich ist. Google Fonts lädt automatisch, jQuery wird von westlichen CDNs gezogen, und YouTube-Player, Facebook-Buttons und Instagram-Widgets sind fest verbaut. Hinter der Firewall funktioniert nichts davon.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Wir gehen alles durch, markieren jeden externen Aufruf, tauschen in China gehostete Alternativen ein und bauen neu, wo es keinen sauberen Ersatz gibt. Das Ergebnis ist ein Frontend, das für Menschen in China tatsächlich lädt.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="bg-white rounded-2xl p-8 border border-[var(--color-surface-border)]">
            <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
              Was wir ersetzen
            </p>
            <div class="space-y-4">
              {themeFixItems.map((item) => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Plugins -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Maßgeschneiderte Plugins
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Standard-WordPress-Plugins lassen China ganz aus
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            {customPlugins.map((item) => (
              <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
                <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
                <p class="text-base text-white/70 leading-relaxed">
                  {item.body}
                </p>
              </div>
            ))}
          </div>
          <p class="mt-8 text-base text-white/50 leading-relaxed">
            Alles ist dokumentiert und nach WordPress-Standards gebaut, sodass es bei Bedarf auch ein anderes Team warten kann.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Performance -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Performance
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Außerhalb der Großstädte bricht die Bandbreite schnell ein
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Peking verfügt über gute Bandbreite, Shanghai ebenfalls. Sobald Sie die großen Städte verlassen, bricht sie jedoch rasch ein. Hinzu kommt, dass grenzüberschreitende Datenübertragungen bewusst gedrosselt werden, sodass alles, was Ihre Seite aus dem Ausland nachlädt, ausgebremst wird.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Wir testen von echten Standorten in China, nicht über ein VPN in Kalifornien. VPN-Tests vermitteln Ihnen den Eindruck, alles sei in Ordnung, während Ihre tatsächlichen Nutzer in Chengdu oder Kunming auf einen Ladekreis starren und sich fragen, ob die Seite defekt ist.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="bg-white rounded-2xl p-8 border border-[var(--color-surface-border)]">
            <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
              Wie wir optimieren
            </p>
            <div class="space-y-4">
              {performanceItems.map((item) => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Connecting to Chinese Platforms -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Anbindung an chinesische Plattformen
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Ihre Seite an das Ökosystem hängen, das wirklich zählt
        </h2>
      </div>

      <CaseStudyCards items={platformItems} />
    </div>
  </section>

  <!-- Data Compliance -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Datenkonformität
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Nach dem Start nachzubessern kostet immer mehr
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Das Gesetz zum Schutz personenbezogener Daten (PIPL) und das chinesische Cybersicherheitsgesetz haben konkrete Folgen dafür, wie Sie Nutzerdaten handhaben: wo diese gespeichert werden und ob sie eine Grenze überschreiten dürfen. Wir bauen die Datenkonformität von Anfang an in die technische Einrichtung ein, denn eine Nachbesserung nach dem Start kostet ausnahmslos mehr, als die Beteiligten einplanen.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="bg-[var(--color-surface-light)] rounded-xl p-6 border-l-4 border-[var(--color-brand-orange)]">
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed italic">
              Datenlokalisierung, Regeln für die grenzüberschreitende Übertragung, Einwilligungsmechanismen, Speicheranforderungen: Wir übernehmen die technische Umsetzung, damit sich Ihr Rechtsteam auf den regulatorischen Teil konzentrieren kann.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How Projects Work -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Wie Projekte ablaufen
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Schicht für Schicht, getestet aus China
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            {processSteps.map((item) => (
              <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
                <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
                <p class="text-base text-white/70 leading-relaxed">
                  {item.body}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Loslegen
      </p>
