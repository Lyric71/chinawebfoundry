---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'maintenance-support'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const includedItems = [
  {
    n: '01',
    cn: '内容',
    title: 'Redaktionelle Pflege',
    body: 'Zwei bis vier Beiträge im Monat für aktive Kunden, in der Regel ein langer, Baidu-tauglicher Artikel (1.500 bis 2.500 chinesische Schriftzeichen), eine Fallstudie oder Produktneuheit sowie ein bis zwei kurze News-Posts. Alles entsteht von Muttersprachlern in originärem Chinesisch, ohne Übersetzung. Die stärksten Beiträge spielen wir zusätzlich auf Baijiahao (百家号), Zhihu (知乎) und Sohu Hao (搜狐号) aus, denn KI-Engines werten diese Plattformen als Bestätigungssignal, wenn sie entscheiden, welche Quellen sie zitieren.',
    tag: 'Inhalte',
    chips: ['百家号', '知乎', '搜狐号', 'Echtes ZH', '双11 / 618 / 春节'],
  },
  {
    n: '02',
    cn: '搜索',
    title: 'Baidu-SEO-Betreuung',
    body: 'Ein monatlicher Ranking-Bericht zu Ihren 30 bis 50 wichtigsten Keywords, die Indexierungskontrolle von mehr als 100 priorisierten URLs über 百度搜索资源平台 sowie zwei bis drei technische SEO-Korrekturen pro Monat, abhängig davon, was die Daten nahelegen. Neue Inhalte übermitteln wir am Tag der Veröffentlichung an die Baidu-Tools, Crawling-Fehler beheben wir, sobald sie auftreten, und was aus dem Index fällt, holen wir zurück.',
    tag: 'Baidu-SEO',
    chips: ['Ranking', '主动推送', 'Indexcheck', 'Algo-Reaktion'],
  },
  {
    n: '03',
    cn: '智能',
    title: 'GEO-Betreuung',
    body: 'Wöchentliche Sichtbarkeitschecks über DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝) und Baidu AI (百度AI), gestützt auf eine feste Matrix aus 40 Suchanfragen je Kunde zu Marke, Kategorie, Anwendungsfall und Wettbewerb. Die Berichte weisen Zitierrate, Empfehlungsrang und Sentiment-Score aus und nennen die Inhaltsanpassungen, die im laufenden Monat anstehen.',
    tag: 'KI-Suche',
    chips: ['DeepSeek', 'Doubao', 'Kimi', '元宝', '文心X1'],
  },
  {
    n: '04',
    cn: '技术',
    title: 'Technische Wartung',
    body: 'Updates für WordPress-Kern, Plugins und Themes, vor dem Livegang auf einer Staging-Umgebung geprüft. Tägliche Off-Site-Backups, 30 Tage vorgehalten. Sicherheitsscans über Wordfence oder Sucuri laufen rund um die Uhr, Verfügbarkeitskontrollen alle 5 Minuten von Servern, die physisch in China stehen. Hinzu kommen eine vierteljährliche Datenbankbereinigung und SSL-Verlängerungen mit China-tauglichen Zertifikaten von Aliyun (阿里云) oder lokalen Zertifizierungsstellen.',
    tag: 'Technik',
    chips: ['Updates', 'Backups', 'Sicherheit', 'Verfügbarkeit', 'SSL'],
  },
  {
    n: '05',
    cn: '防火',
    title: 'Die China-Schicht',
    body: 'Wir beobachten das Verhalten der Großen Firewall in Echtzeit. Wird ein CDN, eine Schriftbibliothek oder eine externe API gesperrt, ersetzen wir sie durch eine China-taugliche Alternative, im Schnitt innerhalb von 14 Minuten von der Erkennung bis zum Deployment. Nach jedem Update-Zyklus prüfen wir die Anmeldung über WeChat (微信), Alipay (支付宝) und WeChat Pay (微信支付) sowie die Reichweitenmessung (Baidu Tongji oder 51la) erneut.',
    tag: 'Firewall-Wache',
    chips: ['CDN-Tausch', 'Schrift-Tausch', 'WeChat-Login', 'Alipay', 'Analytics'],
  },
  {
    n: '06',
    cn: '主机',
    title: 'Hosting',
    body: 'ICP-lizenzierte Server (ICP备案) bei Aliyun, Tencent Cloud (腾讯云) oder Huawei Cloud (华为云), durchgängig betreut, mit Performance-Feinabstimmung, sobald der Traffic anzieht. Die Bei\'an-Verlängerungen (备案) verfolgen wir über die MIIT-Konsole, damit keine ausläuft. Das Verfügbarkeits-SLA liegt bei 99,9 %, mit dokumentierten Reaktionszeiten von 30 Minuten bei kritischen Vorfällen und 4 Stunden bei Standardtickets.',
    tag: 'Hosting',
    chips: ['ICP 备案', 'Aliyun', 'Tencent Cloud', 'Huawei Cloud', '99,9% SLA'],
  },
  {
    n: '07',
    cn: '修复',
    title: 'Störungsbehebung',
    body: 'Wenn etwas ausfällt, greift unser Team in China sofort ein: bei Bugs, Plugin-Konflikten, Sicherheitsvorfällen und Fehlern bei Zahlungs-Gateways mit Alipay oder WeChat Pay. Wird eine Seite gehackt, isolieren wir sie, bereinigen und stellen sie wieder her, härten sie ab und liefern innerhalb von 48 Stunden ein Post-mortem.',
    tag: 'Vorfall',
    chips: ['Bugs', 'Plugin-Konflikte', 'Hack-Reaktion', '48h Post-mortem'],
  },
];

const insightItems = [
  {
    n: '01',
    cn: '变',
    title: 'Das chinesische Digitalfeld bewegt sich schneller',
    body: 'Der Baidu-Algorithmus hat sich 2025 elfmal geändert. DeepSeek hat vier große Modellrevisionen veröffentlicht. Doubao hat seine Inhaltsverarbeitung mindestens monatlich umgebaut. Das Tempo lässt nicht nach.',
  },
  {
    n: '02',
    cn: '退',
    title: 'Unberührte Seiten verfallen',
    body: 'Seiten, die richtig starten und dann ein Jahr lang unberührt bleiben, sind im neunten Monat fast immer unsichtbar. Der Verfall verläuft schleichend, dann plötzlich.',
  },
  {
    n: '03',
    cn: '增',
    title: 'Gepflegte Seiten wachsen mit Zinseszins',
    body: 'Seiten, die regelmäßig frische Inhalte veröffentlichen, ihre KI-Zitate wöchentlich verfolgen und den technischen Stack sauber halten, legen kontinuierlich zu. Rankings steigen, KI-Erwähnungen nehmen zu, die Kosten für Sichtbarkeit sinken.',
  },
  {
    n: '04',
    cn: '盲',
    title: 'Ausländische Agenturen sehen das meiste davon nicht',
    body: 'Internationale Agenturen erkennen die meisten Fehlerquellen ohne VPN nicht. Aus einem Büro in London oder Chicago sieht alles in Ordnung aus, bis es das nicht mehr ist.',
  },
];

const stats = [
  { value: '14 Min.', label: 'Schnitt Erkennung bis Deployment', sub: 'Wenn eine Schrift, ein CDN oder eine API gesperrt wird.' },
  { value: '99,9 %', label: 'Verfügbarkeits-SLA', sub: 'Reaktion in 30 Minuten bei kritischen Vorfällen.' },
  { value: '40', label: 'KI-Suchanfragen pro Woche', sub: 'Zitatverfolgung über 5 Engines, wöchentlich.' },
];

const audiences = [
  {
    label: 'Kein Team vor Ort',
    description: 'Unternehmen mit einer aktiven China-Seite, aber ohne lokales Team für den Betrieb, die fachkundige Unterstützung brauchen, ohne ein Team von Grund auf aufzubauen.',
    image: '/images/audiences/wordpress-china-no-local-team.webp',
  },
  {
    label: 'Marketing zuerst',
    description: 'Marketingabteilungen, die lieber an Kampagnen arbeiten, als kaputten Plugins über neun Zeitzonen hinweg hinterherzujagen.',
    image: '/images/audiences/marketing-not-debugging.webp',
  },
  {
    label: 'IT ohne China-Stelle',
    description: 'IT-Teams, die China-Expertise brauchen, aber eine Vollzeitstelle im Organigramm nicht rechtfertigen können.',
    image: '/images/audiences/it-team-china-expertise.webp',
  },
  {
    label: 'E-Commerce in China',
    description: 'E-Commerce-Unternehmen auf WooCommerce oder Shopify mit chinesischen Zahlungs-Gateways und lokaler Logistik.',
    image: '/images/audiences/woocommerce-china-payments.webp',
  },
];

const marqueePhrases = [
  '维护', 'Wartung',
  '内容', 'GEO', 'SEO',
  'ICP 备案',
  'Aliyun · Tencent Cloud',
  'Wordfence',
  'WeChat Pay',
  'Alipay',
  '99,9% Verfügbarkeit',
  'Wache rund um die Uhr',
  'Ein Team · eine Rechnung',
];

const faqs = [
  {
    id: 'why-not-internal',
    question: 'Warum nicht einfach unser internes IT-Team damit beauftragen?',
    answer: [
      'Theoretisch kann es das. In der Praxis verlieren interne Teams fast immer den Überblick auf der China-Seite: Sie erreichen die Dashboards (百度站长资源, die Aliyun-Konsole, die WeChat-Plattform) ohne VPN nicht, und die Warnmeldungen kommen auf Chinesisch. Die meisten unserer Kunden behalten ihr internes Team für das globale Geschäft und nehmen uns als China-Schreibtisch.',
    ],
  },
  {
    id: 'pricing',
    question: 'Wie werden die Retainer berechnet?',
    answer: [
      'Monatliche Retainer ab 1.200 US-Dollar, zugeschnitten auf das, was Ihre Seite tatsächlich braucht. Der Betrag hängt vom Traffic-Volumen ab, von der Veröffentlichungsfrequenz, von der Zahl der betreuten KI-Engines und davon, ob das Hosting im Umfang liegt. Schildern Sie uns Ihre Lage, und wir schicken innerhalb von zwei Werktagen ein konkretes Angebot.',
    ],
  },
  {
    id: 'response-time',
    question: 'Wie schnell reagieren Sie auf Vorfälle?',
    answer: [
      'Kritische Vorfälle (Seite offline, Zahlung fehlgeschlagen, Hack): 30 Minuten von der Meldung bis zur ersten Maßnahme, rund um die Uhr. Standardtickets (Plugin-Konflikt, Inhaltsänderung, Frage zum Dashboard): 4 Werkstunden. Alle Reaktionszeiten sind im SLA festgehalten.',
    ],
  },
  {
    id: 'content-cadence',
    question: 'Wie viele Inhalte liefern Sie pro Monat?',
    answer: [
      'Zwei bis vier Beiträge bei einem aktiven Retainer. In der Regel ein langer, Baidu-tauglicher Artikel (1.500 bis 2.500 chinesische Schriftzeichen), eine Fallstudie oder Produktneuheit und ein bis zwei kurze News-Posts. Rund um Kampagnenfenster steigt die Frequenz: 双11, 618, 春节.',
    ],
  },
  {
    id: 'baidu-and-geo',
    question: 'Sind Baidu-SEO und GEO inbegriffen oder getrennt?',
    answer: [
      'Beides läuft für aktive Kunden im Wartungs-Retainer mit. Monatlicher Baidu-Ranking-Bericht und Indexierungskontrolle, wöchentliche GEO-Zitatverfolgung über DeepSeek, Doubao, Kimi, Yuanbao und Baidu AI. Größere strukturelle Umbauten (komplette Neuerstellung der Keyword-Karte, Aufbau von Content-Clustern) sind eigene Projekte.',
    ],
  },
  {
    id: 'hosting',
    question: 'Müssen wir unser Hosting zu Ihnen verlegen?',
    answer: [
      'Nein. Wir arbeiten mit dem Stack, den Sie bei Aliyun, Tencent Cloud oder Huawei Cloud haben. Gehört das Hosting zum Retainer, betreuen wir alles durchgängig, einschließlich der 备案-Verlängerungen über die MIIT-Konsole. Behalten Sie das Hosting intern, stimmen wir uns mit demjenigen ab, der es führt.',
    ],
  },
  {
    id: 'firewall',
    question: 'Was passiert, wenn die Große Firewall etwas blockiert?',
    answer: [
      'Wir beobachten das Verhalten in Echtzeit und tauschen China-taugliche Alternativen ein, sobald ein CDN, eine Schriftbibliothek oder eine externe API nicht mehr auflöst. Reaktion im Schnitt: 14 Minuten von der Erkennung bis zum Deployment. Vierteljährlich prüfen wir die Anmeldung über WeChat, Alipay, WeChat Pay und Baidu Tongji erneut, denn Rückschläge sind dort lautlos.',
    ],
  },
  {
    id: 'reporting',
    question: 'Wie sieht das Reporting aus?',
    answer: [
      'Eine schriftliche Monatszusammenfassung zu veröffentlichten Inhalten, Baidu-Ranking-Bewegungen, GEO-Zitatverfolgung, geleisteter technischer Arbeit, gelösten Vorfällen und den empfohlenen Prioritäten für den nächsten Monat. Dazu ein Live-Status-Dashboard, das Sie jederzeit einsehen können.',
    ],
  },
];
const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-maintenance-beijing-team-office.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-emerald-500/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">维</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrümelnavigation" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/de/leistungen/" class="hover:text-white/70 transition-colors no-underline">Leistungen</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Wartung und Support</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Wartung &amp; Support</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Hinter der Großen Firewall, rund um die Uhr</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Ihre China-Seite am Leben halten.
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Monat für</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Monat.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Inhalte, Baidu-SEO, GEO-Betreuung über die fünf chinesischen KI-Engines, technische Wartung, Hosting. Alles getragen von einem Team, das jeden Tag von innerhalb der Großen Firewall arbeitet. <span class="text-white font-medium">Ein Team. Eine Rechnung. Kein Fingerzeigen über neun Zeitzonen hinweg.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-emerald-400/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">99,9<span class="text-base text-white/60">%</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Verfügbarkeits-SLA</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter>14</span><span class="text-base text-white/60">Min.</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Erkennung → Deployment</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">24/7</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Wache vor Ort in China</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/de/kontakt/" variant="primary" size="lg">Mit unserem Team sprechen</Button>
            <Button href="#whats-included" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Sehen, was inbegriffen ist</Button>
          </div>
        </div>

        <!-- Visual: layered status dashboard -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Back: "untouched site" mock -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Ohne Betreuung · 9 Mon.</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">kein Team</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Baidu-Ranking: sinkt
              </div>
            </div>

            <!-- Front: live dashboard -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                </div>
                <span class="text-[10px] font-mono text-white/45 ml-2">seitenstatus · live</span>
                <span class="ml-auto inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-emerald-500/15 border border-emerald-400/30">
                  <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
                  <span class="text-[9px] font-mono text-emerald-300 uppercase">Gesund</span>
                </span>
              </div>

              <div class="space-y-3.5">
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Firewall-Wache</span>
                  <span class="text-[12px] font-mono text-emerald-300">Frei</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Inhaltsfrequenz</span>
                  <span class="text-[12px] font-mono text-emerald-300">3 / Mon.</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Baidu-Index</span>
                  <span class="text-[12px] font-mono text-emerald-300">Gesund</span>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/75">KI-Zitate (Wo.)</span>
                    <span class="text-[12px] font-mono text-[var(--color-brand-orange)]">+<span data-counter data-counter-suffix="%">12</span></span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden shimmer-bar">
                    <div class="h-full w-[72%] bg-gradient-to-r from-[var(--color-brand-orange)] to-[#FF8956] rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/75">Verfügbarkeit · 30 T.</span>
                    <span class="text-[12px] font-mono text-emerald-300">99,98%</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[99%] bg-gradient-to-r from-emerald-400 to-emerald-300 rounded-full"></div>
                  </div>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-white/10 grid grid-cols-3 gap-2">
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">Backups</div>
                  <div class="text-xs font-mono text-emerald-300">Aktuell</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">ICP 备案</div>
                  <div class="text-xs font-mono text-white/70">2027</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">SSL</div>
                  <div class="text-xs font-mono text-emerald-300">Gültig</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- WHY: dramatic statement -->
  <section class="relative section-spacing overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0" data-reveal="left">
          <div class="relative inline-flex items-baseline">
            <span class="text-[10rem] lg:text-[14rem] font-medium font-[var(--font-heading)] leading-none bg-gradient-to-br from-[var(--color-brand-orange)] via-[#FF7E47] to-[#D94E1F] bg-clip-text text-transparent" data-counter data-counter-duration="1800">9</span>
            <span class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] ml-2">Monate</span>
          </div>
          <p class="mt-4 text-base text-[var(--color-text-muted)] max-w-sm">
            Durchschnittliche Zeit, bis eine gestartete und dann sich selbst überlassene China-Seite in die Unsichtbarkeit abdriftet. Schleichender Verfall, dann ein abrupter Sturz aus den Rankings.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-7" data-reveal="right">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)] mb-5">Warum es zählt</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15] mb-6">
            Der Start ist der einfache Teil.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Eine China-Seite startet man nicht, um sie danach zu vergessen. Baidu lässt die Rankings von Seiten fallen, die nicht mehr veröffentlichen. KI-Engines passen ihre Crawling-Logik alle paar Wochen an. Eine Google Font, die Ihr Entwickler im Theme zurückgelassen hat, wird an einem beliebigen Dienstag gesperrt, und die Startseite bricht für jeden Besucher in Shanghai, Shenzhen und Peking.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            Aus Ihrem Büro in London oder Chicago sieht alles in Ordnung aus, bis es das nicht mehr ist. Wir führen die Wache, die Inhalte, die Suchmaschinenarbeit und die technische Schicht als ein einziges Mandat.
          </p>

          <div class="flex flex-wrap items-center gap-2.5">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-cta-bg)] text-white text-sm font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
              Wache
            </span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Veröffentlichung</span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Wartung</span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Wachstum</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED: comparison cards -->
  <section id="whats-included" class="relative section-spacing bg-gradient-to-b from-[var(--color-surface-light)] to-white overflow-hidden scroll-mt-32">
    <span aria-hidden="true" class="absolute -top-24 right-[-2rem] text-[20rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.04] leading-none select-none pointer-events-none" data-parallax="0.15">守</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14 lg:mb-16" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">Was inbegriffen ist · 服务内容</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-5">
          Sieben Arbeitsbereiche. Ein Retainer.
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Die ersten drei halten die Seite sichtbar. Die nächsten drei halten sie aufrecht. Der letzte fängt auf, was die anderen durchlassen.
        </p>
      </div>

      <div class="space-y-5 lg:space-y-6">
        {includedItems.map((q, i) => (
          <article
            data-reveal
            data-reveal-delay={String(i * 50)}
            data-cursor-spotlight
            class:list={[
              'group relative grid grid-cols-1 lg:grid-cols-12 gap-0 rounded-3xl border border-[var(--color-surface-border)] bg-white overflow-hidden transition-all duration-500',
              'hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_30px_70px_-30px_rgba(15,15,18,0.18)] hover:-translate-y-1',
            ]}
          >
            <div class="lg:col-span-3 relative p-7 lg:p-8 bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white overflow-hidden">
              <span aria-hidden="true" class="absolute right-[-1.5rem] bottom-[-3rem] text-[14rem] font-medium font-[var(--font-heading)] text-white/[0.04] leading-none select-none pointer-events-none transition-transform duration-700 group-hover:scale-110 origin-bottom-right">{q.cn}</span>
              <div class="relative">
                <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-2">Nr. {q.n} / 07</div>
                <div class="text-5xl lg:text-6xl font-medium font-[var(--font-heading)] text-white leading-none mb-1.5">{q.cn}</div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange-text)]/90 font-semibold">{q.tag}</div>
              </div>
            </div>

            <div class="lg:col-span-6 p-7 lg:p-9 flex flex-col justify-center">
              <h3 class="text-2xl lg:text-[26px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4">
                {q.title}
              </h3>
              <p class="text-[15px] lg:text-base text-[var(--color-text-body)] leading-relaxed">
                {q.body}
              </p>
            </div>

            <div class="lg:col-span-3 p-6 lg:p-7 bg-[var(--color-surface-light)] border-t lg:border-t-0 lg:border-l border-[var(--color-surface-border)] flex flex-col justify-center gap-3">
              <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)]">Stack / Oberflächen</div>
              <div class="flex flex-wrap gap-1.5">
                {q.chips.map((c) => (
                  <span class="text-[11px] font-mono px-2.5 py-1 rounded-md bg-white text-[var(--color-text-body)] border border-[var(--color-surface-border)]">{c}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ONGOING: 4 insights as bento cards -->
  <section class="relative section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(white_1px,transparent_1px)] [background-size:36px_36px] opacity-[0.025]"></div>
    <div class="absolute -top-32 left-[15%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.08] blur-[140px] pointer-events-none" data-float></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Warum dauerhaft · 为什么要持续</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] mb-5">
          Unberührte Seiten werden unsichtbar.
        </h2>
        <p class="text-lg text-white/65 leading-relaxed">
          Gepflegte Seiten wachsen mit Zinseszins. Die Schere zwischen beiden öffnet sich schnell.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5">
        {insightItems.map((p, i) => (
          <div
            data-reveal
            data-reveal-delay={String(i * 80)}
            class:list={[
              'group relative rounded-3xl bg-white/[0.03] border border-white/10 p-7 lg:p-8 overflow-hidden transition-all duration-300',
              'hover:bg-white/[0.06] hover:border-white/20 hover:-translate-y-0.5',
            ]}
          >
            <span aria-hidden="true" class="absolute -right-3 -bottom-6 text-[8rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.06] leading-none select-none pointer-events-none transition-all duration-500 group-hover:text-[var(--color-brand-orange)]/[0.12] group-hover:scale-110 origin-bottom-right">{p.cn}</span>
            <div class="relative">
              <div class="flex items-center gap-3 mb-5">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)] text-sm font-semibold font-[var(--font-heading)]">
                  {p.n}
                </span>
                <span class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40">Erkenntnis {p.n} von 04</span>
              </div>
              <h3 class="text-xl font-semibold font-[var(--font-heading)] text-white leading-tight mb-3">
                {p.title}
              </h3>
              <p class="text-base text-white/65 leading-relaxed">
                {p.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="relative section-spacing bg-white overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start mb-12">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-text-card-blue)]/10 border border-[var(--color-text-card-blue)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-card-blue)]">Zahlen der Leistung · 数据</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
            Die Zahlen, die wir jeden Monat erreichen.
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-4 lg:mt-0" data-reveal data-reveal-delay="80">
          <p class="text-base text-[var(--color-text-body)] leading-relaxed">
            Festgehalten im SLA. Sichtbar im Live-Dashboard. Monatlich in einer schriftlichen Zusammenfassung berichtet.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-5">
        {stats.map((s, i) => (
          <div
            data-reveal
            data-reveal-delay={String(i * 90)}
            class:list={[
              'group relative rounded-3xl p-7 lg:p-8 transition-all duration-300 hover:-translate-y-1 overflow-hidden',
              i === 1
                ? 'bg-gradient-to-br from-[var(--color-brand-orange)] to-[#D14A1F] text-white hover:shadow-[0_24px_50px_-22px_rgba(242,95,41,0.4)]'
                : 'bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] hover:shadow-[0_24px_50px_-22px_rgba(15,15,18,0.18)] hover:border-[var(--color-brand-orange)]/30',
            ]}
          >
            {i === 1 && <span aria-hidden="true" class="absolute -right-4 -bottom-8 text-[10rem] font-medium font-[var(--font-heading)] text-white/[0.08] leading-none select-none pointer-events-none">守</span>}
            <div class="relative">
              <div class:list={['text-[10px] font-mono uppercase tracking-[0.18em] mb-3', i === 1 ? 'text-white/75' : 'text-[var(--color-text-muted)]']}>{s.label}</div>
              <div class:list={['text-5xl lg:text-6xl font-medium font-[var(--font-heading)] leading-none mb-3', i === 1 ? 'text-white' : 'text-[var(--color-text-dark)]']}>
                {s.value}
              </div>
              <p class:list={['text-sm leading-relaxed', i === 1 ? 'text-white/90' : 'text-[var(--color-text-body)]']}>{s.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IS THIS FOR -->
  <WhoIsThisFor heading="Wer sich an uns wendet" audiences={audiences} background="light" />

  <!-- FAQ -->
  <section id="faq" class="section-spacing bg-white scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32" data-reveal="left">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">FAQ · 常见问题</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Acht Fragen, die wir zu Wartung und Support hören
          </h2>
          <p class="mt-6 text-base text-[var(--color-text-body)] leading-relaxed">
            Tippen Sie auf eine Frage, um sie aufzuklappen. Fehlt Ihre, fragen Sie uns direkt.
          </p>
          <div class="mt-7">
            <Button href="/de/kontakt/" variant="secondary" size="md">Eine andere Frage stellen</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6" data-reveal="right">
          <div data-faq-accordion>
            {faqs.map((faq) => (
              <FAQItem question={faq.question} id={faq.id}>
                {faq.answer.map((para) => (
                  <p class="mb-3 last:mb-0">{para}</p>
                ))}
              </FAQItem>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA with marquee -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="relative border-y border-white/10 bg-[#0f0f12] py-5 overflow-hidden">
      <div class="flex gap-10 animate-[marquee_45s_linear_infinite] whitespace-nowrap">
        {[...marqueePhrases, ...marqueePhrases, ...marqueePhrases].map((phrase) => (
          <span class="inline-flex items-center gap-3 text-base lg:text-lg font-medium text-white/40 hover:text-[var(--color-brand-orange)] transition-colors">
            {phrase}
            <span class="text-white/15">·</span>
          </span>
        ))}
      </div>
      <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#0f0f12] to-transparent pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#0f0f12] to-transparent pointer-events-none"></div>
    </div>

    <div class="relative py-20 lg:py-28">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[var(--color-brand-orange)]/10 rounded-full blur-[140px] pointer-events-none"></div>
      <span aria-hidden="true" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[24rem] lg:text-[30rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none">维</span>

      <div class="relative mx-auto max-w-[1400px] section-padding text-center" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/85">Lassen Sie es nicht abrutschen</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] max-w-3xl mx-auto">
          Den schwierigen Teil haben Sie geschafft. Lassen Sie ihn nicht abrutschen.
        </h2>
        <p class="mt-6 text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
          Schildern Sie uns Ihre Lage. Wir kommen mit einem Plan zurück, der Inhaltsfrequenz, SEO- und GEO-Maßnahmen, technische Wartung und Hosting abdeckt. Monatliche Retainer ab 1.200 US-Dollar, zugeschnitten auf das, was Ihre Seite tatsächlich braucht.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
          <Button href="/de/kontakt/" variant="primary" size="lg">Individuelles Angebot anfordern</Button>
          <Button href="/de/leistungen/china-hosting/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Hosting-Optionen</Button>
          <Button href="/de/leistungen/baidu-seo/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Baidu-SEO</Button>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
