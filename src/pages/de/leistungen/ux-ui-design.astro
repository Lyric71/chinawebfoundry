---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'ux-ui-design'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const stats = [
  { value: '70%+', label: 'Mobiler Traffic in China' },
  { value: '6', label: 'Geprüfte Browser' },
  { value: 'WeChat', label: 'Native Integration' },
  { value: 'ICP', label: 'Konform durch Konzept' },
];

const services = [
  {
    title: 'Nutzerforschung und Erkenntnisse',
    body: 'Wir kartieren, wie sich Ihr Publikum in China tatsächlich durch Inhalte bewegt, vergleichen lokale und internationale Wettbewerber und gestalten Nutzerwege, die dort ansetzen, wo chinesische Nutzer beginnen: auf Douyin, in WeChat oder bei Baidu.',
    icon: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607Z',
    tag: 'Forschung',
  },
  {
    title: 'Informationsarchitektur',
    body: 'Das chinesische Publikum bevorzugt dichtere Seiten, mit mehr sichtbaren Links, mehr Text und mehr Optionen bereits im ersten Bildausschnitt. Wir gliedern Inhalte in der Tiefe, die Besucher erwarten, ohne dass die Seite für das Headquarter unlesbar wird.',
    icon: 'M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5',
    tag: 'Architektur',
  },
  {
    title: 'Visuelles Design',
    body: 'Mobile-first-Layouts für die Geräte, die in China tatsächlich im Einsatz sind. Dazu gehören eine symbolisch aufgeladene Farbgebung, eine Typografie, die chinesische Schriftzeichen respektiert, sowie die Vertrauenssignale (WeChat-QR, ICP, Gewerbelizenz), die chinesische Verbraucher prüfen, bevor sie handeln.',
    icon: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
    tag: 'UI',
  },
  {
    title: 'Gutenberg-natives Designsystem',
    body: 'Wir gestalten direkt in Gutenberg: eigens entwickelte Blöcke, die Ihr Redaktionsteam ohne Entwickler bedient, Komponenten, die für visuelle Stimmigkeit sorgen, und Vorlagen, die auch nicht-technische Mitarbeiter selbst aktualisieren können.',
    icon: 'M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3',
    tag: 'System',
  },
];

const processSteps = [
  { phase: '01', title: 'Erstgespräch und Briefing', body: 'Wir stimmen uns auf Markenrichtlinien und Ziele ab und klären, wen Sie in China erreichen wollen.' },
  { phase: '02', title: 'Recherche und Benchmarking', body: 'Wir sichten das Wettbewerbsumfeld, die lokalen Nutzungsmuster und die Designprinzipien, die in der Kategorie gelten. Diese Vorarbeit ist abgeschlossen, bevor das erste Layout entsteht.' },
  { phase: '03', title: 'Wireframing', body: 'Seitenstruktur und Nutzerwege, abgeglichen mit den Erwartungen, die chinesische Nutzer an eine funktionierende Seite stellen. Ein Wireframe nachzuarbeiten ist günstiger, als ein fertiges Mockup zu korrigieren.' },
  { phase: '04', title: 'Visuelles Design und Iteration', body: 'Mockups in hoher Detailtiefe und mehrere Feedback-Runden, bis das Ergebnis für Ihre globale Marke und den chinesischen Markt zugleich trägt.' },
  { phase: '05', title: 'Designsystem und Übergabe', body: 'Komponenten, Stilrichtlinien und Interaktionsspezifikationen so aufbereitet, dass Ihr Entwicklerteam ohne Rückfragen bauen kann.' },
  { phase: '06', title: 'QA und Validierung', body: 'Wir testen auf chinesischen Browsern und Geräten. Eine Seite, die in London hervorragend aussieht, kann im UC Browser oder QQ Browser auseinanderbrechen, und beide sind in China weiterhin weit verbreitet.' },
];

const colours = [
  { name: 'Glücksverheißendes Rot', hex: '#E11D2E', meaning: 'Glück, Energie, Tatkraft' },
  { name: 'Markenorange', hex: '#F25F29', meaning: 'Vitalität, Akzent' },
  { name: 'Vertrauensgrün', hex: '#52C41A', meaning: 'Bestätigung, WeChat' },
  { name: 'Tinte', hex: '#1F1F1F', meaning: 'Überschriften, Ankerpunkt' },
  { name: 'Wolke', hex: '#FAFAFA', meaning: 'Fläche, nie allein' },
];

const typeScale = [
  { label: 'H1', size: '32', cn: '中文标题', en: 'Display-Überschrift' },
  { label: 'H2', size: '24', cn: '副标题', en: 'Abschnitts-Unterzeile' },
  { label: 'Body', size: '16', cn: '正文段落', en: 'Fließtext-Absatz' },
  { label: 'Caption', size: '12', cn: '辅助说明', en: 'Bildunterschrift / Meta' },
];

const spacingTokens = [
  { name: '4 · XS', width: 'w-2' },
  { name: '8 · S', width: 'w-4' },
  { name: '16 · M', width: 'w-8' },
  { name: '24 · L', width: 'w-12' },
  { name: '32 · XL', width: 'w-16' },
  { name: '48 · 2XL', width: 'w-24' },
];

const intelligence = [
  {
    claim: 'Farbe trägt Bedeutung',
    body: 'Rot steht für Glück und Energie, Gold für gehobene Qualität. Weiß für sich allein trägt eine Bedeutung von Trauer, weshalb wir es mit kräftigen Akzenten kombinieren.',
    visual: 'colour',
  },
  {
    claim: 'Dichte liest sich als Vertrauen',
    body: 'Dichte Layouts im oberen Bildausschnitt wirken auf chinesische Nutzer fundiert. Entwürfe mit viel Weißraum hingegen können leer, unfertig oder ausweichend wirken.',
    visual: 'density',
  },
  {
    claim: 'Vertrauen sitzt an den Rändern',
    body: 'ICP-Anmeldenummer, Gewerbelizenz und offizielle Siegel gehören üblicherweise in den Fußbereich. QR-Codes im oberen Bildausschnitt verankern zusätzlich die Glaubwürdigkeit.',
    visual: 'trust',
  },
  {
    claim: 'WeChat ist Infrastruktur',
    body: 'QR-Codes, Mini-Program-Links, Teilen-Endpunkte und Kundendienst-Kontakte gehören zur Grundausstattung einer China-Seite, nicht zu ihren optionalen Funktionen.',
    visual: 'wechat',
  },
  {
    claim: 'Schrift trägt Gewicht',
    body: 'PingFang SC, Noto Sans SC oder Source Han lassen sich gut mit Inter oder Systemschriften kombinieren. Zeichenabstand und Zeilenhöhe weichen dabei spürbar von der Lateinschrift ab.',
    visual: 'type',
  },
  {
    claim: 'Die untere Leiste ist der Home-Button',
    body: 'Eine fixierte untere Navigation übernimmt im chinesischen mobilen Web die Rolle des Home-Buttons: fünf Tippziele, stets sichtbar und stets mit dem Daumen erreichbar.',
    visual: 'nav',
  },
];

const audiences = [
  { label: 'Von Grund auf neu', description: 'Sie bauen eine WordPress-Seite für China und wollen das Design von Anfang an richtig anlegen.', image: '/images/audiences/building-site-china-design.webp' },
  { label: 'Schwache Leistung', description: 'Ihre Seite ist in China bereits live, doch sie liefert nicht, und Sie vermuten das Design als Ursache.', image: '/images/audiences/live-site-not-performing.webp' },
  { label: 'Kampagnenseiten', description: 'Ihr Marketingteam braucht Seiten für chinesische Verbraucher, denen man die Übersetzung aus dem Englischen nicht anmerkt.', image: '/images/audiences/campaign-chinese-consumers.webp' },
  { label: 'Globales Design anpassen', description: 'Sie verfügen über ein solides globales Designsystem und suchen jemanden, der es fachkundig für China anpasst.', image: '/images/audiences/global-design-adapt-china.webp' },
];

const marqueeWords = [
  '移动优先', 'Mobile-first',
  '微信', 'WeChat',
  '百度', 'Baidu',
  '抖音', 'Douyin',
  '备案', 'ICP-Anmeldung',
  'Gutenberg',
  '中文排版', 'CN-Typografie',
  '信任信号', 'Vertrauenssignale',
  '色彩文化', 'Kulturelle Farbe',
  '密度优先', 'Dichte zuerst',
  'PingFang SC',
  'UC · QQ · Chrome',
];
const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de" jsonLd={pageLd}>

  <!-- HERO: editorial split with phone mockup -->
  <section class="relative bg-[#0a0a0d] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px]"></div>
      <div class="absolute -bottom-40 right-1/3 w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/5 blur-[100px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(242,95,41,0.08),transparent_50%)]"></div>
      <!-- subtle grid overlay -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrümelnavigation" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/de/leistungen/" class="hover:text-white/70 transition-colors no-underline">Leistungen</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">UX/UI-Design</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 lg:pb-32">
        <!-- Text -->
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">UX / UI · 设计</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Gestalten <span class="italic font-light text-white/80">für</span><br/>
            die Art, wie chinesische Nutzer
            <span class="block mt-3 text-[var(--color-brand-orange)]">tatsächlich surfen.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            WordPress-Erlebnisse, die sich für Nutzer in China nativ anfühlen: kulturell verankert, konsequent Mobile-first und um die Plattformen herum entworfen, die Chinas Internet tragen.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/de/kontakt/" variant="primary" size="lg">Ihr Designprojekt starten</Button>
            <a href="#what-we-offer" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              Das System ansehen
              <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <!-- Visual: artboard-framed phone mockup -->
        <div class="col-span-12 lg:col-span-5 mt-16 lg:mt-0">
          <div class="relative">
            <div class="absolute -inset-8 bg-[var(--color-brand-orange)]/15 rounded-[40px] blur-3xl -z-10"></div>

            <!-- Artboard label -->
            <div class="flex items-center justify-between mb-3 px-1">
              <div class="flex items-center gap-2 text-[11px] font-mono text-white/40">
                <span class="w-1.5 h-1.5 rounded-sm bg-[var(--color-brand-orange)]"></span>
                <span>home-mobile.fig</span>
              </div>
              <div class="text-[11px] font-mono text-white/30">375 × 812</div>
            </div>

            <div class="relative rounded-3xl overflow-hidden border border-white/10 bg-gradient-to-br from-white/[0.04] to-transparent">
              <img
                src="/images/ux-design-china-mobile-wordpress-mockup.webp"
                alt="Eine mobile WordPress-Startseite, gestaltet für chinesische Nutzer, mit roten Akzenten, WeChat-QR-Code und ICP-Lizenz"
                class="w-full h-auto block"
                loading="eager"
                decoding="async"
              />
            </div>

            <!-- Floating chip: Mobile-first -->
            <div class="hidden sm:flex absolute -left-6 top-20 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <span class="w-2 h-2 rounded-full bg-green-400"></span>
              <span class="text-xs font-medium text-white">Mobile-first</span>
            </div>

            <!-- Floating chip: trust signals -->
            <div class="hidden sm:flex absolute -right-4 bottom-24 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <svg class="w-3.5 h-3.5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              <span class="text-xs font-medium text-white">WeChat + ICP</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VOCABULARY MARQUEE -->
  <section aria-hidden="true" class="bg-[#0a0a0d] border-y border-white/5 overflow-hidden py-5">
    <div class="marquee-mask">
      <div class="marquee-track flex items-center gap-10 whitespace-nowrap">
        {[...marqueeWords, ...marqueeWords].map((word, i) => (
          <div class="flex items-center gap-10 flex-shrink-0">
            <span class={`text-base font-medium ${i % 2 === 0 ? 'text-white/40' : 'text-white/70'}`}>{word}</span>
            <span class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]/60 flex-shrink-0"></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="bg-white border-b border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-[var(--color-surface-border)] py-10 lg:py-12 -mx-4 sm:-mx-6 lg:-mx-8">
        {stats.map((stat) => (
          <div class="px-4 sm:px-6 lg:px-8">
            <div class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] tracking-tight leading-none">
              {stat.value}
            </div>
            <div class="mt-3 text-sm text-[var(--color-text-muted)]">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-12 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-5">
            Das Problem
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] mb-8 tracking-tight">
            Warum westliches Design<br/>
            <span class="text-[var(--color-text-muted)]">in China nicht greift.</span>
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Ein Unternehmen bringt seine WordPress-Seite im Heimatmarkt zum Konvertieren, startet sie in China, und die Absprungrate schnellt nach oben. Technisch wirkt die Seite einwandfrei, doch für jeden, der aus Shanghai oder Chengdu surft, stimmt etwas daran nicht.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            Chinesische Internetnutzer sind nicht mit demselben Web aufgewachsen. Wie sie navigieren und wie viele Informationen sie gleichzeitig sehen möchten, ist von WeChat, Taobao und Douyin geprägt.
          </p>
          <blockquote class="border-l-2 border-[var(--color-brand-orange)] pl-6 py-1">
            <p class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
              Eine Designsprache, die in Chicago konvertiert, trägt in Chongqing nicht von selbst.
            </p>
          </blockquote>
        </div>

        <div class="col-span-12 lg:col-span-6">
          <div class="relative">
            <div class="rounded-2xl overflow-hidden border border-[var(--color-surface-border)] shadow-xl shadow-black/5">
              <img
                src="/images/ux-design-china-vs-western-mobile-comparison.webp"
                alt="Zwei Telefone nebeneinander: links eine schlichte Seite im westlichen Stil, rechts eine dichte Seite im chinesischen Stil mit WeChat-QR und Vertrauenssignalen"
                class="w-full h-auto block"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="mt-5 grid grid-cols-2 gap-4 text-center">
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Westlicher Stil</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Schlicht, geringes Engagement</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-1">China-nativer Stil</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Dicht, konvertiert</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CHINA DESIGN INTELLIGENCE GRID -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-20">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-4">
            Wissen aus der Praxis
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] tracking-tight">
            Sechs Dinge, die uns das Gestalten<br/>für China gelehrt hat.
          </h2>
        </div>
        <p class="text-base text-[var(--color-text-muted)] max-w-md font-mono uppercase tracking-wider text-xs">
          A.01 bis A.06 / UX-Heuristiken für China
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {intelligence.map((card, idx) => (
          <article class="group relative rounded-2xl bg-white border border-[var(--color-surface-border)] overflow-hidden hover:border-[var(--color-brand-orange)]/40 hover:shadow-xl hover:shadow-black/5 transition-all duration-300">
            <!-- Visual artifact area -->
            <div class="relative h-44 bg-gradient-to-br from-[var(--color-surface-light)] to-white border-b border-[var(--color-surface-border)] overflow-hidden">
              <div class="absolute top-3 left-4 text-[11px] font-mono text-[var(--color-text-muted)] uppercase tracking-wider">
                A.0{idx + 1}
              </div>

              {card.visual === 'colour' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-end gap-1">
                    <div class="w-12 h-20 rounded-md bg-[#E11D2E] shadow-md"></div>
                    <div class="w-12 h-16 rounded-md bg-[#F25F29] shadow-md"></div>
                    <div class="w-12 h-12 rounded-md bg-[#D4AF37] shadow-md"></div>
                    <div class="w-12 h-8 rounded-md bg-[#52C41A] shadow-md"></div>
                  </div>
                </div>
              )}

              {card.visual === 'density' && (
                <div class="absolute inset-0 flex items-center justify-center px-8">
                  <div class="w-full max-w-[180px] space-y-1.5">
                    <div class="h-3 bg-[var(--color-brand-orange)]/80 rounded-sm"></div>
                    <div class="grid grid-cols-3 gap-1.5">
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm"></div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm w-3/4"></div>
                    <div class="grid grid-cols-2 gap-1.5">
                      <div class="h-6 bg-[var(--color-brand-orange)]/30 rounded-sm"></div>
                      <div class="h-6 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'trust' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-center gap-2.5">
                    <div class="px-3 py-2 rounded-md border border-[var(--color-surface-border)] bg-white text-[10px] font-mono text-[var(--color-text-body)]">
                      ICP 沪B2-2024<br/>0123456号
                    </div>
                    <div class="w-12 h-12 rounded-md bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center text-white text-[10px] font-bold">营业<br/>执照</div>
                    <div class="w-10 h-10 rounded-md bg-[#52C41A] flex items-center justify-center">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'wechat' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative w-24 h-24 bg-white rounded-xl border border-[var(--color-surface-border)] p-2">
                    <div class="grid grid-cols-7 gap-px h-full w-full">
                      {Array.from({ length: 49 }).map((_, i) => {
                        const filled = [0,1,2,3,5,6,8,12,14,15,18,20,22,24,28,29,30,32,34,36,40,42,43,44,46,47,48].includes(i);
