  {
    n: '05',
    cn: 'ГӨВәВӨГӨВ»Лң',
    title: 'Schriftliche ГғЕ“bergabe',
    body: 'Das Roadmap-Dokument, dazu ein 90-minГғВјtiges Durchsprache-GesprГғВӨch, in dem wir die Befunde und die empfohlenen nГғВӨchsten Schritte gemeinsam durchgehen.',
    output: 'Roadmap-PDF + GesprГғВӨch',
  },
];

const audiences = [
  {
    label: 'Erster China-Eintritt',
    description: 'Internationale Marken, die ihre erste echte China-PrГғВӨsenz aufbauen und die grundlegenden Entscheidungen beim ersten Mal richtig treffen mГғВјssen.',
    image: '/images/audiences/first-time-china-entry.webp',
  },
  {
    label: 'Schwache China-Seite oder schwacher Stack',
    description: 'Marken mit einer bestehenden China-PrГғВӨsenz, die nicht liefert, und einer GeschГғВӨftsleitung, die nach den GrГғВјnden fragt. Die Ursache liegt meist in einem strategischen MissverhГғВӨltnis unterhalb der technischen Ebene.',
