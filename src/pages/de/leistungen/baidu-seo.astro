---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'baidu-seo'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const whyDifferent = [
  {
    n: '01',
    cn: '算法',
    title: 'Baidu belohnt andere Dinge',
    body: '知心算法 (Zhixin) erkennt inzwischen über 200 semantische Beziehungen in chinesischen Suchanfragen. 飓风算法 3.0 bestraft schlecht redigierte KI-Inhalte. Wort für Wort übersetzter Text verliert schnell seine Positionen.',
    tag: 'Ranking-Signale',
    chips: ['知心算法', '飓风算法 3.0', 'Original ZH', 'Semantik'],
  },
  {
    n: '02',
    cn: '蜘蛛',
    title: 'Baidu Spider arbeitet in einem anderen Takt',
    body: 'Baidu Spider rendert JavaScript um Jahre verzögert gegenüber Googlebot, weshalb clientseitig geladene Inhalte oft unsichtbar bleiben. Mobile-First-Crawling ist Pflicht, eine Ladezeit unter 3 Sekunden eine harte Grenze, HTTPS ein positives Signal.',
    tag: 'Crawl und Rendering',
    chips: ['Baiduspider', 'Mobile First', 'SSR / static', 'HTTPS'],
  },
  {
    n: '03',
    cn: '主机',
    title: 'Der Standort des Hostings ist ein Ranking-Signal',
    body: 'Seiten ohne ICP-Registrierung werden im Index benachteiligt. Bei identischem Inhalt schlägt ein Festland-Hosting eine Seite in Hongkong oder im Ausland. Strukturell, nicht zufällig.',
    tag: 'Infrastruktur',
    chips: ['ICP', 'Festland-Host', 'Aliyun', 'Tencent Cloud'],
  },
  {
    n: '04',
    cn: '推送',
    title: 'Das Einreichungsmodell funktioniert anders',
    body: 'Baidu findet Ihre Inhalte nicht von allein. Es erwartet, dass Sie neue URLs binnen Minuten nach der Veröffentlichung über 主动推送 (Active Push) anstoßen. Wir verdrahten den Push direkt im CMS.',
    tag: 'Einreichung',
    chips: ['主动推送', '自动推送', 'Sitemap', '手工提交'],
  },
  {
    n: '05',
    cn: '关键词',
    title: 'Keyword-Recherche läuft auf Chinesisch, vom weißen Blatt',
    body: 'Was chinesische Nutzer tatsächlich suchen, hat mit einer übersetzten englischen Keyword-Liste fast nichts gemein. Wir arbeiten mit 百度指数 (Baidu Index) und 百度关键词规划师, um die Karte vom weißen Blatt aufzubauen.',
    tag: 'Recherche',
    chips: ['百度指数', '关键词规划师', '5118', 'Long Tail'],
  },
];

const services = [
  {
    n: '01',
    title: 'Technisches SEO für Baidu',
    body: 'Website-Verifizierung auf 百度搜索资源平台. Alle vier Methoden zur URL-Einreichung in Prioritätsreihenfolge eingerichtet, dazu 死链提交, 站点子链 und die Prüfung des Mobile-First-Crawls. Die Geschwindigkeit messen wir aus dem chinesischen Festland heraus.',
    bullets: [
      '主动推送 (Active Push) direkt im CMS verdrahtet für die Einreichung in Echtzeit.',
      '自动推送 (Auto Push) per JS, um URLs aufzufangen, die vor dem CMS-Hook besucht werden.',
      'Vollständige Sitemap, automatisch aktualisiert (50.000 URLs / max. 10 MB pro Datei).',
      '手工提交 als letztes Mittel für Seiten mit hohem Wert.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Muttersprachliche chinesische Inhalte, für Baidu strukturiert',
    body: 'Baidu honoriert 深度原创. 飓风算法 stuft dünne oder kopierte Seiten zurück, 飓风算法 3.0 zielt auf KI-Inhalte ohne menschliche Redaktion. Wir schreiben mit muttersprachlichen chinesischen Redakteuren: Langform-Struktur, Schema-Markup, klare faktische Antworten, die KI-Engines zitieren können.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Optimierung für KI-Suche (文心X1, DeepSeek, Doubao, Kimi)',
    body: 'Über 20 % der Baidu-Ergebnisse enthielten 2025 eine KI-generierte Antwort. Baidu bettet inzwischen 文心X1 und die Deep Search von DeepSeek direkt in die Ergebnisseite ein. Wir strukturieren Inhalte so, dass diese Engines sie lesen, verstehen und Ihre Marke in der Antwort nennen.',
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Autorität im chinesischen Web',
    body: 'Internationale Backlinks zählen auf Baidu kaum. Was die Rankings wirklich bewegt: 百度百科, 百度知道, 百度贴吧, 知乎, 百家号, 百度爱采购, dazu B2B-Branchenportale und Signale von WeChat und Weibo. Wir bauen die Präsenz auf und steuern die Verbreitung.',
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Laufende Optimierung und Reaktion auf den Algorithmus',
    body: 'Baidu kündigt die meisten Updates nicht an, und die, die es ankündigt, erscheinen auf Chinesisch im Blog von 百度搜索资源平台. In den letzten zwölf Monaten haben wir die Erweiterungen von 知心算法, 飓风算法 3.0 und die Integration von 文心X1 und DeepSeek verfolgt. Jedes davon hat verändert, was gewinnt.',
    tag: 'p.30',
  },
];

const tools = [
  {
    name: '百度搜索资源平台',
    en: 'Baidu Webmaster-Plattform',
    cn: '资源',
    body: 'Die offizielle Webmaster-Konsole: Website-Verifizierung, URL-Einreichung, Sitemaps, Indexierungsberichte, Mobile-Test, Meldung toter Links, Feed mit Algorithmus-Ankündigungen.',
    feature: true,
    items: ['Website-Verifizierung', 'URL-Push-API', 'Sitemap', 'Indexierungsberichte', 'Mobile-Test', '死链提交', 'Algo-Feed'],
  },
  {
    name: '百度统计',
    en: 'Baidu Tongji',
    cn: '统计',
    body: 'Das Baidu-Pendant zu Google Analytics. Unverzichtbar für jede ernst gemeinte Messung auf der China-Seite.',
  },
  {
    name: '百度指数',
    en: 'Baidu Index und Keyword Planner',
    cn: '指数',
    body: 'Der Ausgangspunkt für eine echte Keyword-Recherche auf Chinesisch, statt einer übersetzten englischen Liste. Im Zusammenspiel mit 百度关键词规划师.',
  },
  {
    name: '5118 · 爱站 · 站长之家',
    en: 'Chinesische SEO-Tools von Drittanbietern',
    cn: '工具',
    body: 'Oft tiefere Wettbewerbsanalyse und längere Ranking-Historie als die offiziellen Werkzeuge.',
  },
  {
    name: 'Baidu Webmaster-APIs',
    en: 'Active-Push-Integration',
    cn: '接口',
    body: 'Für 主动推送 verdrahten wir direkt im CMS, statt auf Dashboards angewiesen zu sein.',
  },
];

const stages = [
  {
    n: '01',
    cn: '审计',
    title: 'Baidu-Audit',
    body: 'Wir testen aus dem chinesischen Festland heraus: Indexierung, Crawl-Gesundheit bei Baiduspider, inhaltliche Tiefe, ICP- und Hosting-Signale, dazu die aktuelle Position bei 50 bis 100 benannten Keywords.',
    output: 'Audit-Bericht',
  },
  {
    n: '02',
    cn: '关键词',
    title: 'Keyword-Karte',
    body: 'Muttersprachliche chinesische Recherche über 百度指数 und 关键词规划师. Wir bauen eine Keyword-Karte mit Intent-Tags, Suchvolumen und einem Content-Briefing je Cluster.',
    output: 'Keyword-Karte und Briefings',
  },
  {
    n: '03',
    cn: '部署',
    title: 'Technischer Rollout',
    body: 'Website-Verifizierung, 主动推送 im CMS verdrahtet, Sitemaps, Schema-Markup, Korrekturen für Mobile und Geschwindigkeit, llms.txt und die Struktur für die KI-Suche werden gemeinsam ausgeliefert.',
    output: 'Live-Indexierung',
  },
  {
    n: '04',
    cn: '权威',
    title: 'Autorität und Inhalte',
    body: 'Muttersprachliche chinesische Inhalte, dazu Verbreitung auf 百家号, 知乎, 百度知道 und den passenden Branchenportalen. 百度百科-Einträge legen wir nach, sobald die Marke bereit ist.',
    output: 'Zitate und Ranking-Anstieg',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Überwachen und nachsteuern',
    body: 'Wöchentliches Ranking-Tracking, monatlicher schriftlicher Bericht, Reaktion auf Algorithmus-Updates noch in derselben Woche. Baidu verändert sich; das Team, das nicht hinschaut, verliert Positionen, ohne den Grund zu kennen.',
    output: 'Monatlicher schriftlicher Bericht',
  },
];

const stats = [
  { value: '24-72h', label: 'Indexierungszeit über 主动推送', sub: 'Neue URLs binnen Stunden in Baidu, nicht erst nach Wochen.' },
  { value: '11', label: 'Algo-Updates, die wir 2025 verfolgt haben', sub: '知心算法, 飓风算法 3.0, Integration von 文心X1.' },
  { value: '20%+', label: 'Baidu-Ergebnisse mit KI-Antworten', sub: '文心X1 und DeepSeek sind jetzt in den SERPs eingebettet.' },
];

const audiences = [
  {
    label: 'Ausländische Marken, die auf Baidu unsichtbar sind',
    description: 'Unternehmen mit einer chinesischen Website, die monatlich weniger als fünfzig organische Besuche aus Baidu erhält, obwohl auf denselben Keywords bezahlte Anzeigen laufen.',
    image: '/images/audiences/no-organic-traffic-china.webp',
  },
  {
    label: 'Marken mit altem, übersetztem Inhalt',
    description: 'Ausländische Websites, deren chinesische Seiten reine Übersetzungen aus dem Englischen geblieben und seit dem Start nicht aktualisiert worden sind.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marken, die von null starten',
    description: 'Unternehmen, die bereits wissen, dass sie ab Tag eins Baidu-Sichtbarkeit brauchen, und sie sauber in den Bau einplanen wollen, statt sie drei Monate nach dem Start nachzurüsten.',
    image: '/images/audiences/launching-chinese-market.webp',
  },
  {
    label: 'Marken, die es mit der KI-Suche ernst meinen',
    description: 'Unternehmen, die bemerkt haben, dass KI-generierte Antworten oben in den Baidu-Ergebnissen erscheinen, und zitiert statt umgangen werden wollen.',
    image: '/images/audiences/seo-pro-needs-baidu.webp',
  },
];

const marqueePhrases = [
  '百度', 'Baidu',
  '主动推送', 'Active Push',
  '知心算法', '飓风算法 3.0',
  '文心X1', 'DeepSeek',
  '百家号', '知乎', '百度百科',
  'ICP registriert',
  'Festland-Hosting',
  'Bereit für KI',
];

const faqs = [
  {
    id: 'outside-china',
    question: 'Lässt sich Baidu-SEO von außerhalb Chinas betreiben?',
    answer: [
      'Technisch ja, aber mit erheblichen Grenzen. Der Verifizierungsablauf von Baidu erwartet chinesische Telefonnummern, das Dashboard ist auf Chinesisch, die Dokumentation ist nicht übersetzt, und viele Baidu-Tools drosseln oder sperren ausländische IP-Adressen. Die meisten ausländischen Teams, die es versuchen, geben innerhalb eines Quartals auf. Wir betreiben es von Shanghai aus, weil dort die Arbeit tatsächlich stattfindet.',
    ],
  },
  {
    id: 'how-long',
    question: 'Wie lange dauert es, bis sich Ergebnisse zeigen?',
    answer: [
      'Bewegung bei Long-Tail-Keywords in 6 bis 10 Wochen. Wettbewerbsstarke Head-Terms in mindestens 3 bis 6 Monaten. Echtes organisches Wachstum auf einer Kurve von 6 bis 12 Monaten. Indexaufnahme neuer Inhalte über 主动推送 in 24 bis 72 Stunden.',
    ],
  },
  {
    id: 'no-icp',
    question: 'Was, wenn unsere Website keine ICP-Registrierung hat?',
    answer: [
      'Sie wird ranken, aber mit messbarem Nachteil. Baidu behandelt Seiten aus Hongkong und Offshore als ausländisch, crawlt sie seltener und stuft sie niedriger ein als Festland-Alternativen. Für Marken, die es mit Baidu ernst meinen, ist eine ICP-Registrierung auf Festland-Hosting die richtige Entscheidung.',
    ],
  },
  {
    id: 'baidu-ads',
    question: 'Betreiben Sie auch Baidu-Ads-Kampagnen (SEM)?',
    answer: [
      'Nein, wir konzentrieren uns auf organisches Baidu-SEO. Bezahlte Suche ist eine eigene Disziplin und wird von anderen Teams betreut. Wir arbeiten Seite an Seite mit Paid-Media-Partnern und sorgen dafür, dass die SEO-Inhalte und die bezahlten Landingpages einander nicht in die Quere kommen.',
    ],
  },
  {
    id: 'chinese-content',
    question: 'Wie hängt das mit unserer Arbeit an chinesischen Inhalten zusammen?',
    answer: [
      'Eng. Baidu-SEO ohne muttersprachliche chinesische Inhalte ist verschwendete Mühe. Die meisten unserer Kunden nehmen beides als ein Mandat, bei dem unser Content-Team und unser Baidu-SEO-Team von derselben Keyword-Karte und derselben Content-Architektur aus arbeiten.',
    ],
  },
  {
    id: 'ai-search',
    question: 'Was ist mit der KI-Sichtbarkeit auf Doubao, Kimi, DeepSeek, 文心X1?',
    answer: [
      'Zunehmend dasselbe Projekt. Baidu bettet inzwischen 文心X1 und die Deep Search von DeepSeek in über 20 % seiner Ergebnisseiten ein. Inhalte für KI-Engines zu strukturieren (klare faktische Antworten, Schema-Markup, llms.txt, semantische Struktur) deckt sich weitgehend mit der Struktur, die Baidu erwartet. Wir machen beides als ein Arbeitspaket.',
    ],
  },
  {
    id: 'links',
    question: 'Bauen Sie Links auf?',
    answer: [
      'Wir bauen Autorität über chinesische Plattformen auf (百度百科, 百度知道, 知乎, 百家号, 百度爱采购, B2B-Branchenportale), wo Präsenz die Baidu-Rankings tatsächlich bewegt. Generische Backlinks von einem westlichen Link-Broker zu kaufen, funktioniert nicht und birgt das Risiko einer 飓风算法-Strafe. Autorität in China verdient man sich auf chinesischen Plattformen, oder gar nicht.',
    ],
  },
  {
    id: 'measurement',
    question: 'Wie messen Sie den Erfolg?',
    answer: [
      'Indexaufnahme (Anzahl der von Baidu indexierten Seiten), Keyword-Rankings (Position je Suchanfrage, wöchentlich verfolgt), organischer Traffic aus Baidu (über 百度统计), Conversion-Attribution und Sichtbarkeitsanteil gegenüber drei bis fünf benannten Wettbewerbern. Die Berichterstattung ist eine monatliche schriftliche Zusammenfassung, ergänzt um ein Live-Dashboard.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: 'Was passiert, wenn Baidu seinen Algorithmus ändert?',
    answer: [
      'Wir verfolgen die Ankündigungen auf 百度搜索资源平台 wöchentlich und reagieren noch in derselben Woche, sobald etwas Wesentliches ausgeliefert wird. In den letzten zwölf Monaten haben wir die Erweiterungen von 知心算法, 飓风算法 3.0 gegen KI-Inhalte, die Integration von 文心X1 in die Suchergebnisse und mehrere kleinere Verschiebungen durchgearbeitet.',
    ],
  },
  {
    id: 'cost',
    question: 'Was kostet es?',
    answer: [
      'Das hängt vom Umfang ab: Größe der Website, Content-Volumen, Wettbewerbsintensität und ob das Mandat auch die Produktion chinesischer Inhalte und die Optimierung für die KI-Suche umfasst. Beschreiben Sie uns den Umfang, und wir senden innerhalb von zwei Werktagen ein verbindliches Angebot.',
    ],
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'de-DE',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer.join('\n\n') },
  })),
};

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd, faqLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-search-results.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrümel" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/de/leistungen/" class="hover:text-white/70 transition-colors no-underline">Leistungen</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Baidu-SEO</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Baidu-SEO</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Hinter der Großen Firewall, in Shanghai</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Gefunden werden auf
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">百度.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Wo die chinesische Suche beginnt.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Baidu hat einen eigenen Crawler, einen eigenen Index, eine eigene Einreichungs-API und einen eigenen Algorithmus-Zyklus, dazu eine KI-Suchschicht (文心X1, DeepSeek), die über zwanzig Prozent der Ergebnisse schreibt. <span class="text-white font-medium">Von Shanghai aus betrieben, mit den eigenen Werkzeugen von Baidu.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">20</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Jahre auf Baidu</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">200</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">知心-Beziehungen verfolgt</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">72h</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Indexierung über 主动推送</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/de/kontakt/" variant="primary" size="lg">Baidu-Audit anfragen</Button>
            <Button href="#what-we-do" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Die Arbeitspakete ansehen</Button>
          </div>
        </div>

        <!-- Visual: geschichtetes Baidu-Konsolen-Mockup -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Hintere Karte (verblasst, "kein SEO") -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Keine Registrierung</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">Website außerhalb des Festlands</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Index: 4 / 312 Seiten
              </div>
            </div>

            <!-- Vorne: Baidu-Konsolenkarte -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
