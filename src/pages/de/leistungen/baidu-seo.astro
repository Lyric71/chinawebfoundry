          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WARUM BAIDU ANDERS IST -->
  <section id="differences" class="relative section-spacing bg-gradient-to-b from-[var(--color-surface-light)] to-white overflow-hidden scroll-mt-32">
