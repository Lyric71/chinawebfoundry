---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/global/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-de', 'china-hosting'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const proofStats = [
  { value: '0,8', suffix: ' s', label: 'Mittlere Ladezeit auf einem Server in Festland-China', sub: 'Gemessen auf einem chinesischen Mittelklasse-Smartphone, Shanghai-Verbindung' },
  { value: '99,97', suffix: '%', label: 'Verfügbarkeit über die Websites, die wir derzeit hosten', sub: 'Rollierender 30-Tage-Durchschnitt' },
  { value: '100', suffix: '%', label: 'Erfolgsquote bei ICP-Registrierungen bisher', sub: 'Jeder Antrag ist am Ende durchgegangen' },
  { value: '20', suffix: '+', label: 'Jahre vor Ort in Shanghai', sub: 'Dasselbe Team, dieselbe Stadt, seit 2005' },
];

const sectionLinks = [
  { id: 'problem', label: 'Das Problem' },
  { id: 'options', label: 'Hosting-Optionen' },
  { id: 'included', label: 'Was enthalten ist' },
  { id: 'icp', label: 'ICP-Lizenz' },
  { id: 'compliance', label: 'Datenkonformität' },
  { id: 'timeline', label: 'Zeitplan' },
  { id: 'performance', label: 'Performance' },
  { id: 'faq', label: 'FAQ' },
];

const hostingOptions = [
  {
    id: 'mainland',
    name: 'Chinesisches Festland',
    tag: 'ICP erforderlich',
    tagline: 'Server in Peking, Shanghai, Shenzhen oder Guangzhou.',
    headline: 'Die belastbare Lösung mit Ladezeiten unter einer Sekunde und vollem Baidu-Schub.',
    body: 'Ihre Website läuft auf Servern innerhalb von Festland-China. Je nach Projekt setzen wir auf Aliyun, Tencent Cloud oder Huawei Cloud, und da wir seit Jahren mit allen dreien arbeiten, wissen wir genau, was jeder einzelne Anbieter leistet.',
    detail: 'Die Ladezeiten liegen unter einer Sekunde. Baidu verschafft Seiten, die eine ICP-Lizenz auf lokalen Servern halten, einen spürbaren Ranking-Vorteil, und der zählt erheblich, sobald die organische Suche Teil Ihrer China-Strategie ist. Die vollständige ICP-Registrierung übernehmen wir ebenfalls. Genau an dieser Stelle scheitern die meisten ausländischen Unternehmen, wenn sie keine Unterstützung vor Ort haben.',
    fit: 'Marken, die sich dem chinesischen Markt verschrieben haben, alle, die es mit Baidu-SEO ernst meinen, E-Commerce, Websites, die Daten chinesischer Nutzer erfassen.',
    image: '/images/hosting-china-cdn-map.webp',
    imageAlt: 'Eine stilisierte Karte von Festland-China mit leuchtenden Rechenzentrumsknoten in Peking, Shanghai, Shenzhen und Guangzhou, verbunden durch ein CDN-Netz',
    accent: 'orange',
    metrics: [
      { label: 'Ladezeit', value: '< 1 s' },
      { label: 'ICP', value: 'Erforderlich' },
      { label: 'Baidu-Schub', value: 'Groß' },
      { label: 'Bis live', value: '6 bis 10 Wo.' },
    ],
  },
  {
    id: 'hong-kong',
    name: 'Hongkong',
    tag: 'Kein ICP nötig',
    tagline: 'Schnell online, ohne behördliche Registrierung.',
    headline: 'Eine Brücke zum Festland, die sich schnell starten lässt.',
    body: 'Solange noch keine ICP-Lizenz vorliegt, bringt Hongkong Sie schneller online, denn eine behördliche Registrierung ist hier nicht erforderlich. Mit der richtigen CDN- und Caching-Einrichtung erreichen Sie in Festland-China Ladezeiten von zwei bis vier Sekunden. Gegenüber einer Auslieferung aus Frankfurt oder Virginia ist das ein deutlicher Unterschied.',
    detail: 'Wir nutzen diese Variante häufig als Brückenlösung, während Kunden auf ihre ICP-Registrierung warten oder noch entscheiden, ob sie sich auf eine Festland-Präsenz festlegen. Einige unserer langjährigen Kunden sind über Jahre bei Hongkong geblieben und sahen nie einen Grund umzuziehen.',
    fit: 'Schnelle Starts, Übergangslösungen, Projekte, die noch kein ICP bekommen können, Marken, die den chinesischen Markt testen, bevor sie sich festlegen.',
    image: '/images/hosting-hong-kong-bridge.webp',
    imageAlt: 'Die Skyline von Hongkong zur blauen Stunde von der anderen Seite des Victoria Harbour, mit neonorangen Lichtspuren, die das Wasser Richtung Festland-China überqueren',
    accent: 'sky',
    metrics: [
      { label: 'Ladezeit', value: '2 bis 4 s' },
      { label: 'ICP', value: 'Nicht nötig' },
      { label: 'Baidu-Schub', value: 'Gering' },
      { label: 'Bis live', value: '2 bis 3 Wo.' },
    ],
  },
  {
    id: 'dual-stack',
    name: 'Dual-Stack',
    tag: 'Weltweit + China',
    tagline: 'Festland für China-Besucher. Bestehender globaler Stack für alle anderen.',
    headline: 'Eine Marke, zwei Architekturen, die beide schnell sind.',
    body: 'Manche Kunden können nicht allein für China optimieren und den Rest der Welt außer Acht lassen, denn die Website muss überall funktionieren. Für diese Fälle bauen wir eine Aufteilung: Besucher aus China landen auf einem Festland-Server, alle anderen auf Ihrem bestehenden globalen Setup.',
    detail: 'Das DNS übernimmt das Routing automatisch. Ein Backend treibt beide Seiten an, sodass die Inhalte synchron bleiben. Die China-Website verfügt über ihre eigene ICP-Registrierung, die globale Website läuft an ihrem bisherigen Standort weiter. Wir betreuen beide Seiten als ein einziges Mandat, damit das Redaktionsteam nur einen Arbeitsablauf vor sich hat.',
    fit: 'Globale Marken mit einem ernst zu nehmenden China-Publikum, multinationaler E-Commerce, Websites, bei denen sich weder China noch der Rest der Welt zurückstellen lässt.',
    image: '/images/hosting-dual-stack-globe.webp',
    imageAlt: 'Isometrische 3D-Illustration eines Globus mit zwei leuchtenden Server-Clustern (orange über China und cyan über dem Westen) mit Routing-Pfaden, die den Traffic nach Geografie aufteilen',
    accent: 'emerald',
    metrics: [
      { label: 'Ladezeit', value: '< 1 s in CN' },
      { label: 'ICP', value: 'Erforderlich (CN)' },
      { label: 'Baidu-Schub', value: 'Groß' },
      { label: 'Bis live', value: '8 bis 12 Wo.' },
    ],
  },
];

const includedItems = [
  {
    icon: 'server',
    title: 'Server-Einrichtung und -Optimierung',
    body: 'Hosting, abgestimmt auf Ihren Stack, mit China-kompatiblem SSL, Firewalls auf Serverebene und DDoS-Schutz, konfiguriert für die tatsächlichen Verhältnisse hinter der Firewall.',
  },
  {
    icon: 'cdn',
    title: 'China-CDN konfiguriert',
    body: 'Aliyun- oder Tencent-Cloud-CDN angebunden. Ihre Assets werden von Knoten in der Nähe Ihrer Nutzer in Shanghai oder Chengdu ausgeliefert, statt von der anderen Seite des Pazifiks.',
  },
  {
    icon: 'monitor',
    title: 'Überwachung aus China heraus',
    body: 'Die meisten Werkzeuge prüfen von außerhalb der Firewall, weshalb ihre Dashboards ein falsches Bild zeichnen. Wir überwachen aus China heraus. Was nach einem Detail klingt, macht den entscheidenden Unterschied.',
  },
  {
    icon: 'backup',
    title: 'Tägliche Backups und Wiederherstellungsplan',
    body: 'Die Backups laufen täglich automatisiert, werden extern gespeichert und erlauben eine Point-in-Time-Wiederherstellung; der Notfallplan ist dokumentiert. Denn auch zuverlässige Systeme fallen gelegentlich aus.',
  },
  {
    icon: 'document',
    title: 'ICP-Registrierung von Anfang bis Ende übernommen',
    body: 'Wir übernehmen die Unterlagen, die Einreichungen und den gesamten Schriftwechsel mit der Provinzbehörde. Sie melden sich nie in einem chinesischen Hosting-Panel an und lesen keine Formulare auf Chinesisch.',
  },
  {
    icon: 'wrench',
    title: 'Laufende Wartung',
    body: 'Server-Patches, Sicherheitsupdates und Skalierung übernehmen wir, damit die Website weiterläuft, ohne dass Sie daran denken müssen.',
  },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Informationsseiten',
    timing: '20+ Werktage',
    body: 'Diese Registrierung gilt für Unternehmenswebsites, Blogs und Broschürenseiten, also für alles ohne Transaktionen. Sie ist die häufigste Wahl für ausländische Marken, die in China starten.',
    docs: ['Gewerbeanmeldung', 'Domain-Zertifikat', 'Ausweis des Website-Administrators', 'In China registrierte Gesellschaft'],
  },
  {
    code: '经营许可证',
    name: 'Kommerzielle ICP-Lizenz',
    type: 'Kommerzielle Tätigkeit',
    timing: '2 bis 3 Monate',
    body: 'Diese Lizenz ist für Websites mit Transaktionen erforderlich, also für E-Commerce, kostenpflichtige Dienste und jede kommerzielle Tätigkeit. Der Prozess dauert länger, verlangt mehr Unterlagen und wird von der Provinzbehörde genauer geprüft.',
    docs: ['Alles aus dem Bei\'an', 'Prüfung des Geschäftsumfangs', 'Kapitalnachweis', 'Erklärung des kommerziellen Zwecks'],
  },
];

const complianceLaws = [
  {
    abbr: 'PIPL',
    name: 'Gesetz zum Schutz personenbezogener Daten',
    body: 'Es regelt, wie personenbezogene Daten chinesischer Einwohner behandelt, gespeichert und übermittelt werden müssen, und kommt von allen chinesischen Gesetzen der DSGVO am nächsten.',
  },
  {
    abbr: 'CSL',
    name: 'Cybersicherheitsgesetz',
    body: 'Dieses grundlegende Datengesetz gilt seit 2017. Es legt die Regeln für Netzbetreiber und kritische Infrastruktur fest und definiert die Anforderungen an die Datenlokalisierung.',
  },
  {
    abbr: 'DSL',
    name: 'Datensicherheitsgesetz',
    body: 'Stuft Daten nach Sensibilität ein und verlangt einen abgestuften Schutz. Es betrifft, wie Daten chinesischer Nutzer gespeichert und über Grenzen bewegt werden.',
  },
];

const timelines = [
  {
    label: 'Hongkong',
    title: 'Hongkong-Start',
    duration: '2 bis 3 Wochen',
    accent: 'sky',
    phases: [
      { name: 'Einrichtung', width: '40%' },
      { name: 'Konfiguration', width: '40%' },
      { name: 'Go-live', width: '20%' },
    ],
    note: 'Eine ICP-Registrierung ist nicht erforderlich, weshalb dies der schnellste Weg ist, für den chinesischen Markt online zu gehen.',
  },
  {
    label: 'Chinesisches Festland',
    title: 'Festland-China-Start',
    duration: '6 bis 10 Wochen',
    accent: 'orange',
    phases: [
      { name: 'ICP-Registrierung', width: '50%' },
      { name: 'Bau (parallel)', width: '35%' },
      { name: 'Umstellung', width: '15%' },
    ],
    note: 'Das ICP liegt auf dem kritischen Pfad. Wir starten die Registrierung an Tag eins und führen den restlichen Bau parallel.',
  },
  {
    label: 'Dual-Stack',
    title: 'Dual-Stack-Start',
    duration: '8 bis 12 Wochen',
    accent: 'emerald',
    phases: [
      { name: 'Architektur', width: '25%' },
      { name: 'CN-Seite + ICP', width: '45%' },
      { name: 'Routing + Umstellung', width: '30%' },
    ],
    note: 'Der Zeitplan hängt davon ab, wie die globale Website derzeit aufgesetzt ist; die Festland-China-Hälfte gibt den Takt vor.',
  },
];

const performanceRows = [
  { location: 'USA oder Europa', loadTime: 8, loadLabel: '8 bis 15+ Sekunden', icp: 'Nein', baiduBoost: 'Keiner', highlight: false },
  { location: 'Hongkong', loadTime: 2.5, loadLabel: '2 bis 4 Sekunden', icp: 'Nein', baiduBoost: 'Gering', highlight: false },
  { location: 'Chinesisches Festland', loadTime: 0.8, loadLabel: 'Unter 1 Sekunde', icp: 'Ja', baiduBoost: 'Groß', highlight: true },
];

const audiences = [
  { label: 'Für China bauen', description: 'Internationale Unternehmen, die eine ganz neue Website für den chinesischen Markt starten.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Langsam vom Festland', description: 'Unternehmen mit einer bestehenden Website, die für jeden Besucher aus China quälend langsam ist.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'ICP zum ersten Mal', description: 'Teams, die zum ersten Mal mit der ICP-Registrierung zu tun haben und sie verwirrend oder festgefahren finden.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'Konformer E-Commerce', description: 'Marken, die schnelles Hosting brauchen, das zugleich den chinesischen Vorschriften und dem lokalen Zahlungsökosystem entspricht.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];

const faqs = [
  {
    id: 'mainland-or-hk',
    question: 'Müssen wir Festland-Hosting nutzen, oder können wir einfach in Hongkong bleiben?',
    answer: 'Sie können in Hongkong bleiben, gerade für einen Übergangsstart. Allerdings behandelt Baidu Hongkong-Seiten als ausländisch, und dieser Ranking-Nachteil fällt spürbar ins Gewicht. Für Marken, die es langfristig mit dem chinesischen Markt ernst meinen, ist Festland-Hosting mit einer ICP-Registrierung die richtige Wahl.',
  },
  {
    id: 'aliyun-overseas',
    question: 'Brauchen wir ein ICP, wenn wir in der Überseeregion von Aliyun hosten?',
    answer: 'Ja, sofern Sie die Website auf den Festlandservern von Aliyun betreiben wollen. Aliyun unterhält auch Server in Hongkong und Singapur, die kein ICP verlangen; dort verlieren Sie allerdings die Festland-Performance und den Baidu-Schub.',
  },
  {
    id: 'cost',
    question: 'Was kostet China-Hosting?',
    answer: 'Die Kosten richten sich nach Traffic, Speicherbedarf und dem Umfang der Betreuung, den wir hinzunehmen. Die meisten Marketing-Websites liegen in einem vorhersehbaren monatlichen Rahmen, der tatsächlich niedriger ausfällt als ein vergleichbares verwaltetes WordPress-Hosting im Westen. Beschreiben Sie uns den Umfang, und Sie erhalten innerhalb von zwei Werktagen ein verbindliches Angebot.',
  },
  {
    id: 'add-china',
    question: 'Können wir unser bestehendes globales Hosting behalten und nur China hinzufügen?',
    answer: 'Ja, das ist das Dual-Stack-Setup. Ihre globale Website bleibt an ihrem Standort, die China-Besucher werden auf einen Festland-Server geleitet, und beide teilen sich die Redaktionsabläufe dort, wo es sinnvoll ist.',
  },
  {
    id: 'providers',
    question: 'Welche Anbieter nutzen Sie tatsächlich?',
    answer: 'Wir arbeiten mit Aliyun, Tencent Cloud und Huawei Cloud. Aliyun ist für Marketing-Websites meist die Standardwahl, Tencent Cloud spielt seine Stärken bei Seiten aus, die tief mit WeChat verzahnt sind, und Huawei Cloud kommt häufiger bei Kunden zum Einsatz, die Huawei bereits an anderer Stelle ihrer Infrastruktur nutzen.',
  },
  {
    id: 'icp-rejection',
    question: 'Was passiert, wenn der ICP-Antrag abgelehnt wird?',
    answer: 'Das kommt vor, besonders bei einer ersten ausländischen Registrierung. Meist liegt es an den Unterlagen oder an einer fehlenden Angabe in der Gewerbeanmeldung. Wir übernehmen die erneute Einreichung. Jedes ICP, das wir bisher eingereicht haben, ist am Ende durchgegangen.',
  },
  {
    id: 'astro-headless',
    question: 'Können wir eine Astro- oder Headless-Website in China hosten?',
    answer: 'Ja. Der Build läuft außerhalb Chinas auf einer CI-Pipeline, die statische Ausgabe wird auf einen Festland-Server gepusht, und die Website lädt so schnell wie alles, was wir je ausgeliefert haben. Das machen wir regelmäßig mit Astro und mit Headless-WordPress-Setups.',
  },
  {
    id: 'data-privacy',
    question: 'Ist Festland-Hosting mit den chinesischen Datenschutzgesetzen konform?',
    answer: 'Für Websites, die Daten chinesischer Nutzer erfassen, ist es das. Festland-Hosting auf einem sauber konfigurierten Aliyun- oder Tencent-Cloud-Konto ist der klarste Weg zur Konformität mit PIPL, dem Cybersicherheitsgesetz und dem Datensicherheitsgesetz. Wir richten die Architektur so ein, dass personenbezogene Daten im Land bleiben.',
  },
  {
    id: 'hosting-panel',
    question: 'Müssen wir uns selbst mit dem chinesischen Hosting-Panel herumschlagen?',
    answer: 'Nein. Wir führen das Hosting-Konto, die ICP-Registrierung und die tägliche Serverarbeit. Sie melden sich nirgends auf Chinesisch an und lesen keine Formulare, die Sie nicht verstehen. Sie erhalten eine funktionierende Website und einen monatlichen Bericht.',
  },
  {
    id: 'scaling',
    question: 'Was passiert, wenn der Traffic in die Höhe schnellt oder die Website wächst?',
    answer: 'Wir skalieren das Hosting hoch. Aliyun, Tencent und Huawei unterstützen alle flexible Skalierung in den Tarifen, die wir nutzen. Wir übernehmen die Anpassung, das Load Balancing und alle Architekturänderungen, die die Website braucht, um Schritt zu halten.',
  },
];

