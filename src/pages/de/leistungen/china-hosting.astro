  orange: {
    dot: 'bg-[var(--color-brand-orange)]',
    bg: 'bg-[var(--color-brand-orange)]/10',
    text: 'text-[var(--color-brand-orange)]',
    border: 'border-[var(--color-brand-orange)]/25',
    bar: 'bg-[var(--color-brand-orange)]',
  },
