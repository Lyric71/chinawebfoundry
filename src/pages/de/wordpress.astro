---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'WordPress in China | Was trägt, was sich ändern muss | ChinaWebFoundry';
const metaDescription = 'WordPress läuft in Festlandchina zuverlässig, sobald es dafür gebaut ist. Welche Umbauten die Große Firewall verlangt, worin es überzeugt und wo Alternativen zu kurz greifen.';

const stats = [
  { value: 43, suffix: '%', label: 'aller Websites laufen mit WordPress', source: 'W3Techs, 2024' },
  { value: 20, suffix: '+', label: 'Jahre WordPress-Arbeit in China', source: 'In Shanghai ansässig seit 2005' },
  { value: 50, suffix: '+', label: 'internationale Websites hinter der Firewall gestartet', source: 'Branchenübergreifend' },
];

const useCases = [
  {
    icon: 'cart',
    title: 'E-Commerce mit WooCommerce',
    body: 'Für Marken, die in China außerhalb von Tmall und JD verkaufen, kommt WooCommerce einem ernsthaften E-Commerce-Unterbau im offenen Web am nächsten. Sind Alipay, WeChat Pay und UnionPay einmal eingebunden, ist das Wesentliche abgedeckt.',
    span: 'feature',
    badges: ['WooCommerce', 'Alipay', 'WeChat Pay', 'UnionPay'],
  },
  {
    icon: 'pen',
    title: 'Inhaltsstarke Websites',
    body: 'Hunderte von Seiten, ein hoher Publikationstakt und mehrere Autoren, die parallel arbeiten: Für genau dieses Szenario wurde WordPress entwickelt. Redakteure, die das System bereits kennen, müssen sich nicht umstellen.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Mehrsprachige Websites',
    body: 'Chinesisch steht neben Englisch, Französisch, Deutsch oder Japanisch. Mit WPML oder Polylang bewältigt WordPress drei und mehr Sprachen sauber, samt getrennter Sitemaps für Baidu und Google.',
    span: 'normal',
  },
  {
    icon: 'users',
    title: 'Gepflegt von Nicht-Entwicklern',
    body: 'Marketingteams, Content-Verantwortliche und Regionalbüros pflegen die Website ohne Deployment-Pipeline. Für ein eigenständiges China-Team wiegt diese Beweglichkeit oft schwerer als reine Seitengeschwindigkeit.',
    span: 'normal',
  },
  {
    icon: 'sliders',
    title: 'Websites mit eigenen Abläufen',
    body: 'Mitgliederbereiche, bedingte Lead-Erfassung, geschützte Inhalte und Vertriebsunterstützung: Das Plugin-Ökosystem deckt das meiste davon ab, ohne dass eigene Entwicklung nötig wird.',
    span: 'normal',
  },
  {
    icon: 'layers',
    title: 'Mit Page-Buildern gebaute Websites',
    body: 'Die meisten Websites, die wir übernehmen, sind in Elementor, Divi oder Gutenberg gebaut. Alle drei tragen, sobald die externen Abhängigkeiten bereinigt sind. Gutenberg ist die schlankste Variante und lässt sich auf einem chinesischen Server am leichtesten schnell halten.',
    span: 'wide',
    badges: ['Elementor', 'Divi', 'Gutenberg'],
  },
];

const pickAstro = [
  'Die Website besteht überwiegend aus Marketingseiten, die monatlich oder seltener aktualisiert werden',
  'Die Ladegeschwindigkeit ist nicht verhandelbar (Landingpages für bezahlte Medien, Werbekampagnen)',
  'Sie wollen eine kleinere Angriffsfläche und weniger Wartungsaufwand',
  'Inhaltsaktualisierungen können über einen Entwickler oder über uns laufen',
  'Sie brauchen keine CMS-Oberfläche für nichttechnische Redakteure',
];

const pickWordPress = [
  'Die redaktionelle Arbeit ist tägliches Geschäft, keine gelegentliche Aufgabe',
  'Sie brauchen drei Sprachen oder mehr',
  'Sie betreiben einen Online-Shop oder einen Mitgliederbereich',
  'Ihr Team kennt WordPress bereits, und Sie wollen es nicht umschulen',
  'Sie brauchen Plugins für Formulare, SEO, Marketing-Automatisierung oder Compliance',
];

const changeGroups = [
  {
    label: 'Frontend',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Schriften',
        body: 'Google Fonts laden in China nicht. Wir hosten die Schriften selbst oder ersetzen sie durch chinakompatible Alternativen, die lateinische und CJK-Glyphen in einer Datei mitbringen.',
      },
      {
        icon: 'palette',
        title: 'Theme-Stack',
        body: 'Die meisten ThemeForest-Themes rufen externe CDNs auf, binden Google Maps ein oder laden entfernte Skripte, die hinter der Firewall scheitern. Wir prüfen, tauschen und ersetzen die betroffenen Bausteine einzeln.',
      },
      {
        icon: 'blocks',
        title: 'Page-Builder',
        body: 'Jeder Builder braucht eine gezielte Bereinigung. Wir entfernen die Google-Fonts-Lader, holen externe Icon-Bibliotheken lokal auf den Server und schalten alles ab, was einen gesperrten Dienst anpingt.',
      },
    ],
  },
  {
    label: 'Integrationen',
    accent: 'orange',
    items: [
      {
        icon: 'play',
        title: 'Eingebettete Inhalte',
        body: 'Eingebettete Inhalte werden durchgängig ersetzt: YouTube durch Youku oder Bilibili, Vimeo durch Tencent Video, Facebook-Pixel durch WeChat oder Weibo und Google Maps durch Baidu Map oder Amap.',
      },
      {
        icon: 'card',
        title: 'Zahlungen',
        body: 'WooCommerce allein kann von chinesischen Verbrauchern keine Zahlungen entgegennehmen. Wir binden Alipay, WeChat Pay und UnionPay ein und richten den Bezahlvorgang so ein, wie chinesische Nutzer tatsächlich bezahlen.',
      },
      {
        icon: 'plug',
        title: 'Plugins',
        body: 'Yoast SEO muss um eine Baidu-Sitemap ergänzt werden, Google Analytics weicht Baidu Tongji, und reCAPTCHA verlangt eine chinesische Alternative. Welche Plugins betroffen sind, halten wir in einer laufenden Liste fest.',
      },
    ],
  },
  {
    label: 'Hosting und Infrastruktur',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hosting',
        body: 'Die Website läuft auf Servern in Festlandchina, mit einer gültigen ICP-Registrierung auf der Domain. Je nach Projekt setzen wir dabei auf Aliyun, Tencent Cloud oder Huawei Cloud.',
      },
      {
        icon: 'refresh',
        title: 'Automatische Updates',
        body: 'Kern und Plugins melden sich bei wordpress.org und laufen aus China heraus häufig in einen Timeout. Wir leiten die Updates über einen Proxy um oder planen feste Wartungsfenster für manuelle Aktualisierungen.',
      },
      {
        icon: 'shield',
        title: 'Sicherheit',
        body: 'Es gilt die übliche Härtung: Wir sperren die Dateibearbeitung im Admin, riegeln XML-RPC ab, erzwingen die Zwei-Faktor-Authentifizierung und betreiben eine Web Application Firewall beim chinesischen Cloud-Anbieter. Bei der Update-Disziplin geht es in China strenger zu.',
      },
    ],
  },
  {
    label: 'Performance und SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'Wir konfigurieren das CDN für die Auslieferung in Festlandchina, schichten das Caching und stimmen die Datenbank auf die chinesischen Cloud-Server ab. Das Ziel liegt bei unter drei Sekunden bis zum First Meaningful Paint auf einem chinesischen Mittelklasse-Smartphone.',
      },
      {
        icon: 'search',
        title: 'SEO und KI-Suche',
        body: 'Die kritischen Inhalte stehen im HTML, die Baidu Webmaster Tools sind angebunden, und die Website ist so strukturiert, dass Doubao, Kimi, DeepSeek und Wenxin sie lesen und zitieren können.',
      },
    ],
  },
];

const pluginBuckets = [
  {
    eyebrow: 'Erste Wahl',
    title: 'Einen Ersatz finden',
    body: 'In den meisten Fällen lässt sich ein gleichwertiger Ersatz finden: Google Analytics weicht Baidu Tongji, reCAPTCHA einem lokalen Captcha und Google Maps dem Dienst Amap. Für die Redakteure ändert sich dabei nichts.',
  },
  {
    eyebrow: 'Wenn es passt',
    title: 'Es entfernen',
    body: 'Bringt ein Plugin dem chinesischen Publikum keinen Nutzen, entfernen wir es. Jedes eingesparte Plugin bedeutet eine schnellere Website und eine kleinere Angriffsfläche.',
  },
  {
    eyebrow: 'Letzte Möglichkeit',
    title: 'Den Plugin-Code anpassen',
    body: 'Wenn ein Plugin geschäftskritisch ist und sich kein gleichwertiger Ersatz finden lässt, passen wir seinen Code an. Wir leiten den API-Aufruf über einen Proxy um oder ersetzen eine fest verdrahtete CDN-Adresse, sofern die Lizenz des Plugins dies zulässt.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hosting' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hosting' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hosting' },
  { name: 'Baidu', cn: '百度', role: 'Suche und SEO' },
  { name: 'WeChat', cn: '微信', role: 'Login und Messaging' },
  { name: 'Alipay', cn: '支付宝', role: 'Zahlungen' },
];

const elementorItems = [
  {
    label: 'Schriften',
    body: 'Elementor zieht Google Fonts standardmäßig nach, und diese lassen sich in China nicht auflösen. Wir hosten die Schriften selbst oder ersetzen sie durch chinakompatible Alternativen, die lateinische und chinesische Glyphen abdecken.',
  },
  {
    label: 'Widgets und Komponenten',
    body: 'Manche Widgets rufen gesperrte Dienste auf (Google Maps, YouTube, Facebook, reCAPTCHA). Wir ersetzen sie durch chinesische Entsprechungen oder durch eigens gebaute Komponenten.',
  },
  {
    label: 'Icon-Bibliotheken und CDNs',
    body: 'Externe Ressourcen werden so umgeleitet, dass sie lokal vom chinesischen Server laden.',
  },
  {
    label: 'Vorlagen',
    body: 'Die meisten Elementor-Vorlagen gehen von Annahmen aus, die in China nicht tragen. Wir prüfen jede einzelne und bereinigen sie.',
  },
];

const faqs = [
  {
    id: 'wp-icp',
    question: 'Braucht unsere WordPress-Website eine ICP-Lizenz, um in China zu funktionieren?',
    answer: 'Wird sie in Festlandchina gehostet, ist eine ICP-Lizenz zwingend erforderlich. Bei einem Hosting in Hongkong entfällt diese Pflicht, doch die Website lädt dann messbar langsamer, und Baidu behandelt sie als ausländisch. Für die meisten ausländischen Marken, die den chinesischen Markt ernst nehmen, lohnt die ICP-Registrierung den Aufwand.',
  },
  {
    id: 'wp-marketing-team',
    question: 'Kann unser Marketingteam die WordPress-Website weiterhin selbst pflegen?',
    answer: 'Ja. An WordPress selbst ändert sich nichts: Die Admin-Oberfläche bleibt dieselbe, der Redaktionsablauf bleibt derselbe, und die redaktionellen Rollen verhalten sich wie gewohnt. Die Änderungen, die wir unter der Haube vornehmen, bleiben für das Redaktionsteam weitgehend unsichtbar.',
  },
  {
    id: 'wp-vs-astro-speed',
    question: 'Ist WordPress in China langsamer als Astro?',
    answer: 'Bei sonst gleichen Bedingungen ist WordPress in der reinen Ladezeit tatsächlich langsamer, denn WordPress arbeitet dynamisch und Astro statisch. In der Praxis erreicht eine gut abgestimmte WordPress-Website auf Aliyun mit der richtigen Caching-Schicht jedoch die Geschwindigkeitswerte, die sowohl chinesische Nutzer als auch Baidu zufriedenstellen. Für manche Projekte fällt der Unterschied stärker ins Gewicht als für andere.',
  },
  {
    id: 'wp-elementor-divi',
    question: 'Funktioniert unsere bestehende Elementor- oder Divi-Website in China?',
    answer: 'In ihrem jetzigen Zustand läuft sie wahrscheinlich nicht, in den meisten Fällen lässt sie sich jedoch China-tauglich machen. Wir entfernen die Google-Abhängigkeiten, tauschen die Schriften aus und leiten die Integrationen um. Die meisten Elementor- und Divi-Websites, die wir übernehmen, laufen wenige Wochen nach dem Start sauber hinter der Firewall.',
  },
  {
    id: 'wp-auto-updates',
    question: 'Was ist mit den automatischen Plugin-Updates von wordpress.org?',
    answer: 'Sie scheitern oder laufen aus China heraus oft in einen Timeout, weil das wordpress.org-Repository in chinesischen Netzen langsam oder nicht erreichbar ist. Wir leiten die Updates über einen Proxy um oder planen feste Wartungsfenster für manuelle Aktualisierungen. In beiden Fällen muss sich Ihr Team im Alltag nicht darum kümmern.',
  },
  {
    id: 'wp-multilingual',
    question: 'Können wir WPML oder Polylang für unser mehrsprachiges Setup behalten?',
    answer: 'Ja, beide laufen in China gut, sobald der Rest der Website bereinigt ist. WPML ist die gängigere Wahl für Websites mit drei oder mehr Sprachen und komplexen Übersetzungsabläufen, während Polylang die schlankere Lösung ist und für zwei oder drei Sprachen problemlos ausreicht. Wir haben mit beiden Plugins umfangreich gearbeitet; die Wahl hängt am Ende stärker von Ihrem Redaktionsprozess ab als von chinaspezifischen Fragen.',
  },
  {
    id: 'wp-woocommerce-china',
    question: 'Eignet sich WooCommerce für den Verkauf an chinesische Verbraucher?',
    answer: 'WooCommerce selbst funktioniert einwandfrei; die eigentliche Arbeit steckt in der Checkout-Schicht. Chinesische Verbraucher erwarten, mit Alipay, WeChat Pay oder UnionPay zu bezahlen, und zwar fast immer mobil und per QR-Code. Wir binden diese Zahlungsdienste über eigene Plugins ein und gestalten den Bezahlvorgang so um, wie chinesische Nutzer tatsächlich kaufen. Ab Werk geht WooCommerce von Kreditkarten und PayPal aus, was auf dem chinesischen Markt nicht trägt.',
  },
  {
    id: 'wp-single-vs-dual',
    question: 'Können wir eine einzige WordPress-Website für China und den Rest der Welt betreiben?',
    answer: 'Technisch ist das möglich, etwa mit WordPress Multisite oder einem mehrsprachigen Setup. In der Praxis empfehlen wir jedoch meist zwei getrennte WordPress-Installationen: eine außerhalb Chinas und eine auf einem Server in Festlandchina. Ausschlaggebend ist die Performance, denn bei einer einzigen globalen Installation ziehen chinesische Nutzer ihre Inhalte von Servern außerhalb der Firewall, was den Geschwindigkeitsvorteil wieder zunichtemacht. Zwei Installationen teilen sich die Redaktionsabläufe dort, wo es sinnvoll ist, und bleiben unabhängig, wo es nötig ist.',
  },
  {
    id: 'wp-security-china',
    question: 'Wie halten wir unsere WordPress-Website in China sicher?',
    answer: 'Die übliche WordPress-Härtung gilt nach wie vor. Wir sperren die Dateibearbeitung im Admin, riegeln XML-RPC ab, erzwingen die Zwei-Faktor-Authentifizierung und betreiben eine Web Application Firewall, die für den chinesischen Cloud-Anbieter konfiguriert ist. Die zusätzliche Disziplin in China betrifft die Plugin-Updates: Scheitert ein automatisches Update, kann die Website länger auf einer veralteten Plugin-Version verbleiben, als ein westliches Team es gewohnt ist. Wir überwachen das und spielen Patches nach einem festen Zeitplan ein.',
  },
  {
    id: 'wp-hosting-provider',
    question: 'Welcher WordPress-Hoster ist für China am besten geeignet?',
    answer: 'Wir nutzen je nach Projekt Aliyun, Tencent Cloud oder Huawei Cloud. Alle drei sind in Festlandchina lizenziert, bieten eine gute Leistung und tragen den WordPress-Stack zuverlässig. Aliyun ist für Marketing-Websites meist die Standardwahl, Tencent Cloud spielt seine Stärken aus, wenn die Website eng mit WeChat verzahnt ist, und Huawei Cloud kommt vor allem bei Kunden ins Spiel, die ohnehin auf Huawei-Infrastruktur setzen. Wir kümmern uns um das Hosting-Konto, die ICP-Registrierung und die tägliche Server-Arbeit, sodass Sie sich nie selbst in ein chinesisches Hosting-Panel einloggen müssen.',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'de-DE',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="de" jsonLd={[faqLd]}>

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-wordpress-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Brotkrümelnavigation" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/de/" class="hover:text-white/70 transition-colors no-underline">Startseite</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">WordPress</li>
        </ol>
      </nav>

      <div class="grid grid-cols-12 gap-8 items-center pb-20 md:pb-28 lg:pb-36 pt-8 lg:pt-16">
        <div class="col-span-12 lg:col-span-7">
          <!-- WordPress logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[#21759b] to-[#1a5d7a] flex items-center justify-center shadow-[0_8px_30px_rgba(33,117,155,0.45)]">
              <svg class="w-8 h-8 text-white" viewBox="0 0 122.52 122.523" fill="currentColor" aria-label="WordPress logo">
                <path d="m8.708 61.26c0 20.802 12.089 38.779 29.619 47.298l-25.069-68.686c-2.916 6.536-4.55 13.769-4.55 21.388z"/>
                <path d="m96.74 58.608c0-6.495-2.333-10.993-4.334-14.494-2.664-4.329-5.161-7.995-5.161-12.324 0-4.831 3.664-9.328 8.825-9.328.233 0 .454.029.681.042-9.35-8.566-21.807-13.796-35.489-13.796-18.36 0-34.513 9.42-43.91 23.688 1.233.037 2.395.063 3.382.063 5.497 0 14.006-.667 14.006-.667 2.833-.167 3.167 3.994.337 4.329 0 0-2.847.335-6.015.501l19.138 56.925 11.501-34.493-8.188-22.434c-2.83-.166-5.511-.501-5.511-.501-2.832-.166-2.5-4.496.332-4.329 0 0 8.679.667 13.843.667 5.496 0 14.006-.667 14.006-.667 2.835-.167 3.168 3.994.337 4.329 0 0-2.853.335-6.015.501l18.992 56.494 5.242-17.517c2.272-7.269 4.001-12.49 4.001-16.989z"/>
                <path d="m62.184 65.857-15.768 45.819c4.708 1.384 9.687 2.141 14.846 2.141 6.12 0 11.989-1.058 17.452-2.979-.141-.225-.269-.464-.374-.724z"/>
                <path d="m107.376 36.046c.226 1.674.354 3.471.354 5.404 0 5.333-.996 11.328-3.996 18.824l-16.053 46.413c15.624-9.111 26.133-26.038 26.133-45.426.001-9.137-2.333-17.729-6.438-25.215z"/>
                <path d="m61.262 0c-33.779 0-61.262 27.481-61.262 61.26 0 33.783 27.483 61.263 61.262 61.263 33.778 0 61.265-27.48 61.265-61.263-.001-33.779-27.487-61.26-61.265-61.26zm0 119.715c-32.23 0-58.453-26.223-58.453-58.455 0-32.23 26.222-58.451 58.453-58.451 32.229 0 58.45 26.221 58.45 58.451 0 32.232-26.221 58.455-58.45 58.455z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#21759b]/15 border border-[#21759b]/30">
              <span class="text-xs font-semibold uppercase tracking-wider text-[#7cb8d4]">Technologie · WordPress</span>
            </div>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[72px] xl:text-[84px] font-medium font-[var(--font-heading)] text-white leading-[0.98] tracking-tight">
            WordPress in China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Es funktioniert.</span>
          </h1>
          <p class="mt-10 text-lg lg:text-xl text-white/65 max-w-xl leading-relaxed">
            Die meisten Kunden kommen bereits mit WordPress zu uns. Die eigentliche Frage ist, ob es in China trägt und was sich dafür ändern muss.
          </p>
          <p class="mt-4 text-base text-white/45 max-w-xl leading-relaxed">
            Wir sind seit zwanzig Jahren vor Ort und haben über fünfzig internationale Websites gestartet.
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <Button href="/de/kontakt/" variant="primary" size="lg">Mit unserem Team sprechen</Button>
            <Button href="/de/astro/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Astro für China</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with workspace image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Warum es trägt
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            An der Plattform liegt es nicht.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
