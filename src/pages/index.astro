---
import PageLayout from '../layouts/PageLayout.astro';
import ScrollEffects from '../components/global/ScrollEffects.astro';
import PageScrollEffects from '../components/pages/ScrollEffects.astro';
import Hero from '../components/home/Hero.astro';
import ProblemSection from '../components/home/ProblemSection.astro';
import FocusAreas from '../components/home/FocusAreas.astro';
import Testimonial from '../components/home/Testimonial.astro';
import SolutionsSection from '../components/home/SolutionsSection.astro';
import StatsSection from '../components/home/StatsSection.astro';
import AboutSection from '../components/home/AboutSection.astro';
import GuidesSection from '../components/home/GuidesSection.astro';
import SuccessStories from '../components/home/SuccessStories.astro';
import ClientLogos from '../components/home/ClientLogos.astro';
---

<PageLayout
  title="China Web Agency | Websites Built for Chinese Audiences"
  description="We build websites that resonate with Chinese audiences. Native content, local UX, Baidu and AI search optimisation, hosted in China. Twenty years on the ground in Shanghai."
  heroPage={true}
>
  <ScrollEffects />
  <PageScrollEffects />
  <Hero />
  <ProblemSection />
  <FocusAreas />
  <Testimonial />
  <SolutionsSection />
  <StatsSection />
  <AboutSection />
  <SuccessStories />
  <GuidesSection />
  <ClientLogos />
</PageLayout>
