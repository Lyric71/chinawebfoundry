---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/global/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'china-hosting'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const proofStats = [
  { value: '0,8', suffix: ' s', label: 'Tiempo de carga medio desde el continente', sub: 'Medido en un móvil chino de gama media en la red de Shanghái' },
  { value: '99,97', suffix: '%', label: 'Disponibilidad media en los sitios que alojamos', sub: 'Media de los últimos 30 días' },
  { value: '100', suffix: '%', label: 'Tasa de aprobación de los expedientes de ICP', sub: 'Nunca nos han rechazado un expediente' },
  { value: '20', suffix: '+', label: 'Años de presencia en Shanghái', sub: 'El mismo equipo, la misma oficina, desde 2005' },
];

const sectionLinks = [
  { id: 'problem', label: 'El diagnóstico' },
  { id: 'options', label: 'Opciones de alojamiento' },
  { id: 'included', label: 'Servicios incluidos' },
  { id: 'icp', label: 'Licencia ICP' },
  { id: 'compliance', label: 'Cumplimiento' },
  { id: 'timeline', label: 'Plazos' },
  { id: 'performance', label: 'Rendimiento' },
  { id: 'faq', label: 'FAQ' },
];

const hostingOptions = [
  {
    id: 'mainland',
    name: 'China continental',
    tag: 'ICP obligatorio',
    tagline: 'Servidores en Pekín, Shanghái, Shenzhen o Cantón.',
    headline: 'La opción de referencia: páginas en menos de un segundo y el favor de Baidu.',
    body: 'Su sitio se aloja en servidores dentro de China continental. Según el proyecto, lo desplegamos en Aliyun, Tencent Cloud o Huawei Cloud. Son los tres proveedores con los que trabajamos desde hace años. Conocemos bien los puntos fuertes de cada uno.',
    detail: 'Las páginas cargan en menos de un segundo. Baidu da una ventaja clara a los sitios con licencia ICP alojados en el continente, y eso pesa mucho en el posicionamiento. El ICP lo tramitamos nosotros: es la fase donde se atascan las marcas extranjeras que no tienen un socio local.',
    fit: 'Marcas ya asentadas en el mercado chino, proyectos que apuestan fuerte por Baidu, plataformas de comercio electrónico y sitios que recogen datos de usuarios chinos.',
    image: '/images/hosting-china-cdn-map.webp',
    imageAlt: 'Mapa estilizado de China continental con nodos de centros de datos en Pekín, Shanghái, Shenzhen y Cantón unidos por una malla CDN',
    accent: 'orange',
    metrics: [
      { label: 'Carga', value: '< 1 s' },
      { label: 'ICP', value: 'Obligatorio' },
      { label: 'Efecto Baidu', value: 'Fuerte' },
      { label: 'Lanzamiento', value: '6 a 10 sem.' },
    ],
  },
  {
    id: 'hong-kong',
    name: 'Hong Kong',
    tag: 'Sin ICP',
    tagline: 'Lanzamiento rápido, sin trámites administrativos chinos.',
    headline: 'Una puerta de entrada al continente, operativa de inmediato.',
    body: 'Si todavía no tiene licencia ICP, Hong Kong es la vía más rápida para poner el sitio en marcha. No hace falta tramitar ningún expediente y el despliegue es inmediato. Con un buen CDN y la caché bien ajustada, los visitantes chinos ven la página en 2 a 4 segundos. Frente a un sitio servido desde Fráncfort o Virginia, la diferencia se nota.',
    detail: 'Suele ser una etapa intermedia, mientras se tramita el ICP o se decide una implantación completa en el continente. Algunos clientes llevan años en Hong Kong y nunca han necesitado nada más.',
    fit: 'Lanzamientos rápidos, soluciones provisionales, proyectos donde el ICP no es viable de inmediato y marcas que tantean el mercado antes de comprometerse a fondo.',
    image: '/images/hosting-hong-kong-bridge.webp',
    imageAlt: 'Perfil urbano de Hong Kong a la hora azul desde Victoria Harbour, con estelas de luz naranja que cruzan el agua hacia China continental',
    accent: 'sky',
    metrics: [
      { label: 'Carga', value: '2 a 4 s' },
      { label: 'ICP', value: 'No requerido' },
      { label: 'Efecto Baidu', value: 'Débil' },
      { label: 'Lanzamiento', value: '2 a 3 sem.' },
    ],
  },
  {
    id: 'dual-stack',
    name: 'Dual-stack',
    tag: 'Mundial + China',
    tagline: 'El continente para los visitantes chinos. Su infraestructura mundial para el resto.',
    headline: 'Una marca, dos arquitecturas y el mismo rendimiento en ambos lados.',
    body: 'Algunas marcas no pueden concentrar toda su inversión digital en China: el sitio tiene que funcionar igual de bien en cualquier parte del mundo. Para eso montamos una arquitectura compartida. Los visitantes chinos van a un servidor continental y el resto del mundo sigue atendido por su infraestructura actual.',
    detail: 'El DNS dirige cada visita al servidor que le corresponde, sin pasos manuales. Un mismo back-end sirve las dos versiones y el contenido se sincroniza automáticamente. La versión continental lleva su propio ICP y el sitio internacional se queda donde está. Lo gestionamos todo con un único contrato y su equipo editorial publica desde un solo panel.',
    fit: 'Marcas internacionales con un público chino importante, plataformas de comercio electrónico multinacionales y sitios donde el rendimiento importa tanto dentro como fuera de China.',
    image: '/images/hosting-dual-stack-globe.webp',
    imageAlt: 'Ilustración 3D isométrica de un globo terráqueo con dos grupos de servidores luminosos (naranja sobre China, cian sobre Occidente) y rutas de enrutamiento que reparten el tráfico según la geografía',
    accent: 'emerald',
    metrics: [
      { label: 'Carga', value: '< 1 s en CN' },
      { label: 'ICP', value: 'Obligatorio (CN)' },
      { label: 'Efecto Baidu', value: 'Fuerte' },
      { label: 'Lanzamiento', value: '8 a 12 sem.' },
    ],
  },
];

const includedItems = [
  {
    icon: 'server',
    title: 'Puesta en marcha y configuración del servidor',
    body: 'Ajustamos el servidor a su pila tecnológica, instalamos un certificado SSL que funciona bien en China y configuramos el cortafuegos y la protección anti-DDoS según las restricciones del Gran Cortafuegos.',
  },
  {
    icon: 'cdn',
    title: 'CDN de China integrado',
    body: 'Desplegamos una CDN de Aliyun o Tencent Cloud que cumple la normativa vigente. Sus archivos estáticos se sirven desde el nodo más cercano a cada visitante, en Shanghái o Chengdu, sin cruzar el Pacífico.',
  },
  {
    icon: 'monitor',
    title: 'Supervisión desde China',
    body: 'La mayoría de las herramientas de monitorización miden el rendimiento desde fuera del Gran Cortafuegos, así que dan cifras engañosas. La nuestra mide desde China, en condiciones reales. Parece un detalle técnico, pero cambia por completo lo que dicen los números.',
  },
  {
    icon: 'backup',
    title: 'Copias de seguridad diarias y plan de recuperación',
    body: 'Hacemos copias de seguridad automáticas todos los días, con almacenamiento externo, restauración a cualquier momento anterior y un plan de recuperación documentado. Ningún sistema está libre de incidentes, así que conviene estar preparado.',
  },
  {
    icon: 'document',
    title: 'Expediente de ICP tramitado de principio a fin',
    body: 'Preparamos el expediente, lo presentamos y tratamos con la autoridad provincial hasta que llega la licencia. Usted no tiene que abrir ningún panel de alojamiento chino ni descifrar un formulario en mandarín.',
  },
  {
    icon: 'wrench',
    title: 'Mantenimiento a largo plazo',
    body: 'Nos hacemos cargo de los parches del servidor, de las actualizaciones de seguridad y de las ampliaciones de capacidad. El sitio sigue funcionando sin que sus equipos tengan que intervenir.',
  },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Sitios editoriales',
    timing: '20 días hábiles o más',
    body: 'Es para sitios institucionales, blogs y webs de presentación, es decir, cualquier proyecto sin operaciones comerciales. Es la solicitud más habitual entre las marcas extranjeras que se instalan en China.',
    docs: ['Registro mercantil de la sociedad', 'Certificado de titularidad del dominio', 'Documento de identidad del responsable de la publicación', 'Entidad jurídica registrada en China'],
  },
  {
    code: '经营许可证',
    name: 'Licencia comercial ICP',
    type: 'Actividad comercial',
    timing: '2 a 3 meses',
    body: 'Es para sitios transaccionales, plataformas de comercio electrónico y servicios de pago, esto es, cualquier proyecto con operaciones comerciales. El trámite es más largo, el expediente más extenso y la revisión de la autoridad provincial más estricta.',
    docs: ['Todos los documentos del Bei\'an', 'Acreditación del objeto social', 'Comprobación del capital social', 'Declaración de la finalidad comercial del sitio'],
  },
];

const complianceLaws = [
  {
    abbr: 'PIPL',
    name: 'Ley de Protección de la Información Personal',
    body: 'Regula la recogida, el almacenamiento y la transferencia de los datos personales de los residentes en China. Es la norma china más parecida al RGPD europeo.',
  },
  {
    abbr: 'CSL',
    name: 'Ley de Ciberseguridad',
    body: 'Es la norma que sienta las bases del marco legal chino y está en vigor desde 2017. Fija las obligaciones de los operadores de red y de las llamadas infraestructuras críticas, además de las reglas sobre residencia de los datos.',
  },
  {
    abbr: 'DSL',
    name: 'Ley de Seguridad de los Datos',
    body: 'Clasifica los datos según su grado de sensibilidad y exige un nivel de protección distinto para cada categoría. Se aplica sobre todo al almacenamiento y a las transferencias transfronterizas que afectan a usuarios chinos.',
  },
];

const timelines = [
  {
    label: 'Hong Kong',
    title: 'Lanzamiento en Hong Kong',
    duration: '2 a 3 semanas',
    accent: 'sky',
    phases: [
      { name: 'Preparación', width: '40%' },
      { name: 'Configuración', width: '40%' },
      { name: 'Publicación', width: '20%' },
    ],
    note: 'No hay ICP que tramitar, así que es la vía más rápida para abrir una presencia digital dirigida al mercado chino.',
  },
  {
    label: 'China continental',
    title: 'Lanzamiento continental',
    duration: '6 a 10 semanas',
    accent: 'orange',
    phases: [
      { name: 'Expediente de ICP', width: '50%' },
      { name: 'Desarrollo (en paralelo)', width: '35%' },
      { name: 'Migración', width: '15%' },
    ],
    note: 'El expediente de ICP marca todo el calendario. Lo iniciamos el primer día y el desarrollo avanza en paralelo para no retrasar la entrega.',
  },
  {
    label: 'Dual-stack',
    title: 'Lanzamiento dual-stack',
    duration: '8 a 12 semanas',
    accent: 'emerald',
    phases: [
      { name: 'Arquitectura', width: '25%' },
      { name: 'Parte china + ICP', width: '45%' },
      { name: 'Enrutamiento + migración', width: '30%' },
    ],
    note: 'El calendario depende de la infraestructura mundial que ya tenga. En cualquier caso, la parte continental marca el ritmo.',
  },
];

const performanceRows = [
  { location: 'Estados Unidos o Europa', loadTime: 8, loadLabel: '8 a 15 segundos, o más', icp: 'No', baiduBoost: 'Ninguno', highlight: false },
  { location: 'Hong Kong', loadTime: 2.5, loadLabel: '2 a 4 segundos', icp: 'No', baiduBoost: 'Débil', highlight: false },
  { location: 'China continental', loadTime: 0.8, loadLabel: 'Menos de un segundo', icp: 'Sí', baiduBoost: 'Fuerte', highlight: true },
];

const audiences = [
  { label: 'Lanzamiento en China', description: 'Empresas internacionales que lanzan un nuevo sitio dirigido al mercado chino.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Sitio lento desde el continente', description: 'Empresas cuyo sitio actual tarda entre 10 y 15 segundos en cargar para quien lo visita desde China continental.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'Primer expediente de ICP', description: 'Equipos que tramitan el expediente de ICP por primera vez y se encuentran con una documentación y un procedimiento complicados.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'Comercio electrónico conforme', description: 'Marcas que necesitan un alojamiento rápido, conforme con la normativa china y compatible con los medios de pago locales.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];

const faqs = [
  {
    id: 'mainland-or-hk',
    question: '¿Es imprescindible alojar en el continente o se puede permanecer en Hong Kong?',
    answer: 'Hong Kong sigue siendo una opción válida, sobre todo para un lanzamiento de transición. Pero Baidu trata los sitios de Hong Kong como extranjeros, y eso penaliza bastante el posicionamiento. Para las marcas que se instalan en China a largo plazo, el alojamiento continental con licencia ICP es la vía más eficaz.',
  },
  {
    id: 'aliyun-overseas',
    question: '¿Sigue siendo obligatoria una licencia ICP en la región internacional de Aliyun?',
    answer: 'Sí, siempre que el sitio esté en los servidores continentales de Aliyun. Aliyun también tiene zonas en Hong Kong y Singapur, sin ICP, pero ahí se pierde el rendimiento continental y la ventaja que da Baidu en posicionamiento.',
  },
  {
    id: 'cost',
    question: '¿Cuánto cuesta un alojamiento en China?',
    answer: 'El coste depende del tráfico, del almacenamiento y del nivel de gestión técnica que elija. La mayoría de los sitios institucionales se mueven en una cuota mensual estable, que suele quedar por debajo de lo que costaría un alojamiento WordPress gestionado parecido en Europa o Estados Unidos. Díganos el alcance del proyecto y le preparamos un presupuesto detallado en 2 días hábiles.',
  },
  {
    id: 'add-china',
    question: '¿Se puede conservar el alojamiento internacional actual y añadirle una parte china?',
    answer: 'Sí, esa es justo la idea del montaje dual-stack. Su sitio internacional se queda donde está, los visitantes chinos se redirigen a un servidor continental y las dos versiones comparten los flujos editoriales cuando conviene.',
  },
  {
    id: 'providers',
    question: '¿Con qué proveedores trabajan en concreto?',
    answer: 'Trabajamos con tres proveedores: Aliyun, Tencent Cloud y Huawei Cloud. Aliyun es la opción habitual para los sitios institucionales. Tencent Cloud encaja mejor en proyectos muy integrados con WeChat. Y Huawei Cloud suele elegirse cuando el cliente ya usa Huawei en el resto de su infraestructura.',
  },
  {
    id: 'icp-rejection',
    question: '¿Qué ocurre si se rechaza el expediente de ICP?',
    answer: 'Pasa a veces, sobre todo en el primer expediente de una empresa extranjera. Casi siempre la causa es un documento que falta o una incoherencia en el registro de la sociedad. Cuando ocurre, revisamos el expediente y lo volvemos a presentar. Hasta hoy, todos los que hemos tramitado han acabado aprobados.',
  },
  {
    id: 'astro-headless',
    question: '¿Se puede alojar en China un sitio Astro o headless?',
    answer: 'Sí. La compilación se ejecuta fuera de China, en un sistema de integración continua. Los archivos estáticos resultantes pasan a un servidor continental y el sitio logra algunos de los mejores tiempos de carga de toda nuestra cartera. Es un montaje que hacemos a menudo, tanto en Astro como en WordPress headless.',
  },
  {
    id: 'data-privacy',
    question: '¿El alojamiento continental cumple las leyes chinas sobre privacidad?',
    answer: 'Para los sitios que recogen datos de usuarios chinos, sí. Un alojamiento continental en una cuenta de Aliyun o Tencent Cloud bien configurada es la vía más directa para cumplir la PIPL, la Ley de Ciberseguridad y la Ley de Seguridad de los Datos. La arquitectura se diseña para que los datos personales no salgan de China.',
  },
  {
    id: 'hosting-panel',
    question: '¿Hay que administrar uno mismo el panel de alojamiento chino?',
    answer: 'No. Nosotros gestionamos la cuenta de alojamiento, tramitamos el ICP y llevamos el día a día. Usted no tiene que entrar en ninguna interfaz en chino ni descifrar un formulario administrativo. Recibe un sitio listo para funcionar y un informe mensual claro.',
  },
  {
    id: 'scaling',
    question: '¿Qué ocurre cuando aumenta el tráfico o el sitio crece?',
    answer: 'El alojamiento crece con el sitio. Aliyun, Tencent y Huawei permiten ampliar la capacidad con flexibilidad en los planes que usamos. Nos encargamos del escalado, del equilibrio de carga y de los ajustes de arquitectura que pida el aumento de tráfico.',
  },
];

const accentMap: Record<string, { dot: string; bg: string; text: string; border: string; bar: string }> = {
  orange: {
    dot: 'bg-[var(--color-brand-orange)]',
    bg: 'bg-[var(--color-brand-orange)]/10',
    text: 'text-[var(--color-brand-orange)]',
    border: 'border-[var(--color-brand-orange)]/25',
    bar: 'bg-[var(--color-brand-orange)]',
  },
  sky: {
    dot: 'bg-sky-500',
    bg: 'bg-sky-500/10',
    text: 'text-sky-600',
    border: 'border-sky-500/25',
    bar: 'bg-sky-500',
  },
  emerald: {
    dot: 'bg-emerald-500',
    bg: 'bg-emerald-500/10',
    text: 'text-emerald-600',
    border: 'border-emerald-500/25',
    bar: 'bg-emerald-500',
  },
};

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-hosting.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/95 via-[#0f0f12]/75 to-[#0f0f12]/35"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/#OurServices" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Alojamiento en China</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">Alojamiento en China · 中国主机</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-white leading-[1.05] tracking-tight">
            Un alojamiento que rinde
            <span class="block mt-2 text-[var(--color-brand-orange)]">en China continental.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            Diseñamos y gestionamos un alojamiento preparado para la red china: páginas rápidas, ICP tramitado de principio a fin, CDN integrado y supervisión desde el propio país. Y todo funciona sea cual sea la pila tecnológica de su sitio.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-[560px] leading-relaxed">
            Más de 20 años en Shanghái y un 100 % de expedientes de ICP aprobados hasta la fecha.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/es/contacto/" variant="primary" size="lg">Solicitar una recomendación</Button>
            <a href="#options" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              Comparar las tres modalidades
              <span class="inline-block transition-transform group-hover:translate-y-0.5">↓</span>
            </a>
          </div>
        </div>

        <!-- Visual: server status card -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">estado-alojamiento</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Ubicación del servidor</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Shanghái</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Carga (China)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">0,8 s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[8%] h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Disponibilidad (30 d)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">99,97 %</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Estado ICP</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Activo</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Nodos CDN</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">24 activos</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/8 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
        {proofStats.map((stat, i) => (
          <div class:list={[
            'flex flex-col gap-3',
            i > 0 ? 'lg:pl-8 lg:border-l lg:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-5xl lg:text-[60px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div>
