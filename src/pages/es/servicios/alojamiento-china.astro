const performanceRows = [
  { location: 'Estados Unidos o Europa', loadTime: 8, loadLabel: '8 a 15 segundos, incluso más', icp: 'No', baiduBoost: 'Ninguno', highlight: false },
  { location: 'Hong Kong', loadTime: 2.5, loadLabel: '2 a 4 segundos', icp: 'No', baiduBoost: 'Débil', highlight: false },
  { location: 'China continental', loadTime: 0.8, loadLabel: 'Menos de un segundo', icp: 'Sí', baiduBoost: 'Fuerte', highlight: true },
];

const audiences = [
  { label: 'Lanzamiento en China', description: 'Empresas internacionales que abren un nuevo sitio dirigido al mercado chino.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Sitio lento desde el continente', description: 'Empresas cuyo sitio actual tarda de 10 a 15 segundos en cargarse para los visitantes que llegan desde China continental.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'Primera solicitud de ICP', description: 'Equipos que se enfrentan a la solicitud de ICP por primera vez y tropiezan con la complejidad del expediente o con su tramitación administrativa.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'Comercio electrónico en regla', description: 'Marcas que buscan un alojamiento rápido, conforme con la normativa china y compatible con las soluciones de pago locales.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];

const faqs = [
  {
    id: 'mainland-or-hk',
    question: '¿Es imprescindible alojar en el continente o se puede permanecer en Hong Kong?',
    answer: 'Hong Kong sigue siendo una opción viable, sobre todo para un lanzamiento de transición. Aun así, Baidu trata los sitios hongkoneses como extranjeros, con una penalización de posicionamiento muy real. Para las marcas que se instalan en China a largo plazo, el alojamiento continental con licencia ICP es la vía más eficaz.',
  },
  {
    id: 'aliyun-overseas',
    question: '¿Sigue siendo obligatoria una licencia ICP en la región internacional de Aliyun?',
    answer: 'Sí, siempre que se dirija a los servidores continentales de Aliyun. El proveedor dispone también de zonas en Hong Kong y Singapur, exentas de licencia ICP. Pero entonces renuncia al rendimiento continental y a la mejora de posicionamiento en Baidu.',
  },
  {
    id: 'cost',
    question: '¿Cuánto cuesta un alojamiento en China?',
    answer: 'El coste depende del tráfico, del volumen de almacenamiento y del nivel de gestión técnica elegido. La mayoría de los sitios institucionales encajan en una horquilla mensual estable, en la práctica por debajo de un alojamiento WordPress gestionado equivalente en Europa o Estados Unidos. Indíquenos el alcance y le preparamos un presupuesto detallado en 2 días hábiles.',
  },
  {
    id: 'add-china',
    question: '¿Se puede conservar el alojamiento mundial actual y añadirle una vertiente China?',
    answer: 'Sí, esa es precisamente la lógica del dispositivo dual-stack. Su sitio internacional permanece en su sitio, los visitantes chinos se redirigen hacia un servidor continental y ambas caras comparten los flujos editoriales cuando tiene sentido.',
  },
  {
    id: 'providers',
