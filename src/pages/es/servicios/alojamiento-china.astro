---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/global/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'china-hosting'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const proofStats = [
  { value: '0,8', suffix: ' s', label: 'Tiempo de carga medio desde el continente', sub: 'Medido en un teléfono chino de gama media, red de Shanghái' },
  { value: '99,97', suffix: '%', label: 'Disponibilidad observada en los sitios que alojamos', sub: 'Media móvil de los últimos 30 días' },
  { value: '100', suffix: '%', label: 'Tasa de aprobación de los expedientes ICP', sub: 'Ningún expediente tramitado por nosotros se ha quedado fuera' },
  { value: '20', suffix: '+', label: 'Años de presencia en Shanghái', sub: 'El mismo equipo, la misma oficina, desde 2005' },
];

const sectionLinks = [
  { id: 'problem', label: 'El diagnóstico' },
  { id: 'options', label: 'Opciones de alojamiento' },
  { id: 'included', label: 'Servicios incluidos' },
  { id: 'icp', label: 'Licencia ICP' },
  { id: 'compliance', label: 'Cumplimiento' },
  { id: 'timeline', label: 'Calendario' },
  { id: 'performance', label: 'Rendimiento' },
  { id: 'faq', label: 'FAQ' },
];

const hostingOptions = [
  {
    id: 'mainland',
    name: 'China continental',
    tag: 'ICP obligatorio',
    tagline: 'Servidores en Pekín, Shanghái, Shenzhen o Cantón.',
    headline: 'La opción de referencia. Cargas por debajo del segundo y todo el peso de Baidu a su favor.',
    body: 'Su sitio funciona sobre servidores instalados en China continental. Según el perfil del proyecto, el despliegue se hace en Aliyun, Tencent Cloud o Huawei Cloud. Tres proveedores que trabajamos desde hace años y cuyas fortalezas conocemos al detalle.',
    detail: 'Las páginas aparecen en menos de un segundo. Baidu favorece de forma clara los sitios con licencia ICP alojados en el continente, algo que cambia el panorama en cuanto el posicionamiento entra en juego. La solicitud de ICP también la tramitamos internamente. Suele ser justo la fase en la que las marcas extranjeras se atascan cuando avanzan sin un apoyo local.',
    fit: 'Marcas asentadas en el mercado chino, proyectos con fuerte componente de posicionamiento en Baidu, plataformas de comercio electrónico y sitios que recopilan datos de usuarios chinos.',
    image: '/images/hosting-china-cdn-map.webp',
    imageAlt: 'Mapa estilizado de China continental con nodos de centros de datos en Pekín, Shanghái, Shenzhen y Cantón unidos por una malla CDN',
    accent: 'orange',
    metrics: [
      { label: 'Carga', value: '< 1 s' },
      { label: 'ICP', value: 'Obligatorio' },
      { label: 'Efecto Baidu', value: 'Fuerte' },
      { label: 'Puesta en línea', value: '6 a 10 sem.' },
    ],
  },
  {
    id: 'hong-kong',
    name: 'Hong Kong',
    tag: 'Sin ICP',
    tagline: 'Puesta en línea rápida, sin trámite administrativo chino.',
    headline: 'Una pasarela hacia el continente, operativa de inmediato.',
    body: 'Sin una licencia ICP en mano, Hong Kong sigue siendo la opción más rápida de poner en marcha. No hay expediente que tramitar y el despliegue es directo. Con un CDN bien dimensionado y una caché ajustada, los visitantes chinos reciben la página en 2 a 4 segundos. Frente a un sitio servido desde Fráncfort o Virginia, el salto de calidad es notable.',
    detail: 'Esta configuración funciona a menudo como un paso intermedio, mientras se obtiene la licencia ICP o se decide una implantación plena en el mercado chino. Algunos clientes de larga trayectoria se han quedado en Hong Kong durante años sin llegar nunca a notar sus límites.',
    fit: 'Lanzamientos rápidos, soluciones provisionales, proyectos en los que la licencia ICP no resulta accesible de inmediato y marcas en fase de prueba antes de un compromiso más duradero.',
    image: '/images/hosting-hong-kong-bridge.webp',
    imageAlt: 'Perfil urbano de Hong Kong a la hora azul desde Victoria Harbour, con estelas de luz naranja que cruzan el agua hacia China continental',
    accent: 'sky',
    metrics: [
      { label: 'Carga', value: '2 a 4 s' },
      { label: 'ICP', value: 'No requerido' },
      { label: 'Efecto Baidu', value: 'Débil' },
      { label: 'Puesta en línea', value: '2 a 3 sem.' },
    ],
  },
  {
    id: 'dual-stack',
    name: 'Dual-stack',
    tag: 'Mundial + China',
    tagline: 'El continente para los visitantes chinos. Su infraestructura mundial para el resto.',
    headline: 'Una marca, dos arquitecturas y el mismo rendimiento en ambos lados.',
    body: 'Algunas marcas no pueden concentrar su inversión digital únicamente en China. El sitio tiene que funcionar en todas partes, con el mismo nivel de servicio. En esta configuración montamos un dispositivo compartido: los visitantes chinos se enrutan hacia un servidor continental y el resto del mundo se sigue sirviendo desde su infraestructura actual.',
    detail: 'El enrutamiento lo gobierna el DNS, sin intervención manual. Un mismo back-end alimenta las dos caras y el contenido se sincroniza de forma automática. El sitio continental lleva su propia solicitud de ICP y el sitio internacional permanece donde ya opera. Nos hacemos cargo del conjunto dentro de un mismo encargo, y la redacción gestiona un único flujo editorial.',
    fit: 'Marcas internacionales con una audiencia china real, plataformas de comercio electrónico multinacionales y sitios en los que el rendimiento cuenta tanto dentro como fuera de China.',
    image: '/images/hosting-dual-stack-globe.webp',
    imageAlt: 'Ilustración 3D isométrica de un globo terráqueo con dos grupos de servidores luminosos (naranja sobre China, cian sobre Occidente) y rutas de enrutamiento que reparten el tráfico según la geografía',
    accent: 'emerald',
    metrics: [
      { label: 'Carga', value: '< 1 s en CN' },
      { label: 'ICP', value: 'Obligatorio (CN)' },
      { label: 'Efecto Baidu', value: 'Fuerte' },
      { label: 'Puesta en línea', value: '8 a 12 sem.' },
    ],
  },
];

const includedItems = [
  {
    icon: 'server',
    title: 'Puesta en marcha y optimización del servidor',
    body: 'Servidor calibrado para su pila de aplicaciones, certificado SSL adaptado al entorno chino, cortafuegos y protección DDoS configurados teniendo en cuenta las restricciones del Gran Cortafuegos.',
  },
  {
    icon: 'cdn',
    title: 'CDN de China integrado',
    body: 'CDN de Aliyun o Tencent Cloud desplegado en regla. Sus archivos estáticos se sirven desde nodos situados lo más cerca posible de los visitantes, en Shanghái o Chengdu, sin rodeos por el Pacífico.',
  },
  {
    icon: 'monitor',
    title: 'Supervisión desde China',
    body: 'La mayoría de las sondas miden el rendimiento desde fuera del Gran Cortafuegos, lo que arroja paneles de control engañosos. Nuestra supervisión se realiza desde China, en condiciones reales. Un punto en apariencia técnico que cambia por completo la lectura de los indicadores.',
  },
  {
    icon: 'backup',
    title: 'Copias de seguridad diarias y plan de recuperación',
    body: 'Copias de seguridad automáticas diarias, almacenamiento externo, restauración a un instante concreto y un plan de recuperación de actividad documentado. Porque ningún sistema aguanta indefinidamente sin un incidente.',
  },
  {
    icon: 'document',
    title: 'Solicitud de ICP tramitada de principio a fin',
    body: 'Preparación del expediente, presentación e interlocución con la autoridad provincial hasta la concesión de la licencia. En ningún momento abre usted una consola de alojamiento china ni descifra un formulario en mandarín.',
  },
  {
    icon: 'wrench',
    title: 'Operación a largo plazo',
    body: 'Parches del servidor, actualizaciones de seguridad y ampliación de capacidad: todo queda a nuestro cargo. El sitio sigue funcionando sin que sus equipos tengan que intervenir.',
  },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Sitios editoriales',
    timing: '20 días hábiles o más',
    body: 'Sitio institucional, blog editorial, escaparate en línea: todo aquello que no implica ninguna transacción comercial. Es la solicitud más frecuente entre las marcas extranjeras que se implantan en China.',
    docs: ['Inscripción de la sociedad', 'Certificado de propiedad del nombre de dominio', 'Documento de identidad del responsable de la publicación', 'Entidad jurídica registrada en China'],
  },
  {
    code: '经营许可证',
    name: 'Licencia comercial ICP',
    type: 'Actividad comercial',
    timing: '2 a 3 meses',
    body: 'Sitios transaccionales, plataformas de comercio electrónico, servicios de pago: todo aquello que implica un acto comercial. El procedimiento es más largo, el expediente más voluminoso y la revisión de la autoridad provincial más exhaustiva.',
    docs: ['Todos los documentos exigidos para el Bei\'an', 'Justificación del ámbito de actividad', 'Verificación del capital social', 'Declaración de la finalidad comercial del sitio'],
  },
];

const complianceLaws = [
  {
    abbr: 'PIPL',
    name: 'Ley de Protección de la Información Personal',
    body: 'Regula la recopilación, el almacenamiento y la transferencia de los datos personales de los residentes chinos. Es el texto chino que más se acerca al RGPD europeo.',
  },
  {
    abbr: 'CSL',
    name: 'Ley de Ciberseguridad',
    body: 'Texto fundacional del sistema chino, en vigor desde 2017. Fija las obligaciones de los operadores de red y de las llamadas infraestructuras críticas, además de las reglas de residencia de los datos.',
  },
  {
    abbr: 'DSL',
    name: 'Ley de Seguridad de los Datos',
    body: 'Clasifica los datos por su grado de sensibilidad e impone un nivel de protección proporcionado. Se aplica en particular al almacenamiento y a las transferencias transfronterizas que afectan a usuarios chinos.',
  },
];

const timelines = [
  {
    label: 'Hong Kong',
    title: 'Lanzamiento en Hong Kong',
    duration: '2 a 3 semanas',
    accent: 'sky',
    phases: [
      { name: 'Preparación', width: '40%' },
      { name: 'Configuración', width: '40%' },
      { name: 'Puesta en línea', width: '20%' },
