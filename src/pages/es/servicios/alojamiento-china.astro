---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/global/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'china-hosting'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const proofStats = [
  { value: '0,8', suffix: ' s', label: 'Tiempo de carga medio desde el continente', sub: 'Medido en un móvil chino de gama media conectado a la red de Shanghái' },
  { value: '99,97', suffix: '%', label: 'Disponibilidad media en los sitios que alojamos', sub: 'Media de los últimos 30 días' },
  { value: '100', suffix: '%', label: 'Tasa de aprobación de los expedientes de ICP', sub: 'Nunca nos han rechazado un expediente' },
  { value: '20', suffix: '+', label: 'Años de presencia en Shanghái', sub: 'El mismo equipo, la misma oficina, desde 2005' },
];

const sectionLinks = [
  { id: 'problem', label: 'El diagnóstico' },
  { id: 'options', label: 'Opciones de alojamiento' },
  { id: 'included', label: 'Servicios incluidos' },
  { id: 'icp', label: 'Licencia ICP' },
  { id: 'compliance', label: 'Cumplimiento' },
  { id: 'timeline', label: 'Plazos' },
  { id: 'performance', label: 'Rendimiento' },
  { id: 'faq', label: 'FAQ' },
];

const hostingOptions = [
  {
    id: 'mainland',
    name: 'China continental',
    tag: 'ICP obligatorio',
    tagline: 'Servidores en Pekín, Shanghái, Shenzhen o Cantón.',
    headline: 'La opción de referencia: páginas en menos de un segundo y el favor de Baidu.',
    body: 'Su sitio se aloja en servidores ubicados en China continental. En función del proyecto, lo desplegamos en Aliyun, Tencent Cloud o Huawei Cloud, los tres proveedores con los que trabajamos desde hace años y cuyas fortalezas conocemos en profundidad.',
    detail: 'Las páginas cargan en menos de un segundo. Baidu concede una ventaja considerable a los sitios con licencia ICP alojados en el continente, un factor determinante para cualquier estrategia de posicionamiento. El expediente de ICP también lo tramitamos nosotros: es precisamente la fase en la que suelen quedarse bloqueadas las marcas extranjeras que prescinden de un socio local.',
    fit: 'Marcas ya consolidadas en el mercado chino, proyectos con una fuerte apuesta por el posicionamiento en Baidu, plataformas de comercio electrónico y sitios que recogen datos de usuarios chinos.',
    image: '/images/hosting-china-cdn-map.webp',
    imageAlt: 'Mapa estilizado de China continental con nodos de centros de datos en Pekín, Shanghái, Shenzhen y Cantón unidos por una malla CDN',
    accent: 'orange',
    metrics: [
      { label: 'Carga', value: '< 1 s' },
      { label: 'ICP', value: 'Obligatorio' },
      { label: 'Efecto Baidu', value: 'Fuerte' },
      { label: 'Lanzamiento', value: '6 a 10 sem.' },
    ],
  },
  {
    id: 'hong-kong',
    name: 'Hong Kong',
    tag: 'Sin ICP',
    tagline: 'Lanzamiento rápido, sin trámites administrativos chinos.',
    headline: 'Una puerta de entrada al continente, operativa de inmediato.',
    body: 'Mientras no se disponga de una licencia ICP, Hong Kong es la vía más rápida para poner el sitio en marcha. No requiere expediente alguno y el despliegue es inmediato. Con un CDN bien dimensionado y una caché ajustada, los visitantes chinos ven la página en un plazo de 2 a 4 segundos. Frente a un sitio servido desde Fráncfort o Virginia, la mejora resulta evidente.',
    detail: 'Esta configuración suele funcionar como una etapa intermedia, mientras se tramita la licencia ICP o se decide una implantación plena en el mercado chino. Algunos clientes de larga trayectoria llevan años en Hong Kong sin haber necesitado nada más.',
    fit: 'Lanzamientos rápidos, soluciones provisionales, proyectos en los que la licencia ICP no resulta viable de inmediato y marcas que exploran el mercado antes de un compromiso de mayor alcance.',
    image: '/images/hosting-hong-kong-bridge.webp',
    imageAlt: 'Perfil urbano de Hong Kong a la hora azul desde Victoria Harbour, con estelas de luz naranja que cruzan el agua hacia China continental',
    accent: 'sky',
    metrics: [
      { label: 'Carga', value: '2 a 4 s' },
      { label: 'ICP', value: 'No requerido' },
      { label: 'Efecto Baidu', value: 'Débil' },
      { label: 'Lanzamiento', value: '2 a 3 sem.' },
    ],
  },
  {
    id: 'dual-stack',
    name: 'Dual-stack',
    tag: 'Mundial + China',
    tagline: 'El continente para los visitantes chinos. Su infraestructura mundial para el resto.',
    headline: 'Una marca, dos arquitecturas y el mismo rendimiento en ambos lados.',
    body: 'Algunas marcas no pueden concentrar toda su inversión digital en China: el sitio debe funcionar en cualquier parte del mundo y con el mismo nivel de servicio. Para lograrlo construimos una arquitectura compartida, de modo que los visitantes chinos se dirigen a un servidor continental, mientras que el resto del mundo sigue atendido por su infraestructura actual.',
    detail: 'El DNS se encarga del enrutamiento, sin intervención manual alguna. Un mismo back-end alimenta ambas versiones y el contenido se sincroniza de forma automática. La versión continental tramita su propia licencia ICP, mientras que el sitio internacional permanece en su emplazamiento actual. Nos ocupamos del conjunto mediante un único encargo, y su equipo editorial trabaja con un solo flujo de publicación.',
    fit: 'Marcas internacionales con una audiencia china significativa, plataformas de comercio electrónico multinacionales y sitios para los que el rendimiento resulta igual de prioritario dentro y fuera de China.',
    image: '/images/hosting-dual-stack-globe.webp',
    imageAlt: 'Ilustración 3D isométrica de un globo terráqueo con dos grupos de servidores luminosos (naranja sobre China, cian sobre Occidente) y rutas de enrutamiento que reparten el tráfico según la geografía',
    accent: 'emerald',
    metrics: [
      { label: 'Carga', value: '< 1 s en CN' },
      { label: 'ICP', value: 'Obligatorio (CN)' },
      { label: 'Efecto Baidu', value: 'Fuerte' },
      { label: 'Lanzamiento', value: '8 a 12 sem.' },
    ],
  },
];

const includedItems = [
  {
    icon: 'server',
    title: 'Puesta en marcha y configuración del servidor',
    body: 'Ajustamos el servidor a su pila tecnológica, instalamos un certificado SSL adaptado al entorno chino y configuramos el cortafuegos y la protección frente a ataques DDoS teniendo en cuenta las restricciones del Gran Cortafuegos.',
  },
  {
    icon: 'cdn',
    title: 'CDN de China integrado',
    body: 'Desplegamos una CDN de Aliyun o Tencent Cloud conforme a la normativa vigente. Sus archivos estáticos se sirven desde los nodos más próximos a cada visitante, en Shanghái o Chengdu, sin necesidad de cruzar el Pacífico.',
  },
  {
    icon: 'monitor',
    title: 'Supervisión desde China',
    body: 'La mayoría de las herramientas de monitorización miden el rendimiento desde fuera del Gran Cortafuegos, lo que produce paneles de control engañosos. La nuestra realiza la medición desde China, en condiciones reales. Es un matiz en apariencia técnico, pero altera por completo la lectura de las cifras.',
  },
  {
    icon: 'backup',
    title: 'Copias de seguridad diarias y plan de recuperación',
    body: 'Realizamos copias de seguridad automáticas a diario, con almacenamiento externo, restauración a un momento exacto y un plan de recuperación documentado. Ningún sistema queda a salvo de un incidente, y conviene estar preparado para cuando ocurra.',
  },
  {
    icon: 'document',
    title: 'Expediente de ICP tramitado de principio a fin',
    body: 'Preparamos el expediente, lo presentamos y mantenemos la interlocución con la autoridad provincial hasta la obtención de la licencia. En ningún momento tendrá que abrir una consola de alojamiento china ni descifrar un formulario en mandarín.',
  },
  {
    icon: 'wrench',
    title: 'Mantenimiento a largo plazo',
    body: 'Nos hacemos cargo de los parches del servidor, de las actualizaciones de seguridad y de las ampliaciones de capacidad. El sitio se mantiene operativo sin que sus equipos tengan que intervenir.',
  },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Sitios editoriales',
    timing: '20 días hábiles o más',
    body: 'Corresponde a sitios institucionales, blogs editoriales y webs de presentación, es decir, cualquier proyecto sin transacciones comerciales. Es la solicitud más habitual entre las marcas extranjeras que se establecen en China.',
    docs: ['Registro mercantil de la sociedad', 'Certificado de titularidad del dominio', 'Documento de identidad del responsable de la publicación', 'Entidad jurídica registrada en China'],
  },
  {
    code: '经营许可证',
    name: 'Licencia comercial ICP',
    type: 'Actividad comercial',
    timing: '2 a 3 meses',
    body: 'Corresponde a sitios transaccionales, plataformas de comercio electrónico y servicios de pago, esto es, cualquier proyecto que implique una operación comercial. El procedimiento es más largo, el expediente más extenso y la revisión de la autoridad provincial, más rigurosa.',
    docs: ['Todos los documentos del Bei\'an', 'Acreditación del objeto social', 'Comprobación del capital social', 'Declaración de la finalidad comercial del sitio'],
  },
];

const complianceLaws = [
  {
    abbr: 'PIPL',
    name: 'Ley de Protección de la Información Personal',
    body: 'Regula la recogida, el almacenamiento y la transferencia de los datos personales de los residentes en China. Es la norma china más próxima al RGPD europeo.',
  },
  {
    abbr: 'CSL',
    name: 'Ley de Ciberseguridad',
    body: 'Es la norma fundacional del marco legal chino y está en vigor desde 2017. Establece las obligaciones de los operadores de red y de las denominadas infraestructuras críticas, además de las reglas sobre residencia de los datos.',
  },
  {
    abbr: 'DSL',
    name: 'Ley de Seguridad de los Datos',
    body: 'Clasifica los datos según su grado de sensibilidad y exige un nivel de protección acorde con cada categoría. Se aplica sobre todo al almacenamiento y a las transferencias transfronterizas que afectan a usuarios chinos.',
  },
];

const timelines = [
  {
    label: 'Hong Kong',
    title: 'Lanzamiento en Hong Kong',
    duration: '2 a 3 semanas',
    accent: 'sky',
    phases: [
      { name: 'Preparación', width: '40%' },
      { name: 'Configuración', width: '40%' },
      { name: 'Publicación', width: '20%' },
    ],
    note: 'No hay expediente de ICP que tramitar, por lo que es el plazo más corto para abrir una presencia digital dirigida al mercado chino.',
  },
  {
    label: 'China continental',
    title: 'Lanzamiento continental',
    duration: '6 a 10 semanas',
    accent: 'orange',
    phases: [
      { name: 'Expediente de ICP', width: '50%' },
      { name: 'Desarrollo (en paralelo)', width: '35%' },
      { name: 'Migración', width: '15%' },
    ],
    note: 'El expediente de ICP condiciona todo el calendario. Lo iniciamos el primer día y el desarrollo avanza en paralelo para no demorar la entrega.',
  },
  {
    label: 'Dual-stack',
    title: 'Lanzamiento dual-stack',
    duration: '8 a 12 semanas',
    accent: 'emerald',
    phases: [
      { name: 'Arquitectura', width: '25%' },
      { name: 'Parte china + ICP', width: '45%' },
      { name: 'Enrutamiento + migración', width: '30%' },
    ],
    note: 'El calendario depende de la infraestructura mundial ya existente. En cualquier caso, la parte continental es la que determina el ritmo general.',
  },
];

const performanceRows = [
  { location: 'Estados Unidos o Europa', loadTime: 8, loadLabel: '8 a 15 segundos, o más', icp: 'No', baiduBoost: 'Ninguno', highlight: false },
  { location: 'Hong Kong', loadTime: 2.5, loadLabel: '2 a 4 segundos', icp: 'No', baiduBoost: 'Débil', highlight: false },
  { location: 'China continental', loadTime: 0.8, loadLabel: 'Menos de un segundo', icp: 'Sí', baiduBoost: 'Fuerte', highlight: true },
];

const audiences = [
  { label: 'Lanzamiento en China', description: 'Empresas internacionales que lanzan un nuevo sitio dirigido al mercado chino.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Sitio lento desde el continente', description: 'Empresas cuyo sitio actual tarda entre 10 y 15 segundos en cargarse para quienes lo visitan desde China continental.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'Primer expediente de ICP', description: 'Equipos que tramitan el expediente de ICP por primera vez y se enfrentan a la complejidad de la documentación y del procedimiento.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'Comercio electrónico conforme', description: 'Marcas que necesitan un alojamiento rápido, conforme con la normativa china y compatible con los medios de pago locales.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];

const faqs = [
  {
    id: 'mainland-or-hk',
    question: '¿Es imprescindible alojar en el continente o se puede permanecer en Hong Kong?',
    answer: 'Hong Kong sigue siendo una opción válida, sobre todo para un lanzamiento de transición. Ahora bien, Baidu trata los sitios de Hong Kong como extranjeros, lo que conlleva una penalización de posicionamiento nada desdeñable. Para las marcas que se establecen en China a largo plazo, el alojamiento continental con licencia ICP es la vía más eficaz.',
  },
  {
    id: 'aliyun-overseas',
    question: '¿Sigue siendo obligatoria una licencia ICP en la región internacional de Aliyun?',
    answer: 'Sí, siempre que el sitio se aloje en los servidores continentales de Aliyun. El proveedor dispone también de zonas en Hong Kong y Singapur, exentas de licencia ICP, aunque esa opción supone renunciar al rendimiento continental y al impulso de posicionamiento que ofrece Baidu.',
  },
  {
    id: 'cost',
    question: '¿Cuánto cuesta un alojamiento en China?',
    answer: 'El coste depende del tráfico, del volumen de almacenamiento y del nivel de gestión técnica que elija. La mayoría de los sitios institucionales se mantienen en una franja mensual estable, que suele quedar por debajo de un alojamiento WordPress gestionado equivalente en Europa o Estados Unidos. Indíquenos el alcance del proyecto y le preparamos un presupuesto detallado en 2 días hábiles.',
  },
  {
    id: 'add-china',
    question: '¿Se puede conservar el alojamiento internacional actual y añadirle una parte china?',
    answer: 'Sí; esa es precisamente la lógica de la configuración dual-stack. Su web internacional permanece en su emplazamiento actual, los visitantes chinos se redirigen a un servidor continental y ambas versiones comparten los flujos editoriales cuando resulta conveniente.',
  },
  {
    id: 'providers',
    question: '¿Con qué proveedores trabajan en concreto?',
    answer: 'Trabajamos con tres proveedores de referencia: Aliyun, Tencent Cloud y Huawei Cloud. Aliyun es la opción habitual para los sitios institucionales; Tencent Cloud resulta más adecuado para los proyectos estrechamente integrados con WeChat; y Huawei Cloud suele elegirse cuando el cliente ya cuenta con Huawei en el resto de su infraestructura.',
  },
  {
    id: 'icp-rejection',
    question: '¿Qué ocurre si se rechaza el expediente de ICP?',
    answer: 'Sucede en ocasiones, sobre todo en un primer expediente de una entidad extranjera. En la gran mayoría de los casos, la causa es un documento ausente o una incoherencia en el registro de la sociedad. Cuando ello ocurre, revisamos el expediente y lo presentamos de nuevo. Hasta la fecha, todos los expedientes que hemos tramitado han recibido finalmente la aprobación.',
  },
  {
    id: 'astro-headless',
    question: '¿Se puede alojar en China un sitio Astro o headless?',
    answer: 'Sí. La compilación se ejecuta fuera de China, en un sistema de integración continua; los archivos estáticos resultantes se transfieren a un servidor continental y el sitio alcanza algunos de los mejores tiempos de carga de nuestra cartera. Es una configuración que desplegamos con regularidad, tanto en Astro como en WordPress headless.',
  },
  {
    id: 'data-privacy',
    question: '¿El alojamiento continental cumple las leyes chinas sobre privacidad?',
    answer: 'Para los sitios que recogen datos de usuarios chinos, sí. Un alojamiento continental en una cuenta de Aliyun o Tencent Cloud correctamente configurada es la vía más directa para cumplir la PIPL, la Ley de Ciberseguridad y la Ley de Seguridad de los Datos. La arquitectura se diseña para que los datos personales no salgan del territorio chino.',
  },
  {
    id: 'hosting-panel',
    question: '¿Hay que administrar uno mismo el panel de alojamiento chino?',
    answer: 'No. Nosotros gestionamos la cuenta de alojamiento, tramitamos el expediente de ICP y asumimos la operativa diaria. En ningún momento tendrá que acceder a una interfaz en chino ni descifrar un formulario administrativo. Recibirá un sitio plenamente operativo y un informe mensual claro y conciso.',
  },
  {
    id: 'scaling',
    question: '¿Qué ocurre cuando aumenta el tráfico o el sitio crece?',
    answer: 'El alojamiento se redimensiona a medida que el sitio crece. Aliyun, Tencent y Huawei permiten ampliar la capacidad con flexibilidad en los planes que utilizamos. Nos encargamos del escalado, del equilibrio de carga y de los ajustes de arquitectura que el aumento del tráfico requiera.',
  },
];

const accentMap: Record<string, { dot: string; bg: string; text: string; border: string; bar: string }> = {
  orange: {
    dot: 'bg-[var(--color-brand-orange)]',
    bg: 'bg-[var(--color-brand-orange)]/10',
    text: 'text-[var(--color-brand-orange)]',
    border: 'border-[var(--color-brand-orange)]/25',
    bar: 'bg-[var(--color-brand-orange)]',
  },
  sky: {
    dot: 'bg-sky-500',
    bg: 'bg-sky-500/10',
    text: 'text-sky-600',
    border: 'border-sky-500/25',
    bar: 'bg-sky-500',
  },
  emerald: {
    dot: 'bg-emerald-500',
    bg: 'bg-emerald-500/10',
    text: 'text-emerald-600',
    border: 'border-emerald-500/25',
