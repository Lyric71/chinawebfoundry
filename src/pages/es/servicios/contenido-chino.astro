      'Depende del alcance: rediseГғВұo o sitio nuevo, nГғВәmero de pГғВЎginas, cadencia editorial y la eventual integraciГғВіn del SEO de Baidu y de la optimizaciГғВіn para IA. ExpГғВіnganos el alcance y le facilitaremos una cifra firme en un plazo de dos dГғВӯas hГғВЎbiles.',
    ],
  },
];

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-chinese-content.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
