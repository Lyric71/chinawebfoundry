            <!-- Left: number + label -->
            <div class="lg:col-span-3 relative p-7 lg:p-8 bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white overflow-hidden">
              <span aria-hidden="true" class="absolute right-[-1.5rem] bottom-[-3rem] text-[14rem] font-medium font-[var(--font-heading)] text-white/[0.04] leading-none select-none pointer-events-none">{d.cn}</span>
              <div class="relative">
                <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-2">N.ГӮВә {d.n} / 05</div>
                <div class="text-5xl lg:text-6xl font-medium font-[var(--font-heading)] text-white leading-none mb-1.5">{d.cn}</div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange-text)]/90 font-semibold">{d.westernLabel.split(' ')[0]} ГўвҖ вҖҷ ГӨВёВӯГҘвҖәВҪ</div>
              </div>
            </div>

            <!-- Middle: title + body -->
            <div class="lg:col-span-5 p-7 lg:p-9 flex flex-col justify-center">
              <h3 class="text-2xl lg:text-[26px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4">
                {d.title}
              </h3>
              <p class="text-[15px] lg:text-base text-[var(--color-text-body)] leading-relaxed">
                {d.body}
              </p>
            </div>

            <!-- Right: comparison block -->
            <div class="lg:col-span-4 p-6 lg:p-7 bg-[var(--color-surface-light)] border-t lg:border-t-0 lg:border-l border-[var(--color-surface-border)] flex flex-col justify-center gap-4">
              <!-- Western -->
              <div class="relative pl-4 border-l-2 border-red-300/60">
                <div class="flex items-center gap-1.5 mb-1">
                  <svg class="w-3.5 h-3.5 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                  <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-red-500">Esquema occidental</span>
                </div>
                <div class="text-sm font-medium text-[var(--color-text-dark)] leading-snug">{d.westernLabel}</div>
                <div class="text-xs text-[var(--color-text-muted)] mt-0.5 leading-relaxed">{d.westernSub}</div>
              </div>
              <!-- Chinese -->
              <div class="relative pl-4 border-l-2 border-[var(--color-brand-orange)]">
                <div class="flex items-center gap-1.5 mb-1">
                  <svg class="w-3.5 h-3.5 text-[var(--color-brand-orange)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-orange)]">Lo que espera el lector chino</span>
                </div>
                <div class="text-sm font-medium text-[var(--color-text-dark)] leading-snug">{d.chineseLabel}</div>
                <div class="text-xs text-[var(--color-text-muted)] mt-0.5 leading-relaxed">{d.chineseSub}</div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW TO STRUCTURE: sitemap visualisation -->
  <section class="relative section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(white_1px,transparent_1px)] [background-size:36px_36px] opacity-[0.025]"></div>
    <div class="absolute -top-32 left-[20%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.08] blur-[140px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">CГғВіmo estructurar ГӮВ· ГӨВҝВЎГҰВҒВҜГҰЕҫВ¶ГҰЕҫвҖһ</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] mb-5">
          La arquitectura de la informaciГғВіn sigue siendo contenido.
        </h2>
        <p class="text-lg text-white/65 leading-relaxed">
          Sobre una estructura deficiente, el mejor texto imaginable no posiciona en Baidu, no convierte ni genera confianza alguna.
        </p>
      </div>

      <!-- Sitemap comparison -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 lg:gap-6 mb-16 lg:mb-20">
        <!-- Foreign IA -->
        <div class="lg:col-span-6 rounded-3xl bg-white/[0.03] border border-white/10 p-7 lg:p-8 backdrop-blur-sm" data-reveal="left">
          <div class="flex items-center justify-between mb-6">
            <div>
              <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-1">Arquitectura extranjera habitual</div>
              <div class="text-lg font-medium font-[var(--font-heading)] text-white/90">5 pГғВЎginas, centradas en el producto</div>
