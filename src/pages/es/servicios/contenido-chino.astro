  <!-- HOW WE WORK: 4 stages with depth -->
  <section class="relative section-spacing bg-[var(--color-surface-light)] overflow-hidden">
    <div class="absolute -bottom-32 -right-32 w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.06] blur-[140px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="text-center max-w-2xl mx-auto mb-14 lg:mb-16" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">Cómo trabajamos · 工作流程</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-4">
          De la investigación a la labor editorial continua.
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Cuatro etapas, cada una al servicio de la siguiente. La mayoría de nuestros proyectos no concluyen con el lanzamiento: se prolongan en un programa editorial mensual.
        </p>
      </div>

      <!-- Stages: connected card row -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
        {stages.map((s, i) => (
          <article
            data-reveal
            data-reveal-delay={String(i * 80)}
            class:list={[
              'group relative rounded-3xl bg-white border border-[var(--color-surface-border)] p-7 lg:p-8 transition-all duration-300 overflow-hidden',
              'hover:-translate-y-1.5 hover:shadow-[0_24px_50px_-22px_rgba(15,15,18,0.18)] hover:border-[var(--color-brand-orange)]/30',
            ]}
          >
            <!-- Top accent bar -->
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"></div>

            <!-- Big CN char (decorative) -->
            <span aria-hidden="true" class="absolute right-2 top-2 text-6xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.06] leading-none select-none pointer-events-none transition-all duration-500 group-hover:text-[var(--color-brand-orange)]/[0.12] group-hover:scale-110 origin-top-right">{s.cn}</span>

            <div class="relative">
              <!-- Number badge -->
              <div class="flex items-center gap-2 mb-5">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-[var(--color-text-dark)] text-white text-sm font-semibold font-[var(--font-heading)]">
                  {s.n}
                </span>
                <span class="text-[10px] font-mono uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Etapa {i + 1} de 4</span>
              </div>

              <h3 class="text-lg lg:text-[19px] font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-3">
                {s.title}
              </h3>
              <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-5">
                {s.body}
              </p>

              <!-- Output tag -->
              <div class="pt-4 border-t border-[var(--color-surface-border)]">
                <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1.5">Entregable</div>
                <div class="flex items-center gap-2 text-sm font-medium text-[var(--color-text-dark)]">
                  <svg class="w-4 h-4 text-[var(--color-brand-orange)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {s.output}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IS THIS FOR -->
  <WhoIsThisFor heading="Quién nos confía su contenido" audiences={audiences} background="white" />

  <!-- FAQ -->
  <section id="faq" class="section-spacing bg-[var(--color-surface-light)] scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32" data-reveal="left">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">FAQ · 常见问题</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Diez preguntas sobre el contenido chino
          </h2>
          <p class="mt-6 text-base text-[var(--color-text-body)] leading-relaxed">
            Despliegue cualquier pregunta para leer la respuesta. Si la suya no figura aquí, formúlela directamente.
          </p>
          <div class="mt-7">
            <Button href="/es/contacto/" variant="secondary" size="md">Plantear otra pregunta</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6" data-reveal="right">
          <div data-faq-accordion>
            {faqs.map((faq) => (
              <FAQItem question={faq.question} id={faq.id}>
                {faq.answer.map((para) => (
                  <p class="mb-3 last:mb-0">{para}</p>
                ))}
              </FAQItem>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA with marquee -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <!-- Marquee strip -->
    <div class="relative border-y border-white/10 bg-[#0f0f12] py-5 overflow-hidden">
      <div class="flex gap-10 animate-[marquee_45s_linear_infinite] whitespace-nowrap">
        {[...marqueePhrases, ...marqueePhrases, ...marqueePhrases].map((phrase) => (
          <span class="inline-flex items-center gap-3 text-base lg:text-lg font-medium text-white/40 hover:text-[var(--color-brand-orange)] transition-colors">
            {phrase}
            <span class="text-white/15">·</span>
          </span>
        ))}
      </div>
      <!-- fade edges -->
      <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#0f0f12] to-transparent pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#0f0f12] to-transparent pointer-events-none"></div>
    </div>

    <!-- CTA body -->
    <div class="relative py-20 lg:py-28">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[var(--color-brand-orange)]/8 rounded-full blur-[140px] pointer-events-none"></div>
      <span aria-hidden="true" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[24rem] lg:text-[30rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none">中</span>

      <div class="relative mx-auto max-w-[1400px] section-padding text-center" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/85">Listos cuando usted lo esté</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] max-w-3xl mx-auto">
          ¿Dispuesto a tomarse el contenido en serio?
        </h2>
        <p class="mt-6 text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
          La mayoría de los proyectos que dirigimos comienzan con una Estrategia y Auditoría: en ella se definen la línea de contenidos y la arquitectura de la información, en paralelo a la hoja de ruta técnica y de cumplimiento. Si ya sabe que necesita contenido, comenzamos sin más preámbulo.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
          <Button href="/es/contacto/" variant="primary" size="lg">Hablar con el equipo</Button>
          <Button href="/es/servicios/estrategia-auditoria/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Estrategia y Auditoría</Button>
          <Button href="/es/servicios/baidu-seo/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">SEO de Baidu</Button>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
