            <Button href="#structure" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Ver cГғВіmo escribimos</Button>
          </div>
        </div>

        <!-- Visual: layered comparison mockup -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Translated card (back, faded) -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Traducido</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">EN ГўвҖ вҖҷ ZH</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                PosiciГғВіn en Baidu: a la baja
              </div>
            </div>

            <!-- Native card (front, sharp) -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-green-500/15 border border-green-400/30">
                  <span class="w-1 h-1 rounded-full bg-green-400"></span>
                  <span class="text-[10px] font-mono text-green-300 uppercase tracking-wider">ZH nativo</span>
                </span>
                <span class="ml-auto text-[10px] font-mono text-white/40">brand-cn.md</span>
              </div>

              <div class="space-y-3.5 font-[var(--font-heading)]">
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H1</span>
                  <span class="text-[15px] text-white font-medium">ГҘвҖ вҖҰГҘВ®В№ГҘВҚВіГҘвҖңВҒГ§вҖ°Е’</span>
                </div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H2</span>
                  <span class="text-[13px] text-white/85">ГЁВҚВЈГЁВӘвҖ°ГЁВөвҖһГЁВҙВЁ ГӮВ· ГӨВјВҒГӨВёЕЎГҘЕҪвҖ Г§ВЁвҖ№ ГӮВ· Г§вҖқЕёГӨВәВ§ГҘЕёВәГҘЕ“В°</span>
                </div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H2</span>
                  <span class="text-[13px] text-white/85">ГЁВҙВЁГ©вҖЎВҸГЁВ®ВӨГЁВҜВҒ ГӮВ· ГҘВҗЛҶГӨВҪЕ“ГӨВјв„ўГӨВјВҙ ГӮВ· ГҘВӘвҖҷГӨВҪвҖңГҰЕ ВҘГ©ВҒвҖң</span>
                </div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">P</span>
                  <span class="text-[12px] text-white/55 leading-relaxed">Г§вҖқВұГҰЕ“В¬ГҘЕ“В°Г§ВјвҖ“ГЁВҫвҖҳГҰвҖҷВ°ГҘвҖ в„ўГҜВјЕ’Г§В¬ВҰГҘВҗЛҶГҘВ№ВҝГҘвҖҳЕ ГҰВівҖўГҜВјЕ’Г©ВқВўГҘВҗвҖҳ Baidu ГӨВёЕҪ AI ГҰВҗЕ“Г§ВҙВўГӨВјЛңГҘЕ’вҖ“ГЈвӮ¬вҖҡ</span>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-white/10 grid grid-cols-3 gap-2">
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">Baidu</div>
                  <div class="text-xs font-mono text-green-300">Indexado</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">ГҘВ№ВҝГҘвҖҳЕ ГҰВівҖў</div>
                  <div class="text-xs font-mono text-green-300">Conforme</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">BГғВәsqueda con IA</div>
