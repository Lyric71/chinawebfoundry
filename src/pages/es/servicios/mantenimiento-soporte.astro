---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'maintenance-support'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const includedItems = [
  {
    n: '01',
    cn: '内容',
    title: 'Actualizaciones editoriales',
    body: "De dos a cuatro piezas al mes para los clientes activos: un artículo de formato largo compatible con Baidu (de 1.500 a 2.500 caracteres chinos), un caso de éxito o una novedad de producto, una o dos notas de actualidad. Todo se redacta en chino nativo, nunca traducido. Sindicamos las mejores piezas en Baijiahao (百家号), Zhihu (知乎) y Sohu Hao (搜狐号), que las IA tratan como señales de verificación.",
    tag: 'Contenido',
    chips: ['百家号', '知乎', '搜狐号', 'ZH nativo', '双11 / 618 / 春节'],
  },
  {
    n: '02',
    cn: '搜索',
    title: 'Seguimiento de SEO en Baidu',
    body: "Informe mensual de posiciones sobre sus 30 a 50 palabras clave prioritarias, control de indexación en más de 100 URL mediante 百度搜索资源平台, de dos a tres correcciones técnicas al mes según lo que digan las cifras. Empujamos cada contenido nuevo a través de las herramientas de envío de Baidu el día de la publicación, corregimos los errores de rastreo y reconstruimos lo que sale del índice.",
    tag: 'SEO Baidu',
    chips: ['Posición', '主动推送', 'Índice', 'Respuesta al algoritmo'],
  },
  {
    n: '03',
    cn: '智能',
    title: 'Seguimiento GEO',
    body: "Controles de visibilidad semanales en DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝) y Baidu IA (百度AI), con una matriz de 40 consultas fijas por cliente que cubre marca, categoría, escenario y competencia. Los informes recogen la tasa de citación, la posición de recomendación, el sentimiento y la lista de ajustes por empujar durante el mes.",
    tag: 'Búsqueda con IA',
    chips: ['DeepSeek', 'Doubao', 'Kimi', '元宝', '文心X1'],
  },
  {
    n: '04',
    cn: '技术',
    title: 'Mantenimiento técnico',
    body: "Actualizaciones del núcleo de WordPress, de las extensiones y de los temas, probadas en preproducción antes de pasar a producción. Copias de seguridad diarias fuera del sitio, conservadas 30 días. Análisis de seguridad continuo con Wordfence o Sucuri. Controles de disponibilidad cada 5 minutos desde servidores en China. Limpieza trimestral de la base de datos. Renovación de los SSL compatibles con China mediante Aliyun (阿里云) o autoridades locales.",
    tag: 'Técnica',
    chips: ['Actualizaciones', 'Copias de seguridad', 'Seguridad', 'Disponibilidad', 'SSL'],
  },
  {
    n: '05',
    cn: '防火',
    title: 'La capa del Gran Cortafuegos',
    body: "Vigilamos en tiempo real el comportamiento del Gran Cortafuegos. Cuando un CDN, una biblioteca de tipografías o una API externa queda bloqueada, cambiamos a un equivalente compatible. Plazo medio entre la detección y el despliegue: 14 minutos. Volvemos a probar las conexiones con WeChat (微信), Alipay (支付宝), WeChat Pay (微信支付) y la medición de audiencia (Baidu Tongji o 51la) en cada ciclo de actualización.",
    tag: 'Gran Cortafuegos',
    chips: ['CDN', 'Tipografías', 'WeChat', 'Alipay', 'Medición de audiencia'],
  },
  {
    n: '06',
    cn: '主机',
    title: 'Alojamiento',
    body: "Servidores con licencia ICP (ICP备案) en Aliyun, Tencent Cloud (腾讯云) o Huawei Cloud (华为云), gestionados de principio a fin. Optimización durante los picos de tráfico. Renovaciones del Bei’an (备案) controladas en la consola del MIIT para que ninguna se quede en el tintero. SLA del 99,9 % con plazos documentados: 30 minutos para los incidentes críticos, 4 horas para los tickets estándar.",
    tag: 'Alojamiento',
    chips: ['ICP 备案', 'Aliyun', 'Tencent', 'Huawei', '99,9 % SLA'],
  },
  {
    n: '07',
    cn: '修复',
    title: 'Resolución de incidencias',
    body: "Cuando algo se rompe, el equipo en China toma el mando de inmediato. Errores, conflictos de extensiones, incidentes de seguridad, fallos en Alipay o WeChat Pay. En caso de ataque: aislar, limpiar, restaurar, reforzar, informe post mortem en 48 horas.",
    tag: 'Incidente',
    chips: ['Errores', 'Conflictos', 'Ataques', 'Post mortem 48 h'],
  },
];

const insightItems = [
  {
    n: '01',
    cn: '变',
    title: 'El ámbito digital chino se mueve más rápido',
    body: "El algoritmo de Baidu cambió once veces en 2025. DeepSeek publicó cuatro revisiones importantes de modelo. Doubao rehízo su ingesta de contenido al menos una vez al mes. El ritmo no afloja.",
  },
  {
    n: '02',
    cn: '退',
    title: 'Los sitios dejados a su suerte se degradan',
    body: "Los sitios lanzados bien y dejados intactos un año terminan casi siempre invisibles al noveno mes. La degradación es progresiva, y luego repentina.",
  },
  {
    n: '03',
    cn: '增',
    title: 'Los sitios mantenidos componen sus ganancias',
    body: "Los sitios que publican contenido fresco con regularidad, vigilan sus citaciones de IA cada semana y mantienen la pila técnica limpia componen sus ganancias. Las posiciones suben, las menciones de IA se acumulan, el coste de seguir visible baja.",
  },
  {
    n: '04',
    cn: '盲',
    title: 'Las agencias extranjeras lo pasan por alto',
    body: "Las agencias internacionales no detectan la mayoría de los modos de fallo sin VPN. Desde Londres o Chicago, todo parece ir bien, hasta el momento en que deja de irlo.",
  },
];

const stats = [
  { value: '14 min', label: 'Detección-despliegue medio', sub: 'Cuando una tipografía, un CDN o una API queda bloqueada.' },
  { value: '99,9 %', label: 'SLA de disponibilidad', sub: 'Respuesta en 30 minutos para los incidentes críticos.' },
  { value: '40', label: 'Consultas de IA por semana', sub: 'Seguimiento de las citaciones en 5 motores, cada semana.' },
];

const audiences = [
  { label: 'Sin equipo local', description: 'Empresas con un sitio chino en línea pero sin equipo sobre el terreno, que necesitan apoyo experto sin montarlo todo en casa.', image: '/images/audiences/wordpress-china-no-local-team.webp' },
  { label: 'El marketing primero', description: 'Equipos de marketing que prefieren trabajar en las campañas antes que perseguir extensiones rotas a nueve husos horarios de distancia.', image: '/images/audiences/marketing-not-debugging.webp' },
  { label: 'TI sin experto en China en plantilla', description: 'Equipos de TI que necesitan experiencia en China pero no pueden justificar un puesto a tiempo completo en el organigrama.', image: '/images/audiences/it-team-china-expertise.webp' },
  { label: 'Comercio electrónico en China', description: 'Negocios de comercio electrónico sobre WooCommerce o Shopify, con pasarelas de pago chinas y logística local.', image: '/images/audiences/woocommerce-china-payments.webp' },
];

const marqueePhrases = [
  '维护', 'Mantenimiento',
  '内容', 'GEO', 'SEO',
  'ICP 备案',
  'Aliyun · Tencent Cloud',
  'Wordfence',
  'WeChat Pay',
  'Alipay',
  '99,9 % disponibilidad',
  'Vigilancia 24/7',
  'Un equipo · una factura',
];

const faqs = [
  {
    id: 'why-not-internal',
    question: '¿Por qué no encargar esto a nuestro equipo de TI interno?',
    answer: [
      "Pueden, en teoría. En la práctica, los equipos internos pierden casi siempre la visibilidad del lado de China: no alcanzan los paneles de control (百度站长资源, consola de Aliyun, plataforma de WeChat) sin VPN, y las alertas llegan en chino. La mayoría de nuestros clientes conserva su TI para lo global y nos contrata como su oficina en China.",
    ],
  },
  {
    id: 'pricing',
    question: '¿Cómo se tarifan los planes?',
    answer: [
      "Planes mensuales desde 1.200 USD, ajustados a las necesidades reales del sitio. El importe depende del volumen de tráfico, de la cadencia editorial, del número de motores de IA bajo seguimiento y de si el alojamiento entra o no. Descríbanos su situación y volvemos en dos días laborables con una cifra precisa.",
    ],
  },
  {
    id: 'response-time',
    question: '¿Con qué rapidez reaccionan ante los incidentes?',
    answer: [
      "Incidentes críticos (sitio fuera de línea, pago, ataque): 30 minutos entre la alerta y la primera acción, 24/7. Tickets estándar (conflicto de extensión, cambio de contenido, duda sobre un panel de control): 4 horas laborables. Todos los plazos están por escrito en el SLA.",
    ],
  },
  {
    id: 'content-cadence',
    question: '¿Cuánto contenido publican al mes?',
    answer: [
      "De dos a cuatro piezas con un plan activo: un artículo de formato largo para Baidu (de 1.500 a 2.500 caracteres chinos), un caso de éxito o una novedad de producto, una o dos notas. La cadencia sube en torno a las ventanas de campaña: 双11, 618, 春节.",
    ],
  },
  {
    id: 'baidu-and-geo',
    question: '¿El SEO de Baidu y el GEO van incluidos o por separado?',
    answer: [
      "Ambos van incluidos en el plan para los clientes activos. Informe mensual de posiciones en Baidu y control de indexación, seguimiento semanal de las citaciones de IA en DeepSeek, Doubao, Kimi, Yuanbao y Baidu IA. Los trabajos estructurales de calado, rehacer el mapa de palabras clave o los grupos de contenido, siguen siendo proyectos aparte.",
    ],
  },
  {
    id: 'hosting',
    question: '¿Hay que trasladar el alojamiento a su empresa?',
    answer: [
      "No. Trabajamos con lo que tiene en Aliyun, Tencent Cloud o Huawei Cloud. Si el alojamiento entra en el plan, lo gestionamos todo, incluidas las renovaciones del 备案 en la consola del MIIT. Si no, nos coordinamos con quien lo lleve.",
    ],
  },
  {
    id: 'firewall',
    question: '¿Qué ocurre cuando el Gran Cortafuegos bloquea algo?',
    answer: [
      "Vigilamos el comportamiento en tiempo real y cambiamos a equivalentes compatibles con China cuando un CDN, una biblioteca de tipografías o una API externa deja de resolver. Plazo medio: 14 minutos entre la detección y el despliegue. Cada trimestre volvemos a probar las conexiones con WeChat, Alipay, WeChat Pay y Baidu Tongji, porque ahí las regresiones son silenciosas.",
    ],
  },
  {
    id: 'reporting',
    question: '¿Cómo son los informes?',
    answer: [
      "Resumen escrito mensual que cubre el contenido publicado, los movimientos de posiciones en Baidu, el seguimiento de las citaciones GEO, el trabajo técnico realizado, los incidentes resueltos y las prioridades recomendadas para el mes siguiente. Además, un panel de control en directo, accesible en cualquier momento.",
    ],
  },
];
const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-maintenance-beijing-team-office.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-emerald-500/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">维</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/servicios/" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Mantenimiento y soporte</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Mantenimiento y soporte</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Tras el Gran Cortafuegos, 24 horas al día</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Mantenga vivo su sitio chino.
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Mes tras</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">mes.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Contenido, SEO en Baidu, seguimiento GEO en los cinco motores de IA chinos, mantenimiento técnico, alojamiento. Todo lo lleva un equipo que opera desde dentro del Gran Cortafuegos, cada día. <span class="text-white font-medium">Un equipo. Una factura. Sin pasarse la pelota a nueve husos horarios.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-emerald-400/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">99,9<span class="text-base text-white/60">%</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">SLA disponibilidad</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter>14</span><span class="text-base text-white/60">min</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Detección → despliegue</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">24/7</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Vigilancia desde China</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/es/contacto/" variant="primary" size="lg">Hablar con nuestro equipo</Button>
            <Button href="#whats-included" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Ver qué incluye</Button>
          </div>
        </div>

        <!-- Visual: panel de control por capas -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Fondo: maqueta del sitio «dejado a su suerte» -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Sin seguimiento · 9 meses</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">sin equipo</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Posición en Baidu: a la baja
              </div>
            </div>

            <!-- Frente: panel de control en directo -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                </div>
                <span class="text-[10px] font-mono text-white/45 ml-2">estado-sitio · live</span>
                <span class="ml-auto inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-emerald-500/15 border border-emerald-400/30">
                  <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
                  <span class="text-[9px] font-mono text-emerald-300 uppercase">Sano</span>
                </span>
              </div>

              <div class="space-y-3.5">
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Vigilancia del Gran Cortafuegos</span>
                  <span class="text-[12px] font-mono text-emerald-300">Sin novedad</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Cadencia de contenido</span>
                  <span class="text-[12px] font-mono text-emerald-300">3 / mes</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Índice de Baidu</span>
                  <span class="text-[12px] font-mono text-emerald-300">Sano</span>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/75">Citaciones de IA (sem.)</span>
                    <span class="text-[12px] font-mono text-[var(--color-brand-orange)]">+<span data-counter data-counter-suffix="%">12</span></span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden shimmer-bar">
                    <div class="h-full w-[72%] bg-gradient-to-r from-[var(--color-brand-orange)] to-[#FF8956] rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/75">Disponibilidad · 30 d</span>
                    <span class="text-[12px] font-mono text-emerald-300">99,98 %</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[99%] bg-gradient-to-r from-emerald-400 to-emerald-300 rounded-full"></div>
                  </div>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-white/10 grid grid-cols-3 gap-2">
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">Copias de seguridad</div>
                  <div class="text-xs font-mono text-emerald-300">Al día</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">ICP 备案</div>
                  <div class="text-xs font-mono text-white/70">2027</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">SSL</div>
                  <div class="text-xs font-mono text-emerald-300">Válido</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- POR QUÉ: afirmación fuerte -->
  <section class="relative section-spacing overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0" data-reveal="left">
          <div class="relative inline-flex items-baseline">
            <span class="text-[10rem] lg:text-[14rem] font-medium font-[var(--font-heading)] leading-none bg-gradient-to-br from-[var(--color-brand-orange)] via-[#FF7E47] to-[#D94E1F] bg-clip-text text-transparent" data-counter data-counter-duration="1800">9</span>
            <span class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] ml-2">meses</span>
          </div>
          <p class="mt-4 text-base text-[var(--color-text-muted)] max-w-sm">
            Tiempo medio hasta que un sitio chino lanzado y luego abandonado desaparece del radar. Degradación progresiva, y luego salida brusca de las posiciones.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-7" data-reveal="right">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)] mb-5">Por qué importa</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15] mb-6">
            El lanzamiento es la parte fácil.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Un sitio chino no se lanza para olvidarlo después. Baidu hace retroceder a los sitios que dejan de publicar. Los motores de IA cambian su lógica de rastreo cada pocas semanas. Una fuente de Google que su desarrollador olvidó en el tema queda bloqueada un martes sin avisar, y la página de inicio se rompe para todos los visitantes de Shanghái, Shenzhen y Pekín.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            Desde su oficina en Londres o Chicago, todo parece ir bien hasta el momento en que deja de ir. Llevamos la vigilancia, el contenido, el trabajo de posicionamiento y la capa técnica dentro de un mismo compromiso.
          </p>

          <div class="flex flex-wrap items-center gap-2.5">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-brand-orange)] text-white text-sm font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
              Vigilancia
            </span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Publicación</span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Mantenimiento</span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Composición</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- QUÉ INCLUYE: tarjetas comparativas -->
  <section id="whats-included" class="relative section-spacing bg-gradient-to-b from-[var(--color-surface-light)] to-white overflow-hidden scroll-mt-32">
    <span aria-hidden="true" class="absolute -top-24 right-[-2rem] text-[20rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.04] leading-none select-none pointer-events-none" data-parallax="0.15">守</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14 lg:mb-16" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">Qué incluye · 服务内容</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-5">
          Siete frentes. Un solo plan.
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Los tres primeros mantienen el sitio visible. Los tres siguientes lo sostienen en pie. El último recupera lo que se cuela entre las mallas.
        </p>
      </div>

      <div class="space-y-5 lg:space-y-6">
        {includedItems.map((q, i) => (
          <article
            data-reveal
            data-reveal-delay={String(i * 50)}
            data-cursor-spotlight
            class:list={[
              'group relative grid grid-cols-1 lg:grid-cols-12 gap-0 rounded-3xl border border-[var(--color-surface-border)] bg-white overflow-hidden transition-all duration-500',
              'hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_30px_70px_-30px_rgba(15,15,18,0.18)] hover:-translate-y-1',
            ]}
          >
            <div class="lg:col-span-3 relative p-7 lg:p-8 bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white overflow-hidden">
              <span aria-hidden="true" class="absolute right-[-1.5rem] bottom-[-3rem] text-[14rem] font-medium font-[var(--font-heading)] text-white/[0.04] leading-none select-none pointer-events-none transition-transform duration-700 group-hover:scale-110 origin-bottom-right">{q.cn}</span>
              <div class="relative">
                <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-2">N.º {q.n} / 07</div>
                <div class="text-5xl lg:text-6xl font-medium font-[var(--font-heading)] text-white leading-none mb-1.5">{q.cn}</div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)]/90 font-semibold">{q.tag}</div>
              </div>
            </div>

            <div class="lg:col-span-6 p-7 lg:p-9 flex flex-col justify-center">
              <h3 class="text-2xl lg:text-[26px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4">
                {q.title}
              </h3>
              <p class="text-[15px] lg:text-base text-[var(--color-text-body)] leading-relaxed">
                {q.body}
              </p>
            </div>

            <div class="lg:col-span-3 p-6 lg:p-7 bg-[var(--color-surface-light)] border-t lg:border-t-0 lg:border-l border-[var(--color-surface-border)] flex flex-col justify-center gap-3">
              <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)]">Stack / superficies</div>
              <div class="flex flex-wrap gap-1.5">
                {q.chips.map((c) => (
                  <span class="text-[11px] font-mono px-2.5 py-1 rounded-md bg-white text-[var(--color-text-body)] border border-[var(--color-surface-border)]">{c}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUÉ DE FORMA CONTINUA: 4 observaciones en tarjetas bento -->
  <section class="relative section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(white_1px,transparent_1px)] [background-size:36px_36px] opacity-[0.025]"></div>
    <div class="absolute -top-32 left-[15%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.08] blur-[140px] pointer-events-none" data-float></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Por qué de forma continua · 为什么要持续</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] mb-5">
          Los sitios dejados a su suerte se vuelven invisibles.
        </h2>
        <p class="text-lg text-white/65 leading-relaxed">
          Los sitios mantenidos componen sus ganancias. La brecha entre unos y otros se ensancha rápido.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5">
        {insightItems.map((p, i) => (
          <div
            data-reveal
            data-reveal-delay={String(i * 80)}
            class:list={[
              'group relative rounded-3xl bg-white/[0.03] border border-white/10 p-7 lg:p-8 overflow-hidden transition-all duration-300',
              'hover:bg-white/[0.06] hover:border-white/20 hover:-translate-y-0.5',
            ]}
          >
            <span aria-hidden="true" class="absolute -right-3 -bottom-6 text-[8rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.06] leading-none select-none pointer-events-none transition-all duration-500 group-hover:text-[var(--color-brand-orange)]/[0.12] group-hover:scale-110 origin-bottom-right">{p.cn}</span>
            <div class="relative">
              <div class="flex items-center gap-3 mb-5">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)] text-sm font-semibold font-[var(--font-heading)]">
                  {p.n}
                </span>
                <span class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40">Observación {p.n} de 04</span>
              </div>
              <h3 class="text-xl font-semibold font-[var(--font-heading)] text-white leading-tight mb-3">
                {p.title}
              </h3>
              <p class="text-base text-white/65 leading-relaxed">
                {p.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CIFRAS -->
  <section class="relative section-spacing bg-white overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start mb-12">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-text-card-blue)]/10 border border-[var(--color-text-card-blue)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-card-blue)]">Cifras del servicio · 数据</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
            Las cifras que cumplimos, cada mes.
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-4 lg:mt-0" data-reveal data-reveal-delay="80">
          <p class="text-base text-[var(--color-text-body)] leading-relaxed">
            Recogidas en el SLA. Visibles en el panel de control en directo. Repasadas cada mes en un resumen escrito.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-5">
        {stats.map((s, i) => (
          <div
            data-reveal
            data-reveal-delay={String(i * 90)}
            class:list={[
              'group relative rounded-3xl p-7 lg:p-8 transition-all duration-300 hover:-translate-y-1 overflow-hidden',
              i === 1
                ? 'bg-gradient-to-br from-[var(--color-brand-orange)] to-[#D14A1F] text-white hover:shadow-[0_24px_50px_-22px_rgba(242,95,41,0.4)]'
                : 'bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] hover:shadow-[0_24px_50px_-22px_rgba(15,15,18,0.18)] hover:border-[var(--color-brand-orange)]/30',
            ]}
          >
            {i === 1 && <span aria-hidden="true" class="absolute -right-4 -bottom-8 text-[10rem] font-medium font-[var(--font-heading)] text-white/[0.08] leading-none select-none pointer-events-none">守</span>}
            <div class="relative">
              <div class:list={['text-[10px] font-mono uppercase tracking-[0.18em] mb-3', i === 1 ? 'text-white/75' : 'text-[var(--color-text-muted)]']}>{s.label}</div>
              <div class:list={['text-5xl lg:text-6xl font-medium font-[var(--font-heading)] leading-none mb-3', i === 1 ? 'text-white' : 'text-[var(--color-text-dark)]']}>
                {s.value}
              </div>
              <p class:list={['text-sm leading-relaxed', i === 1 ? 'text-white/90' : 'text-[var(--color-text-body)]']}>{s.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PARA QUIÉN -->
  <WhoIsThisFor heading="Quién nos contacta" audiences={audiences} background="light" />

  <!-- FAQ -->
  <section id="faq" class="section-spacing bg-white scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32" data-reveal="left">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">FAQ · 常见问题</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Ocho preguntas que nos hacen sobre el mantenimiento y el soporte
          </h2>
          <p class="mt-6 text-base text-[var(--color-text-body)] leading-relaxed">
            Pulse en una pregunta para desplegarla. Si la suya no está aquí, plantéenosla directamente.
          </p>
          <div class="mt-7">
            <Button href="/es/contacto/" variant="secondary" size="md">Plantear otra pregunta</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6" data-reveal="right">
          <div data-faq-accordion>
            {faqs.map((faq) => (
              <FAQItem question={faq.question} id={faq.id}>
                {faq.answer.map((para) => (
                  <p class="mb-3 last:mb-0">{para}</p>
                ))}
              </FAQItem>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA con marquee -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="relative border-y border-white/10 bg-[#0f0f12] py-5 overflow-hidden">
      <div class="flex gap-10 animate-[marquee_45s_linear_infinite] whitespace-nowrap">
        {[...marqueePhrases, ...marqueePhrases, ...marqueePhrases].map((phrase) => (
          <span class="inline-flex items-center gap-3 text-base lg:text-lg font-medium text-white/40 hover:text-[var(--color-brand-orange)] transition-colors">
            {phrase}
            <span class="text-white/15">·</span>
          </span>
        ))}
      </div>
      <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#0f0f12] to-transparent pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#0f0f12] to-transparent pointer-events-none"></div>
    </div>

    <div class="relative py-20 lg:py-28">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[var(--color-brand-orange)]/10 rounded-full blur-[140px] pointer-events-none"></div>
      <span aria-hidden="true" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[24rem] lg:text-[30rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none">维</span>

      <div class="relative mx-auto max-w-[1400px] section-padding text-center" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/85">No deje que se le escape</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] max-w-3xl mx-auto">
          Ya hizo lo más difícil. No deje que se le escape.
        </h2>
        <p class="mt-6 text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
          Descríbanos su situación. Volvemos con un plan que cubre la cadencia editorial, las acciones de SEO y GEO, el mantenimiento técnico y el alojamiento. Planes mensuales desde 1.200 USD, ajustados a las necesidades reales del sitio.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
          <Button href="/es/contacto/" variant="primary" size="lg">Propuesta a medida</Button>
          <Button href="/es/servicios/alojamiento-china/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Opciones de alojamiento</Button>
          <Button href="/es/servicios/baidu-seo/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">SEO en Baidu</Button>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
