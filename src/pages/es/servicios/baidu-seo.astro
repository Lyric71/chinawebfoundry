---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'baidu-seo'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const whyDifferent = [
  {
    n: '01',
    cn: '算法',
    title: 'Baidu premia otras señales',
    body: 'El 知心算法 (Zhixin) ya reconoce más de 200 relaciones semánticas entre las búsquedas en chino. El 飓风算法 3.0 penaliza el contenido de IA publicado sin revisión. Los textos traducidos de forma literal pierden posiciones en pocas semanas.',
    tag: 'Criterios de posicionamiento',
    chips: ['知心算法', '飓风算法 3.0', 'Redacción nativa', 'Semántica'],
  },
  {
    n: '02',
    cn: '蜘蛛',
    title: 'Baidu Spider rastrea de otra manera',
    body: 'Baidu Spider interpreta JavaScript con años de retraso respecto a Googlebot, de modo que el contenido generado en el navegador suele quedar fuera del índice. El rastreo prioriza la versión móvil, un tiempo de carga inferior a tres segundos constituye un requisito estricto y el HTTPS aporta una señal de confianza adicional.',
    tag: 'Rastreo y renderizado',
    chips: ['Baiduspider', 'Móvil primero', 'SSR / estático', 'HTTPS'],
  },
  {
    n: '03',
    cn: '主机',
    title: 'El país del alojamiento es una señal más',
    body: 'Un sitio sin registro ICP parte penalizado en el índice. A igualdad de contenido, el alojado en China continental se posiciona por encima de los situados en Hong Kong o en el extranjero. Es una señal estructural que influye en cada consulta.',
    tag: 'Infraestructura',
    chips: ['ICP', 'Continental', 'Aliyun', 'Tencent Cloud'],
  },
  {
    n: '04',
    cn: '推送',
    title: 'Baidu espera el envío de cada URL',
    body: 'Baidu no rastrea las páginas nuevas por iniciativa propia. Da por supuesto que las URL recién publicadas se le enviarán mediante 主动推送 (envío activo) en los minutos siguientes a su publicación. Ese envío lo conectamos directamente al CMS.',
    tag: 'Envío',
    chips: ['主动推送', '自动推送', 'Sitemap', '手工提交'],
  },
  {
    n: '05',
    cn: '关键词',
    title: 'Las palabras clave se investigan en chino, desde cero',
    body: 'Lo que un usuario chino escribe en el cuadro de búsqueda apenas se parece a una lista de palabras clave traducida del inglés. Investigamos desde cero, a partir de datos reales de búsqueda en chino, con 百度指数 (Baidu Index) y el 百度关键词规划师.',
    tag: 'Descubrimiento',
    chips: ['百度指数', '关键词规划师', '5118', 'Cola larga'],
  },
];

const services = [
  {
    n: '01',
    title: 'SEO técnico para Baidu',
    body: 'Verificamos el sitio en el 百度搜索资源平台 y configuramos los cuatro métodos de envío de URL por orden de prioridad. A ello se añaden el 死链提交, el 站点子链 y la comprobación del rastreo móvil. Medimos la velocidad desde China continental, el entorno donde realmente la percibe el usuario.',
    bullets: [
      '主动推送 (envío activo), conectado al CMS para enviar cada URL en tiempo real.',
      '自动推送 (envío automático) por JavaScript, que recoge las URL visitadas antes incluso de que se active el hook del CMS.',
      'Sitemap completo y actualizado de forma automática (50.000 URL o 10 MB como máximo por archivo).',
      '手工提交 (envío manual), reservado a las páginas de mayor valor.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Contenido chino nativo, estructurado para Baidu',
    body: 'Baidu recompensa el 深度原创, el contenido original y elaborado con rigor. El 飓风算法 degrada las páginas de baja calidad o duplicadas, y su versión 3.0 actúa específicamente contra el contenido de IA publicado sin revisión humana. Trabajamos con redactores chinos nativos: textos extensos, marcado Schema y respuestas precisas que los motores de IA puedan citar.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Optimización para la búsqueda con IA (文心X1, DeepSeek, Doubao, Kimi)',
    body: 'En 2025, más del 20 % de los resultados de Baidu ya incluían una respuesta generada por IA. El buscador integra 文心X1 y la búsqueda profunda de DeepSeek en la propia página de resultados. Preparamos el contenido para que esos motores lo lean, lo interpreten y mencionen su marca al redactar la respuesta.',
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Autoridad en el ecosistema web chino',
    body: 'Sus enlaces internacionales apenas cuentan para Baidu. Las plataformas que inciden en el posicionamiento son 百度百科, 百度知道, 百度贴吧, 知乎, 百家号 y 百度爱采购, a las que se suman los portales B2B del sector y las señales de WeChat y Weibo. Desarrollamos esa presencia y coordinamos la difusión del contenido.',
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Optimización continua y respuesta a los algoritmos',
    body: 'Baidu no anuncia la mayoría de sus actualizaciones; las pocas que comunica aparecen en chino en el blog del 百度搜索资源平台. En los últimos doce meses hemos seguido la evolución del 知心算法, el paso al 飓风算法 3.0 y la entrada de 文心X1 y DeepSeek. Cada uno de esos cambios ha redefinido qué se posiciona y qué no.',
    tag: 'p.30',
  },
];

const tools = [
  {
    name: '百度搜索资源平台',
    en: 'Plataforma para webmasters de Baidu',
    cn: '资源',
    body: 'La consola oficial para webmasters: verificación del sitio, envío de URL, sitemaps, informes de indexación, prueba de visualización móvil, aviso de enlaces rotos y un canal con los cambios de algoritmo.',
    feature: true,
    items: ['Verificación del sitio', 'API de envío de URL', 'Sitemap', 'Informes de indexación', 'Prueba móvil', '死链提交', 'Avisos de algoritmo'],
  },
  {
    name: '百度统计',
    en: 'Baidu Tongji',
    cn: '统计',
    body: 'El Google Analytics de Baidu. Imprescindible para medir con rigor todo lo que ocurre en el mercado chino.',
  },
  {
    name: '百度指数',
    en: 'Baidu Index y Keyword Planner',
    cn: '指数',
    body: 'El punto de partida para investigar palabras clave directamente en chino, sin pasar por una lista traducida del inglés. Se usa junto con el 百度关键词规划师.',
  },
  {
    name: '5118 · 爱站 · 站长之家',
    en: 'Herramientas SEO chinas de terceros',
    cn: '工具',
    body: 'A menudo ofrecen un análisis de la competencia y un histórico de posiciones más exhaustivo que las propias herramientas oficiales.',
  },
  {
    name: 'API para webmasters de Baidu',
    en: 'Integración del envío activo',
    cn: '接口',
    body: 'Para el 主动推送 nos conectamos directamente al CMS, sin pasar por los paneles manuales.',
  },
];

const stages = [
  {
    n: '01',
    cn: '审计',
    title: 'Auditoría de Baidu',
    body: 'Realizamos las pruebas desde China continental: indexación, estado del rastreo de Baiduspider, profundidad del contenido y señales de ICP y alojamiento. Medimos la posición de partida en 50 a 100 palabras clave objetivo.',
    output: 'Informe de auditoría',
  },
  {
    n: '02',
    cn: '关键词',
    title: 'Mapa de palabras clave',
    body: 'Realizamos la investigación en chino nativo con 百度指数 y el 关键词规划师. Entregamos un mapa con la intención de búsqueda, los volúmenes y una pauta de contenido para cada grupo de términos.',
    output: 'Mapa y pautas',
  },
  {
    n: '03',
    cn: '部署',
    title: 'Despliegue técnico',
    body: 'En un mismo despliegue entregamos la verificación del sitio, el 主动推送 conectado al CMS, los sitemaps, el marcado Schema, los ajustes de velocidad y de versión móvil, el archivo llms.txt y la estructura preparada para la búsqueda con IA.',
    output: 'Indexación en marcha',
  },
  {
    n: '04',
    cn: '权威',
    title: 'Autoridad y contenido',
    body: 'Producimos contenido en chino nativo y lo difundimos en 百家号, 知乎, 百度知道 y los portales del sector que correspondan. Las fichas en 百度百科 se incorporan cuando la marca reúne las condiciones para sostenerlas.',
    output: 'Menciones y avances',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Seguimiento e iteración',
    body: 'Hacemos un seguimiento semanal de las posiciones, entregamos un informe mensual por escrito y reaccionamos a cada actualización del algoritmo dentro de la misma semana. Baidu evoluciona sin previo aviso; el equipo que no lo supervisa pierde posiciones sin advertir la causa.',
    output: 'Informe mensual',
  },
];

const stats = [
  { value: '24-72h', label: 'Indexación vía 主动推送', sub: 'Las URL nuevas entran en Baidu en cuestión de horas, frente a las semanas que tarda el rastreo natural.' },
  { value: '11', label: 'Actualizaciones del algoritmo seguidas en 2025', sub: 'Entre ellas, el 知心算法, el 飓风算法 3.0 y la integración de 文心X1.' },
  { value: '20%+', label: 'Páginas de Baidu con respuesta de IA', sub: '文心X1 y DeepSeek ya integrados en los resultados.' },
];

const audiences = [
  {
    label: 'Marcas extranjeras invisibles en Baidu',
    description: 'Empresas cuyo sitio chino recibe menos de cincuenta visitas orgánicas al mes desde Baidu, mientras ya pagan publicidad por esas mismas palabras clave.',
    image: '/images/audiences/no-organic-traffic-china.webp',
  },
  {
    label: 'Marcas con contenido traducido y antiguo',
    description: 'Sitios extranjeros cuyas páginas en chino siguen siendo una mera traducción, sin revisión alguna desde el lanzamiento.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marcas que parten de cero',
    description: 'Empresas que desean estar presentes en Baidu desde el primer día, con la visibilidad prevista ya en el diseño del sitio y en el calendario editorial.',
    image: '/images/audiences/launching-chinese-market.webp',
  },
  {
    label: 'Marcas que priorizan la búsqueda con IA',
    description: 'Equipos que observan las respuestas de IA ocupando los primeros lugares de Baidu y aspiran a que esos motores citen su marca.',
    image: '/images/audiences/seo-pro-needs-baidu.webp',
  },
];

const marqueePhrases = [
  '百度', 'Baidu',
  '主动推送', 'Active Push',
  '知心算法', '飓风算法 3.0',
  '文心X1', 'DeepSeek',
  '百家号', '知乎', '百度百科',
  'ICP registrado',
  'Alojamiento continental',
  'Preparado para la IA',
];

const faqs = [
  {
    id: 'outside-china',
    question: '¿Se puede dirigir el SEO de Baidu desde fuera de China?',
    answer: [
      'Técnicamente sí, pero con limitaciones considerables. La verificación de Baidu exige un número de teléfono chino, el panel está en chino, la documentación no se traduce y muchas de sus herramientas restringen o bloquean las IP extranjeras. La mayoría de los equipos extranjeros que lo intentan abandonan antes de un trimestre. Lo gestionamos desde Shanghái, el único lugar desde el que este trabajo se realiza con garantías.',
    ],
  },
  {
    id: 'how-long',
    question: '¿En cuánto tiempo se ven resultados?',
    answer: [
      'Las palabras clave de cola larga registran sus primeros avances entre la semana 6 y la 10. Los términos competitivos necesitan de 3 a 6 meses, como mínimo. El crecimiento orgánico de fondo sigue una curva de 6 a 12 meses. La indexación de los contenidos nuevos, en cambio, se produce en 24 a 72 horas gracias al 主动推送.',
    ],
  },
  {
    id: 'no-icp',
    question: '¿Y si nuestro sitio no tiene registro ICP?',
    answer: [
      'Se posicionará, pero con una desventaja apreciable. Baidu considera extranjeros los sitios alojados en Hong Kong o fuera del país, los rastrea con menos frecuencia y los sitúa por debajo de los continentales. Para una marca con objetivos serios en Baidu, el registro ICP con alojamiento en el continente sigue siendo la opción correcta.',
    ],
  },
  {
    id: 'baidu-ads',
    question: '¿También gestionan Baidu Ads (SEM)?',
    answer: [
      'No. Nos centramos en el SEO orgánico de Baidu. La publicidad de pago es otra especialidad, de la que se encargan equipos distintos. No obstante, colaboramos estrechamente con las agencias de medios para que el contenido SEO y las páginas de aterrizaje de pago no compitan entre sí.',
    ],
  },
  {
    id: 'chinese-content',
    question: '¿Cómo se articula este servicio con el trabajo de contenido chino?',
    answer: [
      'Son inseparables. Hacer SEO de Baidu sin contenido chino nativo es un esfuerzo en vano. La mayoría de nuestros clientes contratan ambos servicios en un mismo encargo, de modo que el equipo de contenido y el de SEO trabajan con el mismo mapa de palabras clave y la misma arquitectura editorial.',
    ],
  },
  {
    id: 'ai-search',
    question: '¿Y la visibilidad ante las IA en Doubao, Kimi, DeepSeek y 文心X1?',
    answer: [
      'Cada vez más, se trata del mismo trabajo. Baidu ya integra 文心X1 y DeepSeek en más del 20 % de sus páginas de resultados. Preparar el contenido para la IA (respuestas claras y verificables, marcado Schema, llms.txt, una estructura semántica ordenada) coincide casi por completo con las exigencias de Baidu. Por eso abordamos ambos frentes de forma conjunta.',
    ],
  },
  {
    id: 'links',
    question: '¿Hacen construcción de enlaces?',
    answer: [
      'Construimos autoridad en las plataformas chinas (百度百科, 百度知道, 知乎, 百家号, 百度爱采购 y portales B2B del sector), que son las que influyen en el posicionamiento de Baidu. Comprar enlaces genéricos a un intermediario occidental resulta ineficaz y expone al sitio a una sanción del 飓风算法. En China, la autoridad se construye en las plataformas chinas, y no existe una vía alternativa.',
    ],
  },
  {
    id: 'measurement',
    question: '¿Cómo miden el éxito?',
    answer: [
      'Medimos las páginas incluidas en el índice, la posición de las palabras clave con seguimiento semanal, el tráfico orgánico de Baidu a través de 百度统计, la atribución de conversiones y la cuota de voz frente a un grupo de tres a cinco competidores concretos. Todo ello se recoge en un informe mensual por escrito, acompañado de un panel actualizado en tiempo real.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: '¿Qué hacen cuando Baidu cambia su algoritmo?',
    answer: [
      'Revisamos cada semana los comunicados del 百度搜索资源平台 y reaccionamos dentro de esa misma semana cuando se publica una novedad relevante. En los últimos doce meses hemos registrado la ampliación del 知心算法, el 飓风算法 3.0 contra el contenido de IA, la entrada de 文心X1 en los resultados y varios ajustes menores.',
    ],
  },
  {
    id: 'cost',
    question: '¿Cuánto cuesta?',
    answer: [
      'Depende del alcance: el tamaño del sitio, el volumen de contenido, la intensidad de la competencia y la inclusión o no de la producción de contenido chino y la optimización para IA. Descríbanos sus necesidades y en dos días hábiles le entregaremos un presupuesto cerrado.',
    ],
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'es-ES',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer.join('\n\n') },
  })),
};

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd, faqLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-search-results.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/servicios/" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">SEO en Baidu</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">SEO en Baidu</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Detrás del Great Firewall, en Shanghái</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Que le encuentren en
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">百度.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Donde empieza la búsqueda en China.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Baidu funciona con su propio rastreador, su propio índice, su propia API de envío y su propio ciclo de actualizaciones. A todo ello se añade, desde hace poco, una capa de inteligencia artificial (文心X1, DeepSeek) que ya redacta más de uno de cada cinco resultados. <span class="text-white font-medium">Lo gestionamos desde Shanghái, con las herramientas oficiales del buscador.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">20</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Años con Baidu</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">200</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Relaciones semánticas 知心</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">72h</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Indexación vía 主动推送</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/es/contacto/" variant="primary" size="lg">Solicitar una auditoría de Baidu</Button>
            <Button href="#what-we-do" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Lo que hacemos</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Sin registro</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">sitio fuera del continente</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Índice: 4 / 312 páginas
              </div>
            </div>

            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
