---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'baidu-seo'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const whyDifferent = [
  {
    n: '01',
    cn: '算法',
    title: 'Baidu premia señales distintas',
    body: 'El 知心算法 (Zhixin) ya distingue más de 200 relaciones semánticas entre las búsquedas en chino. El 飓风算法 3.0 castiga el contenido de IA que se publica sin revisar. Una traducción literal, por buena que parezca, cae en el ranking en cuestión de semanas.',
    tag: 'Criterios de posicionamiento',
    chips: ['知心算法', '飓风算法 3.0', 'Redacción nativa', 'Semántica'],
  },
  {
    n: '02',
    cn: '蜘蛛',
    title: 'Baiduspider rastrea de otra forma',
    body: 'Baiduspider va años por detrás de Googlebot a la hora de interpretar JavaScript, así que el contenido que se genera en el navegador rara vez llega al índice. Rastrea primero la versión móvil, exige tiempos de carga por debajo de los tres segundos y toma el HTTPS como una señal más de confianza.',
    tag: 'Rastreo y renderizado',
    chips: ['Baiduspider', 'Móvil primero', 'SSR / estático', 'HTTPS'],
  },
  {
    n: '03',
    cn: '主机',
    title: 'Dónde se aloja el sitio también cuenta',
    body: 'Un sitio sin registro ICP parte con desventaja en el índice. Con el mismo contenido, el que se aloja en China continental queda por encima de los de Hong Kong o del extranjero. Es una señal de fondo que pesa en cada consulta.',
    tag: 'Infraestructura',
    chips: ['ICP', 'Continental', 'Aliyun', 'Tencent Cloud'],
  },
  {
    n: '04',
    cn: '推送',
    title: 'Baidu espera que le envíe cada URL',
    body: 'Baidu no sale a buscar las páginas nuevas por su cuenta. Da por hecho que cada URL recién publicada le llegará por 主动推送 (envío activo) en los minutos siguientes. Conectamos ese envío directamente al CMS.',
    tag: 'Envío',
    chips: ['主动推送', '自动推送', 'Sitemap', '手工提交'],
  },
  {
    n: '05',
    cn: '关键词',
    title: 'Las palabras clave se investigan en chino, de cero',
    body: 'Lo que un usuario chino teclea en el buscador se parece poco a una lista de keywords traducida del inglés. Partimos de cero, con datos reales de búsqueda en chino, y nos apoyamos en 百度指数 (Baidu Index) y el 百度关键词规划师.',
    tag: 'Descubrimiento',
    chips: ['百度指数', '关键词规划师', '5118', 'Cola larga'],
  },
];

const services = [
  {
    n: '01',
    title: 'SEO técnico para Baidu',
    body: 'Verificamos el sitio en el 百度搜索资源平台 y ordenamos por prioridad los cuatro métodos de envío de URL. Sumamos el 死链提交, el 站点子链 y la revisión del rastreo móvil. Y medimos la velocidad desde China continental, que es donde la nota de verdad el usuario.',
    bullets: [
      '主动推送 (envío activo), conectado al CMS para mandar cada URL en tiempo real.',
      '自动推送 (envío automático) por JavaScript, que recoge las URL visitadas antes incluso de que salte el hook del CMS.',
      'Sitemap completo, que se actualiza solo (máximo 50.000 URL o 10 MB por archivo).',
      '手工提交 (envío manual), reservado a las páginas más valiosas.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Contenido chino nativo, estructurado para Baidu',
    body: 'Baidu recompensa el 深度原创: contenido original y trabajado a fondo. El 飓风算法 hunde las páginas flojas o duplicadas, y su versión 3.0 va a por el contenido de IA publicado sin revisión humana. Por eso trabajamos con redactores chinos nativos: textos largos, marcado Schema y respuestas precisas que los motores de IA puedan citar.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Optimización para la búsqueda con IA (文心X1, DeepSeek, Doubao, Kimi)',
    body: 'En 2025, más del 20 % de los resultados de Baidu ya traían una respuesta generada por IA. El buscador integra 文心X1 y la búsqueda profunda de DeepSeek en la propia página de resultados. Preparamos el contenido para que esos motores lo lean, lo entiendan y nombren su marca al redactar la respuesta.',
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Autoridad en el ecosistema web chino',
    body: 'Sus enlaces internacionales apenas cuentan para Baidu. Las plataformas que mueven la aguja son 百度百科, 百度知道, 百度贴吧, 知乎, 百家号 y 百度爱采购, más los portales B2B del sector y las señales de WeChat y Weibo. Construimos esa presencia y coordinamos la difusión del contenido.',
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Optimización continua y respuesta a los algoritmos',
    body: 'Baidu no anuncia la mayoría de sus actualizaciones; las pocas que comunica salen en chino en el blog del 百度搜索资源平台. En el último año hemos seguido la evolución del 知心算法, el salto al 飓风算法 3.0 y la llegada de 文心X1 y DeepSeek. Cada uno de esos cambios ha reescrito las reglas de qué posiciona y qué no.',
    tag: 'p.30',
  },
];

const tools = [
  {
    name: '百度搜索资源平台',
    en: 'Plataforma para webmasters de Baidu',
    cn: '资源',
    body: 'La consola oficial para webmasters: verificación del sitio, envío de URL, sitemaps, informes de indexación, prueba de vista móvil, aviso de enlaces rotos y un canal donde Baidu publica sus cambios de algoritmo.',
    feature: true,
    items: ['Verificación del sitio', 'API de envío de URL', 'Sitemap', 'Informes de indexación', 'Prueba móvil', '死链提交', 'Avisos de algoritmo'],
  },
  {
    name: '百度统计',
    en: 'Baidu Tongji',
    cn: '统计',
    body: 'El Google Analytics de Baidu. Imprescindible para medir con rigor lo que pasa en el mercado chino.',
  },
  {
    name: '百度指数',
    en: 'Baidu Index y Keyword Planner',
    cn: '指数',
    body: 'El punto de partida para investigar palabras clave en chino de primera mano, sin pasar por una lista traducida del inglés. Se combina con el 百度关键词规划师.',
  },
  {
    name: '5118 · 爱站 · 站长之家',
    en: 'Herramientas SEO chinas de terceros',
    cn: '工具',
    body: 'A menudo dan un análisis de la competencia y un histórico de posiciones más completos que las propias herramientas oficiales.',
  },
  {
    name: 'API para webmasters de Baidu',
    en: 'Integración del envío activo',
    cn: '接口',
    body: 'Para el 主动推送 nos conectamos directamente al CMS y nos saltamos los paneles manuales.',
  },
];

const stages = [
  {
    n: '01',
    cn: '审计',
    title: 'Auditoría de Baidu',
    body: 'Hacemos las pruebas desde China continental: indexación, estado del rastreo de Baiduspider, profundidad del contenido y señales de ICP y alojamiento. Medimos la posición de partida en 50 o 100 palabras clave objetivo.',
    output: 'Informe de auditoría',
  },
  {
    n: '02',
    cn: '关键词',
    title: 'Mapa de palabras clave',
    body: 'Investigamos en chino nativo con 百度指数 y el 关键词规划师. Le entregamos un mapa con la intención de búsqueda, los volúmenes y una pauta de contenido para cada grupo de términos.',
    output: 'Mapa y pautas',
  },
  {
    n: '03',
    cn: '部署',
    title: 'Despliegue técnico',
    body: 'En un mismo despliegue dejamos listos la verificación del sitio, el 主动推送 conectado al CMS, los sitemaps, el marcado Schema, los ajustes de velocidad y de versión móvil, el archivo llms.txt y la estructura preparada para la búsqueda con IA.',
    output: 'Indexación en marcha',
  },
  {
    n: '04',
    cn: '权威',
    title: 'Autoridad y contenido',
    body: 'Producimos contenido en chino nativo y lo difundimos en 百家号, 知乎, 百度知道 y los portales del sector que toquen. Las fichas en 百度百科 llegan cuando la marca reúne las condiciones para sostenerlas.',
    output: 'Menciones y avances',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Seguimiento e iteración',
    body: 'Seguimos las posiciones cada semana, entregamos un informe mensual por escrito y respondemos a cada actualización del algoritmo dentro de la misma semana. Baidu cambia sin avisar, y el equipo que no lo vigila pierde posiciones sin saber por qué.',
    output: 'Informe mensual',
  },
];

const stats = [
  { value: '24-72h', label: 'Indexación vía 主动推送', sub: 'Las URL nuevas entran en Baidu en cuestión de horas, frente a las semanas del rastreo natural.' },
  { value: '11', label: 'Actualizaciones del algoritmo seguidas en 2025', sub: 'Entre ellas, el 知心算法, el 飓风算法 3.0 y la llegada de 文心X1.' },
  { value: '20%+', label: 'Páginas de Baidu con respuesta de IA', sub: '文心X1 y DeepSeek, ya integrados en los resultados.' },
];

const audiences = [
  {
    label: 'Marcas extranjeras invisibles en Baidu',
    description: 'Empresas cuyo sitio chino recibe menos de cincuenta visitas orgánicas al mes desde Baidu, mientras ya pagan anuncios por esas mismas palabras clave.',
    image: '/images/audiences/no-organic-traffic-china.webp',
  },
  {
    label: 'Marcas con contenido traducido y antiguo',
    description: 'Sitios extranjeros cuyas páginas en chino siguen siendo una traducción sin más, que nadie ha tocado desde el lanzamiento.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marcas que parten de cero',
    description: 'Empresas que quieren estar en Baidu desde el primer día, con la visibilidad prevista ya en el diseño del sitio y en el calendario editorial.',
    image: '/images/audiences/launching-chinese-market.webp',
  },
  {
    label: 'Marcas que priorizan la búsqueda con IA',
    description: 'Equipos que ven cómo las respuestas de IA ocupan los primeros puestos de Baidu y quieren que esos motores citen su marca.',
    image: '/images/audiences/seo-pro-needs-baidu.webp',
  },
];

const marqueePhrases = [
  '百度', 'Baidu',
  '主动推送', 'Active Push',
  '知心算法', '飓风算法 3.0',
  '文心X1', 'DeepSeek',
  '百家号', '知乎', '百度百科',
  'ICP registrado',
  'Alojamiento continental',
  'Preparado para la IA',
];

const faqs = [
  {
    id: 'outside-china',
    question: '¿Se puede llevar el SEO de Baidu desde fuera de China?',
    answer: [
      'Técnicamente sí, pero a trompicones. La verificación de Baidu pide un número de teléfono chino, el panel está en chino, la documentación no se traduce y muchas de sus herramientas limitan o bloquean las IP extranjeras. La mayoría de los equipos de fuera que lo intentan tiran la toalla antes de un trimestre. Nosotros lo llevamos desde Shanghái, que es donde este trabajo sale bien.',
    ],
  },
  {
    id: 'how-long',
    question: '¿En cuánto tiempo se ven resultados?',
    answer: [
      'Las palabras clave de cola larga dan sus primeros frutos entre la semana 6 y la 10. Los términos competitivos piden de 3 a 6 meses, como poco. El crecimiento orgánico de fondo tarda entre 6 y 12 meses en cuajar. La indexación de los contenidos nuevos, en cambio, ocurre en 24 a 72 horas gracias al 主动推送.',
    ],
  },
  {
    id: 'no-icp',
    question: '¿Y si nuestro sitio no tiene registro ICP?',
    answer: [
      'Posicionará, pero con una clara desventaja. Baidu trata como extranjeros los sitios alojados en Hong Kong o fuera del país: los rastrea menos a menudo y los deja por debajo de los continentales. Si una marca se toma Baidu en serio, el registro ICP con alojamiento en el continente sigue siendo la opción acertada.',
    ],
  },
  {
    id: 'baidu-ads',
    question: '¿También gestionan Baidu Ads (SEM)?',
    answer: [
      'No. Nos centramos en el SEO orgánico de Baidu. La publicidad de pago es otra especialidad, con equipos propios. Aun así, trabajamos codo con codo con las agencias de medios para que el contenido SEO y las páginas de aterrizaje de pago no se pisen.',
    ],
  },
  {
    id: 'chinese-content',
    question: '¿Cómo encaja este servicio con el trabajo de contenido chino?',
    answer: [
      'Van de la mano. Hacer SEO de Baidu sin contenido chino nativo no lleva a ninguna parte. La mayoría de nuestros clientes contratan los dos servicios en un mismo encargo, así el equipo de contenido y el de SEO trabajan con el mismo mapa de palabras clave y la misma arquitectura editorial.',
    ],
  },
  {
    id: 'ai-search',
    question: '¿Y la visibilidad ante las IA en Doubao, Kimi, DeepSeek y 文心X1?',
    answer: [
      'Cada vez más, es el mismo trabajo. Baidu ya integra 文心X1 y DeepSeek en más del 20 % de sus páginas de resultados. Preparar el contenido para la IA (respuestas claras y verificables, marcado Schema, llms.txt, una estructura semántica ordenada) coincide casi punto por punto con lo que pide Baidu. Por eso tratamos los dos frentes a la vez.',
    ],
  },
  {
    id: 'links',
    question: '¿Hacen construcción de enlaces?',
    answer: [
      'Construimos autoridad en las plataformas chinas (百度百科, 百度知道, 知乎, 百家号, 百度爱采购 y portales B2B del sector), que son las que pesan en el posicionamiento de Baidu. Comprar enlaces genéricos a un intermediario occidental no sirve de nada y expone al sitio a una sanción del 飓风算法. En China, la autoridad se gana en las plataformas chinas, y no hay atajo que valga.',
    ],
  },
  {
    id: 'measurement',
    question: '¿Cómo miden el éxito?',
    answer: [
      'Medimos las páginas que entran en el índice, la posición de las palabras clave con seguimiento semanal, el tráfico orgánico de Baidu a través de 百度统计, la atribución de conversiones y la cuota de voz frente a un grupo de tres a cinco competidores concretos. Todo ello va en un informe mensual por escrito, con un panel que se actualiza en tiempo real.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: '¿Qué hacen cuando Baidu cambia su algoritmo?',
    answer: [
      'Revisamos cada semana los comunicados del 百度搜索资源平台 y respondemos en esa misma semana cuando sale una novedad importante. En el último año hemos anotado la ampliación del 知心算法, el 飓风算法 3.0 contra el contenido de IA, la entrada de 文心X1 en los resultados y varios ajustes menores.',
    ],
  },
  {
    id: 'cost',
    question: '¿Cuánto cuesta?',
    answer: [
      'Depende del alcance: el tamaño del sitio, el volumen de contenido, la presión de la competencia y si se suman o no la producción de contenido chino y la optimización para IA. Cuéntenos qué necesita y en dos días hábiles le pasamos un presupuesto cerrado.',
    ],
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'es-ES',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer.join('\n\n') },
  })),
};

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd, faqLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-search-results.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/servicios/" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">SEO en Baidu</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">SEO en Baidu</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Detrás del Great Firewall, en Shanghái</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Que le encuentren en
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">百度.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Ahí empieza la búsqueda en China.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Baidu funciona con su propio rastreador, su propio índice, su propia API de envío y su propio ciclo de actualizaciones. Y desde hace poco suma una capa de inteligencia artificial (文心X1, DeepSeek) que ya redacta más de uno de cada cinco resultados. <span class="text-white font-medium">Lo gestionamos desde Shanghái, con las herramientas oficiales del buscador.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">20</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Años con Baidu</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">200</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Relaciones semánticas 知心</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">72h</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Indexación vía 主动推送</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/es/contacto/" variant="primary" size="lg">Solicitar una auditoría de Baidu</Button>
            <Button href="#what-we-do" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Lo que hacemos</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Sin registro</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">sitio fuera del continente</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Índice: 4 / 312 páginas
              </div>
            </div>

            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                </div>
