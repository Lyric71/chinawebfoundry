---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'geo'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const engines = [
  {
    n: '01',
    cn: '深度',
    name: 'DeepSeek',
    enLabel: '深度求索',
    body: 'Prioriza el contenido bien estructurado, técnicamente impecable y de fuentes oficiales. Si su web tarda en cargar desde China, o depende de recursos que bloquea el Gran Cortafuegos (防火长城), DeepSeek ni siquiera la ve.',
    tag: 'Contenido extenso y estructurado',
    chips: ['JSON-LD', 'SSR', 'Velocidad', 'Sin dependencias bloqueadas'],
  },
  {
    n: '02',
    cn: '豆包',
    name: 'Doubao',
    enLabel: '字节跳动',
    body: 'El motor de ByteDance se nutre de su propio ecosistema: Toutiao (今日头条), Douyin (抖音) y Baijiahao (百家号). Para posicionarse en Doubao hay que trabajar ese ecosistema, además de la propia web.',
    tag: 'Grafo de ByteDance',
    chips: ['Toutiao', 'Douyin', 'Baijiahao', 'Sindicación'],
  },
  {
    n: '03',
    cn: 'Kimi',
    name: 'Kimi',
    enLabel: 'Moonshot AI',
    body: 'Premia los análisis extensos: comparativas, guías técnicas, informes de miles de palabras con tablas claras. El contenido comercial breve pasa inadvertido.',
    tag: 'Profundidad y tablas',
    chips: ['Comparativas', 'Guías', 'Tablas', 'Artículos de fondo'],
  },
  {
    n: '04',
    cn: '元宝',
    name: 'Yuanbao',
    enLabel: '腾讯混元',
    body: 'Es la puerta de entrada de Tencent al ecosistema de WeChat (微信) y el único asistente capaz de rastrear las cuentas oficiales (公众号).',
    tag: 'Conectado con WeChat',
    chips: ['公众号', '视频号', 'Mini Program', 'WeCom'],
  },
  {
    n: '05',
    cn: '文心',
    name: 'Baidu IA',
    enLabel: '文心一言',
    body: 'Funciona con el modelo ERNIE (文心一言) y premia las fuentes con autoridad: Baidu Baike (百度百科), portales gubernamentales, marcado JSON-LD y presencia constante en Baijiahao y Baidu Zhidao (百度知道).',
    tag: 'Fuentes con autoridad',
    chips: ['百度百科', '百度知道', 'JSON-LD', 'Baijiahao'],
  },
];

const services = [
  {
    n: '01',
    title: 'Diagnóstico de visibilidad',
    body: 'Lanzamos de 80 a 150 consultas en los cinco motores. Las hacemos desde dispositivos reales en Shanghái, Pekín y Shenzhen, en redes domésticas y de empresa, nunca por VPN.',
    bullets: [
      'Tasa de citación: con qué frecuencia aparece su marca en las respuestas relevantes.',
      'Posición en la recomendación: el lugar que ocupa cuando el motor enumera las opciones.',
      'Sentimiento: el tono de la mención, ya sea neutro, positivo o crítico.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Auditoría de fuentes',
    body: 'Los motores premian lo verificable: patentes, informes de laboratorios independientes, normativa publicada. Todo eso forma el nivel T1. El material comercial sin respaldo externo cae al T3, que los motores ignoran o marcan como poco fiable. Revisamos cada afirmación de su web y apuntalamos las más frágiles con pruebas que la IA puede contrastar.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Arquitectura de contenido',
    body: 'Un artículo aislado ya no basta. Organizamos el contenido en grupos temáticos: una página pilar rodeada de preguntas frecuentes, comparativas, escenarios de uso y casos de éxito. Venga como venga la pregunta, su web aparece entre las respuestas.',
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Difusión multiplataforma',
    body: 'Los motores no se fían de una marca hasta cruzar sus menciones en varias plataformas. Por eso publicamos en Baijiahao (百家号), Zhihu (知乎) y portales sectoriales. Cuando procede, también en Baidu Baike (百度百科).',
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Cimientos técnicos',
    body: 'Trabajamos el marcado JSON-LD, el robots.txt para Baiduspider, Sogouspider y ByteSpider, los mapas de sitio en XML y las canónicas que no dispersan la autoridad entre idiomas. Ahí tropieza la mayoría de las webs internacionales.',
    tag: 'p.28',
  },
  {
    n: '06',
    title: 'Gestión continua',
    body: 'Solo en 2025, DeepSeek cambió cuatro veces. Lo que funcionaba en febrero ya no servía en mayo. Medimos cada semana y ajustamos antes de que las citaciones caigan.',
    tag: 'p.34',
  },
];

const stages = [
  {
    n: '01',
    cn: '诊断',
    title: 'Diagnóstico de visibilidad',
    body: 'Lanzamos la batería de consultas en los cinco motores, desde dispositivos reales en Shanghái, Pekín y Shenzhen. Le entregamos un informe de referencia con las carencias de cada plataforma.',
    output: 'Informe de referencia',
  },
  {
    n: '02',
    cn: '证据',
    title: 'Auditoría de pruebas y fuentes',
    body: 'Clasificamos cada afirmación en T1, T2 o T3. Apuntalamos las más débiles con patentes, informes de laboratorio, expertos acreditados y datos estructurados que los motores validan.',
    output: 'Mapa de pruebas',
  },
  {
    n: '03',
    cn: '内容',
    title: 'Grupos de contenido',
    body: 'Redactamos en chino nativo las páginas pilar y lo que las rodea: preguntas frecuentes, comparativas, escenarios de uso y casos de éxito. Ninguna forma de plantear la pregunta deja su web fuera.',
    output: 'Contenidos publicados',
  },
  {
    n: '04',
    cn: '分发',
    title: 'Difusión y base técnica',
    body: 'Publicamos en 百家号, 知乎, 百度百科 (cuando el proyecto ya está maduro) y portales sectoriales. Cerramos la fase con el marcado JSON-LD, el robots.txt, el llms.txt, las canónicas y los mapas de sitio.',
    output: 'Presencia multiplataforma',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Seguimiento e iteración',
    body: 'Cada semana relanzamos la batería de consultas en los cinco motores y ajustamos el rumbo antes de que una actualización haga caer las citaciones. Cada mes recibe un informe por escrito.',
    output: 'Gestión semanal',
  },
];

const evidenceTiers = [
  {
    label: 'T1',
    title: 'Pruebas sólidas',
    body: 'Números de patente, informes de laboratorios independientes, normativa publicada y datos oficiales.',
    weight: 100,
    color: 'green',
    examples: ['Patente CN10X', 'Informe SGS', 'Norma GB/T', 'Datos CNNIC'],
  },
  {
    label: 'T2',
    title: 'Reconocido por el sector',
    body: 'Cobertura de prensa especializada, informes de analistas, expertos acreditados y distinciones del sector.',
    weight: 60,
    color: 'amber',
    examples: ['36Kr', '艾瑞咨询', 'Experto acreditado', 'Premio sectorial'],
  },
  {
    label: 'T3',
    title: 'Contenido comercial',
    body: 'Afirmaciones de la propia marca, sin respaldo externo. Los motores las ignoran o las marcan como poco fiables.',
    weight: 15,
    color: 'red',
    examples: ['«El mejor»', '«Líder del mercado»', 'Sin fuente', 'Solo el eslogan'],
  },
];

const stats = [
  { value: '600M+', label: 'Usuarios de IA en China · 2026', sub: 'Usuarios de IA generativa en China, según el CNNIC.' },
  { value: '20%+', label: 'Páginas de Baidu con respuesta de IA', sub: '文心X1 y DeepSeek ya van integrados en los resultados.' },
  { value: '4', label: 'Revisiones de DeepSeek en 2025', sub: 'Lo que funcionaba en febrero ya no servía en mayo.' },
];

const audiences = [
  {
    label: 'Marcas invisibles en las IA chinas',
    description: 'Su nombre no sale cuando un comprador pregunta a DeepSeek, Doubao o Yuanbao por su categoría. La competencia, en cambio, aparece citada y enlazada.',
    image: '/images/audiences/audience-geo-invisible-on-ai.webp',
  },
  {
    label: 'Marcas internacionales que aterrizan en China',
    description: 'Equipos que quieren visibilidad en la IA desde el lanzamiento. Recuperarla seis meses después, con el tráfico estancado, cuesta mucho más.',
    image: '/images/audiences/audience-geo-launching-china-market.webp',
  },
  {
    label: 'Marcas con contenido pero sin pruebas',
    description: 'Webs con buen contenido chino que los motores pasan por alto de todos modos. Les faltan fuentes verificables, datos estructurados y validación de terceros.',
    image: '/images/audiences/audience-geo-content-without-evidence.webp',
  },
  {
    label: 'Marcas cuyo tráfico orgánico se aplana',
    description: 'Su tráfico orgánico chino toca techo a medida que los compradores se pasan a la búsqueda con IA. Ahora quieren que sean los motores los que citen su marca.',
    image: '/images/audiences/audience-geo-search-traffic-flat.webp',
  },
];

const marqueePhrases = [
  'GEO China',
  'DeepSeek', '深度求索',
  'Doubao', '豆包',
  'Kimi', '元宝',
  '文心一言',
  'Citado por las IA',
  'Pruebas T1',
  'JSON-LD',
  'llms.txt',
  '百家号 · 知乎 · 百度百科',
];

const faqs = [
  {
    id: 'difference-from-seo',
    question: '¿En qué se diferencia el GEO del SEO de Baidu?',
    answer: [
      'Se solapan, pero no son lo mismo. El SEO de Baidu trabaja la página de resultados, donde el usuario aún repasa diez enlaces azules antes de hacer clic. El GEO se dirige a los asistentes de IA, que leen su contenido y deciden si lo citan en una sola respuesta. Cambian los criterios, la estructura y las métricas. Aun así, casi todos nuestros clientes llevan los dos frentes a la vez: la base editorial es prácticamente la misma.',
    ],
  },
  {
    id: 'platforms-covered',
    question: '¿Qué plataformas de IA chinas cubren en concreto?',
    answer: [
      'Cubrimos DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝) y Baidu IA, que funciona con el modelo 文心一言. Son los cinco motores que cuentan hoy en la China continental. ChatGPT, Perplexity, Google AI Overviews o Claude no tienen aquí ninguna presencia: detrás del Gran Cortafuegos, su alcance es nulo.',
    ],
  },
  {
    id: 'measurement',
    question: '¿Cómo miden el éxito?',
    answer: [
      'Seguimos tres indicadores y los revisamos cada mes. El primero es la tasa de citación: cuántas veces aparece su marca en las respuestas a una batería de consultas fija. El segundo es la posición: qué puesto ocupa cuando el motor enumera opciones. El tercero es el sentimiento: si la mención es positiva, neutra o crítica. Todo va en un informe breve, de pocas páginas, que se lee de una sola vez.',
    ],
  },
  {
    id: 'how-long',
    question: '¿Cuánto se tarda en ver despegar las citaciones?',
    answer: [
      'La auditoría y los cimientos técnicos llevan de cuatro a seis semanas. La producción editorial y la difusión, de tres a cuatro meses. Hacia el sexto mes, la mayoría de los clientes ya ve un avance claro en al menos dos motores. La cobertura completa suele llegar entre el noveno y el duodécimo. Si alguien le promete cuota de citación en treinta días, le está vendiendo humo.',
    ],
  },
  {
    id: 'evidence-tiers',
    question: 'T1, T2, T3: ¿qué son y por qué importan?',
    answer: [
      'Los motores valoran cada fuente por lo verificable que sea. El T1 es el contenido con pruebas sólidas: patentes, informes de laboratorios independientes, normativa publicada, datos oficiales. El T2 es el respaldo del sector, ya secundario: prensa especializada, informes de analistas, expertos acreditados. El T3 es el contenido comercial sin prueba externa, el que los motores ignoran o marcan como poco fiable. Clasificamos cada afirmación de su web y apuntalamos los puntos débiles.',
    ],
  },
  {
    id: 'translated-content',
    question: '¿Podemos simplemente traducir nuestro contenido en inglés?',
    answer: [
      'No. A los motores chinos un texto traducido les suena extraño. Pierde las señales de estructura que necesitan para decidir y rara vez refleja cómo preguntan realmente los usuarios chinos. Por eso trabajamos con redactores nativos: escriben desde cero y conservan intactas las afirmaciones originales y sus pruebas.',
    ],
  },
  {
    id: 'syndication',
    question: '¿Dónde sindican el contenido?',
    answer: [
      'Publicamos en Baijiahao (百家号) para llegar a Baidu y Yuanbao, y en Zhihu (知乎) para la credibilidad técnica y B2B. Usamos Toutiao (今日头条) y Baijiahao para los canales de ByteDance y Doubao. Cuando tiene sentido, añadimos fichas de Baidu Baike (百度百科). Y rematamos con los portales especializados de su sector.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: '¿Qué ocurre cuando los motores modifican sus modelos?',
    answer: [
      'Lo hacen a menudo. Solo en 2025, DeepSeek publicó cuatro revisiones de calado. Por eso seguimos las citaciones cada semana, con la misma batería de consultas de la auditoría, y ajustamos contenido, marcado y difusión antes de que el cambio acabe en caída. Quien descuida este seguimiento pierde visibilidad sin saber por qué.',
    ],
  },
  {
    id: 'cost',
    question: '¿Cuánto cuesta un programa de GEO China?',
    answer: [
      'Depende del alcance: cuántas líneas de producto o temas hay que cubrir, con qué contenido se parte, en cuántos motores hay que estar y si se suman la creación de contenido en chino y el SEO de Baidu. Descríbanos el proyecto y le damos un presupuesto cerrado en dos días hábiles.',
    ],
  },
];

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-geo-beijing-ai-research.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[#4D6BFE]/15 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">答</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/servicios/" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">GEO China</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">GEO China</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">5 motores, un solo programa</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Citado
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">por las IA</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">chinas.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Optimización para los motores generativos en el mercado chino. Convertimos su contenido en la respuesta que DeepSeek, Doubao, Kimi, Yuanbao y Baidu IA consideran fiable y entregan a sus usuarios. <span class="text-white font-medium">La IA solo da una respuesta. Su marca tiene que estar en ella.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter>5</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Motores cubiertos</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">600M</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Usuarios de IA en China</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">150</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Consultas por auditoría</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/es/contacto/" variant="primary" size="lg">Solicitar una auditoría de IA</Button>
            <Button href="#engines" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Ver los cinco motores</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Sin citar</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">gana el competidor</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Tasa de citación: 0%
              </div>
            </div>

            <div data-tilt class="relative bg-white rounded-2xl shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)] overflow-hidden">
              <div class="flex items-center gap-2.5 px-5 py-3 bg-white border-b border-gray-100">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#4D6BFE] to-[#3a55e8] flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm5.5 11.5c-1.4.4-2.9.5-4.4.3-.4 1.6-.4 3.3 0 4.9-1.4-.6-2.6-1.5-3.5-2.7-1.5.4-3 .5-4.5.4 1-1.5 2.4-2.6 4-3.3-.6-1.4-1-3-1-4.6 1.4.6 2.7 1.6 3.6 2.8 1.5-.5 3.1-.6 4.6-.4-.7 1.4-1.7 2.6-3 3.5.6.4 1.3.7 2 .9.6.6 1.4 1.5 2.2 2.2z"/>
                  </svg>
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="text-sm font-semibold text-gray-900">DeepSeek</span>
                  <span class="text-[10px] text-gray-400">深度求索</span>
                </div>
                <div class="ml-auto flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                  <span class="text-[10px] text-gray-400">在线</span>
                </div>
              </div>

              <div class="px-5 py-4 space-y-4 bg-white">
                <div class="flex justify-end">
                  <div class="max-w-[85%] bg-[#F4F5F7] rounded-2xl rounded-tr-sm px-3.5 py-2.5">
                    <p class="text-[12.5px] text-gray-900 leading-relaxed">推荐几家专门服务国际品牌的中国 WordPress 建站代理商</p>
                  </div>
                </div>

                <div class="flex items-center gap-1.5">
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#EEF2FF] text-[#4D6BFE] text-[10px] font-medium">
                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    深度思考 R1
                  </span>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#ECFDF5] text-emerald-600 text-[10px] font-medium">
                    联网搜索
                  </span>
                </div>

