---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'ux-ui-design'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const stats = [
  { value: '70 %+', label: 'Tráfico móvil en China' },
  { value: '6', label: 'Navegadores probados' },
  { value: 'WeChat', label: 'Integración nativa' },
  { value: 'ICP', label: 'Conforme desde el diseño' },
];

const services = [
  {
    title: 'Investigación de usuarios',
    body: 'Trazamos cómo navega de verdad su público en China, medimos a los competidores locales e internacionales y diseñamos recorridos que arrancan justo donde el internauta chino empieza su día: Douyin, WeChat o Baidu.',
    icon: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607Z',
    tag: 'Investigación',
  },
  {
    title: 'Arquitectura de la información',
    body: 'El lector chino prefiere las páginas densas. Más enlaces a la vista, más texto, más opciones desde la primera pantalla. Estructuramos el contenido con la profundidad que se espera, sin volverlo ilegible para la sede.',
    icon: 'M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5',
    tag: 'Arquitectura',
  },
  {
    title: 'Diseño visual',
    body: 'Maquetas pensadas primero para el móvil, sobre los aparatos que se usan de verdad en China. Color simbólico, tipografía que respeta los caracteres, señales de confianza (QR de WeChat, número ICP, licencia de empresa) que el consumidor chino comprueba antes de actuar.',
    icon: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
    tag: 'UI',
  },
  {
    title: 'Sistema de diseño Gutenberg',
    body: 'Diseñamos directamente en Gutenberg. Bloques a medida que sus equipos de contenido manejan sin recurrir a un desarrollador, componentes que mantienen la coherencia visual y plantillas editables sin la menor competencia técnica.',
    icon: 'M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3',
    tag: 'Sistema',
  },
];

const processSteps = [
  { phase: '01', title: 'Encuadre inicial', body: 'Partimos de su manual de marca, de los objetivos que persigue y del público que quiere alcanzar en China.' },
  { phase: '02', title: 'Investigación y análisis competitivo', body: 'Mapa de la competencia, patrones de uso locales y principios de diseño propios del mercado. Es la fase de cimientos, y le dedicamos el tiempo que pide.' },
  { phase: '03', title: 'Wireframes', body: 'Estructura de las páginas y recorridos contrastados con lo que espera el internauta chino. Rehacer un wireframe cuesta muchísimo menos que rehacer una maqueta acabada.' },
  { phase: '04', title: 'Diseño visual e iteraciones', body: 'Maquetas de alta fidelidad y ciclos de revisión hasta que el diseño funciona a la vez para la marca global y para el mercado chino.' },
  { phase: '05', title: 'Sistema y entrega', body: 'Componentes, reglas de estilo y especificaciones de interacción reunidos en un único entregable, para que sus desarrolladores avancen sin tener que adivinar nada.' },
  { phase: '06', title: 'Pruebas y validación', body: 'Pruebas en los navegadores y dispositivos chinos. Un sitio espléndido en Londres puede caer a plomo en UC Browser o QQ Browser, aún muy extendidos en el continente.' },
];

const colours = [
  { name: 'Rojo propicio', hex: '#E11D2E', meaning: 'Suerte, energía, acción' },
  { name: 'Naranja de marca', hex: '#F25F29', meaning: 'Vitalidad, acento' },
  { name: 'Verde de validación', hex: '#52C41A', meaning: 'Validación, WeChat' },
  { name: 'Tinta', hex: '#1F1F1F', meaning: 'Titulares, anclaje' },
  { name: 'Nube', hex: '#FAFAFA', meaning: 'Fondo, nunca aislado' },
];

const typeScale = [
  { label: 'H1', size: '32', cn: '中文标题', en: 'Titular principal' },
  { label: 'H2', size: '24', cn: '副标题', en: 'Subtítulo de sección' },
  { label: 'Body', size: '16', cn: '正文段落', en: 'Párrafo corriente' },
  { label: 'Caption', size: '12', cn: '辅助说明', en: 'Pie o metadato' },
];

const spacingTokens = [
  { name: '4 · XS', width: 'w-2' },
  { name: '8 · S', width: 'w-4' },
  { name: '16 · M', width: 'w-8' },
  { name: '24 · L', width: 'w-12' },
  { name: '32 · XL', width: 'w-16' },
  { name: '48 · 2XL', width: 'w-24' },
];

const intelligence = [
  {
    claim: 'El color transmite un significado',
    body: 'El rojo evoca la suerte y la energía. El dorado, la gama alta. El blanco, por sí solo, arrastra una pesadez fúnebre: lo combinamos siempre con acentos marcados.',
    visual: 'colour',
  },
  {
    claim: 'La densidad transmite confianza',
    body: 'Las páginas densas en la parte alta de la pantalla tranquilizan al internauta chino. Los diseños muy aireados se leen a menudo como inacabados, a veces incluso como evasivos.',
    visual: 'density',
  },
  {
    claim: 'La confianza se aloja en los márgenes',
    body: 'Número ICP, licencia de empresa, sellos oficiales. El pie de página sigue siendo el lugar habitual. Los códigos QR colocados en la parte alta de la pantalla refuerzan mucho la credibilidad que se percibe.',
    visual: 'trust',
  },
  {
    claim: 'WeChat funciona como infraestructura',
    body: 'Códigos QR, enlaces a Mini Programs, puntos de compartición, identificadores de atención al cliente. Conviene tratarlo como una base del sitio, al mismo nivel que la navegación principal.',
    visual: 'wechat',
  },
  {
    claim: 'La tipografía cuenta tanto como las palabras',
    body: 'PingFang SC, Noto Sans SC o Source Han se combinan con Inter o con las pilas del sistema. El interletrado y el interlineado obedecen a reglas distintas de las de las lenguas latinas.',
    visual: 'type',
  },
  {
    claim: 'La barra inferior hace de botón de inicio',
    body: 'La barra de navegación pegada abajo cumple, en la web móvil china, el papel de un botón de inicio universal. Cinco objetivos táctiles, siempre visibles, siempre al alcance del pulgar.',
    visual: 'nav',
  },
];

const audiences = [
  { label: 'Empezar desde cero', description: 'Está construyendo un sitio WordPress para China y quiere asentar el diseño correcto desde el primer día.', image: '/images/audiences/building-site-china-design.webp' },
  { label: 'Un sitio en línea que apenas convierte', description: 'Su sitio chino funciona, pero las conversiones no acompañan. Sospecha que la causa está en el diseño.', image: '/images/audiences/live-site-not-performing.webp' },
  { label: 'Páginas de campaña', description: 'Sus equipos de marketing necesitan páginas calibradas para el consumidor chino, sin ese aire de «página traducida» que se nota al instante.', image: '/images/audiences/campaign-chinese-consumers.webp' },
  { label: 'Adaptar un diseño internacional', description: 'Cuenta con un sistema de diseño internacional sólido y busca al interlocutor capaz de trasladarlo al mercado chino.', image: '/images/audiences/global-design-adapt-china.webp' },
];

const marqueeWords = [
  '移动优先', 'Primero el móvil',
  '微信', 'WeChat',
  '百度', 'Baidu',
  '抖音', 'Douyin',
  '备案', 'Registro ICP',
  'Gutenberg',
  '中文排版', 'Tipografía china',
  '信任信号', 'Señales de confianza',
  '色彩文化', 'Color cultural',
  '密度优先', 'Primero la densidad',
  'PingFang SC',
  'UC · QQ · Chrome',
];

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <!-- HERO: composición editorial con maqueta móvil -->
  <section class="relative bg-[#0a0a0d] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px]"></div>
      <div class="absolute -bottom-40 right-1/3 w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/5 blur-[100px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(242,95,41,0.08),transparent_50%)]"></div>
      <!-- rejilla discreta -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/#OurServices" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Diseño UX y UI</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 lg:pb-32">
        <!-- Texto -->
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">UX / UI · 设计</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Diseñar <span class="italic font-light text-white/80">para</span><br/>
            cómo navega el público chino
            <span class="block mt-3 text-[var(--color-brand-orange)]">cada día.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            Experiencias WordPress que le suenan nativas al lector chino. Ancladas en la cultura, pensadas primero para el móvil y construidas alrededor de las plataformas que mueven internet en China.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/es/contacto/" variant="primary" size="lg">Poner en marcha un proyecto de diseño</Button>
            <a href="#nuestro-servicio" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              Conocer el sistema
              <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <!-- Visual: maqueta móvil enmarcada como un artboard -->
        <div class="col-span-12 lg:col-span-5 mt-16 lg:mt-0">
          <div class="relative">
            <div class="absolute -inset-8 bg-[var(--color-brand-orange)]/15 rounded-[40px] blur-3xl -z-10"></div>

            <!-- Etiqueta artboard -->
            <div class="flex items-center justify-between mb-3 px-1">
              <div class="flex items-center gap-2 text-[11px] font-mono text-white/40">
                <span class="w-1.5 h-1.5 rounded-sm bg-[var(--color-brand-orange)]"></span>
                <span>home-mobile.fig</span>
              </div>
              <div class="text-[11px] font-mono text-white/30">375 × 812</div>
            </div>

            <div class="relative rounded-3xl overflow-hidden border border-white/10 bg-gradient-to-br from-white/[0.04] to-transparent">
              <img
                src="/images/ux-design-china-mobile-wordpress-mockup.webp"
                alt="Página de inicio móvil en WordPress diseñada para el público chino, con acentos rojos, código QR de WeChat y número ICP"
                class="w-full h-auto block"
                loading="eager"
                decoding="async"
              />
            </div>

            <!-- Pastilla flotante: Primero el móvil -->
            <div class="hidden sm:flex absolute -left-6 top-20 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <span class="w-2 h-2 rounded-full bg-green-400"></span>
              <span class="text-xs font-medium text-white">Primero el móvil</span>
            </div>

            <!-- Pastilla flotante: señales de confianza -->
            <div class="hidden sm:flex absolute -right-4 bottom-24 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <svg class="w-3.5 h-3.5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              <span class="text-xs font-medium text-white">WeChat + ICP</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BANDA DE VOCABULARIO -->
  <section aria-hidden="true" class="bg-[#0a0a0d] border-y border-white/5 overflow-hidden py-5">
    <div class="marquee-mask">
      <div class="marquee-track flex items-center gap-10 whitespace-nowrap">
        {[...marqueeWords, ...marqueeWords].map((word, i) => (
          <div class="flex items-center gap-10 flex-shrink-0">
            <span class={`text-base font-medium ${i % 2 === 0 ? 'text-white/40' : 'text-white/70'}`}>{word}</span>
            <span class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]/60 flex-shrink-0"></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BANDA DE CIFRAS -->
  <section class="bg-white border-b border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-[var(--color-surface-border)] py-10 lg:py-12 -mx-4 sm:-mx-6 lg:-mx-8">
        {stats.map((stat) => (
          <div class="px-4 sm:px-6 lg:px-8">
            <div class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] tracking-tight leading-none">
              {stat.value}
            </div>
            <div class="mt-3 text-sm text-[var(--color-text-muted)]">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EL PROBLEMA -->
  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-12 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-5">
            El problema
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] mb-8 tracking-tight">
            Por qué el diseño occidental<br/>
            <span class="text-[var(--color-text-muted)]">se viene abajo en China.</span>
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Una empresa hace funcionar su sitio WordPress en casa, lo despliega en China y la tasa de rebote se dispara. En lo técnico, el sitio sigue impecable, pero algo suena falso a quien lo consulta desde Shanghái o Chengdú.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            El internauta chino no creció en la misma web. Su forma de navegar y el volumen de información que espera abarcar de un vistazo llevan la huella de WeChat, de Taobao y de Douyin.
          </p>
          <blockquote class="border-l-2 border-[var(--color-brand-orange)] pl-6 py-1">
            <p class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
              Un lenguaje visual que convierte en Chicago necesita repensarse para hablarle a Chongqing.
            </p>
          </blockquote>
        </div>

        <div class="col-span-12 lg:col-span-6">
          <div class="relative">
            <div class="rounded-2xl overflow-hidden border border-[var(--color-surface-border)] shadow-xl shadow-black/5">
              <img
                src="/images/ux-design-china-vs-western-mobile-comparison.webp"
                alt="Dos teléfonos uno junto al otro: a la izquierda, un sitio occidental despejado; a la derecha, un sitio chino denso, con QR de WeChat y señales de confianza"
                class="w-full h-auto block"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="mt-5 grid grid-cols-2 gap-4 text-center">
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Estilo occidental</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Aireado, poca interacción</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-1">Estilo chino</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Denso, eficaz en conversión</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REJILLA DE CONVICCIONES UX CHINA -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-20">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-4">
            Conocimiento de campo
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] tracking-tight">
            Seis lecciones que China<br/>nos enseñó sobre diseño.
          </h2>
        </div>
        <p class="text-base text-[var(--color-text-muted)] max-w-md font-mono uppercase tracking-wider text-xs">
          A.01 a A.06 / Heurísticas UX China
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {intelligence.map((card, idx) => (
          <article class="group relative rounded-2xl bg-white border border-[var(--color-surface-border)] overflow-hidden hover:border-[var(--color-brand-orange)]/40 hover:shadow-xl hover:shadow-black/5 transition-all duration-300">
            <!-- Zona de artefacto visual -->
            <div class="relative h-44 bg-gradient-to-br from-[var(--color-surface-light)] to-white border-b border-[var(--color-surface-border)] overflow-hidden">
              <div class="absolute top-3 left-4 text-[11px] font-mono text-[var(--color-text-muted)] uppercase tracking-wider">
                A.0{idx + 1}
              </div>

              {card.visual === 'colour' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-end gap-1">
                    <div class="w-12 h-20 rounded-md bg-[#E11D2E] shadow-md"></div>
                    <div class="w-12 h-16 rounded-md bg-[#F25F29] shadow-md"></div>
                    <div class="w-12 h-12 rounded-md bg-[#D4AF37] shadow-md"></div>
                    <div class="w-12 h-8 rounded-md bg-[#52C41A] shadow-md"></div>
                  </div>
                </div>
              )}

              {card.visual === 'density' && (
                <div class="absolute inset-0 flex items-center justify-center px-8">
                  <div class="w-full max-w-[180px] space-y-1.5">
                    <div class="h-3 bg-[var(--color-brand-orange)]/80 rounded-sm"></div>
                    <div class="grid grid-cols-3 gap-1.5">
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm"></div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm w-3/4"></div>
                    <div class="grid grid-cols-2 gap-1.5">
                      <div class="h-6 bg-[var(--color-brand-orange)]/30 rounded-sm"></div>
                      <div class="h-6 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'trust' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-center gap-2.5">
                    <div class="px-3 py-2 rounded-md border border-[var(--color-surface-border)] bg-white text-[10px] font-mono text-[var(--color-text-body)]">
                      ICP 沪B2-2024<br/>0123456号
                    </div>
                    <div class="w-12 h-12 rounded-md bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center text-white text-[10px] font-bold">营业<br/>执照</div>
                    <div class="w-10 h-10 rounded-md bg-[#52C41A] flex items-center justify-center">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'wechat' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative w-24 h-24 bg-white rounded-xl border border-[var(--color-surface-border)] p-2">
                    <div class="grid grid-cols-7 gap-px h-full w-full">
                      {Array.from({ length: 49 }).map((_, i) => {
                        const filled = [0,1,2,3,5,6,8,12,14,15,18,20,22,24,28,29,30,32,34,36,40,42,43,44,46,47,48].includes(i);
                        return <div class={filled ? 'bg-[var(--color-text-dark)] rounded-[1px]' : ''}></div>;
                      })}
                    </div>
                    <div class="absolute -bottom-2 -right-2 w-7 h-7 rounded-full bg-[#52C41A] border-2 border-white flex items-center justify-center">
                      <span class="text-white text-[9px] font-bold">微信</span>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'type' && (
                <div class="absolute inset-0 flex items-center justify-center gap-3 px-6">
                  <span class="text-[80px] leading-none font-medium text-[var(--color-text-dark)]">中</span>
                  <div class="h-16 w-px bg-[var(--color-surface-border)]"></div>
                  <span class="text-[72px] leading-none font-light text-[var(--color-text-dark)] italic">Aa</span>
                </div>
              )}

              {card.visual === 'nav' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative w-20 h-32 rounded-xl border-2 border-[var(--color-text-dark)]/30 bg-white p-1.5 flex flex-col">
                    <div class="flex-1 space-y-1">
                      <div class="h-1.5 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-3 bg-[var(--color-text-dark)]/10 rounded-sm"></div>
                      <div class="h-1.5 bg-[var(--color-text-dark)]/15 rounded-sm w-3/4"></div>
                      <div class="h-3 bg-[var(--color-brand-orange)]/30 rounded-sm"></div>
                    </div>
                    <div class="mt-1 flex items-center justify-around bg-[var(--color-brand-orange)]/10 rounded-md px-1 py-1.5 border-t border-[var(--color-brand-orange)]/30">
                      {Array.from({ length: 5 }).map(() => (
                        <div class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]"></div>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </div>

            <!-- Cuerpo -->
            <div class="p-7">
              <h3 class="text-lg lg:text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3 tracking-tight">
                {card.claim}
              </h3>
              <p class="text-[14px] text-[var(--color-text-body)] leading-relaxed">
                {card.body}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- NUESTRO SERVICIO: bento -->
  <section id="nuestro-servicio" class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14 lg:mb-20">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-4">
