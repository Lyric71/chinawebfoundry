        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] tracking-tight">
          Cuatro disciplinas.<br/>Un resultado único.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-5 lg:gap-6">
        {services.map((service, idx) => {
          const span = idx === 0 ? 'lg:col-span-7' : idx === 1 ? 'lg:col-span-5' : idx === 2 ? 'lg:col-span-5' : 'lg:col-span-7';
          return (
            <article class:list={[
              'group relative rounded-2xl bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] p-6 sm:p-8 lg:p-10 transition-all duration-300 hover:bg-white hover:shadow-xl hover:shadow-black/5 hover:-translate-y-0.5',
              span,
            ]}>
              <div class="flex items-start gap-5">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center group-hover:bg-[var(--color-brand-orange)]/15 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="w-6 h-6 text-[var(--color-brand-orange)]">
                    <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
                  </svg>
                </div>
                <div class="flex-1">
                  <span class="block text-[11px] font-mono uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-3">/ {service.tag}</span>
                  <h3 class="text-xl lg:text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4 tracking-tight">
                    {service.title}
                  </h3>
                  <p class="text-[15px] lg:text-base text-[var(--color-text-body)] leading-relaxed">
                    {service.body}
                  </p>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- TOKENS DE DISEÑO VIVOS -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-20">
