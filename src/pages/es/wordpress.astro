---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'WordPress en China: qué funciona y qué debe reconstruirse | ChinaWebFoundry';
const metaDescription = 'WordPress funciona en la China continental si se concibe pensando en ella. En qué proyectos conviene, qué obliga a rehacer el Gran Cortafuegos y dónde encuentran su límite las alternativas.';

const stats = [
  { value: 43, suffix: '%', label: 'de los sitios web del mundo funcionan con WordPress', source: 'W3Techs, 2024' },
  { value: 20, suffix: '+', label: 'años de WordPress en China', source: 'Presentes en Shanghái desde 2005' },
  { value: 50, suffix: '+', label: 'sitios internacionales publicados detrás del Cortafuegos', source: 'En todos los sectores' },
];

const useCases = [
  {
    icon: 'cart',
    title: 'Comercio electrónico con WooCommerce',
    body: 'Las marcas que venden en China sin depender de Tmall ni de JD necesitan una tienda propia, y WooCommerce es hoy la plataforma de comercio electrónico abierta más fiable para ese propósito. Una vez integrados Alipay, WeChat Pay y UnionPay en la pasarela de pago, queda cubierta la práctica totalidad de las transacciones del mercado chino.',
    span: 'feature',
    badges: ['WooCommerce', 'Alipay', 'WeChat Pay', 'UnionPay'],
  },
  {
    icon: 'pen',
    title: 'Sitios con mucho volumen editorial',
    body: 'Cuando un proyecto reúne cientos de páginas, una redacción que publica sin descanso y varias firmas que coordinar, WordPress se encuentra en su terreno: se concibió precisamente para ese escenario. Y el equipo que ya lo conoce no necesita aprender ninguna herramienta nueva.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Sitios multilingües',
    body: 'El chino puede convivir con el inglés, el francés, el alemán o el japonés. Con WPML o Polylang, WordPress gestiona tres idiomas o más sin dificultad y genera un sitemap para Baidu y otro para Google.',
    span: 'normal',
  },
  {
    icon: 'users',
    title: 'Sitios que actualiza un equipo no técnico',
    body: 'El equipo de marketing, los responsables editoriales o una oficina regional pueden publicar de forma autónoma, sin necesidad de lanzar un despliegue. Para un equipo que opera sin apoyo en China, esa autonomía importa más que una pequeña ganancia de velocidad.',
    span: 'normal',
  },
  {
    icon: 'sliders',
    title: 'Sitios con lógica de negocio',
    body: 'WordPress puede sostener un área privada para socios, formularios que se adaptan a cada visitante, contenido restringido o herramientas de ventas. El catálogo de extensiones cubre casi todas estas necesidades sin una sola línea de desarrollo a medida.',
    span: 'normal',
  },
  {
    icon: 'layers',
    title: 'Sitios creados con un constructor de páginas',
    body: 'La mayoría de los sitios que recibimos están construidos con Elementor, Divi o Gutenberg. Los tres funcionan bien una vez depuradas sus dependencias. Gutenberg parte con ventaja: es más ligero y resulta más sencillo mantenerlo veloz en un servidor chino.',
    span: 'wide',
    badges: ['Elementor', 'Divi', 'Gutenberg'],
  },
];

const pickAstro = [
  'Su sitio se compone sobre todo de páginas de marketing y se actualiza una vez al mes, o menos',
  'La velocidad de carga es innegociable: páginas de aterrizaje de campañas, anuncios de pago',
  'Desea reducir la superficie de ataque y la carga de mantenimiento',
  'Las actualizaciones de contenido pueden encargarse a un desarrollador o a nuestro equipo',
  'No necesita un panel de edición para redactores sin perfil técnico',
];

const pickWordPress = [
  'Publica contenido cada día',
  'Trabaja con tres idiomas o más',
  'Tiene una tienda en línea o un área privada para socios',
  'Su equipo ya domina WordPress y no quiere cambiar de herramienta',
  'Necesita extensiones para formularios, SEO, automatización de marketing o cumplimiento normativo',
];

const changeGroups = [
  {
    label: 'Front-end',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Tipografías',
        body: 'Google Fonts no carga en China. Alojamos las tipografías en el propio servidor o las sustituimos por fuentes que reúnen el alfabeto latino y los caracteres CJK en un único archivo.',
      },
      {
        icon: 'palette',
        title: 'Temas',
        body: 'La mayoría de los temas de ThemeForest dependen de CDN extranjeros, incrustan Google Maps o cargan scripts remotos que fallan detrás del Cortafuegos. Los revisamos a fondo y sustituimos los componentes problemáticos uno por uno.',
      },
      {
        icon: 'blocks',
        title: 'Constructores de páginas',
        body: 'Cada constructor exige una limpieza propia. Desactivamos la carga de Google Fonts, trasladamos al servidor local las bibliotecas de iconos externas y suprimimos cualquier llamada a un servicio bloqueado.',
      },
    ],
  },
  {
    label: 'Integraciones',
    accent: 'orange',
    items: [
      {
        icon: 'play',
        title: 'Contenidos incrustados',
        body: 'YouTube se sustituye por Youku o Bilibili; Vimeo, por Tencent Video; los píxeles de Facebook, por los de WeChat o Weibo; Google Maps, por Baidu Map o Amap.',
      },
      {
        icon: 'card',
        title: 'Pagos',
        body: 'WooCommerce, por sí solo, no basta para cobrar a un cliente chino. Añadimos Alipay, WeChat Pay y UnionPay, y reconstruimos el proceso de compra para que se ajuste a los hábitos del mercado chino.',
      },
      {
        icon: 'plug',
        title: 'Extensiones',
        body: 'Configuramos Yoast SEO para que genere también el sitemap de Baidu. Google Analytics se sustituye por Baidu Tongji; reCAPTCHA, por un equivalente chino. Mantenemos una tabla de equivalencias permanentemente actualizada.',
      },
    ],
  },
  {
    label: 'Alojamiento e infraestructura',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Alojamiento',
        body: 'El servidor se ubica en la China continental, con la licencia ICP del dominio en regla. Elegimos Aliyun, Tencent Cloud o Huawei Cloud según las necesidades del proyecto.',
      },
      {
        icon: 'refresh',
        title: 'Actualizaciones automáticas',
        body: 'El núcleo y las extensiones consultan wordpress.org cada vez que buscan una actualización, y esa conexión falla con frecuencia desde China. La resolvemos mediante un proxy o con ventanas de mantenimiento manuales.',
      },
      {
        icon: 'shield',
        title: 'Seguridad',
        body: 'El refuerzo es el habitual: edición de archivos desactivada desde el panel, XML-RPC bloqueado, doble factor de autenticación obligatorio y un WAF en la nube china. La diferencia, en China, está en el rigor que exige mantener todo el sistema actualizado.',
      },
    ],
  },
  {
    label: 'Rendimiento y SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Rendimiento',
        body: 'Un CDN que distribuye desde la China continental, varias capas de caché y una base de datos ajustada a los servidores de la nube china. El objetivo: que el contenido sea visible en menos de tres segundos en un teléfono chino de gama media.',
      },
      {
        icon: 'search',
        title: 'SEO y búsqueda con IA',
        body: 'El contenido esencial se entrega siempre en HTML. Conectamos las herramientas para webmasters de Baidu y estructuramos el sitio para que Doubao, Kimi, DeepSeek y Wenxin puedan leerlo y citarlo.',
      },
    ],
  },
];

const pluginBuckets = [
  {
    eyebrow: 'Primera opción',
    title: 'Buscar un equivalente',
    body: 'Es la vía más frecuente. Google Analytics se sustituye por Baidu Tongji; reCAPTCHA, por un captcha local; Google Maps, por Amap. Para la redacción, el cambio resulta imperceptible.',
  },
  {
    eyebrow: 'Cuando el contexto lo permite',
    title: 'Desinstalarla',
    body: 'Si una extensión no aporta nada a un público chino, la eliminamos. El sitio queda más ligero, gana velocidad y ofrece menos puntos vulnerables a un ataque.',
  },
  {
    eyebrow: 'Último recurso',
    title: 'Modificar el código de la extensión',
    body: 'Cuando una extensión es imprescindible y carece de equivalente, intervenimos su código y lo parcheamos: una llamada a la API que redirigimos mediante un proxy, una URL de CDN incrustada que reemplazamos. Siempre que la licencia lo permita.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Alojamiento' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Alojamiento' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Alojamiento' },
  { name: 'Baidu', cn: '百度', role: 'Búsqueda y SEO' },
  { name: 'WeChat', cn: '微信', role: 'Identidad y mensajería' },
  { name: 'Alipay', cn: '支付宝', role: 'Pagos' },
];

const elementorItems = [
  {
    label: 'Tipografías',
    body: 'Elementor carga Google Fonts por defecto, y esa petición no llega a completarse en China. Alojamos las tipografías en el propio servidor o las sustituimos por fuentes que cubren a la vez el alfabeto latino y los caracteres chinos.',
  },
  {
    label: 'Widgets y componentes',
    body: 'Algunos widgets dependen de servicios bloqueados: Google Maps, YouTube, Facebook, reCAPTCHA. Los sustituimos por equivalentes chinos o por componentes desarrollados a medida.',
  },
  {
    label: 'Bibliotecas de iconos y CDN',
    body: 'Trasladamos los recursos externos al servidor chino y los servimos desde allí.',
  },
  {
    label: 'Plantillas',
    body: 'La mayoría de las plantillas de Elementor parten de supuestos que en China no se cumplen. Las revisamos una por una y las depuramos.',
  },
];

const faqs = [
  {
    id: 'wp-icp',
    question: '¿Es necesaria una licencia ICP para que nuestro sitio WordPress funcione en China?',
    answer: 'Si el alojamiento está en la China continental, sí. En Hong Kong no es obligatoria, pero el sitio funcionará notablemente más lento y Baidu lo considerará extranjero. Para casi cualquier marca que se tome en serio el mercado chino, la licencia ICP justifica con creces la inversión.',
  },
  {
    id: 'wp-marketing-team',
    question: '¿Podrá nuestro equipo de marketing seguir actualizando el sitio?',
    answer: 'Sí. WordPress sigue siendo WordPress: el panel de administración es el mismo, el circuito de publicación no cambia y los permisos de usuario funcionan igual que siempre. Casi todas nuestras intervenciones quedan en la capa técnica, sin que la redacción llegue a percibirlas.',
  },
  {
    id: 'wp-vs-astro-speed',
    question: '¿Es WordPress más lento que Astro en China?',
    answer: 'Si solo se mide el tiempo bruto de carga, y en igualdad de condiciones, sí: WordPress es dinámico y Astro es estático. Pero un WordPress bien afinado en Aliyun, con las capas de caché adecuadas, alcanza el rendimiento que esperan los usuarios chinos y Baidu. La importancia de esa diferencia varía según el proyecto.',
  },
  {
    id: 'wp-elementor-divi',
    question: '¿Funcionará en China nuestro sitio actual de Elementor o Divi?',
    answer: 'Tal como está, probablemente no. Pero ponerlo a punto suele estar a nuestro alcance: retiramos las dependencias de Google, sustituimos las tipografías y redirigimos las integraciones. La mayoría de los sitios de Elementor y Divi que recibimos funcionan con fluidez detrás del Cortafuegos al cabo de unas semanas.',
  },
  {
    id: 'wp-auto-updates',
    question: '¿Y las actualizaciones automáticas de extensiones desde wordpress.org?',
    answer: 'Desde China casi nunca se completan: el repositorio de wordpress.org responde con dificultad, o no responde, en las redes chinas. Lo resolvemos con un proxy o con ventanas de mantenimiento manuales. En ambos casos, su equipo no tiene que ocuparse de ello.',
  },
  {
    id: 'wp-multilingual',
    question: '¿Podemos seguir usando WPML o Polylang para la gestión multilingüe?',
    answer: 'Sí. Ambos funcionan en China sin problemas una vez saneado el resto del sitio. WPML sigue siendo la opción habitual cuando hay tres idiomas o más y circuitos de traducción complejos; Polylang, más ligero, encaja a la perfección con dos o tres. Hemos trabajado a fondo con ambos, y la elección depende sobre todo del proceso editorial, no de China.',
  },
  {
    id: 'wp-woocommerce-china',
    question: '¿Sirve WooCommerce para vender al consumidor chino?',
    answer: 'WooCommerce en sí funciona muy bien. El trabajo se concentra en el proceso de pago. El comprador chino paga con Alipay, WeChat Pay o UnionPay, casi siempre desde el teléfono y casi siempre escaneando un código QR. Conectamos esas pasarelas con extensiones específicas y reconstruimos el recorrido de compra para que se ajuste a la forma real de comprar del mercado chino. WooCommerce presupone el pago con tarjeta o con PayPal, un supuesto que en China no se cumple.',
  },
  {
    id: 'wp-single-vs-dual',
    question: '¿Sirve un único sitio WordPress para China y para el resto del mundo?',
    answer: 'Técnicamente sí, mediante WordPress Multisite o una instalación multilingüe. En la práctica, casi siempre recomendamos dos instalaciones independientes: una fuera de China y otra en un servidor de la China continental. Es una cuestión de rendimiento: con una sola instalación global, el usuario chino termina descargando los recursos de servidores situados fuera del Cortafuegos, y con ello se pierde toda la ventaja. Dos instalaciones permiten compartir el trabajo editorial cuando conviene y mantenerse independientes cuando es necesario.',
  },
  {
    id: 'wp-security-china',
    question: '¿Cómo se protege nuestro sitio WordPress en China?',
    answer: 'Las medidas habituales siguen siendo válidas: desactivamos la edición de archivos desde el panel, bloqueamos XML-RPC, exigimos doble factor de autenticación e instalamos un firewall de aplicación (WAF) preparado para la nube china. El rigor adicional que impone China afecta a las extensiones: si la actualización automática falla, el sitio puede permanecer en una versión obsoleta más tiempo del que aceptaría un equipo occidental. Por eso lo supervisamos y aplicamos los parches en fechas fijadas de antemano.',
  },
  {
    id: 'wp-hosting-provider',
    question: '¿Qué proveedor de alojamiento conviene más para WordPress en China?',
    answer: 'Trabajamos con Aliyun, Tencent Cloud y Huawei Cloud, según el proyecto. Los tres disponen de licencia continental, ofrecen buen rendimiento y ejecutan WordPress sin problemas. Para sitios de marketing solemos optar por Aliyun. Tencent Cloud destaca cuando hay integración con WeChat. Y Huawei Cloud aparece con más frecuencia cuando el cliente ya emplea el ecosistema Huawei en otros ámbitos. Nos ocupamos de la cuenta de alojamiento, del trámite ICP y del mantenimiento diario: usted no tendrá que acceder nunca al panel de un proveedor chino.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'es-ES',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={[faqLd]}>

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-wordpress-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">WordPress</li>
        </ol>
      </nav>

      <div class="grid grid-cols-12 gap-8 items-center pb-20 md:pb-28 lg:pb-36 pt-8 lg:pt-16">
        <div class="col-span-12 lg:col-span-7">
          <!-- WordPress logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[#21759b] to-[#1a5d7a] flex items-center justify-center shadow-[0_8px_30px_rgba(33,117,155,0.45)]">
              <svg class="w-8 h-8 text-white" viewBox="0 0 122.52 122.523" fill="currentColor" aria-label="Logo de WordPress">
                <path d="m8.708 61.26c0 20.802 12.089 38.779 29.619 47.298l-25.069-68.686c-2.916 6.536-4.55 13.769-4.55 21.388z"/>
                <path d="m96.74 58.608c0-6.495-2.333-10.993-4.334-14.494-2.664-4.329-5.161-7.995-5.161-12.324 0-4.831 3.664-9.328 8.825-9.328.233 0 .454.029.681.042-9.35-8.566-21.807-13.796-35.489-13.796-18.36 0-34.513 9.42-43.91 23.688 1.233.037 2.395.063 3.382.063 5.497 0 14.006-.667 14.006-.667 2.833-.167 3.167 3.994.337 4.329 0 0-2.847.335-6.015.501l19.138 56.925 11.501-34.493-8.188-22.434c-2.83-.166-5.511-.501-5.511-.501-2.832-.166-2.5-4.496.332-4.329 0 0 8.679.667 13.843.667 5.496 0 14.006-.667 14.006-.667 2.835-.167 3.168 3.994.337 4.329 0 0-2.853.335-6.015.501l18.992 56.494 5.242-17.517c2.272-7.269 4.001-12.49 4.001-16.989z"/>
                <path d="m62.184 65.857-15.768 45.819c4.708 1.384 9.687 2.141 14.846 2.141 6.12 0 11.989-1.058 17.452-2.979-.141-.225-.269-.464-.374-.724z"/>
                <path d="m107.376 36.046c.226 1.674.354 3.471.354 5.404 0 5.333-.996 11.328-3.996 18.824l-16.053 46.413c15.624-9.111 26.133-26.038 26.133-45.426.001-9.137-2.333-17.729-6.438-25.215z"/>
                <path d="m61.262 0c-33.779 0-61.262 27.481-61.262 61.26 0 33.783 27.483 61.263 61.262 61.263 33.778 0 61.265-27.48 61.265-61.263-.001-33.779-27.487-61.26-61.265-61.26zm0 119.715c-32.23 0-58.453-26.223-58.453-58.455 0-32.23 26.222-58.451 58.453-58.451 32.229 0 58.45 26.221 58.45 58.451 0 32.232-26.221 58.455-58.45 58.455z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#21759b]/15 border border-[#21759b]/30">
              <span class="text-xs font-semibold uppercase tracking-wider text-[#7cb8d4]">Tecnología · WordPress</span>
            </div>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[72px] xl:text-[84px] font-medium font-[var(--font-heading)] text-white leading-[0.98] tracking-tight">
            WordPress en China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Sí, resiste.</span>
          </h1>
          <p class="mt-10 text-lg lg:text-xl text-white/65 max-w-xl leading-relaxed">
            Casi todos nuestros clientes llegan con WordPress ya instalado. La cuestión es si esa instalación resistirá detrás del Cortafuegos y qué hay que rehacer para lograrlo.
          </p>
          <p class="mt-4 text-base text-white/45 max-w-xl leading-relaxed">
            Llevamos veinte años en Shanghái y más de cincuenta sitios internacionales publicados.
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <Button href="/es/contacto/" variant="primary" size="lg">Hablar con el equipo</Button>
            <Button href="/es/astro/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Astro en China</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with workspace image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-4">
            Por qué resiste
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Por dentro, WordPress funciona en China.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            El núcleo de WordPress, el código que distribuye wordpress.org, el circuito habitual de publicación: todo se comporta igual en un servidor de Shanghái que en uno de Londres. Y al panel wp-admin se accede sin VPN.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            El problema está en las dependencias que WordPress incluye por defecto. Los temas solicitan tipografías a Google. Las extensiones consultan API alojadas fuera del Cortafuegos. Las bibliotecas se descargan de CDN bloqueados. Los contenidos incrustados apuntan a YouTube. Y la analítica envía sus datos a Google.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Una vez retiradas esas dependencias y sustituidas por equivalentes chinos, el resultado sigue siendo un WordPress: rápido, conforme a la normativa, indexado por Baidu y administrable por un equipo que ya lo conoce.
          </p>
        </div>

        <!-- WordPress admin screenshot -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-12 lg:mt-0">
