---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/pages/ScrollEffects.astro';
import { getCollection } from 'astro:content';

const teamMembers = (await getCollection('team-es')).sort((a, b) => a.data.order - b.data.order);

const disciplines = [
  {
    title: 'Estrategas',
    cn: '战略',
    icon: 'compass',
    accent: '#F25F29',
    description: 'Profesionales sénior que han dirigido la entrada en el mercado chino de marcas de lujo, de gran consumo y de los sectores B2B y SaaS. En ellos recae la auditoría inicial, el posicionamiento y la hoja de ruta, las decisiones que determinan buena parte de los resultados del primer año.',
    chips: ['Auditoría', 'Posicionamiento', 'Hoja de ruta', 'GTM'],
  },
  {
    title: 'Especialistas en contenido',
    cn: '内容',
    icon: 'pen',
    accent: '#EF4444',
    description: 'Redactores chinos nativos que parten del encargo para escribir pensando en el lector local. Sus artículos se sustentan en un análisis riguroso de las búsquedas en Baidu, y las páginas de producto responden a la forma en que los compradores chinos leen y deciden.',
    chips: ['Reescritura nativa', 'Intención Baidu', 'Citable por IA', 'Páginas de producto'],
  },
  {
    title: 'Diseñadores UX/UI',
    cn: '设计',
    icon: 'layers',
    accent: '#4D6BFE',
    description: 'Un equipo local que diseña a partir de los hábitos del usuario chino. El trabajo parte siempre del móvil, que concentra más del 80 % del tráfico, y los recorridos de WeChat (微信) y Alipay (支付宝) se conciben para que resulten naturales a quien los usa a diario. A ello se añaden las señales de confianza de las que depende la conversión en este mercado.',
    chips: ['Mobile-first', 'WeChat', 'Alipay', 'Señales de confianza'],
  },
  {
    title: 'Integradores técnicos',
    cn: '技术',
    icon: 'code',
    accent: '#10B981',
    description: 'Desarrolladores sénior que suman, cada uno, un mínimo de cinco años de experiencia en China. Dominan WordPress, Astro, las arquitecturas headless, la gestión de extensiones y una integración continua adaptada a las particularidades de la red local. También se encargan del alojamiento con licencia ICP (ICP备案) en Aliyun, Tencent Cloud o Huawei Cloud, que gestionan de principio a fin.',
    chips: ['WordPress', 'Astro', 'Headless', 'Alojamiento ICP'],
  },
  {
    title: 'Especialistas en SEO y GEO',
    cn: '搜索',
    icon: 'search',
    accent: '#F59E0B',
    description: 'Especialistas en Baidu que conocen a fondo el comportamiento de Baiduspider y su manera de rastrear e indexar los sitios. El equipo de GEO supervisa cada semana la visibilidad de la marca en DeepSeek, Doubao, Kimi, Yuanbao y Baidu IA, y ajusta el contenido y su distribución al ritmo con el que evolucionan estos modelos.',
    chips: ['SEO Baidu', 'DeepSeek', 'Doubao', 'Yuanbao'],
  },
];

const ticker = [
  'Estrategia', '战略',
  'Contenido', '内容',
  'Diseño', '设计',
  'Tecnología', '技术',
  'Alojamiento', 'ICP备案',
  'SEO Baidu', '百度',
  'GEO', 'Búsqueda con IA',
  'WeChat', '微信',
  'Alipay', '支付宝',
  'Aliyun', '阿里云',
  'Tencent Cloud', '腾讯云',
  'Huawei Cloud', '华为云',
  'DeepSeek', '深度求索',
  'Doubao', '豆包',
  'Kimi', 'Yuanbao',
];

const faqs = [
  {
    id: 'who-actually-works',
    question: '¿Quién se ocupará realmente de nuestro proyecto?',
    answer: 'El mismo equipo que usted conoce en la fase de propuesta es el que lleva a cabo el proyecto. El estratega, el diseñador, el desarrollador y el responsable de SEO intervienen desde la primera reunión. Nunca presentamos perfiles sénior para acabar delegando el trabajo en profesionales júnior.',
  },
  {
    id: 'how-involved-week-to-week',
    question: '¿Qué nivel de implicación exige el proyecto cada semana?',
    answer: 'Por lo general bastan entre dos y tres horas a la semana: una reunión de 45 minutos, algunas revisiones asíncronas durante la fase de producción y una revisión más amplia una vez al mes. A cambio le pedimos una sola condición: que designe a un interlocutor con capacidad de decisión, capaz de resolver sin elevar cada acuerdo a una instancia superior.',
  },
  {
    id: 'time-difference-handling',
    question: '¿Cómo gestionan la diferencia horaria?',
    answer: 'Nuestros jefes de proyecto solapan su jornada con la mañana europea y, al cierre del día en China, con los equipos de Norteamérica. El informe semanal estará en su bandeja de entrada antes incluso de que usted empiece a trabajar. Y nos adaptamos a la herramienta que su empresa ya utilice, sea Slack, Teams o Zoom.',
  },
  {
    id: 'strategy-execution-alignment',
    question: '¿Cómo evitan que la estrategia se aleje de la ejecución?',
    answer: 'Quien define la estrategia se la explica en persona al redactor, al diseñador y al desarrollador. No existe ningún documento de traspaso que se deforme al pasar de una mano a otra. Y cuando la estrategia cambia, la decisión se toma en la misma sala y con el mismo equipo.',
  },
  {
    id: 'existing-team-or-agency',
    question: '¿Y si ya tenemos un equipo interno u otra agencia?',
    answer: 'Es una situación habitual. Sus equipos internacionales mantienen el rumbo de la marca, mientras que nosotros nos ocupamos de la ejecución en China. El reparto de responsabilidades queda fijado por escrito desde el inicio, y la coordinación entre ambos equipos se concentra en los momentos clave del proyecto.',
  },
  {
    id: 'keep-us-in-the-loop',
    question: '¿Cómo nos mantienen al corriente?',
    answer: 'Cada semana recibe un informe escrito con lo que se ha entregado, lo que sigue en marcha, lo que está bloqueado y lo que necesitamos de usted. A ello se añade un panel compartido con las cifras actualizadas al momento, una llamada semanal de 45 minutos y una revisión más extensa una vez al mes. Con eso basta.',
  },
  {
    id: 'when-we-disagree',
    question: '¿Qué ocurre si surge un desacuerdo?',
    answer: 'Lo decimos con franqueza. Si pensamos que un encargo no va a funcionar en el mercado chino, se lo advertimos antes de empezar, con los argumentos sobre la mesa y una alternativa concreta. Una conversación incómoda en la segunda semana siempre vale más que un entregable fallido en el sexto mes.',
  },
  {
    id: 'after-launch',
    question: '¿Cómo sigue la relación después de la puesta en marcha?',
    answer: 'La mayoría de los clientes opta por un acompañamiento continuado que abarca el contenido, el SEO y el GEO, el mantenimiento técnico y el alojamiento. Es el mismo equipo trimestre tras trimestre, de modo que no tendrá que volver a explicar su marca a un nuevo jefe de proyecto cada pocos meses.',
  },
];
---

<PageLayout
  title="Quiénes somos | El equipo de ChinaWebFoundry en Shanghái"
  description="Un equipo sénior radicado en Shanghái que reúne estrategia, redacción nativa china, diseño UX/UI, desarrollo y posicionamiento en buscadores, con veinte años de trabajo sobre el terreno."
  heroPage={true}
  lang="es"
>
  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero-who-we-are-office.webp"
        alt=""
        class="absolute inset-0 w-full h-full object-cover opacity-70"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/80 to-[#0f0f12]/55"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[5%] w-[520px] h-[520px] rounded-full bg-[#4D6BFE]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[26rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">团</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Quiénes somos</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Quiénes somos</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">5 disciplinas, 1 equipo</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Arraigados en China.</span>
            <span class="block mt-1.5 text-white/95">Con exigencia internacional.</span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Usted dirige su marca desde el extranjero y necesita una base sólida en China. Esa base la construimos y la sostenemos nosotros: un equipo multidisciplinar completo, presente sobre el terreno desde hace más de <span class="text-white font-medium">20 años</span>.
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">
                <span data-counter data-counter-suffix="+">20</span>
              </div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Años en China</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">
                <span data-counter>5</span>
              </div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Disciplinas</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">
                <span data-counter data-counter-suffix="%">100</span>
              </div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Equipo propio en China</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/es/contacto/" variant="primary" size="lg">Trabajar con nosotros</Button>
            <Button href="#leadership" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Conocer al equipo</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative h-[420px]">
            <div class="absolute top-0 left-0 right-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[10px] font-mono text-white/40 uppercase tracking-wider">Usted</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">fuera de China</span>
              </div>
              <div class="space-y-2">
                <div class="h-2.5 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
              </div>
            </div>

            <div class="absolute top-[120px] left-1/2 -translate-x-1/2 w-px h-12 bg-gradient-to-b from-white/30 to-[var(--color-brand-orange)]/60"></div>

            <div data-tilt class="absolute top-[160px] left-4 right-0 rounded-2xl bg-white shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)] overflow-hidden">
              <div class="flex items-center gap-2.5 px-5 py-3 bg-white border-b border-gray-100">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[var(--color-brand-orange)] to-[#FF7E47] flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-7m0 0V3m0 11h11m6 7v-7m0 0V3m0 11h-6"/></svg>
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="text-sm font-semibold text-gray-900">ChinaWebFoundry</span>
                  <span class="text-[10px] text-gray-400">在中国 · Shanghái</span>
                </div>
                <div class="ml-auto flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                  <span class="text-[10px] text-gray-400">在线</span>
                </div>
              </div>

              <div class="px-5 py-4 space-y-2.5 bg-white">
                {disciplines.map((d, i) => (
                  <div class="flex items-center gap-3" data-reveal data-reveal-delay={String(i * 80)}>
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style={`background-color: ${d.accent}15; color: ${d.accent}`}>
                      <span class="text-[11px] font-medium">{d.cn}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[12.5px] font-medium text-gray-900 truncate">{d.title}</div>
                    </div>
                    <svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                ))}
              </div>

              <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
                <span class="text-[10px] font-mono text-gray-500">Un equipo. Un encargo. Un Slack.</span>
                <span class="text-[10px] font-mono text-emerald-600">Sin traspasos</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="relative border-t border-white/[0.08] bg-[#0f0f12]/60 backdrop-blur-sm overflow-hidden">
      <div class="flex whitespace-nowrap py-4 gap-10" style="animation: marquee 50s linear infinite; width: 300%;">
        {[...ticker, ...ticker, ...ticker].map((item) => (
          <span class="text-sm text-white/40 font-medium tracking-wider flex items-center gap-10">
            <span>{item}</span>
            <span class="text-[var(--color-brand-orange)]/40">●</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="relative py-24 md:py-32 lg:py-40 bg-white overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.04]">
      <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-gradient-to-bl from-[var(--color-brand-orange)] to-transparent blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-[1100px] section-padding">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)] text-center mb-6" data-reveal>Un equipo, un mismo objetivo.</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[52px] text-center font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]" data-reveal data-reveal-delay="80">
        Estrategia, contenido, diseño, tecnología y búsqueda.<br class="hidden sm:block" />
        Un solo equipo, desde el primer día.
      </h2>
      <p class="mt-8 text-xl text-center text-[var(--color-text-body)] max-w-3xl mx-auto leading-relaxed" data-reveal data-reveal-delay="160">
        Hemos reunido un equipo completo en torno a un único objetivo: que su sitio cumpla en el mercado chino aquello que promete. <span class="text-[var(--color-text-dark)] font-medium">Estrategia, contenido, diseño, tecnología y búsqueda</span> conviven bajo un mismo techo.
      </p>

      <div class="mt-16 grid grid-cols-2 md:grid-cols-5 gap-px bg-[var(--color-surface-border)] border border-[var(--color-surface-border)] rounded-2xl overflow-hidden" data-reveal data-reveal-delay="240">
        {disciplines.map((d) => (
          <div class="bg-white p-6 text-center hover:bg-[var(--color-surface-light)] transition-colors group">
            <div class="text-3xl font-medium font-[var(--font-heading)] mb-2 transition-transform group-hover:scale-110" style={`color: ${d.accent}`}>{d.cn}</div>
            <div class="text-xs uppercase tracking-wider text-[var(--color-text-muted)]">{d.title}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DISCIPLINAS -->
  <section id="disciplines" class="relative py-24 md:py-32 lg:py-40 bg-[var(--color-surface-light)] overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.05] pointer-events-none">
      <div class="absolute top-1/4 left-0 w-96 h-96 rounded-full bg-[var(--color-brand-orange)] blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-96 h-96 rounded-full bg-[#4D6BFE] blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-16 lg:mb-20" data-reveal>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)] mb-5">Nuestro oficio</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.05]">
          5 disciplinas.<br />
          <span class="text-[var(--color-brand-orange)]">1 equipo.</span>
        </h2>
        <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed max-w-2xl">
          En cada puesto trabaja un profesional sénior, y toda la cadena de producción se cubre internamente, desde nuestras oficinas de Shanghái.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-5 auto-rows-fr">
        {disciplines.map((d, i) => (
          <article
            data-reveal
            data-reveal-delay={String(i * 90)}
            data-cursor-spotlight
            class:list={[
              'group relative bg-white rounded-2xl p-7 lg:p-8 border border-[var(--color-surface-border)] overflow-hidden transition-all duration-300 hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_30px_80px_-40px_rgba(0,0,0,0.25)] hover:-translate-y-1 flex flex-col',
              i === 0 && 'lg:col-span-7',
              i === 1 && 'lg:col-span-5',
              i === 2 && 'lg:col-span-4',
              i === 3 && 'lg:col-span-4',
              i === 4 && 'md:col-span-2 lg:col-span-4',
            ]}
          >
            <span aria-hidden="true" class="absolute -right-4 -top-4 text-[9rem] font-medium font-[var(--font-heading)] leading-none select-none pointer-events-none transition-transform duration-500 group-hover:scale-110 group-hover:-rotate-6" style={`color: ${d.accent}; opacity: 0.07`}>{d.cn}</span>

            <div class="relative flex flex-col flex-1">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style={`background-color: ${d.accent}15; color: ${d.accent}`}>
                {d.icon === 'compass' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 8l-2 5-5 2 2-5z"/></svg>
                )}
                {d.icon === 'pen' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 4l4 4-12 12H4v-4L16 4zM14 6l4 4"/></svg>
                )}
                {d.icon === 'layers' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l9 5-9 5-9-5 9-5zM3 13l9 5 9-5M3 18l9 5 9-5"/></svg>
                )}
                {d.icon === 'code' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7l-5 5 5 5M16 7l5 5-5 5M14 4l-4 16"/></svg>
                )}
                {d.icon === 'search' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path stroke-linecap="round" d="M21 21l-4.5-4.5"/></svg>
                )}
              </div>

              <h3 class="text-xl lg:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">
                {d.title}
              </h3>
              <p class="text-base text-[var(--color-text-body)] leading-relaxed mb-6 flex-1">
                {d.description}
              </p>

              <div class="flex flex-wrap gap-2 pt-5 border-t border-[var(--color-surface-border)]">
                {d.chips.map((chip) => (
                  <span class="text-[11px] font-medium px-2.5 py-1 rounded-full bg-[var(--color-surface-light)] text-[var(--color-text-body)] border border-[var(--color-surface-border)] group-hover:border-[var(--color-brand-orange)]/30 transition-colors">
                    {chip}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUÉ FUNCIONA -->
  <section class="relative bg-[var(--color-surface-dark)] py-24 md:py-32 lg:py-40 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.06]">
      <div class="absolute top-1/4 right-0 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)] blur-[160px]"></div>
      <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] rounded-full bg-[#4D6BFE] blur-[160px]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start gap-y-16">
