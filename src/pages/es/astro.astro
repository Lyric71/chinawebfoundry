---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'Astro en China | Sitios estáticos rápidos para redes móviles lentas';
const metaDescription = 'Astro es la vía más rápida para publicar un sitio de marketing en China continental. Qué es, cuándo se impone a WordPress y los ajustes que lo hacen aguantar detrás del Cortafuegos.';

const stats = [
  { value: 100, suffix: '', label: 'Puntuación Lighthouse media de un sitio Astro, sin ningún ajuste manual', source: 'Sitepins, Astro en 2026' },
  { value: 60, suffix: '%', label: 'de los sitios Astro superan los umbrales «Good» de los Core Web Vitals', source: 'Frente al 38 % de WordPress' },
  { value: 50, suffix: '%', label: 'menos de LCP que un WordPress comparable, con el mismo proveedor chino', source: 'Mediciones de ChinaWebFoundry' },
];

const useCases = [
  {
    icon: 'rocket',
    title: 'Sitios de marketing y sitios de marca',
    body: 'Sitios de marca, páginas de producto, páginas de aterrizaje, microsites de campaña. La velocidad tiene que ser excelente, el contenido cambia una vez por semana, a veces menos. Astro se pensó justo para este terreno, y aquí la ventaja de rendimiento se vuelve evidente.',
    span: 'feature',
    badges: ['Sitios de marca', 'Páginas de aterrizaje', 'Microsites'],
  },
  {
    icon: 'book',
    title: 'Documentación y bibliotecas de recursos',
    body: 'Starlight, el framework de documentación propio de Astro, es lo más sólido de su ecosistema. Para la documentación técnica, las bases de conocimiento y los centros de recursos servidos desde China, el contenido carga rápido y la navegación se mantiene clara.',
    span: 'normal',
  },
  {
    icon: 'pen',
    title: 'Sitios editoriales y blogs',
    body: 'Las Content Collections ofrecen un Markdown y un MDX tipados, validados al compilar. El circuito de producción gana velocidad frente a WordPress, y el resultado pesa mucho menos en las redes móviles chinas.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Sitios de marketing multilingües',
    body: 'Astro incorpora el enrutamiento i18n de forma nativa. El chino convive sin problemas con el inglés, el francés, el alemán o el japonés. Hemos entregado sitios Astro de diez idiomas o más, sin tropiezos.',
    span: 'normal',
  },
  {
    icon: 'zap',
    title: 'Sitios donde los Core Web Vitals gobiernan el presupuesto',
    body: 'Cuando la compra de medios depende de la velocidad de la página de aterrizaje, o su posicionamiento se apoya en la indexación de Baidu, Astro es el framework que le lleva hasta ahí con menos fricción. Primer renderizado por debajo del segundo en un teléfono chino de gama media.',
    span: 'normal',
  },
  {
    icon: 'shield',
    title: 'Sitios con alta exigencia de seguridad',
    body: 'HTML estático, por tanto ninguna base de datos que atacar, ningún PHP que explotar, ningún acceso de administración que forzar. Para las marcas que ya han sufrido un ataque, o para los sectores regulados donde la seguridad llega hasta el comité de dirección, una superficie de ataque reducida pesa de verdad en la balanza.',
    span: 'wide',
    badges: ['Sin base de datos', 'Sin runtime PHP', 'Sin acceso de administración', 'Entrega estática'],
  },
];

const pickAstro = [
  'El sitio se concibe ante todo como un proyecto de contenido y comunicación',
  'La velocidad de carga es una exigencia medida, no negociable',
  'El equipo acepta un circuito que dirigen los desarrolladores, o le conectamos un CMS headless',
  'Quiere reducir los costes de alojamiento y mantenimiento a largo plazo',
  'La seguridad y una superficie de ataque reducida priman sobre la flexibilidad editorial',
];

const pickWordPress = [
  'Su equipo de contenido publica a diario, sin recurrir a un desarrollador',
  'Opera un e-commerce con cientos, o miles, de referencias en WooCommerce',
  'Depende de extensiones de WordPress concretas (membresías, LMS, automatización de marketing)',
  'El equipo de marketing ya trabaja con Elementor o Divi y no quiere migrar',
  'El proyecto es muy interactivo (paneles conectados, funciones en tiempo real)',
];

const changeGroups = [
  {
    label: 'Front-end',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Tipografías',
        body: 'Las plantillas de inicio de Astro van a buscar sus tipografías a Google Fonts. Cortamos la llamada y alojamos las fuentes en el propio servidor, o las sustituimos por tipografías que cubren los glifos latinos y CJK en un mismo archivo.',
      },
      {
        icon: 'palette',
        title: 'Recursos externos e imágenes',
        body: 'Algunos temas de Astro buscan sus iconos o sus bibliotecas en CDN occidentales (jsDelivr, unpkg). Redirigimos el conjunto hacia un CDN chino, o incorporamos esos recursos directamente al build. Las imágenes, por su parte, se sirven desde Aliyun OSS o Tencent COS, en formatos modernos.',
      },
      {
        icon: 'blocks',
        title: 'Scripts de terceros',
        body: 'Toda llamada a un servicio bloqueado se retira o se sustituye. Mapas, tipografías, analítica, captchas y contenidos incrustados reciben cada uno su equivalente compatible con China durante la compilación, antes de que el resultado estático salga a producción.',
      },
    ],
  },
  {
    label: 'Integraciones y CMS',
    accent: 'orange',
    items: [
      {
        icon: 'plug',
        title: 'CMS headless, cuando hace falta',
        body: 'Cuando el equipo editorial pide una interfaz visual, conectamos Storyblok, Sanity, Decap o WordPress en modo headless. El CMS vive fuera de China, el contenido se sincroniza al compilar, y el sitio estático vive en un servidor continental.',
      },
      {
        icon: 'card',
        title: 'Formularios y widgets',
        body: 'Los formularios funcionan en Astro Islands. Google reCAPTCHA cede a un captcha chino. Google Maps deja paso a Baidu Map o Amap. Los bloques interactivos siguen funcionando sin ninguna dependencia externa.',
      },
      {
        icon: 'chart',
        title: 'Analítica',
        body: 'Vercel Analytics o Plausible dejan paso a Baidu Tongji, o a una herramienta autoalojada. Los mismos paneles que el equipo necesita, sin un solo endpoint bloqueado.',
      },
    ],
  },
  {
    label: 'Alojamiento y compilación',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Alojamiento',
        body: 'Servidor en China continental, licencia ICP en regla sobre el dominio. Aliyun, Tencent Cloud o Huawei Cloud, detrás de un CDN chino. El propio CDN de Cloudflare se comporta mal en el continente; por eso no lo desplegamos allí.',
      },
      {
        icon: 'refresh',
        title: 'Pipeline de compilación',
        body: 'La compilación corre fuera de China en un pipeline de CI (GitHub Actions, GitLab CI). El resultado estático se empuja hacia el proveedor chino. Un push a la rama principal, y el sitio se actualiza en unos minutos.',
      },
      {
        icon: 'shield',
        title: 'Postura de seguridad',
        body: 'Ninguna base de datos, ningún runtime PHP, ningún acceso de administración. El trabajo de seguridad se traslada al pipeline de compilación y al borde de la nube china, en lugar de a un runtime que hay que parchear cada semana.',
      },
    ],
  },
  {
    label: 'Rendimiento y SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Rendimiento',
        body: 'HTML estático servido por un CDN continental resulta difícil de superar. Apuntamos a un primer renderizado útil por debajo del segundo en un teléfono chino de gama media, y lo alcanzamos la mayoría de las veces.',
      },
      {
        icon: 'search',
        title: 'Baidu y búsqueda con IA',
        body: 'Baidu no indexa como Google. Por eso ajustamos los metadatos con cuidado, conectamos Baidu Webmaster Tools y estructuramos el sitio para que Doubao, Kimi, DeepSeek y Wenxin puedan leerlo y citarlo. Tener archivos en claro dentro de Git facilita generar los datos estructurados y el llms.txt.',
      },
    ],
  },
];

const fitBuckets = [
  {
    eyebrow: 'Astro encaja',
    title: 'Sitios de marketing con interactividad ligera',
    body: 'Un sitio de marketing con un pequeño escaparate de producto, un formulario de contacto o algunos widgets interactivos: Astro se diseñó justo para este uso. Páginas estáticas, cargas rápidas, JavaScript solo en los puntos donde sirve para algo.',
  },
  {
    eyebrow: 'WordPress encaja mejor',
    title: 'E-commerce y editorial diario',
    body: 'Miles de referencias gestionadas día a día por un equipo sin perfil técnico, dependencias profundas de extensiones, equipos de marketing que viven dentro de un constructor de páginas. Para estos usos, WooCommerce sobre WordPress sigue siendo la respuesta acertada la mayoría de las veces.',
  },
  {
    eyebrow: 'Otra herramienta',
    title: 'Experiencias cercanas a una aplicación',
    body: 'Paneles conectados, colaboración en tiempo real, espacios sociales, todo lo que se parece más a una aplicación que a un sitio. Pasada esa frontera, Next.js o Remix toman el relevo con más soltura que Astro.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Alojamiento' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Alojamiento' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Alojamiento' },
  { name: 'Baidu', cn: '百度', role: 'Búsqueda y SEO' },
  { name: 'WeChat', cn: '微信', role: 'Identidad y mensajería' },
  { name: 'Alipay', cn: '支付宝', role: 'Pagos' },
];

const faqs = [
  {
    id: 'astro-icp',
    question: '¿Nuestro sitio Astro necesita una licencia ICP para funcionar en China?',
    answer: 'Si está alojado en China continental, sí. Alojado a través de Hong Kong o Cloudflare, no, pero el sitio perderá velocidad de forma medible para los usuarios continentales, y Baidu lo tratará como un sitio extranjero. Para las marcas que se toman en serio el mercado chino, el trámite ICP justifica la inversión.',
  },
  {
    id: 'astro-marketing-team',
    question: '¿El equipo de marketing podrá seguir actualizando el sitio?',
    answer: 'Depende de la configuración elegida. Con Markdown y las Content Collections, los cambios pasan por Git y exigen un desarrollador, o un usuario técnico con soltura. Con un CMS headless conectado (Storyblok, Sanity, Decap), el equipo editorial dispone de una interfaz visual y actualiza el sitio sin tocar el código. Elegimos el modelo que de verdad encaja con la forma de trabajar del equipo.',
  },
  {
    id: 'astro-vs-wp-speed',
    question: '¿Astro es realmente más rápido que WordPress en China?',
    answer: 'En cifras brutas, sí. Astro entrega HTML estático con casi cero JavaScript, lo que reduce el volumen transferido, acelera el renderizado y limita las idas y vueltas al servidor. Hemos medido entre un 40 % y un 60 % menos de Largest Contentful Paint en Astro frente a un WordPress comparable, en el mismo proveedor chino.',
  },
  {
    id: 'astro-headless-cms',
    question: '¿Se puede asociar un CMS headless a Astro?',
    answer: 'Sí, y es uno de los modelos más sólidos de Astro. Hemos entregado sitios con Storyblok, Sanity, Decap y WordPress en modo headless. El CMS vive fuera de China, donde los redactores trabajan sin la atadura de un VPN. El front estático vive en un servidor continental. El contenido se sincroniza al compilar. El equipo editorial conserva la interfaz que conoce, y la audiencia china recibe un sitio rápido.',
  },
  {
    id: 'astro-ecommerce',
    question: '¿Y el e-commerce sobre Astro?',
    answer: 'Para catálogos pequeños y medianos (menos de quinientas referencias), Astro se asocia bien con el comercio headless: Shopify Storefront, Snipcart o Stripe Checkout para los pagos internacionales, más integraciones a medida del lado de Alipay y WeChat Pay para los consumidores chinos. Para los grandes e-commerce con miles de referencias y un equipo sin perfil técnico que gestiona el inventario a diario, WooCommerce sobre WordPress sigue siendo la respuesta acertada la mayoría de las veces.',
  },
  {
    id: 'astro-multilingual',
    question: '¿Cómo gestiona Astro el multilingüe en el caso de China?',
    answer: 'Astro incorpora el enrutamiento i18n de forma nativa. La convivencia del chino con el inglés, el francés o cualquier otro idioma se mantiene limpia y estructurada. Las URL, las etiquetas hreflang y los sitemaps por idioma funcionan desde el principio. Hemos entregado sitios Astro de diez idiomas o más.',
  },
  {
    id: 'astro-migrate-wp',
    question: '¿Se puede migrar nuestro WordPress actual a Astro?',
    answer: 'Sí, y lo hacemos con regularidad. El contenido se exporta desde WordPress, se reestructura en Content Collections de Astro o se redirige a un CMS headless, y luego el diseño se reconstruye para la nueva pila. El plazo habitual se sitúa entre cuatro y ocho semanas. El resultado: un sitio más rápido y costes de funcionamiento más bajos. La contrapartida: la desaparición de la interfaz de administración de WordPress, salvo que se conserve como back-office headless.',
  },
  {
    id: 'astro-hosting',
    question: '¿Qué alojamiento usan para Astro en China?',
    answer: 'Alojamos en Aliyun, Tencent Cloud o Huawei Cloud según el proyecto. La compilación corre fuera de China en un pipeline de CI. El resultado estático se empuja hacia el proveedor chino, detrás de un CDN continental. Gestionamos la cuenta de alojamiento, el trámite ICP y el pipeline de despliegue, para que su equipo no tenga que conectarse nunca por su cuenta a un panel de un proveedor chino.',
  },
  {
    id: 'astro-maintenance',
    question: '¿Cuánto mantenimiento exige un sitio Astro?',
    answer: 'Mucho menos que un WordPress, y por mucho. Ninguna base de datos que respaldar, ninguna extensión que actualizar, ninguna versión de PHP que hacer evolucionar, ningún parche de seguridad que aplicar cada dos semanas. El propio framework recibe unas pocas actualizaciones al año, las dependencias merecen una revisión de vez en cuando, y poco más. Para la mayoría de los sitios de marketing, una pasada trimestral basta de sobra.',
  },
  {
    id: 'astro-cloudflare',
    question: '¿Y la compra de Astro por Cloudflare, qué cambia para China?',
    answer: 'Sí y no. La inversión más profunda de Cloudflare significa que Astro se apoya ahora en una infraestructura respaldada por un actor valorado en treinta mil millones de dólares, lo que tranquiliza a los clientes preocupados por la viabilidad a largo plazo. El framework sigue bajo licencia MIT y se puede desplegar donde uno quiera, incluidos los proveedores de nube chinos. El propio CDN de Cloudflare se comporta mal en el continente, pero los sitios Astro se despliegan muy bien en Aliyun o Tencent Cloud, sin perder funcionalidad.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es">

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-astro-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Astro</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <!-- Astro logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--color-brand-orange)] to-[#EF4444] flex items-center justify-center shadow-[0_8px_30px_rgba(242,95,41,0.4)]">
              <svg class="h-8 w-auto text-white" viewBox="0 0 85 107" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Logo de Astro">
                <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z"/>
                <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-[var(--color-brand-orange)] ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/25">
              <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">Framework · Astro</span>
            </div>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Astro en China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Pensado para la velocidad.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            El framework front-end moderno para los sitios que viven del contenido. Estático ante todo, JavaScript cercano a cero y especialmente tolerante con las redes móviles chinas saturadas.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            En manos de Cloudflare desde enero de 2026. Diseñamos tanto con Astro como con WordPress, y eso nos permite decirle cuál le conviene.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/es/contacto/" variant="primary" size="lg">Hablar con el equipo</Button>
            <Button href="/es/wordpress/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">WordPress en China</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">astro-china-build</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Lighthouse</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100 / 100</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">JS entregado</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">~0 KB</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Edge</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aliyun</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Trámite ICP</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Presentado</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with code editor image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
