---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'Astro en China | Sitios estáticos veloces para la red móvil china';
const metaDescription = 'Astro es la vía más rápida para publicar un sitio de marketing en China continental. Qué es, cuándo conviene más que WordPress y cómo se adapta al Cortafuegos.';

const stats = [
  { value: 100, suffix: '', label: 'Puntuación Lighthouse media de un sitio Astro, sin un solo ajuste manual', source: 'Sitepins, Astro en 2026' },
  { value: 60, suffix: '%', label: 'de los sitios Astro superan el umbral «Good» en los Core Web Vitals', source: 'Frente al 38 % de WordPress' },
  { value: 50, suffix: '%', label: 'menos LCP que un WordPress equivalente en el mismo proveedor chino', source: 'Mediciones de ChinaWebFoundry' },
];

const useCases = [
  {
    icon: 'rocket',
    title: 'Sitios de marketing y de marca',
    body: 'Un sitio de marca, una ficha de producto, una página de aterrizaje o un microsite de campaña piden lo mismo: que carguen muy rápido, aunque el contenido cambie una vez por semana como mucho. Astro nació para esto. Es donde más se nota su rendimiento.',
    span: 'feature',
    badges: ['Sitios de marca', 'Páginas de aterrizaje', 'Microsites'],
  },
  {
    icon: 'book',
    title: 'Documentación y bibliotecas de recursos',
    body: 'Starlight, el sistema de documentación del propio Astro, es una de sus grandes bazas. Para documentación técnica, bases de conocimiento o centros de recursos servidos desde China, el contenido carga deprisa y la navegación se mantiene clara.',
    span: 'normal',
  },
  {
    icon: 'pen',
    title: 'Sitios editoriales y blogs',
    body: 'Las Content Collections trabajan con Markdown y MDX tipados, que se validan al compilar. Publicar es más ágil que en WordPress y las páginas pesan mucho menos. En la red móvil china, eso se nota.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Sitios de marketing multilingües',
    body: 'Astro incorpora el enrutamiento i18n de forma nativa. El chino convive con el inglés, el francés, el alemán o el japonés sin el menor conflicto. Hemos publicado sitios Astro con diez idiomas o más, y todos funcionan sin problemas.',
    span: 'normal',
  },
  {
    icon: 'zap',
    title: 'Sitios donde los Core Web Vitals condicionan el presupuesto',
    body: 'Cuando la inversión en medios va ligada a la velocidad de la página de aterrizaje, o el posicionamiento se decide en la indexación de Baidu, Astro lo consigue con menos esfuerzo que casi cualquier alternativa. La página empieza a verse en menos de un segundo, incluso en un teléfono chino de gama media.',
    span: 'normal',
  },
  {
    icon: 'shield',
    title: 'Sitios con alta exigencia de seguridad',
    body: 'Al ser HTML estático, no hay base de datos que atacar, ni PHP que explotar, ni panel de administración que forzar. Para una marca que ya ha sufrido una brecha, o para un sector regulado donde la seguridad llega al comité de dirección, reducir la superficie de ataque pesa mucho.',
    span: 'wide',
    badges: ['Sin base de datos', 'Sin runtime PHP', 'Sin panel de administración', 'Entrega estática'],
  },
];

const pickAstro = [
  'El sitio es, sobre todo, un proyecto de contenido y comunicación',
  'La velocidad de carga se mide y no se negocia',
  'El equipo trabaja con un flujo en manos de desarrolladores, o con un CMS headless conectado',
  'Bajar los costes de alojamiento y mantenimiento a largo plazo es una prioridad',
  'La seguridad y una superficie de ataque mínima importan más que la flexibilidad editorial',
];

const pickWordPress = [
  'Su equipo de contenidos publica a diario, sin pasar por un desarrollador',
  'Gestiona un e-commerce de cientos o miles de referencias en WooCommerce',
  'Depende de extensiones concretas de WordPress: membresías, LMS, automatización de marketing',
  'El equipo de marketing ya trabaja con Elementor o Divi y no quiere migrar',
  'El proyecto es muy interactivo: paneles conectados, funciones en tiempo real',
];

const changeGroups = [
  {
    label: 'Front-end',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Tipografías',
        body: 'Las plantillas de inicio de Astro cargan las tipografías desde Google Fonts. Quitamos esa dependencia y alojamos las fuentes en el propio servidor del sitio, o las cambiamos por tipografías que cubren los glifos latinos y CJK en un solo archivo.',
      },
      {
        icon: 'palette',
        title: 'Recursos externos e imágenes',
        body: 'Algunos temas de Astro cargan sus iconos o sus bibliotecas desde CDN occidentales, como jsDelivr o unpkg. Redirigimos esas peticiones a un CDN chino, o integramos los recursos en la propia compilación. Las imágenes se sirven desde Aliyun OSS o Tencent COS, en formatos modernos.',
      },
      {
        icon: 'blocks',
        title: 'Scripts de terceros',
        body: 'Toda petición a un servicio bloqueado se retira o se sustituye. Mapas, tipografías, analítica, captchas, contenidos incrustados: cada uno recibe su alternativa compatible con China al compilar, antes de que el sitio estático llegue a producción.',
      },
    ],
  },
  {
    label: 'Integraciones y CMS',
    accent: 'orange',
    items: [
      {
        icon: 'plug',
        title: 'CMS headless, cuando hace falta',
        body: 'Cuando el equipo editorial necesita una interfaz visual, integramos Storyblok, Sanity, Decap o WordPress en modo headless. Alojamos el CMS fuera de China. En cada compilación se sincroniza el contenido, y el sitio estático reside en un servidor continental.',
      },
      {
        icon: 'card',
        title: 'Formularios y widgets',
        body: 'Los formularios funcionan sobre Astro Islands. Google reCAPTCHA pasa a un captcha chino y Google Maps a Baidu Maps o Amap. Los bloques interactivos siguen funcionando sin ninguna dependencia externa.',
      },
      {
        icon: 'chart',
        title: 'Analítica',
        body: 'Vercel Analytics o Plausible dan paso a Baidu Tongji, o a una herramienta autoalojada. El equipo conserva sus paneles de siempre, sin ningún endpoint bloqueado.',
      },
    ],
  },
  {
    label: 'Alojamiento y compilación',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Alojamiento',
        body: 'El sitio se aloja en un servidor de China continental, con el registro ICP del dominio en regla. Trabajamos con Aliyun, Tencent Cloud o Huawei Cloud, siempre detrás de un CDN chino. La red de Cloudflare rinde mal en el continente, así que no la usamos allí.',
      },
      {
        icon: 'refresh',
        title: 'Pipeline de compilación',
        body: 'La compilación se ejecuta fuera de China, en un pipeline de integración continua: GitHub Actions o GitLab CI. El resultado estático se publica en el proveedor chino. Basta un push a la rama principal para que el sitio se actualice en minutos.',
      },
      {
        icon: 'shield',
        title: 'Enfoque de seguridad',
        body: 'No hay base de datos, ni entorno PHP, ni panel de administración expuesto. La seguridad se traslada al pipeline de compilación y al perímetro de la nube china, en vez de recaer en un runtime que pide parches cada semana.',
      },
    ],
  },
  {
    label: 'Rendimiento y SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Rendimiento',
        body: 'El HTML estático servido desde un CDN continental es difícil de igualar. Buscamos que la página empiece a verse en menos de un segundo en un teléfono chino de gama media, y lo conseguimos casi siempre.',
      },
      {
        icon: 'search',
        title: 'Baidu y búsqueda con IA',
        body: 'Baidu no indexa como Google. Por eso cuidamos los metadatos, conectamos Baidu Webmaster Tools y estructuramos el sitio para que Doubao, Kimi, DeepSeek y Wenxin lo lean y lo citen. Tener el contenido en archivos de texto y bajo control de versiones facilita generar los datos estructurados y el archivo llms.txt.',
      },
    ],
  },
];

const fitBuckets = [
  {
    eyebrow: 'Astro encaja',
    title: 'Sitios de marketing con interactividad ligera',
    body: 'Un sitio de marketing con un pequeño escaparate de producto, un formulario de contacto o algún widget interactivo es justo lo que Astro hace bien: páginas estáticas, de carga rápida, con JavaScript solo donde hace falta.',
  },
  {
    eyebrow: 'WordPress encaja mejor',
    title: 'E-commerce y publicación diaria',
    body: 'Miles de referencias que gestiona a diario un equipo sin perfil técnico, una fuerte dependencia de las extensiones, un departamento de marketing acostumbrado a un constructor de páginas: en ese caso, WooCommerce sobre WordPress casi siempre es la opción correcta.',
  },
  {
    eyebrow: 'Otra herramienta',
    title: 'Experiencias cercanas a una aplicación',
    body: 'Un panel conectado, la colaboración en tiempo real o un espacio social se parecen más a una aplicación que a un sitio web. Pasada esa frontera, Next.js o Remix toman el relevo mejor que Astro.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Alojamiento' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Alojamiento' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Alojamiento' },
  { name: 'Baidu', cn: '百度', role: 'Búsqueda y SEO' },
  { name: 'WeChat', cn: '微信', role: 'Identidad y mensajería' },
  { name: 'Alipay', cn: '支付宝', role: 'Pagos' },
];

const faqs = [
  {
    id: 'astro-icp',
    question: '¿Nuestro sitio Astro necesita un registro ICP para funcionar en China?',
    answer: 'Si está alojado en China continental, sí. En Hong Kong o en Cloudflare no es obligatorio, pero el sitio irá bastante más lento para los usuarios del continente y Baidu lo tratará como un sitio extranjero. Para una marca que se toma en serio el mercado chino, el registro ICP compensa.',
  },
  {
    id: 'astro-marketing-team',
    question: '¿El equipo de marketing podrá seguir actualizando el sitio?',
    answer: 'Depende de la configuración. Con Markdown y las Content Collections, los cambios pasan por Git y necesitan un desarrollador o un perfil técnico con cierta soltura. Con un CMS headless integrado, sea Storyblok, Sanity o Decap, el equipo editorial tiene una interfaz visual y actualiza el sitio sin tocar el código. Elegimos el modelo que mejor encaja con cada equipo.',
  },
  {
    id: 'astro-vs-wp-speed',
    question: '¿Astro es realmente más rápido que WordPress en China?',
    answer: 'En rendimiento puro, sí. Astro genera HTML estático con muy poco JavaScript: se transfieren menos datos, el renderizado es más rápido y hay menos peticiones al servidor. Hemos medido entre un 40 % y un 60 % menos de Largest Contentful Paint en Astro frente a un WordPress equivalente, en el mismo proveedor chino.',
  },
  {
    id: 'astro-headless-cms',
    question: '¿Se puede integrar un CMS headless con Astro?',
    answer: 'Sí, y es uno de los modelos más sólidos de Astro. Hemos publicado sitios con Storyblok, Sanity, Decap y WordPress en modo headless. El CMS se aloja fuera de China, donde los redactores trabajan sin VPN. El sitio estático reside en un servidor continental y el contenido se sincroniza en cada compilación. El equipo editorial mantiene la interfaz que ya conoce y el público chino tiene un sitio veloz.',
  },
  {
    id: 'astro-ecommerce',
    question: '¿Y el e-commerce sobre Astro?',
    answer: 'Para catálogos pequeños y medianos, por debajo de quinientas referencias, Astro se combina bien con el comercio headless: Shopify Storefront, Snipcart o Stripe Checkout para los pagos internacionales, y integraciones a medida de Alipay y WeChat Pay para los consumidores chinos. Para un e-commerce grande, con miles de referencias y un equipo sin perfil técnico que gestiona el inventario a diario, WooCommerce sobre WordPress sigue siendo la opción más sensata.',
  },
  {
    id: 'astro-multilingual',
    question: '¿Cómo gestiona Astro los sitios multilingües en China?',
    answer: 'Astro incorpora el enrutamiento i18n de forma nativa. El chino convive con el inglés, el francés o cualquier otro idioma, y la estructura del sitio se mantiene ordenada. Las URL, las etiquetas hreflang y los sitemaps por idioma funcionan desde el primer momento. Hemos publicado sitios Astro con diez idiomas o más.',
  },
  {
    id: 'astro-migrate-wp',
    question: '¿Se puede migrar nuestro WordPress actual a Astro?',
    answer: 'Sí, y lo hacemos a menudo. Exportamos el contenido desde WordPress, lo reestructuramos en las Content Collections de Astro o lo enviamos a un CMS headless, y luego reconstruimos el diseño. Suele llevar entre cuatro y ocho semanas. El resultado es un sitio más rápido y unos costes de funcionamiento más bajos. A cambio se pierde el panel de administración de WordPress, salvo que se conserve como back-office headless.',
  },
  {
    id: 'astro-hosting',
    question: '¿Qué alojamiento utilizan para Astro en China?',
    answer: 'Alojamos en Aliyun, Tencent Cloud o Huawei Cloud, según el proyecto. La compilación se ejecuta fuera de China, en un pipeline de integración continua. El resultado estático se publica en el proveedor chino, detrás de un CDN continental. Nos ocupamos de la cuenta de alojamiento, del registro ICP y del pipeline de despliegue, así su equipo nunca tiene que acceder por su cuenta al panel de un proveedor chino.',
  },
  {
    id: 'astro-maintenance',
    question: '¿Cuánto mantenimiento exige un sitio Astro?',
    answer: 'Exige mucho menos que un sitio WordPress. No hay base de datos que respaldar, ni extensiones que actualizar, ni versiones de PHP que mantener al día, ni parches de seguridad que aplicar cada dos semanas. El framework recibe unas pocas actualizaciones al año y conviene revisar las dependencias de vez en cuando. No hay mucho más. Para la mayoría de los sitios de marketing, una revisión trimestral es más que suficiente.',
  },
  {
    id: 'astro-cloudflare',
    question: '¿Qué cambia para China la adquisición de Astro por Cloudflare?',
    answer: 'Poco, en lo esencial. Con el respaldo de Cloudflare, Astro se apoya ahora en una empresa valorada en treinta mil millones de dólares, algo que tranquiliza a quien duda de la viabilidad del proyecto a largo plazo. El framework sigue bajo licencia MIT y puede alojarse en cualquier proveedor, incluidos los chinos. La red de Cloudflare rinde mal en el continente, pero los sitios Astro funcionan sin problema en Aliyun o Tencent Cloud, sin perder ninguna funcionalidad.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es">

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-astro-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Astro</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <!-- Astro logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--color-brand-orange)] to-[#EF4444] flex items-center justify-center shadow-[0_8px_30px_rgba(242,95,41,0.4)]">
              <svg class="h-8 w-auto text-white" viewBox="0 0 85 107" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Logo de Astro">
                <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z"/>
                <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-[var(--color-brand-orange)] ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/25">
              <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)]">Framework · Astro</span>
            </div>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Astro en China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Pensado para la velocidad.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Astro es el framework front-end moderno para los sitios centrados en el contenido. Genera HTML estático, reduce el JavaScript al mínimo y se comporta bien en la red móvil china, incluso en las horas de más carga.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            El framework pasó a manos de Cloudflare en enero de 2026. Trabajamos con Astro y con WordPress, así podemos recomendarle con criterio la opción que más le conviene.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/es/contacto/" variant="primary" size="lg">Hablar con el equipo</Button>
            <Button href="/es/wordpress/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">WordPress en China</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">astro-china-build</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Lighthouse</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100 / 100</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">JS enviado</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">~0 KB</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Edge</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aliyun</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Registro ICP</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Presentado</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with code editor image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange-text)] mb-4">
            Por qué funciona
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
