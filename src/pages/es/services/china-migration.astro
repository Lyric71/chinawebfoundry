---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'china-migration'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const layers = [
  {
    label: 'Contenido',
    title: 'Un contenido reescrito para el lector chino',
    body: 'Nuestros redactores chinos de nacimiento retoman su mensaje y se apoyan en las señales de confianza que el lector busca primero, esas que las versiones traducidas casi siempre dejan en la cuneta.',
