    body: 'Registro ICP llevado de principio a fin. Alojamiento en Aliyun, Tencent o Huawei Cloud. Dependencias bloqueadas sustituidas una a una. Herramientas de webmaster de Baidu conectadas desde la puesta en línea.',
    iconPath: 'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z',
  },
];

interface Scenario {
  timeline: string;
  title: string;
  lead: string;
  body: string;
  fit: string[];
  diagram: 'single' | 'swap' | 'parallel';
}

const scenarios: Scenario[] = [
  {
    timeline: '6 a 10 semanas',
    title: 'Migración de su sitio actual',
    lead: 'Un único sitio global, repensado para el mercado chino.',
    body: 'Contenido reescrito, usabilidad ajustada, alojamiento trasladado a un servidor continental conforme. El sitio global se queda donde está, sobre la plataforma que sus equipos ya conocen.',
    fit: [
      'Un sitio global que ya funciona',
      'Una presencia china que aún cuesta arrancar',
      'WordPress, headless o cualquier otra arquitectura',
    ],
    diagram: 'single',
  },
  {
    timeline: '8 a 14 semanas',
    title: 'Cambiar de CMS durante la migración',
    lead: 'Cambiar de plataforma y entrar en China en la misma ventana.',
    body: 'Aprovechamos la migración para corregir lo que ya fallaba en el sitio anterior, antes de colocar encima la capa china. Drupal, Sitecore, AEM, Webflow, Shopify o desarrollo a medida.',
    fit: [
      'El CMS actual sale caro de mantener',
      'Llevar un solo proyecto en lugar de dos por separado',
      'La renovación ya figuraba en la agenda',
    ],
    diagram: 'swap',
  },
  {
    timeline: '10 a 16 semanas',
    title: 'Dos sitios llevados en paralelo',
    lead: 'Un sitio global y un sitio China, alimentados por una misma cadena editorial.',
    body: 'Un único equipo dirige el flujo. Dos públicos radicalmente distintos disponen cada uno del sitio que de verdad les habla.',
    fit: [
      'La marca global y la marca China siguen trayectorias distintas',
      'Quiere mantener el control en ambos lados',
      'Cuenta con los recursos para sostener los dos equipos',
    ],
    diagram: 'parallel',
  },
];

const phases = [
  {
    label: 'Fase 1',
    title: 'Descubrir',
    steps: [
      {
        title: 'Descubrimiento y auditoría',
        body: 'Auditoría escrita del sitio, de la marca, de la categoría y de la competencia china. Distinguimos lo que puede quedarse tal cual de lo que exige una reescritura. Calcule de dos a tres semanas.',
