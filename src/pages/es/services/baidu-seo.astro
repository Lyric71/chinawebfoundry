---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'baidu-seo'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const whyDifferent = [
  {
    n: '01',
    cn: '算法',
    title: 'Baidu premia otras cosas',
    body: 'El 知心算法 (Zhixin) reconoce ya más de 200 relaciones semánticas en las consultas en chino. El 飓风算法 3.0 castiga el contenido de IA mal revisado. Los textos traducidos palabra por palabra pierden posiciones enseguida.',
    tag: 'Criterios de posicionamiento',
    chips: ['知心算法', '飓风算法 3.0', 'Original ZH', 'Semántica'],
  },
  {
    n: '02',
    cn: '蜘蛛',
    title: 'Baidu Spider va a otro ritmo',
    body: "Baidu Spider procesa JavaScript con varios años de retraso respecto a Googlebot: el contenido cargado en el cliente suele quedarse fuera. El rastreo prioriza el móvil, la carga por debajo de tres segundos es un umbral rígido y el HTTPS cuenta como señal positiva.",
    tag: 'Rastreo y renderizado',
    chips: ['Baiduspider', 'Móvil primero', 'SSR / estático', 'HTTPS'],
  },
  {
    n: '03',
    cn: '主机',
    title: 'La ubicación del alojamiento es una señal',
    body: 'Los sitios sin trámite ICP quedan penalizados en el índice. Con el mismo contenido, un alojamiento continental supera a un sitio alojado en Hong Kong o en el extranjero. Es una señal estructural que pesa en cada consulta.',
    tag: 'Infraestructura',
    chips: ['ICP', 'Continental', 'Aliyun', 'Tencent Cloud'],
  },
  {
    n: '04',
    cn: '推送',
    title: 'El modelo de envío es distinto',
    body: "Baidu no encuentra su contenido por sí solo. Espera que se le empujen las URL nuevas mediante 主动推送 (Active Push) en los minutos posteriores a la publicación. Conectamos ese envío directamente al CMS.",
    tag: 'Envío',
    chips: ['主动推送', '自动推送', 'Sitemap', '手工提交'],
  },
  {
    n: '05',
    cn: '关键词',
    title: 'La investigación de palabras clave se hace en chino, desde cero',
    body: 'Lo que buscan de verdad los internautas chinos casi no se parece a una lista de palabras clave en inglés traducida. Trabajamos con 百度指数 (Baidu Index) y 百度关键词规划师 para levantar el mapa desde la página en blanco.',
    tag: 'Descubrimiento',
    chips: ['百度指数', '关键词规划师', '5118', 'Cola larga'],
  },
];

const services = [
  {
    n: '01',
    title: 'SEO técnico para Baidu',
    body: 'Verificación del sitio en el 百度搜索资源平台. Los cuatro métodos de envío de URL configurados por orden de prioridad, más 死链提交, 站点子链 y la comprobación del rastreo con prioridad móvil. La velocidad se mide desde China continental.',
    bullets: [
      '主动推送 (Active Push) conectado al CMS para el envío en tiempo real.',
      '自动推送 (Auto Push) en JS para recoger las URL visitadas antes de que se dispare el hook del CMS.',
      'Sitemap completo, actualizado de forma automática (50.000 URL / 10 MB máximo por archivo).',
      '手工提交 como último recurso para las páginas de mayor valor.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Contenido chino nativo, estructurado para Baidu',
    body: 'Baidu valora el 深度原创. El 飓风算法 degrada las páginas pobres o copiadas, y el 飓风算法 3.0 va a por el contenido de IA sin revisión humana. Escribimos con editores chinos nativos: formato largo, marcado Schema y respuestas factuales que las IA pueden citar.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Optimización para la búsqueda con IA (文心X1, DeepSeek, Doubao, Kimi)',
    body: "Más del 20 % de los resultados de Baidu en 2025 incluían una respuesta generada por IA. Baidu integra ya 文心X1 y la búsqueda profunda de DeepSeek directamente en la página de resultados. Estructuramos el contenido para que esos motores lo lean, lo entiendan y nombren su marca en la respuesta.",
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Autoridad en el ecosistema web chino',
    body: "Sus enlaces internacionales casi no pesan en Baidu. Las plataformas que de verdad mueven el posicionamiento son 百度百科, 百度知道, 百度贴吧, 知乎, 百家号, 百度爱采购, además de los portales B2B sectoriales y las señales de WeChat y Weibo. Construimos esa presencia y dirigimos la sindicación.",
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Optimización continua y respuesta a los algoritmos',
    body: "Baidu no anuncia la mayoría de sus actualizaciones, y las que publica salen en chino en el blog del 百度搜索资源平台. En los últimos doce meses hemos seguido los cambios del 知心算法, del 飓风算法 3.0 y la integración de 文心X1 y DeepSeek. Cada uno redefinió lo que gana posiciones.",
    tag: 'p.30',
  },
];

const tools = [
  {
    name: '百度搜索资源平台',
    en: 'Plataforma para webmasters de Baidu',
    cn: '资源',
    body: 'La consola oficial para webmasters: verificación del sitio, envío de URL, sitemaps, informes de indexación, prueba móvil, aviso de enlaces rotos y un canal de anuncios algorítmicos.',
    feature: true,
    items: ['Verificación del sitio', 'API de envío de URL', 'Sitemap', 'Informes de indexación', 'Prueba móvil', '死链提交', 'Canal de algoritmos'],
  },
  {
    name: '百度统计',
    en: 'Baidu Tongji',
    cn: '统计',
    body: 'El equivalente de Baidu a Google Analytics. Imprescindible para cualquier medición seria del lado chino.',
  },
  {
    name: '百度指数',
    en: 'Baidu Index y Keyword Planner',
    cn: '指数',
    body: 'El punto de partida de una investigación real de palabras clave en chino, en lugar de una lista en inglés traducida. Se usa junto con el 百度关键词规划师.',
  },
  {
    name: '5118 · 爱站 · 站长之家',
    en: 'Herramientas SEO chinas de terceros',
    cn: '工具',
    body: 'A menudo aportan una inteligencia competitiva y un historial de posiciones más profundos que las herramientas oficiales.',
  },
  {
    name: 'API para webmasters de Baidu',
    en: 'Integración de Active Push',
    cn: '接口',
    body: 'Para el 主动推送 conectamos directamente al CMS en lugar de pasar por los paneles de control.',
  },
];

const stages = [
  {
    n: '01',
    cn: '审计',
    title: 'Auditoría de Baidu',
    body: 'Pruebas desde China continental: indexación, salud del rastreo de Baiduspider, profundidad del contenido, señales de ICP y alojamiento, además de la posición actual sobre 50 a 100 palabras clave objetivo.',
    output: 'Informe de auditoría',
  },
  {
    n: '02',
    cn: '关键词',
    title: 'Mapa de palabras clave',
    body: 'Investigación en chino nativo con 百度指数 y 关键词规划师. Un mapa con etiquetas de intención, volúmenes y un brief de contenido por cada grupo.',
    output: 'Mapa + briefs',
  },
  {
    n: '03',
    cn: '部署',
    title: 'Despliegue técnico',
    body: 'Verificación del sitio, 主动推送 conectado al CMS, sitemaps, marcado Schema, optimizaciones de móvil y velocidad, llms.txt y estructura para la búsqueda con IA, todo entregado a la vez.',
    output: 'Indexación en marcha',
  },
  {
    n: '04',
    cn: '权威',
    title: 'Autoridad y contenido',
    body: 'Contenido chino nativo, más sindicación en 百家号, 知乎, 百度知道 y los portales sectoriales pertinentes. Las fichas de 百度百科 se añaden cuando la marca está lista.',
    output: 'Citas + progreso',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Seguimiento e iteración',
    body: "Seguimiento semanal de posiciones, informe mensual por escrito y reacción a las actualizaciones algorítmicas en la misma semana. Baidu cambia; el equipo que no lo sigue pierde posiciones sin entender por qué.",
    output: 'Informe mensual',
  },
];

const stats = [
  { value: '24-72h', label: 'Indexación vía 主动推送', sub: 'URL nuevas en Baidu en cuestión de horas, cuando el rastreo natural tarda semanas.' },
  { value: '11', label: 'Actualizaciones del algoritmo seguidas en 2025', sub: '知心算法, 飓风算法 3.0, integración de 文心X1.' },
  { value: '20%+', label: 'Páginas de Baidu con respuesta de IA', sub: '文心X1 y DeepSeek ya integrados en los resultados.' },
];

const audiences = [
  {
    label: 'Marcas extranjeras invisibles en Baidu',
    description: 'Empresas cuyo sitio chino genera menos de cincuenta visitas orgánicas al mes desde Baidu, mientras ya pagan anuncios sobre las mismas palabras clave.',
    image: '/images/audiences/no-organic-traffic-china.webp',
  },
  {
    label: 'Marcas con contenido traducido y antiguo',
    description: 'Sitios extranjeros cuyas páginas en chino se han quedado en simples traducciones y no han evolucionado desde el lanzamiento.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marcas que arrancan desde cero',
    description: 'Empresas que quieren visibilidad en Baidu desde el primer día, integrada en el diseño del sitio y en el calendario de publicación.',
    image: '/images/audiences/launching-chinese-market.webp',
  },
  {
    label: 'Marcas que se toman en serio la búsqueda con IA',
    description: 'Equipos que ven las respuestas de IA en la parte alta de los resultados de Baidu y quieren que esos motores nombren su marca en la respuesta.',
    image: '/images/audiences/seo-pro-needs-baidu.webp',
  },
];

const marqueePhrases = [
  '百度', 'Baidu',
  '主动推送', 'Active Push',
  '知心算法', '飓风算法 3.0',
  '文心X1', 'DeepSeek',
  '百家号', '知乎', '百度百科',
  'ICP registrado',
  'Alojamiento continental',
  'Preparado para la IA',
];

const faqs = [
  {
    id: 'outside-china',
    question: '¿Se puede dirigir el SEO de Baidu desde fuera de China?',
    answer: [
      "Técnicamente sí, pero con límites serios. La verificación de Baidu pide números de teléfono chinos, el panel está en chino, la documentación no se traduce y muchas herramientas de Baidu limitan o bloquean las direcciones IP extranjeras. La mayoría de los equipos extranjeros que lo intentan lo dejan en un trimestre. Lo dirigimos desde Shanghái porque ahí es donde el trabajo se hace de verdad.",
    ],
  },
  {
    id: 'how-long',
    question: '¿Cuánto tarda en verse resultados?',
    answer: [
      'Movimiento en la cola larga en 6 a 10 semanas. Los términos competitivos tardan al menos de 3 a 6 meses. El crecimiento orgánico real sigue una curva de 6 a 12 meses. La indexación de los contenidos nuevos mediante 主动推送 ocurre en 24 a 72 horas.',
    ],
  },
  {
    id: 'no-icp',
    question: '¿Y si nuestro sitio no tiene trámite ICP?',
    answer: [
      'Se posicionará, pero con una desventaja medible. Baidu trata los sitios de Hong Kong y offshore como extranjeros, los rastrea con menos frecuencia y los sitúa por debajo de los sitios continentales. Para una marca que se toma en serio Baidu, el ICP con alojamiento continental sigue siendo la decisión acertada.',
    ],
  },
  {
    id: 'baidu-ads',
    question: '¿También gestionan Baidu Ads (SEM)?',
    answer: [
      "No, nos centramos en el SEO orgánico de Baidu. La publicidad de pago es un oficio aparte que llevan otros equipos. Trabajamos junto a los socios de medios y nos aseguramos de que el contenido SEO y las páginas de aterrizaje de pago no compitan entre sí.",
    ],
  },
  {
    id: 'chinese-content',
    question: '¿Cómo se conecta esto con el trabajo de contenido chino?',
    answer: [
      'Muy de cerca. Hacer SEO de Baidu sin contenido chino nativo es cavar en el vacío. La mayoría de nuestros clientes contratan ambos en un solo encargo, con el equipo de contenido y el de SEO trabajando sobre el mismo mapa de palabras clave y la misma arquitectura editorial.',
    ],
  },
  {
    id: 'ai-search',
    question: '¿Y la visibilidad ante las IA en Doubao, Kimi, DeepSeek y 文心X1?',
    answer: [
      'Cada vez es el mismo trabajo. Baidu integra ya 文心X1 y DeepSeek en más del 20 % de sus páginas de resultados. Estructurar el contenido para las IA (respuestas factuales limpias, marcado Schema, llms.txt, estructura semántica) coincide en gran medida con la estructura que espera Baidu. Tratamos ambas cosas juntas.',
    ],
  },
  {
    id: 'links',
    question: '¿Hacen construcción de enlaces?',
    answer: [
      "Construimos autoridad en las plataformas chinas (百度百科, 百度知道, 知乎, 百家号, 百度爱采购, portales B2B sectoriales) donde la presencia mueve de verdad el posicionamiento en Baidu. Comprar enlaces genéricos a un intermediario occidental no funciona y expone a un riesgo con el 飓风算法. La autoridad en China se gana en las plataformas chinas, o no se gana.",
    ],
  },
  {
    id: 'measurement',
    question: '¿Cómo miden el éxito?',
    answer: [
      'Inclusión en el índice (número de páginas indexadas), posiciones de palabras clave (seguimiento semanal), tráfico orgánico de Baidu (vía 百度统计), atribución de conversiones y cuota de voz frente a tres a cinco competidores con nombre y apellidos. Lo presentamos en un resumen mensual por escrito, acompañado de un panel en directo.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: '¿Qué hacen cuando Baidu cambia su algoritmo?',
    answer: [
      "Seguimos cada semana los anuncios del 百度搜索资源平台 y reaccionamos en la misma semana cuando sale algo relevante. En los últimos doce meses: ampliaciones del 知心算法, el 飓风算法 3.0 contra el contenido de IA, la integración de 文心X1 en los resultados y varios ajustes menores.",
    ],
  },
  {
    id: 'cost',
    question: '¿Cuánto cuesta?',
    answer: [
      'Depende del alcance: tamaño del sitio, volumen de contenido, intensidad competitiva y si se incluye o no la producción de contenido chino y la optimización para IA. Descríbanos el alcance y le respondemos en dos días laborables con una cifra firme.',
    ],
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'es-ES',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer.join('\n\n') },
  })),
};

const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd, faqLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-search-results.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/services/" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">SEO en Baidu</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">SEO en Baidu</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Detrás del Great Firewall, en Shanghái</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Que le encuentren en
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">百度.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Donde empieza la búsqueda china.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Baidu juega con su propio rastreador, su propio índice, su propia API de envío, su propio ciclo algorítmico y, ahora, una capa de IA (文心X1, DeepSeek) que redacta más del veinte por ciento de los resultados. <span class="text-white font-medium">Lo dirigimos desde Shanghái, con las herramientas propias de Baidu.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">20</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Años en Baidu</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">200</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Relaciones 知心 seguidas</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">72h</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Indexación vía 主动推送</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/es/contact/" variant="primary" size="lg">Pedir una auditoría de Baidu</Button>
            <Button href="#what-we-do" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Ver los trabajos</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Sin registro</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">sitio fuera del continente</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Índice: 4 / 312 páginas
              </div>
            </div>

            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                </div>
                <span class="text-[10px] font-mono text-white/45 ml-2">百度搜索资源平台</span>
                <span class="ml-auto inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-green-500/15 border border-green-400/30">
                  <span class="w-1 h-1 rounded-full bg-green-400 animate-pulse"></span>
                  <span class="text-[9px] font-mono text-green-300 uppercase">En línea</span>
                </span>
              </div>

              <div class="space-y-4">
                <div>
                  <div class="flex items-center justify-between mb-1.5">
