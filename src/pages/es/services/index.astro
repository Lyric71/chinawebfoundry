---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';

// Definiciones de fase y datos de servicio extraídos de las páginas individuales
const phases = [
  {
    id: 'plan',
    label: 'Planificar',
    cn: '策略',
    title: 'Decidir qué construir antes de construir',
    blurb: 'Auditamos lo que ya existe. Trazamos lo que su público chino realmente necesita. El resultado es una hoja de ruta hacia una presencia sólida en China, en el orden correcto.',
  },
  {
    id: 'build',
    label: 'Construir',
    cn: '搭建',
    title: 'Rehacer la pila para el otro lado del Cortafuegos',
    blurb: 'Migración, diseño, integración técnica, extensiones a medida. Reconstruimos y probamos cada capa desde conexiones chinas reales.',
  },
  {
    id: 'host',
    label: 'Alojar',
    cn: '主机',
    title: 'Un alojamiento que aguanta en China continental',
    blurb: 'Carga por debajo del segundo en un teléfono de Shanghái. Trámite ICP gestionado de principio a fin. Continental, Hong Kong o doble pila.',
  },
  {
    id: 'grow',
    label: 'Crecer',
    cn: '增长',
    title: 'Visible en Baidu, citado por las IA chinas',
    blurb: 'Contenido chino nativo, SEO en Baidu dirigido desde China, visibilidad ante las IA en DeepSeek, Doubao, Kimi, Yuanbao y Baidu IA.',
  },
  {
    id: 'run',
    label: 'Mantener',
    cn: '维护',
    title: 'Alguien que vigila desde dentro, cada semana',
    blurb: 'Ritmo editorial, seguimiento de SEO y GEO, mantenimiento técnico, alojamiento. Un solo equipo, una sola factura, supervisado desde Shanghái.',
  },
];

// Servicio destacado: Estrategia y auditoría
const strategy = {
  title: 'Estrategia y auditoría',
  cn: '策略',
  tagline: 'Una hoja de ruta por escrito, que usted se lleva donde quiera.',
  description: "Abrimos su sitio desde navegadores reales en Pekín, Shanghái y Shenzhen, y observamos lo que ocurre de verdad. Posicionamiento de marca, visibilidad en buscadores, pila tecnológica, huella en WeChat, cumplimiento normativo: lo trazamos todo y después escribimos la hoja de ruta que lleva al lanzamiento, en el orden correcto.",
  link: '/es/services/strategy-audit/',
  cta: 'Empezar por la estrategia',
  deliverables: [
    'Diagnóstico de preparación para China sobre contenido, UX, búsqueda, rendimiento y cumplimiento normativo',
    'Posicionamiento estratégico calibrado a las señales de confianza chinas',
    'Arquitectura tecnológica: WordPress o Astro, Mini Program o H5, doble pila',
    'Hoja de ruta secuenciada, con el trámite ICP situado en la ruta crítica',
  ],
  stats: [
    { value: '15+', label: 'años en Shanghái' },
    { value: '50+', label: 'marcas lanzadas' },
    { value: '3-4 sem.', label: 'hasta la entrega' },
  ],
};

// Servicios de la fase Construir
const buildServices = [
  {
    title: 'Migración a China',
    cn: '迁移',
    tagline: 'Una migración a China de verdad es un relanzamiento completo.',
    description: "Relanzamos contenido, UX y alojamiento a la vez. Reescribimos las señales de confianza, repensamos la maquetación para los hábitos de lectura chinos, trasladamos la infraestructura a servidores continentales y tramitamos el ICP en paralelo.",
    link: '/es/services/china-migration/',
    cta: 'Hablar de su migración',
    icon: 'migration',
    deliverables: [
      'Contenido reescrito en chino por editores nativos',
      'UX repensada para páginas más densas y el navegador de WeChat',
      'Cambio sin cortes, con vuelta atrás posible en 48 h',
      'Mapeo de URL y redirecciones 301 para conservar la autoridad SEO',
    ],
    stats: [
      { value: '50+', label: 'marcas migradas' },
      { value: '6-10 sem.', label: 'ventana habitual' },
    ],
  },
  {
    title: 'Diseño UX y UI',
    cn: '设计',
    tagline: 'Diseñar para la forma en que los chinos navegan de verdad.',
    description: "Primero el móvil, maquetaciones densas, ajustadas a cómo navegan los internautas chinos después de WeChat, Taobao y Douyin. Los diseños muy aireados se leen como vacíos. Las señales de confianza se quedan por encima del pliegue.",
    link: '/es/services/ux-ui-design/',
    cta: 'Empezar un proyecto de diseño',
    icon: 'design',
    deliverables: [
      'Investigación de usuarios que traza los recorridos de Douyin, WeChat y Baidu',
      'Arquitectura de la información preparada para páginas más densas',
      'QR de WeChat, ICP y licencia de empresa por encima del pliegue',
      'QA en UC Browser, QQ Browser y Chrome',
    ],
    stats: [
      { value: '70%+', label: 'tráfico móvil en China' },
      { value: '6', label: 'navegadores probados de forma nativa' },
    ],
  },
  {
    title: 'Integración técnica',
    cn: '技术',
    tagline: 'Dos segundos en Occidente se vuelven quince en Shenzhen.',
    description: "Configuración del servidor, limpieza del tema, sustitución de dependencias bloqueadas, WeChat Pay, Alipay, Baidu Tongji. Reconstruimos toda la pila y la probamos desde redes chinas reales, en Shanghái y en Shenzhen.",
    link: '/es/services/technical-integration/',
    cta: 'Reservar una consulta técnica',
    icon: 'technical',
    deliverables: [
      'Optimización para Aliyun, Tencent o Huawei según el proveedor',
      'WeChat Pay, Alipay, inicio de sesión con WeChat y Baidu Tongji integrados',
      'Google Fonts sustituidas, jQuery redirigido, API bloqueadas reemplazadas',
      'Arquitectura conforme a la PIPL y a la Ley de Ciberseguridad desde el primer día',
    ],
    stats: [
      { value: '47', label: 'recursos bloqueados por sitio' },
      { value: '2,1 s', label: 'carga tras las correcciones' },
    ],
  },
  {
    title: 'Extensiones y plugins',
    cn: '插件',
    tagline: 'Extensiones de WordPress hechas a la medida del Cortafuegos.',
    description: "Cerca del 40 % de las extensiones populares de WordPress dependen de Google. Todas quedan bloqueadas detrás del Cortafuegos. Construimos las que funcionan y reparamos las que tienen arreglo.",
    link: '/es/services/plugins-extensions/',
    cta: 'Pedir una consulta',
    icon: 'plugins',
    deliverables: [
      'OAuth de WeChat, puentes hacia Mini Programs, enlaces a la cuenta oficial',
      'Alipay, WeChat Pay y UnionPay como extensiones de WooCommerce',
      'Sitemap para Baidu, API de envío y herramientas de etiquetas meta',
      'Bloques Gutenberg a medida: QR de WeChat, Mapas de Baidu, Bilibili',
    ],
    stats: [
      { value: '60 %', label: 'de extensiones reparables in situ' },
      { value: 'UC', label: 'Browser incluido en el QA' },
    ],
  },
];

// Fase Alojar: tarjeta destacada de alojamiento
const hosting = {
  title: 'Alojamiento en China',
  cn: '主机',
  tagline: 'Con licencia ICP, rápido, gestionado.',
  description: "Lo más probable es que su sitio no cargue en China. Diez o quince segundos es lo habitual para una web internacional. Tráfico ralentizado, CDN bloqueados, Google Fonts que no se resuelven. Lo corregimos en la capa de infraestructura.",
  link: '/es/services/china-hosting/',
  cta: 'Ver las opciones de alojamiento',
  options: [
    {
      name: 'Continental',
      timeframe: '6-10 semanas',
      bullets: ['Carga por debajo del segundo en los teléfonos chinos', 'Necesario para el efecto Baidu', 'Licencia ICP gestionada de principio a fin'],
    },
    {
      name: 'Hong Kong',
      timeframe: '2-3 semanas',
      bullets: ['De 2 a 4 segundos desde el continente', 'Sin ICP', 'Lanzamiento rápido, efecto Baidu débil'],
    },
    {
      name: 'Doble pila',
      timeframe: '8-12 semanas',
      bullets: ['Mundo y China en paralelo', 'Un único flujo editorial', 'Enrutamiento geográfico en el borde'],
    },
  ],
  stats: [
    { value: '0,8 s', label: 'carga mediana en el continente' },
    { value: '99,97 %', label: 'disponibilidad a 30 días' },
    { value: '100 %', label: 'tasa de éxito del ICP' },
  ],
};

// Servicios de la fase Crecer
const growServices = [
  {
    title: 'Contenido chino',
    cn: '内容',
    tagline: 'Editores que escriben en chino, con la voz de su marca.',
    description: "Redactores chinos nativos retoman sus mensajes en el orden en que el lector chino realmente decide: primero la prueba, luego la credibilidad, la aspiración al final.",
    link: '/es/services/chinese-content/',
    cta: 'Hablar con el equipo de contenido',
    icon: 'content',
    deliverables: [
      'Estrategia editorial construida sobre auditorías de Baidu, Zhihu y del sector',
      'Páginas de confianza que las webs occidentales olvidan: 荣誉资质, 企业历程, 生产基地',
      'Redacción nativa en chino con la voz de su marca',
      'Discurso conforme a la 广告法 para los sectores médico, financiero, alimentario y cosmético',
    ],
    stats: [
      { value: '9 s', label: 'antes del rebote en textos traducidos' },
      { value: '50+', label: 'marcas lanzadas' },
    ],
  },
  {
    title: 'SEO en Baidu',
    cn: '百度',
    tagline: 'Baidu juega con su rastreador, su API y su ciclo algorítmico.',
    description: "Otro rastreador, otra API de envío, otro algoritmo. Dirigimos el SEO en Baidu desde China, con las herramientas propias de Baidu, mediante especialistas que siguen el 百度搜索资源平台 cada semana.",
    link: '/es/services/baidu-seo/',
    cta: 'Pedir una auditoría de Baidu',
    icon: 'seo',
    deliverables: [
      'API 主动推送 conectada al CMS para el envío en tiempo real',
      'Investigación de palabras clave en chino nativo, desde Baidu Index',
      'Trabajo de autoridad en 百度百科, 百度知道 y 百家号',
      'Seguimiento semanal de las actualizaciones de 知心算法 y 飓风算法',
    ],
    stats: [
      { value: '24-72 h', label: 'indexación vía 主动推送' },
      { value: '6-10 sem.', label: 'movimiento en cola larga' },
    ],
  },
  {
    title: 'GEO China',
    cn: '智搜',
    tagline: 'Convertirse en la respuesta que citan las IA chinas.',
    description: "Optimización para los motores generativos en DeepSeek, Doubao, Kimi, Yuanbao y Baidu IA. Cinco motores, cinco juegos de reglas, un sitio que debe aguantar ante los cinco.",
    link: '/es/services/geo/',
    cta: 'Pedir una auditoría de IA',
    icon: 'ai',
    deliverables: [
      'Matriz de 80 a 150 preguntas en dispositivos reales, en tres ciudades',
      'Auditoría T1 / T2 / T3 sobre los niveles de prueba frente a las IA',
      'Contenido pilar con preguntas frecuentes, comparativas y grupos de escenarios',
      'Sindicación en Baijiahao, Zhihu, Toutiao y Baidu Baike',
    ],
    stats: [
      { value: '600M+', label: 'usuarios de IA en China' },
      { value: '6 meses', label: 'hasta las primeras citas' },
    ],
  },
];

// Fase Mantener: tarjeta destacada de mantenimiento
const maintenance = {
  title: 'Mantenimiento y acompañamiento',
  cn: '维护',
  tagline: 'Un sitio chino en producción necesita un ojo sobre el terreno.',
  description: "Lanzar es fácil. Baidu degrada los sitios que dejan de publicar. DeepSeek y Doubao actualizan su lógica de ingesta cada pocas semanas. Una Google Font olvidada en el tema acaba bloqueada un martes cualquiera. Desde Londres o Chicago todo parece ir bien.",
  link: '/es/services/maintenance-support/',
  cta: 'Pedir una propuesta a medida',
  deliverables: [
    'De 2 a 4 piezas de contenido al mes, sindicadas en Baijiahao y Zhihu',
    'Informe mensual de posiciones en Baidu sobre las 30 a 50 palabras clave principales',
    'Seguimiento semanal de GEO en DeepSeek, Doubao, Kimi, Yuanbao y Baidu IA',
    'Actualizaciones del núcleo, las extensiones y el tema probadas primero en staging',
    'Detección de bloqueos del Cortafuegos: CDN, fuentes y API corregidos en unos 14 min',
    'Respuesta a intrusiones: aislar, limpiar, restaurar, reforzar, análisis posterior en 48 h',
  ],
  stats: [
    { value: '11', label: 'actualizaciones del algoritmo de Baidu en 2025' },
    { value: '14 min', label: 'de la detección a la corrección de media' },
    { value: '99,9 %', label: 'SLA de disponibilidad' },
  ],
};
---

<PageLayout
  title="Servicios web en China para marcas internacionales | ChinaWebFoundry"
  description="Todo lo que una marca internacional necesita para lanzar y mantener un sitio en China. De la estrategia al mantenimiento, en manos de un único equipo senior en Shanghái desde 2005."
  heroPage={true}
  lang="es"
>
  <!-- ============== HERO ============== -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <video
        class="absolute inset-0 w-full h-full object-cover"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        poster="/images/hero-services.webp"
        aria-hidden="true"
      >
        <source src="/images/Video/great-wall-services-bg.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/92 via-[#0f0f12]/75 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-28 lg:pb-32">
      <div class="io-grid items-end gap-y-10">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Nuestros servicios
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.06]">
            Una presencia en China,<br />diseñada de principio a fin.
          </h1>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9">
          <p class="text-lg text-white/65 leading-relaxed">
            Una sola agencia, con base en China, que cubre cada capa que su sitio necesita para lanzarse, rendir y seguir visible detrás del Gran Cortafuegos. Con la pila que usted utilice.
          </p>
          <div class="mt-7">
            <Button href="/es/contact/" variant="primary" size="md">Cuéntenos qué necesita</Button>
          </div>
        </div>
      </div>
    </div>

    <!-- Pastillas de navegación por fase -->
    <div class="relative border-t border-white/10 bg-[#0f0f12]/60 backdrop-blur-sm">
      <div class="mx-auto max-w-[1400px] section-padding py-5">
        <nav class="flex flex-wrap items-center gap-x-2 gap-y-2 justify-center lg:justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-white/40 mr-2 hidden lg:inline">
            Ir a una fase
          </span>
          <div class="flex flex-wrap gap-2">
            {phases.map((phase) => (
              <a
                href={`#${phase.id}`}
                class="group inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/15 text-white/80 hover:border-[var(--color-brand-orange)] hover:text-white hover:bg-[var(--color-brand-orange)]/10 transition-all duration-200 text-sm font-medium font-[var(--font-button)] no-underline"
              >
                <span class="text-[var(--color-brand-orange)] text-xs font-normal">{phase.cn}</span>
                <span>{phase.label}</span>
              </a>
            ))}
          </div>
        </nav>
      </div>
    </div>
  </section>

  <!-- ============== INTRO ============== -->
  <section class="py-20 md:py-24 lg:py-28">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid gap-y-8">
        <div class="col-span-12 lg:col-span-5">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Lo que hacemos
          </p>
          <h2 class="text-3xl lg:text-[40px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15]">
            La mayoría de los sitios extranjeros fallan en China.
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-6">
            Dependencias bloqueadas, páginas que nunca terminan de cargar, Baidu incapaz de indexar nada, asistentes de IA que citan a sus competidores en su lugar. Lo arreglamos todo desde dentro de China, desde hace 15 años, con 10 servicios que encajan entre sí.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Los hemos agrupado en 5 fases de trabajo con nosotros, para que encuentre lo que necesita sin leer 10 folletos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== FASE PLAN ============== -->
  <section id="plan" class="bg-[var(--color-surface-light)] py-20 md:py-24 lg:py-28 scroll-mt-20">
    <div class="mx-auto max-w-[1400px] section-padding">
      <!-- Encabezado de fase -->
      <div class="flex items-baseline gap-4 mb-12 lg:mb-14 pb-6 border-b border-[var(--color-surface-border)]">
        <span class="text-2xl lg:text-3xl font-light text-[var(--color-brand-orange)] font-[var(--font-heading)]">{phases[0].cn}</span>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Fase uno</p>
        <h2 class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
          {phases[0].label}
        </h2>
      </div>

      <!-- Tarjeta destacada Estrategia -->
      <a
        href={strategy.link}
        class="group block bg-white border border-[var(--color-surface-border)] rounded-3xl overflow-hidden no-underline transition-all duration-300 hover:shadow-[0_20px_50px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
      >
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-0">
          <!-- Izquierda: texto -->
          <div class="lg:col-span-7 p-8 md:p-10 lg:p-14">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-xl font-light text-[var(--color-brand-orange)]">{strategy.cn}</span>
              <span class="h-px w-12 bg-[var(--color-brand-orange)]"></span>
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">
                {strategy.tagline}
              </p>
            </div>
            <h3 class="text-3xl lg:text-[40px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-5">
              {strategy.title}
            </h3>
            <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
              {strategy.description}
            </p>

            <!-- Entregables -->
            <ul class="space-y-3 mb-8">
              {strategy.deliverables.map((item) => (
                <li class="flex gap-3 text-[15px] text-[var(--color-text-body)]">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <span class="inline-flex items-center gap-2 text-base font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] group-hover:gap-3 transition-all duration-200">
              {strategy.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>

          <!-- Derecha: panel de cifras -->
          <div class="lg:col-span-5 bg-[var(--color-surface-dark)] p-8 md:p-10 lg:p-14 flex flex-col justify-center">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-orange)] mb-8">
              En cifras
            </p>
            <div class="space-y-8">
              {strategy.stats.map((stat) => (
                <div class="border-b border-white/10 pb-6 last:border-0 last:pb-0">
                  <p class="text-4xl lg:text-5xl font-medium font-[var(--font-heading)] text-white mb-1">{stat.value}</p>
                  <p class="text-sm text-white/55">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============== FASE BUILD ============== -->
  <section id="build" class="py-20 md:py-24 lg:py-28 scroll-mt-20">
    <div class="mx-auto max-w-[1400px] section-padding">
      <!-- Encabezado de fase -->
      <div class="flex items-baseline gap-4 mb-12 lg:mb-14 pb-6 border-b border-[var(--color-surface-border)]">
        <span class="text-2xl lg:text-3xl font-light text-[var(--color-brand-orange)] font-[var(--font-heading)]">{phases[1].cn}</span>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Fase dos</p>
        <h2 class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
          {phases[1].label}
        </h2>
      </div>

      <!-- Cuadrícula 2x2 de los servicios Construir -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7">
        {buildServices.map((service) => (
          <a
            href={service.link}
            class="group flex flex-col bg-white border border-[var(--color-surface-border)] rounded-2xl p-7 lg:p-9 no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
          >
            <div class="flex items-start justify-between mb-6">
              <div class="w-12 h-12 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center group-hover:bg-[var(--color-brand-orange)]/20 transition-colors duration-300">
                {service.icon === 'migration' && (
                  <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                  </svg>
                )}
                {service.icon === 'design' && (
