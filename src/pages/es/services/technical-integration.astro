---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import CaseStudyCards from '../../../components/ui/CaseStudyCards.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-es', 'technical-integration'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

const serverItems = [
  {
    title: 'Optimización del proveedor cloud',
    body: 'Cada proveedor cloud chino tiene sus propias reglas del juego. Alibaba Cloud gestiona la configuración de las bases de datos de otra manera que Tencent Cloud, y Huawei Cloud tiene sus particularidades en los parámetros de PHP y el almacenamiento de archivos. Hemos trabajado con los tres y optimizamos WordPress para el que usted elija.',
  },
  {
    title: 'Certificados SSL',
    body: 'Algunas autoridades de certificación occidentales sencillamente no las reconocen los navegadores chinos. El usuario llega, recibe un aviso de seguridad en cuestión de un segundo y ya se ha marchado. Instalamos certificados emitidos por proveedores que sí gozan de reconocimiento en China.',
  },
  {
    title: 'Multisitio y multilingüe',
    body: '¿Necesita un sitio de China que funcione en paralelo a su sitio global? Desplegamos configuraciones multisitio y multilingües. El reto central: que los dos se mantengan sincronizados sin convertirse en un quebradero de cabeza dentro de tres meses.',
  },
];

const themeFixItems = [
  'Google Fonts sustituidas por tipografías autoalojadas',
  'jQuery y bibliotecas JavaScript trasladadas de los CDN occidentales a alternativas alojadas en China',
  'Reproductores de YouTube, botones de Facebook y widgets de Instagram retirados y sustituidos',
  'Imágenes rotas y hojas de estilo ausentes vueltas a poner en su sitio',
  'Llamadas a API externas redirigidas o reconstruidas para que sigan siendo accesibles desde China',
  'Todo el front-end probado desde China antes de la puesta en producción',
];

const customPlugins = [
  {
    title: 'Pasarelas de pago',
    body: 'WeChat Pay ofrece rutas de integración distintas para la web móvil, las aplicaciones y los Mini Programs. Una configuración mal hecha y la transacción falla sin el menor mensaje de error: el usuario sencillamente no ve que ocurra nada. Desarrollamos extensiones de Alipay, WeChat Pay y UnionPay que funcionan de verdad.',
  },
  {
    title: 'Inicio de sesión y compartir en WeChat',
    body: 'Botones de inicio de sesión con WeChat, compartir hacia las cuentas oficiales, generación de códigos QR. La capa social que los internautas chinos esperan de cualquier sitio profesional serio.',
  },
  {
    title: 'Baidu Tongji Analytics',
    body: 'Integración completa con la plataforma de analítica de Baidu. Un apunte útil: hace falta una licencia ICP verificada para que Baidu abra el conjunto de sus informes. Un detalle que las agencias no implantadas en China olvidan señalar con frecuencia.',
  },
  {
    title: 'Verificación por SMS',
    body: 'Validación por número de teléfono chino para el registro, los embudos de compra y los formularios. Pensado para funcionar con los operadores de SMS locales.',
  },
];

const performanceItems = [
  'Recursos servidos desde nodos locales mediante Alibaba CDN o Tencent CDN',
  'Capa de caché Redis o Varnish, ajustada para su entorno de alojamiento',
  'Imágenes comprimidas para las condiciones de red que viven realmente sus usuarios',
  'Consultas de base de datos depuradas para acelerar la respuesta del servidor',
  'Pruebas desde ubicaciones reales en China, no a través de una VPN',
];

const platformItems = [
  {
    title: 'Pagos',
    body: 'Alipay y WeChat Pay captan la práctica totalidad de las transacciones. La tarjeta bancaria apenas pesa en los hábitos de los consumidores chinos. Integramos las dos, más UnionPay. ¿No tiene una entidad jurídica en China? Configuramos los pagos transfronterizos para que cobre en renminbi y reciba los fondos en su divisa.',
  },
  {
    title: 'Ecosistema social',
    body: 'En China, WeChat lo es todo a la vez: un navegador, una cartera, una tienda de aplicaciones, una plataforma editorial. Conectamos su sitio WordPress a las cuentas oficiales, a los Mini Programs, a Weibo, Douyin y RED.',
  },
  {
    title: 'Medición de audiencia',
    body: 'Google Analytics no carga en China. En absoluto. Instalamos Baidu Tongji como herramienta principal y añadimos un seguimiento de WeChat para el tráfico social y los embudos de conversión, ajustado a cómo navegan de verdad los internautas chinos.',
  },
  {
    title: 'Herramientas corporativas',
    body: '¿Usa Salesforce, SAP, HubSpot u Odoo a escala mundial? Construimos los conectores de API y la sincronización de datos para mantener alineados sus catálogos de productos y sus fichas de clientes a ambos lados. Ya nadie tiene que copiar y pegar entre sistemas.',
  },
];

const processSteps = [
  {
    title: 'Auditoría técnica',
    body: 'Examinamos a fondo su instalación actual de WordPress y documentamos cada extensión, cada dependencia y cada servicio externo al que llama su sitio. El objetivo: detectar con precisión qué se rompe en China.',
  },
  {
    title: 'Implementación por capas',
    body: 'Configuración del servidor. Limpieza del tema. Sustitución o desarrollo a medida de las extensiones. Rendimiento. Integraciones con las plataformas. Una capa cada vez.',
  },
  {
    title: 'Pruebas desde China',
    body: 'Todo se prueba desde territorio chino antes de la puesta en línea. No a través de una VPN en California.',
  },
  {
    title: 'Traspaso',
    body: 'Usted recibe la documentación completa y su equipo toma el relevo. Todo queda documentado y construido según los estándares de WordPress, para que otro desarrollador pueda asumir el mantenimiento sin contratiempos.',
  },
];
const serviceLd = serviceSchema(Astro.url, Astro.site, service.data);
const pageLd = [...serviceLd];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="es" jsonLd={pageLd}>

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-technical-integration.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Ruta de navegación" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/es/" class="hover:text-white/70 transition-colors no-underline">Inicio</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/es/services/" class="hover:text-white/70 transition-colors no-underline">Servicios</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Integración técnica</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Integración técnica
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Toda su pila WordPress,
            <span class="block mt-2 text-[var(--color-brand-orange)]">rediseñada para China</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Infraestructura de servidor, correcciones de temas y extensiones, pagos chinos, plataformas sociales, conectores hacia sus herramientas corporativas. Todo rediseñado para un mercado donde las suposiciones habituales se derrumban una tras otra.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/es/contact/" variant="primary" size="lg">Reservar una consulta técnica</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">integration-check</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Google Fonts</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">Bloqueado</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">CDN occidental</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">Bloqueado</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Stripe / PayPal</span>
                  <span class="text-sm font-semibold text-yellow-400 font-mono">Inservible</span>
                </div>
                <div class="w-full h-px bg-white/10 my-1"></div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Alibaba Cloud</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Configurado</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">WeChat Pay</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Integrado</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Baidu Tongji</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Activo</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-8">
          Dos segundos en Europa, quince en Shenzhen
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
          Su sitio WordPress vuela en Nueva York. Vuela en Londres. Ábralo desde Shanghái y es otra historia. Los temas llaman a tipografías en los servidores de Google, que China bloquea. Las extensiones lanzan llamadas a API que mueren detrás del Gran Cortafuegos. Las bibliotecas JavaScript intentan cargarse desde CDN a los que el país no tiene acceso.
        </p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
          La mayoría de las empresas descubren el problema después del lanzamiento, y la conversación con el equipo se vuelve enseguida desagradable.
        </p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Migrar a un proveedor de alojamiento chino tampoco basta. Hay que reformar todo el sitio: la configuración del servidor, las dependencias del tema, el tratamiento de los pagos hasta el final del embudo de compra. Absolutamente todo.
        </p>
      </div>
    </div>
  </section>

  <!-- WordPress Core and Server Setup -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Núcleo de WordPress y configuración del servidor
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Los cimientos, primero
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {serverItems.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Theme and Plugin Overhaul -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Temas y extensiones, replanteados
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Aquí es donde la mayoría de los sitios descarrila
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Los temas y las extensiones dan por hecho que la internet abierta existe para todo el mundo. Google Fonts se carga de forma automática. jQuery se llama desde CDN occidentales. Reproductores de YouTube, botones de Facebook, widgets de Instagram: todo viene integrado por defecto. Nada de eso aguanta detrás del Gran Cortafuegos.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Lo revisamos todo con lupa. Cada llamada externa se identifica y luego se reemplaza por una alternativa alojada en China. Y cuando no existe ningún sustituto en condiciones, lo reconstruimos. El resultado: un front-end que carga de verdad para los internautas sobre el terreno.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="bg-white rounded-2xl p-8 border border-[var(--color-surface-border)]">
            <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
              Lo que sustituimos
            </p>
            <div class="space-y-4">
              {themeFixItems.map((item) => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Plugins -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Extensiones a medida
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Las extensiones estándar de WordPress ignoran China
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            {customPlugins.map((item) => (
              <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
                <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
                <p class="text-base text-white/70 leading-relaxed">
                  {item.body}
                </p>
              </div>
            ))}
          </div>
          <p class="mt-8 text-base text-white/50 leading-relaxed">
            Todo queda documentado y construido según los estándares de WordPress, para que otro desarrollador pueda tomar el relevo si hace falta.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Performance -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Rendimiento
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Fuera de las grandes ciudades, el ancho de banda se hunde rápido
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Pekín dispone de un buen ancho de banda. Shanghái también. Salga de las grandes metrópolis y la calidad cae a ojos vistas. Las transferencias de datos transfronterizas están bridadas a propósito: todo lo que su sitio va a buscar al extranjero lo sufre.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Probamos desde ubicaciones reales en China. No a través de una VPN en California. Una prueba con VPN le dice que todo va bien, mientras sus usuarios en Chengdu o Kunming miran fijamente un indicador de carga preguntándose si el sitio está caído.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="bg-white rounded-2xl p-8 border border-[var(--color-surface-border)]">
            <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
              Cómo optimizamos
            </p>
            <div class="space-y-4">
              {performanceItems.map((item) => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Connecting to Chinese Platforms -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Conexiones con las plataformas chinas
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Conecte su sitio al ecosistema que de verdad importa
        </h2>
      </div>

      <CaseStudyCards items={platformItems} />
    </div>
  </section>

  <!-- Data Compliance -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Cumplimiento de datos
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Corregir después del lanzamiento sale siempre más caro de lo previsto
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            La Ley de Protección de la Información Personal (PIPL) y la Ley china de Ciberseguridad tienen consecuencias muy concretas sobre la gestión de los datos de los usuarios: dónde residen, si cruzan una frontera. Inscribimos el cumplimiento en la arquitectura técnica desde el principio, porque dar marcha atrás después del lanzamiento sale siempre más caro de lo presupuestado. Siempre.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="bg-[var(--color-surface-light)] rounded-xl p-6 border-l-4 border-[var(--color-brand-orange)]">
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed italic">
              Localización de los datos, reglas de transferencia transfronteriza, mecanismos de consentimiento, requisitos de almacenamiento: nos hacemos cargo de la implementación técnica para que su departamento jurídico pueda concentrarse en la parte normativa.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How Projects Work -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Desarrollo de los proyectos
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Capa por capa, y probado desde China
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            {processSteps.map((item) => (
              <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
                <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
                <p class="text-base text-white/70 leading-relaxed">
                  {item.body}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Dé el paso
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Todo proyecto arranca con un diagnóstico
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Cuéntenos sus ambiciones en China y estableceremos qué necesita su sitio WordPress para alcanzarlas. Sin propuestas de talla única.
      </p>
