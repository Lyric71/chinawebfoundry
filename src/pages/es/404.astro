---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
---

<PageLayout
  title="Página no encontrada | ChinaWebFoundry"
  description="La página que busca ya no existe o ha cambiado de dirección. Vuelva al inicio o explore nuestros proyectos y servicios para las marcas internacionales en China."
  lang="es"
>
  <section class="section-spacing">
    <Container class="text-center">
      <h1 class="text-6xl font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)] mb-4">404</h1>
      <p class="text-xl text-[var(--color-text-dark)] font-[var(--font-heading)] mb-2">Página no encontrada</p>
      <p class="text-[var(--color-text-body)] mb-8">Esta dirección ya no existe o ha cambiado de sitio.</p>
      <Button href="/es/" variant="primary" size="lg">Volver al inicio</Button>
    </Container>
  </section>
</PageLayout>
