---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQItem from '../components/pages/FAQItem.astro';
import ScrollEffects from '../components/global/ScrollEffects.astro';

const metaTitle = 'WordPress for China | What Works, What Changes | ChinaWebFoundry';
const metaDescription = 'WordPress works in China when it’s built for it. The use cases that fit, the changes required behind the Firewall, and the alternatives that don’t.';

const stats = [
  { value: 43, suffix: '%', label: 'of all websites run on WordPress', source: 'W3Techs, 2024' },
  { value: 20, suffix: '+', label: 'years of WordPress work in China', source: 'Shanghai-based since 2005' },
  { value: 50, suffix: '+', label: 'international sites launched behind the Firewall', source: 'Across industries' },
];

const useCases = [
  {
    icon: 'cart',
    title: 'E-commerce with WooCommerce',
    body: 'For brands selling in China outside Tmall or JD, WooCommerce is the closest thing the open web has to serious e-commerce. Add Alipay, WeChat Pay, and UnionPay and it covers most of what is needed.',
    span: 'feature',
    badges: ['WooCommerce', 'Alipay', 'WeChat Pay', 'UnionPay'],
  },
  {
    icon: 'pen',
    title: 'Content-heavy sites',
    body: 'Hundreds of pages, regular publishing, multiple authors. WordPress was built for this. Editors who already know it don’t need to learn anything new.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Multilingual sites',
    body: 'Chinese alongside English, French, German, or Japanese. WordPress with WPML or Polylang handles three or more languages cleanly, with separate sitemaps for Baidu and Google.',
    span: 'normal',
  },
  {
    icon: 'users',
    title: 'Updated by non-developers',
    body: 'Marketing teams, content managers, regional offices update the site without a deployment pipeline. For independent China teams, that flexibility matters more than raw page speed.',
    span: 'normal',
  },
  {
    icon: 'sliders',
    title: 'Sites with custom workflows',
    body: 'Membership areas, conditional lead capture, gated content, sales enablement. The plugin ecosystem covers most of it out of the box.',
    span: 'normal',
  },
  {
    icon: 'layers',
    title: 'Builder-driven sites',
    body: 'Most sites we inherit are built in Elementor, Divi, or Gutenberg. All three work once the dependencies are cleaned up. Gutenberg is the lightest and easiest to keep fast on a Chinese server.',
    span: 'wide',
    badges: ['Elementor', 'Divi', 'Gutenberg'],
  },
];

const pickAstro = [
  'The site is mostly marketing pages, updated monthly or less',
  'Page speed is a hard requirement (paid media landing pages, ad campaigns)',
  'You want a smaller attack surface and less maintenance overhead',
  'Content updates can run through a developer or through us',
  'You don’t need a CMS interface for non-technical editors',
];

const pickWordPress = [
  'Editorial workflow is a daily activity, not an occasional task',
  'You need three or more languages',
  'You run e-commerce or membership',
  'Your team already knows WordPress and you don’t want to retrain them',
  'You need plugins for forms, SEO, marketing automation, or compliance',
];

const changeGroups = [
  {
    label: 'Frontend',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Fonts',
        body: 'Google Fonts don’t load. We self-host, or swap in Chinese-compatible alternatives that ship Latin and CJK glyphs in one file.',
      },
      {
        icon: 'palette',
        title: 'Theme stack',
        body: 'Most ThemeForest themes call external CDNs, embed Google Maps, or load remote scripts that fail behind the Firewall. We audit, swap, and replace.',
      },
      {
        icon: 'blocks',
        title: 'Builders',
        body: 'Each needs targeted cleanup. We strip Google Fonts loaders, replace external icon libraries with local ones, and disable anything that pings a blocked service.',
      },
    ],
  },
  {
    label: 'Integrations',
    accent: 'orange',
    items: [
      {
        icon: 'play',
        title: 'Embeds',
        body: 'YouTube becomes Youku or Bilibili. Vimeo becomes Tencent Video. Facebook pixels become WeChat or Weibo. Google Maps becomes Baidu Map or Amap.',
      },
      {
        icon: 'card',
        title: 'Payments',
        body: 'WooCommerce alone won’t take a Chinese consumer’s money. We add Alipay, WeChat Pay, and UnionPay, and configure checkout the way Chinese users actually pay.',
      },
      {
        icon: 'plug',
        title: 'Plugins',
        body: 'Yoast SEO needs Baidu sitemap support added. Google Analytics gets replaced with Baidu Tongji. reCAPTCHA needs a Chinese alternative. We keep a running list.',
      },
    ],
  },
  {
    label: 'Hosting & Infrastructure',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hosting',
        body: 'Mainland Chinese server, valid ICP filing on the domain. Aliyun, Tencent Cloud, or Huawei Cloud, depending on the project.',
      },
      {
        icon: 'refresh',
        title: 'Auto-updates',
        body: 'Core and plugins phone home to wordpress.org and frequently time out from inside China. We route updates through a proxy or schedule manual update windows.',
      },
      {
        icon: 'shield',
        title: 'Security',
        body: 'Standard hardening: disable admin file editing, lock down xmlrpc, enforce 2FA, run a WAF on the Chinese cloud provider. Update discipline is stricter here.',
      },
    ],
  },
  {
    label: 'Performance & SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'CDN configured for mainland delivery. Caching layered. Database tuned for Chinese cloud servers. Target: under three seconds first meaningful paint on a mid-range Chinese phone.',
      },
      {
        icon: 'search',
        title: 'SEO and AI search',
        body: 'Critical content lives in HTML. Baidu Webmaster Tools wired in. Site structured so Doubao, Kimi, DeepSeek and Wenxin can read and cite it.',
      },
    ],
  },
];

const pluginBuckets = [
  {
    eyebrow: 'First choice',
    title: 'Find a replacement',
    body: 'What we do most of the time. Google Analytics becomes Baidu Tongji. reCAPTCHA becomes a local captcha. Google Maps becomes Amap. Editors don’t notice.',
  },
  {
    eyebrow: 'When it fits',
    title: 'Remove it',
    body: 'If the plugin doesn’t apply to a Chinese audience, we remove it. Fewer plugins, faster site, smaller attack surface.',
  },
  {
    eyebrow: 'Last resort',
    title: 'Modify the plugin code',
    body: 'Critical plugin, no replacement: we modify the code. Reroute the API call through a proxy, or swap a hardcoded CDN URL. Only when the licence allows.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hosting' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hosting' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hosting' },
  { name: 'Baidu', cn: '百度', role: 'Search & SEO' },
  { name: 'WeChat', cn: '微信', role: 'Auth & messaging' },
  { name: 'Alipay', cn: '支付宝', role: 'Payments' },
];

const elementorItems = [
  {
    label: 'Fonts',
    body: 'Elementor pulls Google Fonts by default, which don’t resolve in China. We self-host them or swap in Chinese-compatible alternatives.',
  },
  {
    label: 'Widgets and components',
    body: 'Some widgets call blocked services (Google Maps, YouTube, Facebook, reCAPTCHA). We replace them with Chinese equivalents or custom ones.',
  },
  {
    label: 'Icon libraries and CDNs',
    body: 'External assets get rerouted to load locally from the Chinese server.',
  },
  {
    label: 'Templates',
    body: 'Most Elementor templates ship with assumptions that don’t hold in China. We audit and clean each one.',
  },
];

const faqs = [
  {
    id: 'wp-icp',
    question: 'Does our WordPress site need an ICP licence to work in China?',
    answer: 'If it’s hosted in mainland China, yes. If you host in Hong Kong, no, but the site will be measurably slower and Baidu will treat it as foreign. For most foreign brands serious about the Chinese market, the ICP filing is worth doing.',
  },
  {
    id: 'wp-marketing-team',
    question: 'Will our marketing team still be able to update the WordPress site?',
    answer: 'Yes. WordPress stays WordPress. The admin interface is the same, the content workflow is the same, and the editorial roles work the way they always have. The changes we make under the hood are mostly invisible to the editorial team.',
  },
  {
    id: 'wp-vs-astro-speed',
    question: 'Is WordPress slower than Astro in China?',
    answer: 'In raw load time, yes, all things equal. WordPress is dynamic, Astro is static. In practice though, a well-tuned WordPress site on Aliyun with the right caching layer hits page speed targets that satisfy both Chinese users and Baidu. The difference matters more for some projects than others.',
  },
  {
    id: 'wp-elementor-divi',
    question: 'Will our existing Elementor or Divi site work in China?',
    answer: 'Probably not, in its current state. But it can usually be made to work. We strip out the Google dependencies, swap the fonts, and reroute the integrations. Most Elementor and Divi sites we inherit are running cleanly inside the Firewall within a few weeks of getting started.',
  },
  {
    id: 'wp-auto-updates',
    question: 'What about plugin auto-updates from wordpress.org?',
    answer: 'They often fail or time out from inside China because the wordpress.org repository is slow or unreachable on Chinese networks. We configure update routing through a proxy or run scheduled manual update windows. Either way, your team shouldn’t have to think about it day to day.',
  },
  {
    id: 'wp-multilingual',
    question: 'Can we keep WPML or Polylang for our multilingual setup?',
    answer: 'Yes, both work well in China once the rest of the site is cleaned up. WPML is the more common choice for sites with three or more languages and complex translation workflows. Polylang is lighter and works fine for two or three languages. We have used both extensively. The choice depends more on your editorial process than on China-specific concerns.',
  },
  {
    id: 'wp-woocommerce-china',
    question: 'Will WooCommerce work for selling to Chinese consumers?',
    answer: 'WooCommerce itself works fine. The work is in the checkout layer. Chinese consumers expect to pay through Alipay, WeChat Pay, or UnionPay, almost always on mobile, almost always via QR code. We add those payment gateways through dedicated plugins, and we redesign the checkout flow for the way Chinese users actually buy. Out of the box WooCommerce assumes credit cards and PayPal, which don’t apply here.',
  },
  {
    id: 'wp-single-vs-dual',
    question: 'Can we run one WordPress site for both China and the rest of the world?',
    answer: 'Technically yes, with WordPress Multisite or a multilingual setup. In practice we usually recommend two separate WordPress installs, one outside China and one on a mainland Chinese server. The reason is performance: a single global install means Chinese users are pulling from servers outside the Firewall, which defeats the point. Two installs share editorial workflows where it makes sense and stay independent where they need to.',
  },
  {
    id: 'wp-security-china',
    question: 'How do we keep our WordPress site secure in China?',
    answer: 'Standard WordPress hardening still applies. We disable file editing in the admin, lock down xmlrpc, enforce two-factor authentication, and run a Web Application Firewall configured for the Chinese cloud provider. The extra discipline in China is around plugin updates: when auto-updates fail, the site can sit on an outdated plugin version longer than a Western team is used to. We monitor and patch on a fixed schedule.',
  },
  {
    id: 'wp-hosting-provider',
    question: 'Which WordPress hosting provider is best for China?',
    answer: 'We use Aliyun, Tencent Cloud, and Huawei Cloud depending on the project. All three are mainland-licensed, all three perform well, and all three support the WordPress stack properly. Aliyun is usually the default for marketing sites, Tencent Cloud is strong for sites that integrate with WeChat, and Huawei Cloud comes up more often for clients who already use Huawei infrastructure elsewhere. We handle the hosting account, the ICP filing, and the day-to-day server work, so you never have to log into a Chinese hosting panel yourself.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-wordpress-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Breadcrumb" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">WordPress</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Technology
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            WordPress in China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Yes, it works.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Most clients arrive on WordPress already. The real question is whether it can work in China, and what has to change to make that true.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            Twenty years on the ground. Fifty-plus international sites launched.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Talk to our team</Button>
            <Button href="/astro/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Astro for China</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">wp-china-config</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Self-hosted fonts</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">on</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Blocked dependencies</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">0</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">CDN</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aliyun</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP filing</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Filed</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with workspace image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Why It Works
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            The platform isn’t the problem.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            WordPress runs in China. Core, wordpress.org, the standard publishing workflow: it all works the same on a Shanghai server as on a London one, and wp-admin is reachable without a VPN.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            The problem is what it depends on by default. Themes load Google Fonts. Plugins call APIs outside the Firewall. Libraries pull from blocked CDNs. Embeds point at YouTube. Analytics call Google.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Strip those out, swap in local equivalents, and what’s left is a fast, compliant WordPress site, indexed by Baidu and manageable by a team that already knows it.
          </p>
        </div>

        <!-- WordPress admin screenshot -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-12 lg:mt-0">
          <figure class="relative">
            <div class="relative aspect-square rounded-2xl overflow-hidden bg-[var(--color-surface-light)] border border-[var(--color-surface-border)]">
              <img
                src="/images/wordpress-admin-dashboard.webp"
                alt="The WordPress wp-admin dashboard interface, showing the sidebar, welcome panel and dashboard widgets"
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-2xl"></div>
            </div>
            <!-- Floating caption card -->
            <div class="absolute bottom-3 left-3 sm:-bottom-6 sm:-left-6 lg:-left-10 bg-white border border-[var(--color-surface-border)] rounded-xl shadow-[0_20px_60px_-20px_rgba(0,0,0,0.25)] p-4 sm:p-5 max-w-[220px] sm:max-w-[260px]">
              <p class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)] font-semibold mb-2">
                Same wp-admin →
              </p>
              <p class="text-sm text-[var(--color-text-body)] leading-snug">
                A WordPress site administered from inside China runs the same wp-admin you already know, on infrastructure tuned for the local network.
              </p>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- What WordPress is For: icon cards -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            What It Is For
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            What WordPress is best at, in China.
          </h2>
        </div>
        <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed lg:max-w-md">
          Not the right answer for every project. For a specific set of use cases, still the best tool we have.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-5 auto-rows-fr">
        {useCases.map((item) => {
          const spanClass =
            item.span === 'feature'
              ? 'lg:col-span-7'
              : item.span === 'wide'
                ? 'lg:col-span-12'
                : 'lg:col-span-4';
          const isFeature = item.span === 'feature';
          const isWide = item.span === 'wide';
          return (
            <article class:list={[
              'group relative rounded-2xl border overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_-30px_rgba(0,0,0,0.25)]',
              spanClass,
              isFeature
                ? 'bg-gradient-to-br from-[var(--color-surface-dark)] to-[#1a1a20] border-white/10 text-white p-8 lg:p-10'
                : 'bg-white border-[var(--color-surface-border)] hover:border-[var(--color-brand-orange)]/30 p-7',
            ]}>
              <!-- Hover glow -->
              <div class="absolute -top-16 -right-16 w-48 h-48 rounded-full bg-[var(--color-brand-orange)]/10 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

              <div class="relative h-full flex flex-col">
                <div class:list={[
                  'w-11 h-11 rounded-xl flex items-center justify-center mb-5',
                  isFeature ? 'bg-[var(--color-brand-orange)]/15' : 'bg-[var(--color-brand-orange)]/10',
                ]}>
                  {item.icon === 'pen' && (
                    <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5Z"/></svg>
                  )}
                  {item.icon === 'languages' && (
                    <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>
                  )}
                  {item.icon === 'cart' && (
                    <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                  )}
                  {item.icon === 'users' && (
