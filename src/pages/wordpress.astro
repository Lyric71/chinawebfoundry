---
import PageLayout from '../layouts/PageLayout.astro';

const metaTitle = 'WordPress';
const metaDescription = 'WordPress';
---

<PageLayout title={metaTitle} description={metaDescription}>
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <h1 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
        WordPress
      </h1>
    </div>
  </section>
</PageLayout>
