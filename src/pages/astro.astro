---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQItem from '../components/pages/FAQItem.astro';
import ScrollEffects from '../components/global/ScrollEffects.astro';

const metaTitle = 'Astro in China | Fast, Static Sites for the Mainland | ChinaWebFoundry';
const metaDescription = 'Astro is the fastest way to ship a marketing site in China. What it is, when it fits, and the changes that make it work behind the Firewall.';

const stats = [
  { value: 100, suffix: '', label: 'Lighthouse score on a typical Astro site, no manual tuning', source: 'Sitepins, Astro in 2026' },
  { value: 60, suffix: '%', label: 'of Astro sites pass Core Web Vitals “Good” thresholds', source: 'Versus 38% on WordPress' },
  { value: 50, suffix: '%', label: 'faster LCP versus a comparable WordPress site, same Chinese host', source: 'ChinaWebFoundry measurements' },
];

const useCases = [
  {
    icon: 'rocket',
    title: 'Marketing sites and brand websites',
    body: 'Brand sites, product pages, landing pages, campaign microsites. Page speed has to be excellent and content is updated weekly or less. This is what Astro was designed for, and where the performance advantage shows up most clearly.',
    span: 'feature',
    badges: ['Brand sites', 'Landing pages', 'Microsites'],
  },
  {
    icon: 'book',
    title: 'Documentation and resource libraries',
    body: 'Starlight, Astro’s own docs framework, is the strongest in the ecosystem. For technical docs, knowledge bases and resource centres in China, it keeps content fast to load and navigation clean to follow.',
    span: 'normal',
  },
  {
    icon: 'pen',
    title: 'Editorial sites and blogs',
    body: 'Content Collections give you type-safe Markdown and MDX with build-time validation. The workflow is faster than anything we have used on WordPress, and the output is dramatically lighter on Chinese mobile networks.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Multilingual marketing sites',
    body: 'Astro has built-in i18n routing. Running Chinese alongside English, French, German or Japanese is straightforward. We have shipped Astro sites with ten or more languages without trouble.',
    span: 'normal',
  },
  {
    icon: 'zap',
    title: 'Sites where Core Web Vitals are the budget',
    body: 'When paid media depends on landing page speed, or your SEO depends on Baidu indexing your content cleanly, Astro is the framework that gets you there with the least fight. Sub-second loads on a mid-range Chinese phone.',
    span: 'normal',
  },
  {
    icon: 'shield',
    title: 'High-security sites',
    body: 'Static HTML has no database to attack, no PHP to exploit, no admin login to brute-force. For brands that have been hacked before, or that operate in regulated industries where security is a board-level concern, the reduced attack surface is a real argument.',
    span: 'wide',
    badges: ['No database', 'No PHP runtime', 'No admin login', 'Static delivery'],
  },
];

const pickAstro = [
  'The site is mostly content and marketing',
  'Page speed is a hard, measurable requirement',
  'The team is comfortable with developer-led workflows, or you connect a headless CMS',
  'You want lower long-term maintenance and hosting costs',
  'Security and a small attack surface matter more than editorial flexibility',
];

const pickWordPress = [
  'Your content team needs to publish daily without calling a developer',
  'You run e-commerce with hundreds or thousands of products through WooCommerce',
  'You depend on specific WordPress plugins (membership, LMS, marketing automation)',
  'The marketing team uses Elementor or Divi and isn’t going to switch',
  'The project is deeply interactive (logged-in dashboards, real-time features)',
];

const changeGroups = [
  {
    label: 'Frontend',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Fonts',
        body: 'Astro starters often pull from Google Fonts. We disable the loader and self-host the fonts directly, or swap in Chinese-compatible alternatives that ship Latin and CJK glyphs in one file.',
      },
      {
        icon: 'palette',
        title: 'External assets and images',
        body: 'Some Astro themes reference Western CDNs (jsdelivr, unpkg) for icons or libraries. We reroute everything through a Chinese CDN or bundle assets into the build. Images get served from Aliyun OSS or Tencent COS in modern formats.',
      },
      {
        icon: 'blocks',
        title: 'Third-party scripts',
        body: 'Anything that pings a blocked service is removed or replaced. Maps, fonts, analytics, captchas and embeds each get a Chinese-compatible swap during the build, before the static output ever ships.',
      },
    ],
  },
  {
    label: 'Integrations & CMS',
    accent: 'orange',
    items: [
      {
        icon: 'plug',
        title: 'Headless CMS, where needed',
        body: 'When the editorial team needs a visual interface, we wire up Storyblok, Sanity, Decap or headless WordPress. The CMS lives outside China, content syncs at build time, and the static site lives on a mainland server.',
      },
      {
        icon: 'card',
        title: 'Forms and widgets',
        body: 'Forms run as Astro Islands. Google reCAPTCHA becomes a Chinese captcha. Google Maps becomes Baidu Map or Amap. The interactive bits keep working without external dependencies.',
      },
      {
        icon: 'chart',
        title: 'Analytics',
        body: 'Vercel Analytics or Plausible gets replaced with Baidu Tongji or a self-hosted tool. Same dashboards your team needs, none of the blocked endpoints.',
      },
    ],
  },
  {
    label: 'Hosting & Build',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hosting',
        body: 'Mainland Chinese server, valid ICP filing on the domain. Aliyun, Tencent Cloud or Huawei Cloud, fronted by a Chinese CDN. Cloudflare’s own CDN doesn’t perform well on the mainland, so we don’t deploy there.',
      },
      {
        icon: 'refresh',
        title: 'Build pipeline',
        body: 'The build runs outside China on a CI pipeline (GitHub Actions, GitLab CI). Static output gets pushed to the Chinese host. Push to main and the site updates within a few minutes.',
      },
      {
        icon: 'shield',
        title: 'Security posture',
        body: 'No database, no PHP runtime, no admin login. Security work shifts to the build pipeline and the Chinese cloud edge instead of a runtime that has to be patched every week.',
      },
    ],
  },
  {
    label: 'Performance & SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'Static HTML on a mainland CDN is hard to beat. We target sub-second first meaningful paint on a mid-range Chinese phone, and we usually hit it.',
      },
      {
        icon: 'search',
        title: 'Baidu and AI search',
        body: 'Baidu has different crawling rules to Google, so we configure proper metadata, set up Baidu Webmaster Tools, and structure the site so Doubao, Kimi, DeepSeek and Wenxin can read and cite it. Plain files in Git make structured data and llms.txt easy to generate.',
      },
    ],
  },
];

const fitBuckets = [
  {
    eyebrow: 'Astro fits',
    title: 'Marketing sites with light interactivity',
    body: 'A marketing site with a small product showcase, a contact form or a few interactive widgets is exactly what Astro was designed for. Static pages, fast loads, JavaScript only where it has to be.',
  },
  {
    eyebrow: 'WordPress fits better',
    title: 'E-commerce and daily editorial',
    body: 'Thousands of products with a non-technical team managing inventory daily, deep plugin dependencies, builder-led marketing teams. WooCommerce on WordPress is still usually the right call.',
  },
  {
    eyebrow: 'Different tool entirely',
    title: 'App-like experiences',
    body: 'Logged-in dashboards, real-time collaboration, social areas, anything closer to an application than a website. Past that point, Next.js or Remix is a better fit than Astro.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hosting' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hosting' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hosting' },
  { name: 'Baidu', cn: '百度', role: 'Search & SEO' },
  { name: 'WeChat', cn: '微信', role: 'Auth & messaging' },
  { name: 'Alipay', cn: '支付宝', role: 'Payments' },
];

const faqs = [
  {
    id: 'astro-icp',
    question: 'Does our Astro site need an ICP licence to work in China?',
    answer: 'If it’s hosted in mainland China, yes. If you host in Hong Kong or on Cloudflare, no, but the site will be measurably slower for mainland users and Baidu will treat it as foreign. For brands serious about the Chinese market, the ICP filing is worth doing.',
  },
  {
    id: 'astro-marketing-team',
    question: 'Will our marketing team still be able to update the site?',
    answer: 'Depends on how we set it up. With Markdown and Content Collections, content edits go through Git and need a developer or a comfortable technical user. With a headless CMS connected (Storyblok, Sanity, Decap), the editorial team gets a visual interface and updates the site without touching code. We pick the right model based on how the team actually works.',
  },
  {
    id: 'astro-vs-wp-speed',
    question: 'Is Astro really faster than WordPress in China?',
    answer: 'In raw numbers, yes. Astro ships static HTML with near-zero JavaScript, which means lower data transfer, faster parsing and fewer round-trips to a server. We have measured 40 to 60 percent faster Largest Contentful Paint on Astro versus a comparable WordPress site, on the same Chinese host.',
  },
  {
    id: 'astro-headless-cms',
    question: 'Can we use a headless CMS with Astro?',
    answer: 'Yes, this is one of Astro’s strongest patterns. We have shipped sites using Storyblok, Sanity, Decap and headless WordPress. The CMS lives outside China where editors can work freely without VPN issues, the static frontend lives on a mainland server, content syncs at build time. The editorial team keeps the interface they know and the Chinese audience gets a fast site.',
  },
  {
    id: 'astro-ecommerce',
    question: 'What about e-commerce on Astro?',
    answer: 'For small to medium catalogues (under five hundred products) Astro pairs well with headless commerce: Shopify Storefront, Snipcart, or Stripe checkout for international payments, plus custom integrations for Alipay and WeChat Pay for Chinese consumers. For large e-commerce with thousands of products and a non-technical team managing daily inventory, WooCommerce on WordPress is still usually the right call.',
  },
  {
    id: 'astro-multilingual',
    question: 'How does Astro handle multilingual content for China?',
    answer: 'Astro has built-in i18n routing, which makes Chinese alongside English, French or any other language clean and structured. URLs, hreflang tags and language-specific sitemaps all work out of the box. We have shipped Astro sites with ten or more languages.',
  },
  {
    id: 'astro-migrate-wp',
    question: 'Can we migrate our existing WordPress site to Astro?',
    answer: 'Yes, and we do this regularly. Content gets exported from WordPress, restructured into Astro Content Collections or routed through a headless CMS, and the design is rebuilt for the new stack. Typical timeline is four to eight weeks. The result is a faster site with lower running costs, but you do lose the WordPress admin interface unless we keep it as a headless backend.',
  },
  {
    id: 'astro-hosting',
    question: 'What hosting do you use for Astro in China?',
    answer: 'We host on Aliyun, Tencent Cloud or Huawei Cloud, depending on the project. The build runs outside China on a CI pipeline, the static output gets pushed to the Chinese host, fronted by a mainland CDN. We handle the hosting account, the ICP filing and the deployment pipeline, so your team never has to log into a Chinese hosting panel.',
  },
  {
    id: 'astro-maintenance',
    question: 'How much maintenance does an Astro site need?',
    answer: 'Less than a WordPress site, by a wide margin. There is no database to back up, no plugins to keep updated, no PHP versions to upgrade, no security patches arriving every other week. The framework itself updates a few times a year, dependencies need occasional review, and that’s roughly it. For most marketing sites a quarterly maintenance pass is enough.',
  },
  {
    id: 'astro-cloudflare',
    question: 'What about Cloudflare buying Astro? Does that change anything for China?',
    answer: 'It does and it doesn’t. Cloudflare’s deeper investment means Astro is now backed by a thirty-billion-dollar infrastructure company, which is a real trust signal for clients worried about long-term viability. The framework itself stays MIT-licensed and deployable anywhere, including on Chinese cloud providers. Cloudflare’s own CDN doesn’t perform well on the mainland, but Astro sites can still be deployed to Aliyun or Tencent Cloud without any loss of functionality.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true}>

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-astro-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Breadcrumb" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Astro</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <!-- Astro logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--color-brand-orange)] to-[#EF4444] flex items-center justify-center shadow-[0_8px_30px_rgba(242,95,41,0.4)]">
              <svg class="h-8 w-auto text-white" viewBox="0 0 85 107" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Astro logo">
                <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z"/>
                <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-[var(--color-brand-orange)] ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/25">
              <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">Framework · Astro</span>
            </div>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Astro in China.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Built for speed.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            The modern frontend framework for content-driven websites. Static-first, near-zero JavaScript, and very kind to slow Chinese mobile networks.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            Backed by Cloudflare since January 2026. We build Astro and WordPress, so we can be honest about which one fits.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contact/" variant="primary" size="lg">Talk to our team</Button>
            <Button href="/wordpress/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">WordPress for China</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">astro-china-build</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Lighthouse</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100 / 100</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">JS shipped</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">~0 KB</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Edge</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aliyun</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">ICP filing</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Filed</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with code editor image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Why It Works
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Static HTML, no fight with the Firewall.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Astro builds pages as static HTML and ships them to a CDN. No PHP, no database, JavaScript only where it’s actually needed. The technical name is Islands Architecture, and Astro pioneered it.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            In China that shape is exactly right. Less data over crowded mobile networks, fewer things that can quietly break behind the Firewall, and Baidu and the Chinese AI engines can crawl the content without a JavaScript runtime in the way.
          </p>
        </div>

        <!-- Astro code editor screenshot -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-12 lg:mt-0">
          <figure class="relative">
            <div class="relative aspect-square rounded-2xl overflow-hidden bg-[var(--color-surface-light)] border border-[var(--color-surface-border)]">
              <img
                src="/images/astro-code-editor.webp"
                alt="A modern code editor showing an Astro project structure, content collection markdown files in the sidebar and a static page rendered on the right"
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-2xl"></div>
            </div>
            <!-- Floating caption card -->
            <div class="absolute bottom-3 left-3 sm:-bottom-6 sm:-left-6 lg:-left-10 bg-white border border-[var(--color-surface-border)] rounded-xl shadow-[0_20px_60px_-20px_rgba(0,0,0,0.25)] p-4 sm:p-5 max-w-[220px] sm:max-w-[260px]">
              <p class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)] font-semibold mb-2">
                Plain files, in Git →
              </p>
              <p class="text-sm text-[var(--color-text-body)] leading-snug">
                Markdown content, type-safe Content Collections and Astro components live in version control. The build produces static HTML, ready for a Chinese CDN.
              </p>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- What Astro is For: icon cards -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            What It Is For
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            What Astro is best at, in China.
          </h2>
        </div>
        <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed lg:max-w-md">
          Purpose-built for content-driven sites. Within that category, hard to beat right now.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-5 auto-rows-fr">
        {useCases.map((item) => {
          const spanClass =
            item.span === 'feature'
              ? 'lg:col-span-7'
              : item.span === 'wide'
                ? 'lg:col-span-12'
                : 'lg:col-span-4';
          const isFeature = item.span === 'feature';
          return (
            <article class:list={[
