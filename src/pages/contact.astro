---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/pages/ContactForm.astro';
---

<PageLayout
  title="Contact Us | ChinaWebFoundry"
  description="Get in touch with ChinaWebFoundry. Tell us about your WordPress project in China and we'll respond within 24 hours."
  heroPage={true}
>
  <!-- Hero intro -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero-contact.webp"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-32 lg:pb-40">
      <div class="io-grid items-start gap-y-12 lg:gap-y-16">
        <!-- Left top: heading + intro -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-1 lg:row-start-1 order-1">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Contact
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.08]">
            Have a question about WordPress in China?
          </h1>
          <p class="mt-6 text-lg text-white/60 leading-relaxed">
            Whether you're starting fresh or fixing an existing site, we'll reply within 24 hours with straight answers and a clear path forward.
          </p>
        </div>

        <!-- Left bottom: contact details -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-1 lg:row-start-2 order-3">
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-brand-orange)]/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Email</p>
                <a href="mailto:hello@beyondbordergroup.com" class="text-base text-white/60 no-underline hover:text-[var(--color-brand-orange)] transition-colors">
                  hello@beyondbordergroup.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-brand-orange)]/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Response time</p>
                <p class="text-base text-white/60">Within 24 hours, Monday to Friday</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-brand-orange)]/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Shanghai, China</p>
                <p class="text-base text-white/60">Trinity Plaza, 19th floor, Changshou Road 868, Putuo district, Shanghai, China</p>
                <p class="text-base text-white/60">中港汇大厦, 上海市普陀区长寿路868号19楼</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-brand-orange)]/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Hong Kong</p>
                <p class="text-base text-white/60">806 Capitol Center, 5-19 Jardine's Bazaar, Causeway Bay, Hong Kong</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#07C160]/15 flex items-center justify-center">
                <svg class="w-5 h-5 text-[#07C160]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">WeChat</p>
                <p class="text-base text-white/60 mb-3">Scan to chat with us</p>
                <div class="inline-block rounded-lg bg-white p-2">
                  <img
                    src="/images/wechat-qr.webp"
                    alt="WeChat QR code"
                    width="160"
                    height="160"
                    class="block w-40 h-40"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: contact form (spans both rows on desktop) -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7 lg:row-start-1 lg:row-span-2 order-2">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</PageLayout>
