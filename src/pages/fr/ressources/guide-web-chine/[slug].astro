---
import { getCollection, getEntry, render } from 'astro:content';
import GuideLayout from '../../../../layouts/GuideLayout.astro';
import { guideSlugs } from '../../../../i18n/routes';

export async function getStaticPaths() {
  const guides = await getCollection('guides-fr');
  return guides
    .filter((guide) => guide.data.published)
    .map((guide) => ({
      params: { slug: guideSlugs[guide.id]?.fr ?? guide.id },
      props: { guide },
    }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const tocItems = headings.filter((h) => h.depth === 2);

// Author lookup: prefer FR team entry, fall back to EN team if no FR mirror.
const teamFrEntry = await getEntry('team-fr', guide.data.author).catch(() => undefined);
const teamEntry = teamFrEntry ?? await getEntry('team', guide.data.author);
const author = teamEntry
  ? {
      name: teamEntry.data.name,
      role: teamEntry.data.role,
      url: teamEntry.data.linkedin,
      bio: teamEntry.data.bio,
    }
  : undefined;
---

<GuideLayout
  title={guide.data.title}
  subtitle={guide.data.subtitle}
  summary={guide.data.summary}
  visual={guide.data.visual}
  tocItems={tocItems}
  lang="fr"
  author={author}
  publishedAt={guide.data.publishedAt}
  updatedAt={guide.data.updatedAt}
>
  <Content />
</GuideLayout>
