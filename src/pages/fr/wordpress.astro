---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'WordPress en Chine | Ce qui marche, ce qu’il faut changer | ChinaWebFoundry';
const metaDescription = 'WordPress fonctionne en Chine quand il est conçu pour. Les cas d’usage adaptés, les ajustements imposés par le Pare-feu, et les alternatives qui ne tiennent pas la route.';

const stats = [
  { value: 43, suffix: '%', label: 'des sites web tournent sous WordPress', source: 'W3Techs, 2024' },
  { value: 20, suffix: '+', label: 'ans de WordPress en Chine', source: 'Implantés à Shanghai depuis 2005' },
  { value: 50, suffix: '+', label: 'sites internationaux mis en ligne derrière le Pare-feu', source: 'Tous secteurs confondus' },
];

const useCases = [
  {
    icon: 'cart',
    title: 'E-commerce avec WooCommerce',
    body: 'Pour les marques qui vendent en Chine en dehors de Tmall ou JD, WooCommerce reste ce qui se rapproche le plus d’un vrai socle e-commerce ouvert. Avec Alipay, WeChat Pay et UnionPay branchés, on couvre l’essentiel.',
    span: 'feature',
    badges: ['WooCommerce', 'Alipay', 'WeChat Pay', 'UnionPay'],
  },
  {
    icon: 'pen',
    title: 'Sites à fort volume éditorial',
    body: 'Des centaines de pages, une publication régulière, plusieurs auteurs. WordPress a été pensé pour ça. Les rédacteurs qui le connaissent déjà n’ont rien à apprendre.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Sites multilingues',
    body: 'Le chinois aux côtés de l’anglais, du français, de l’allemand ou du japonais. WordPress avec WPML ou Polylang gère trois langues ou plus proprement, avec des sitemaps séparés pour Baidu et Google.',
    span: 'normal',
  },
  {
    icon: 'users',
    title: 'Mis à jour par des non-développeurs',
    body: 'Équipes marketing, content managers, bureaux régionaux : tous mettent le site à jour sans pipeline de déploiement. Pour une équipe Chine indépendante, cette souplesse compte plus que la vitesse brute.',
    span: 'normal',
  },
  {
    icon: 'sliders',
    title: 'Sites à workflows métier',
    body: 'Espaces membres, capture de leads conditionnelle, contenu réservé, outillage commercial. L’écosystème d’extensions couvre l’essentiel sans développement spécifique.',
    span: 'normal',
  },
  {
    icon: 'layers',
    title: 'Sites construits avec un page builder',
    body: 'La plupart des sites qu’on reprend sont sous Elementor, Divi ou Gutenberg. Les trois fonctionnent une fois les dépendances nettoyées. Gutenberg reste le plus léger et le plus facile à garder rapide sur un serveur chinois.',
    span: 'wide',
    badges: ['Elementor', 'Divi', 'Gutenberg'],
  },
];

const pickAstro = [
  'Le site est principalement composé de pages marketing, mises à jour une fois par mois ou moins',
  'La vitesse de chargement est non négociable (landing pages publicitaires, campagnes payantes)',
  'Vous voulez réduire la surface d’attaque et la charge de maintenance',
  'Les mises à jour de contenu peuvent passer par un développeur ou par nous',
  'Vous n’avez pas besoin d’une interface CMS pour des éditeurs non techniques',
];

const pickWordPress = [
  'Le travail éditorial est quotidien, pas occasionnel',
  'Vous gérez trois langues ou plus',
  'Vous avez du e-commerce ou un espace membres',
  'Votre équipe maîtrise déjà WordPress et vous ne voulez pas la former à autre chose',
  'Vous avez besoin d’extensions pour les formulaires, le SEO, le marketing automation ou la conformité',
];

const changeGroups = [
  {
    label: 'Front-end',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Polices',
        body: 'Google Fonts ne charge pas. On auto-héberge ou on remplace par des alternatives compatibles chinois qui livrent les glyphes latins et CJK dans un seul fichier.',
      },
      {
        icon: 'palette',
        title: 'Thèmes',
        body: 'La majorité des thèmes ThemeForest appellent des CDN externes, intègrent Google Maps ou chargent des scripts distants qui tombent derrière le Pare-feu. On audite, on remplace, on substitue.',
      },
      {
        icon: 'blocks',
        title: 'Page builders',
        body: 'Chacun demande un nettoyage ciblé. On supprime les chargeurs Google Fonts, on remplace les bibliothèques d’icônes externes par des locales, on désactive tout ce qui ping un service bloqué.',
      },
    ],
  },
  {
    label: 'Intégrations',
    accent: 'orange',
    items: [
      {
        icon: 'play',
        title: 'Embeds',
        body: 'YouTube devient Youku ou Bilibili. Vimeo devient Tencent Video. Les pixels Facebook deviennent WeChat ou Weibo. Google Maps devient Baidu Map ou Amap.',
      },
      {
        icon: 'card',
        title: 'Paiements',
        body: 'WooCommerce seul ne prendra pas l’argent d’un consommateur chinois. On ajoute Alipay, WeChat Pay et UnionPay, et on configure le checkout selon les usages réels de paiement en Chine.',
      },
      {
        icon: 'plug',
        title: 'Extensions',
        body: 'Yoast SEO doit recevoir le support du sitemap Baidu. Google Analytics est remplacé par Baidu Tongji. reCAPTCHA passe à un équivalent chinois. On tient une liste à jour.',
      },
    ],
  },
  {
    label: 'Hébergement et infrastructure',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hébergement',
        body: 'Serveur en Chine continentale, licence ICP valide sur le domaine. Aliyun, Tencent Cloud ou Huawei Cloud, selon le projet.',
      },
      {
        icon: 'refresh',
        title: 'Mises à jour automatiques',
        body: 'Le cœur et les extensions appellent wordpress.org et tombent souvent en timeout depuis la Chine. On route les mises à jour via un proxy ou on planifie des fenêtres manuelles.',
      },
      {
        icon: 'shield',
        title: 'Sécurité',
        body: 'Durcissement standard : édition de fichiers admin désactivée, xmlrpc verrouillé, double authentification imposée, WAF sur le cloud chinois. La discipline de mise à jour est plus stricte ici.',
      },
    ],
  },
  {
    label: 'Performance et SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'CDN configuré pour la livraison en Chine continentale. Cache empilé. Base de données réglée pour les serveurs cloud chinois. Cible : moins de trois secondes pour le first meaningful paint sur un mobile chinois milieu de gamme.',
      },
      {
        icon: 'search',
        title: 'SEO et recherche IA',
        body: 'Le contenu critique est en HTML. Outils webmaster Baidu branchés. Site structuré pour que Doubao, Kimi, DeepSeek et Wenxin puissent le lire et le citer.',
      },
    ],
  },
];

const pluginBuckets = [
  {
    eyebrow: 'Premier choix',
    title: 'Trouver un remplaçant',
    body: 'Ce qu’on fait dans la majorité des cas. Google Analytics devient Baidu Tongji. reCAPTCHA devient un captcha local. Google Maps devient Amap. Les rédacteurs ne voient pas la différence.',
  },
  {
    eyebrow: 'Quand ça s’y prête',
    title: 'Le retirer',
    body: 'Si l’extension n’a aucun sens pour un public chinois, on la retire. Moins d’extensions, site plus rapide, surface d’attaque réduite.',
  },
  {
    eyebrow: 'Dernier recours',
    title: 'Modifier le code de l’extension',
    body: 'Extension critique, aucun remplaçant : on modifie le code. Reroute d’un appel API via un proxy, ou substitution d’une URL CDN codée en dur. Uniquement quand la licence le permet.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hébergement' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hébergement' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hébergement' },
  { name: 'Baidu', cn: '百度', role: 'Recherche et SEO' },
  { name: 'WeChat', cn: '微信', role: 'Auth et messagerie' },
  { name: 'Alipay', cn: '支付宝', role: 'Paiements' },
];

const elementorItems = [
  {
    label: 'Polices',
    body: 'Elementor charge Google Fonts par défaut, ce qui ne résout pas en Chine. On auto-héberge ou on remplace par des alternatives compatibles chinois.',
  },
  {
    label: 'Widgets et composants',
    body: 'Certains widgets appellent des services bloqués (Google Maps, YouTube, Facebook, reCAPTCHA). On les remplace par des équivalents chinois ou par des composants sur mesure.',
  },
  {
    label: 'Bibliothèques d’icônes et CDN',
    body: 'Les actifs externes sont reroutés pour être chargés localement depuis le serveur chinois.',
  },
  {
    label: 'Templates',
    body: 'La plupart des templates Elementor partent d’hypothèses qui ne tiennent pas en Chine. On les audite et on les nettoie un par un.',
  },
];

const faqs = [
  {
    id: 'wp-icp',
    question: 'Notre site WordPress a-t-il besoin d’une licence ICP pour fonctionner en Chine ?',
    answer: 'S’il est hébergé en Chine continentale, oui. Si vous hébergez à Hong Kong, non, mais le site sera mesurablement plus lent et Baidu le traitera comme étranger. Pour la plupart des marques étrangères sérieuses sur le marché chinois, la licence ICP vaut le coup.',
  },
  {
    id: 'wp-marketing-team',
    question: 'Notre équipe marketing pourra-t-elle continuer à mettre à jour le site WordPress ?',
    answer: 'Oui. WordPress reste WordPress. L’interface admin est la même, le workflow éditorial est le même, et les rôles fonctionnent comme ils l’ont toujours fait. Les changements qu’on opère sous le capot sont, pour l’essentiel, invisibles pour l’équipe éditoriale.',
  },
  {
    id: 'wp-vs-astro-speed',
    question: 'WordPress est-il plus lent qu’Astro en Chine ?',
    answer: 'En temps de chargement brut, oui, toutes choses égales par ailleurs. WordPress est dynamique, Astro est statique. En pratique, un site WordPress bien réglé sur Aliyun avec la bonne couche de cache atteint des cibles de performance qui satisfont à la fois les utilisateurs chinois et Baidu. L’écart pèse plus pour certains projets que pour d’autres.',
  },
  {
    id: 'wp-elementor-divi',
    question: 'Notre site Elementor ou Divi existant fonctionnera-t-il en Chine ?',
    answer: 'Probablement pas en l’état. Mais on peut généralement le rendre fonctionnel. On retire les dépendances Google, on change les polices et on reroute les intégrations. La majorité des sites Elementor et Divi qu’on reprend tournent proprement derrière le Pare-feu en quelques semaines.',
  },
  {
    id: 'wp-auto-updates',
    question: 'Et les mises à jour automatiques d’extensions depuis wordpress.org ?',
    answer: 'Elles échouent ou expirent souvent depuis la Chine, parce que le dépôt wordpress.org est lent ou inaccessible sur les réseaux chinois. On configure le routage des mises à jour via un proxy ou on planifie des fenêtres manuelles. Dans tous les cas, votre équipe n’a pas à s’en occuper au quotidien.',
  },
  {
    id: 'wp-multilingual',
    question: 'Peut-on garder WPML ou Polylang pour le multilingue ?',
    answer: 'Oui, les deux fonctionnent bien en Chine une fois le reste du site nettoyé. WPML reste le choix le plus courant pour les sites avec trois langues ou plus et des workflows de traduction complexes. Polylang est plus léger et convient parfaitement à deux ou trois langues. On a beaucoup utilisé l’un comme l’autre. Le choix tient plus à votre processus éditorial qu’à des contraintes propres à la Chine.',
  },
  {
    id: 'wp-woocommerce-china',
    question: 'WooCommerce convient-il pour vendre à des consommateurs chinois ?',
    answer: 'WooCommerce en lui-même fonctionne très bien. Le travail se fait sur la couche checkout. Les consommateurs chinois s’attendent à payer via Alipay, WeChat Pay ou UnionPay, presque toujours sur mobile, presque toujours via QR code. On ajoute ces passerelles de paiement avec des extensions dédiées, et on redessine le tunnel d’achat pour la façon dont les utilisateurs chinois achètent réellement. WooCommerce part du principe qu’on paie par carte ou via PayPal, ce qui n’a pas cours ici.',
  },
  {
    id: 'wp-single-vs-dual',
    question: 'Peut-on faire tourner un seul site WordPress pour la Chine et le reste du monde ?',
    answer: 'Techniquement oui, avec WordPress Multisite ou un setup multilingue. En pratique, on recommande généralement deux installations WordPress distinctes, une hors de Chine et une sur un serveur chinois continental. La raison est la performance : avec une installation globale unique, les utilisateurs chinois tirent les ressources depuis des serveurs hors du Pare-feu, ce qui annule l’intérêt. Deux installations partagent les workflows éditoriaux quand c’est utile et restent indépendantes quand il le faut.',
  },
  {
    id: 'wp-security-china',
    question: 'Comment sécuriser notre site WordPress en Chine ?',
    answer: 'Le durcissement WordPress standard reste valable. On désactive l’édition de fichiers dans l’admin, on verrouille xmlrpc, on impose la double authentification et on déploie un Web Application Firewall configuré pour le cloud chinois. La discipline supplémentaire en Chine porte sur les mises à jour d’extensions : quand l’auto-update échoue, le site peut rester sur une version périmée plus longtemps qu’une équipe occidentale n’en a l’habitude. On surveille et on patche selon un calendrier fixe.',
  },
  {
    id: 'wp-hosting-provider',
    question: 'Quel hébergeur WordPress est le meilleur pour la Chine ?',
    answer: 'On utilise Aliyun, Tencent Cloud et Huawei Cloud selon les projets. Les trois disposent de licences continentales, les trois performent bien et les trois supportent correctement la pile WordPress. Aliyun est généralement le choix par défaut pour les sites marketing, Tencent Cloud est solide pour les sites qui s’intègrent à WeChat, et Huawei Cloud revient plus souvent chez les clients qui utilisent déjà l’infrastructure Huawei ailleurs. On gère le compte d’hébergement, le dépôt ICP et les opérations serveur au quotidien, pour que vous n’ayez jamais à vous connecter à un panel d’hébergement chinois vous-même.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-wordpress-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">WordPress</li>
        </ol>
      </nav>

      <div class="grid grid-cols-12 gap-8 items-center pb-20 md:pb-28 lg:pb-36 pt-8 lg:pt-16">
        <div class="col-span-12 lg:col-span-7">
          <!-- WordPress logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[#21759b] to-[#1a5d7a] flex items-center justify-center shadow-[0_8px_30px_rgba(33,117,155,0.45)]">
              <svg class="w-8 h-8 text-white" viewBox="0 0 122.52 122.523" fill="currentColor" aria-label="WordPress logo">
                <path d="m8.708 61.26c0 20.802 12.089 38.779 29.619 47.298l-25.069-68.686c-2.916 6.536-4.55 13.769-4.55 21.388z"/>
                <path d="m96.74 58.608c0-6.495-2.333-10.993-4.334-14.494-2.664-4.329-5.161-7.995-5.161-12.324 0-4.831 3.664-9.328 8.825-9.328.233 0 .454.029.681.042-9.35-8.566-21.807-13.796-35.489-13.796-18.36 0-34.513 9.42-43.91 23.688 1.233.037 2.395.063 3.382.063 5.497 0 14.006-.667 14.006-.667 2.833-.167 3.167 3.994.337 4.329 0 0-2.847.335-6.015.501l19.138 56.925 11.501-34.493-8.188-22.434c-2.83-.166-5.511-.501-5.511-.501-2.832-.166-2.5-4.496.332-4.329 0 0 8.679.667 13.843.667 5.496 0 14.006-.667 14.006-.667 2.835-.167 3.168 3.994.337 4.329 0 0-2.853.335-6.015.501l18.992 56.494 5.242-17.517c2.272-7.269 4.001-12.49 4.001-16.989z"/>
                <path d="m62.184 65.857-15.768 45.819c4.708 1.384 9.687 2.141 14.846 2.141 6.12 0 11.989-1.058 17.452-2.979-.141-.225-.269-.464-.374-.724z"/>
                <path d="m107.376 36.046c.226 1.674.354 3.471.354 5.404 0 5.333-.996 11.328-3.996 18.824l-16.053 46.413c15.624-9.111 26.133-26.038 26.133-45.426.001-9.137-2.333-17.729-6.438-25.215z"/>
                <path d="m61.262 0c-33.779 0-61.262 27.481-61.262 61.26 0 33.783 27.483 61.263 61.262 61.263 33.778 0 61.265-27.48 61.265-61.263-.001-33.779-27.487-61.26-61.265-61.26zm0 119.715c-32.23 0-58.453-26.223-58.453-58.455 0-32.23 26.222-58.451 58.453-58.451 32.229 0 58.45 26.221 58.45 58.451 0 32.232-26.221 58.455-58.45 58.455z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#21759b]/15 border border-[#21759b]/30">
              <span class="text-xs font-semibold uppercase tracking-wider text-[#7cb8d4]">Technologie · WordPress</span>
            </div>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[72px] xl:text-[84px] font-medium font-[var(--font-heading)] text-white leading-[0.98] tracking-tight">
            WordPress en Chine.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Oui, ça marche.</span>
          </h1>
          <p class="mt-10 text-lg lg:text-xl text-white/65 max-w-xl leading-relaxed">
            La plupart des clients arrivent déjà sur WordPress. La vraie question, c’est de savoir si ça tient en Chine, et ce qu’il faut changer pour y arriver.
          </p>
          <p class="mt-4 text-base text-white/45 max-w-xl leading-relaxed">
            Vingt ans à Shanghai. Plus de cinquante sites internationaux mis en ligne.
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Parler à notre équipe</Button>
            <Button href="/fr/astro/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Astro en Chine</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with workspace image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Pourquoi ça marche
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            La plateforme n’est pas le problème.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            WordPress tourne en Chine. Le cœur, wordpress.org, le workflow de publication standard : tout fonctionne pareil sur un serveur de Shanghai que sur un serveur de Londres, et wp-admin est joignable sans VPN.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Le problème, ce sont ses dépendances par défaut. Les thèmes chargent Google Fonts. Les extensions appellent des API hors du Pare-feu. Les bibliothèques tirent depuis des CDN bloqués. Les embeds pointent vers YouTube. L’analytics appelle Google.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Une fois ces dépendances retirées et remplacées par des équivalents locaux, il reste un site WordPress rapide, conforme, indexé par Baidu, et toujours administrable par une équipe qui le maîtrise déjà.
          </p>
        </div>

        <!-- WordPress admin screenshot -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-12 lg:mt-0">
          <figure class="relative">
            <div class="relative aspect-square rounded-2xl overflow-hidden bg-[var(--color-surface-light)] border border-[var(--color-surface-border)]">
              <img
                src="/images/wordpress-admin-dashboard.webp"
                alt="L’interface du tableau de bord wp-admin de WordPress, avec la barre latérale, le panneau de bienvenue et les widgets du tableau de bord"
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-2xl"></div>
            </div>
            <!-- Floating caption card -->
            <div class="absolute bottom-3 left-3 sm:-bottom-6 sm:-left-6 lg:-left-10 bg-white border border-[var(--color-surface-border)] rounded-xl shadow-[0_20px_60px_-20px_rgba(0,0,0,0.25)] p-4 sm:p-5 max-w-[220px] sm:max-w-[260px]">
              <p class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)] font-semibold mb-2">
                Le même wp-admin →
              </p>
              <p class="text-sm text-[var(--color-text-body)] leading-snug">
                Un site WordPress administré depuis la Chine fait tourner le wp-admin que vous connaissez déjà, sur une infrastructure réglée pour le réseau local.
              </p>
            </div>
