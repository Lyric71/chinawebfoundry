---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'WordPress en Chine | Ce qui tient, ce qu’il faut revoir | ChinaWebFoundry';
const metaDescription = 'WordPress passe en Chine, à condition d’y être préparé. Les usages où il s’impose, les ajustements imposés par le Pare-feu, et les alternatives qui ne tiennent pas la distance.';

const stats = [
  { value: 43, suffix: '%', label: 'des sites Web fonctionnent sous WordPress', source: 'W3Techs, 2024' },
  { value: 20, suffix: '+', label: 'ans de WordPress en Chine', source: 'Implantés à Shanghai depuis 2005' },
  { value: 50, suffix: '+', label: 'sites internationaux mis en ligne derrière le Pare-feu', source: 'Tous secteurs confondus' },
];

const useCases = [
  {
    icon: 'cart',
    title: 'E-commerce avec WooCommerce',
    body: 'Pour les marques qui vendent en Chine hors des marketplaces Tmall et JD, WooCommerce reste ce qui se rapproche le plus d’un vrai socle e-commerce ouvert. Une fois Alipay, WeChat Pay et UnionPay intégrés au tunnel, l’essentiel des paiements est couvert.',
    span: 'feature',
    badges: ['WooCommerce', 'Alipay', 'WeChat Pay', 'UnionPay'],
  },
  {
    icon: 'pen',
    title: 'Sites à fort volume éditorial',
    body: 'Des centaines de pages, une cadence de publication soutenue, plusieurs signatures à coordonner. WordPress a été pensé exactement pour cet usage. Les rédacteurs déjà familiers de l’outil n’ont rien à réapprendre.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Sites multilingues',
    body: 'Le chinois aux côtés de l’anglais, du français, de l’allemand ou du japonais. Couplé à WPML ou Polylang, WordPress encaisse trois langues ou davantage sans broncher, avec des sitemaps distincts pour Baidu et pour Google.',
    span: 'normal',
  },
  {
    icon: 'users',
    title: 'Mis à jour par des non-développeurs',
    body: 'Équipes marketing, responsables éditoriaux, bureaux régionaux : chacun publie sans déclencher le moindre pipeline de déploiement. Pour une équipe Chine autonome, cette souplesse pèse souvent plus lourd que la vitesse brute.',
    span: 'normal',
  },
  {
    icon: 'sliders',
    title: 'Sites à logique métier',
    body: 'Espaces membres, captation de prospects conditionnelle, contenus réservés, outillage commercial. L’écosystème d’extensions couvre l’essentiel sans le moindre développement sur mesure.',
    span: 'normal',
  },
  {
    icon: 'layers',
    title: 'Sites bâtis avec un constructeur de pages',
    body: 'La majorité des sites que nous reprenons reposent sur Elementor, Divi ou Gutenberg. Les trois tiennent la route une fois les dépendances purgées. Gutenberg garde l’avantage : plus léger, plus simple à maintenir rapide sur un serveur chinois.',
    span: 'wide',
    badges: ['Elementor', 'Divi', 'Gutenberg'],
  },
];

const pickAstro = [
  'Le site se compose pour l’essentiel de pages marketing, actualisées une fois par mois, voire moins',
  'La vitesse de chargement n’est pas négociable (pages d’atterrissage publicitaires, campagnes payantes)',
  'Vous cherchez à réduire la surface d’attaque et la charge de maintenance',
  'Les mises à jour de contenu peuvent passer par un développeur, ou par notre équipe',
  'Vous n’avez pas besoin d’une interface CMS pour des rédacteurs non techniques',
];

const pickWordPress = [
  'Le travail éditorial se fait au quotidien',
  'Vous gérez trois langues ou davantage',
  'Vous avez une boutique en ligne ou un espace membres',
  'Votre équipe maîtrise déjà WordPress, et vous n’avez pas envie de la former à un nouvel outil',
  'Vous avez besoin d’extensions pour les formulaires, le SEO, l’automatisation marketing ou la conformité',
];

const changeGroups = [
  {
    label: 'Front-end',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Polices',
        body: 'Google Fonts ne se charge pas en Chine. Nous auto-hébergeons les fontes, ou nous les remplaçons par des polices qui couvrent à la fois les glyphes latins et CJK dans un même fichier.',
      },
      {
        icon: 'palette',
        title: 'Thèmes',
        body: 'La majorité des thèmes ThemeForest appellent des CDN étrangers, embarquent Google Maps ou chargent des scripts distants qui s’effondrent derrière le Pare-feu. Nous les passons au crible et nous remplaçons les composants fautifs un à un.',
      },
      {
        icon: 'blocks',
        title: 'Constructeurs de pages',
        body: 'Chaque builder réclame un nettoyage ciblé. Nous coupons les chargeurs Google Fonts, nous rapatrions les bibliothèques d’icônes externes en local, et nous désactivons tout appel vers un service bloqué.',
      },
    ],
  },
  {
    label: 'Intégrations',
    accent: 'orange',
    items: [
      {
        icon: 'play',
        title: 'Contenus intégrés',
        body: 'YouTube cède la place à Youku ou Bilibili. Vimeo passe à Tencent Video. Les pixels Facebook deviennent WeChat ou Weibo. Google Maps fait place à Baidu Map ou Amap.',
      },
      {
        icon: 'card',
        title: 'Paiements',
        body: 'WooCommerce seul ne suffit pas pour encaisser le règlement d’un consommateur chinois. Nous ajoutons Alipay, WeChat Pay et UnionPay, puis nous reconfigurons le tunnel de commande selon les habitudes réelles du marché chinois.',
      },
      {
        icon: 'plug',
        title: 'Extensions',
        body: 'Yoast SEO est étendu au sitemap Baidu. Google Analytics laisse la place à Baidu Tongji. reCAPTCHA bascule sur un équivalent chinois. Nous tenons une liste de correspondances à jour.',
      },
    ],
  },
  {
    label: 'Hébergement et infrastructure',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hébergement',
        body: 'Serveur en Chine continentale, licence ICP en règle sur le domaine. Aliyun, Tencent Cloud ou Huawei Cloud, selon la nature du projet.',
      },
      {
        icon: 'refresh',
        title: 'Mises à jour automatiques',
        body: 'Le noyau et les extensions interrogent wordpress.org, et l’appel arrive souvent à expiration depuis la Chine. Nous faisons transiter les mises à jour par un proxy, ou nous programmons des fenêtres manuelles.',
      },
      {
        icon: 'shield',
        title: 'Sécurité',
        body: 'Durcissement standard : édition de fichiers depuis l’admin coupée, XML-RPC verrouillé, double authentification imposée, WAF posé sur le cloud chinois. La discipline de mise à jour, elle, demande davantage de rigueur ici qu’ailleurs.',
      },
    ],
  },
  {
    label: 'Performance et SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'CDN paramétré pour la livraison en Chine continentale. Couches de cache empilées. Base de données calibrée pour les serveurs cloud chinois. Cible : moins de trois secondes pour le first meaningful paint sur un téléphone chinois de milieu de gamme.',
      },
      {
        icon: 'search',
        title: 'SEO et recherche IA',
        body: 'Le contenu critique reste servi en HTML. Outils webmaster Baidu raccordés. Site structuré pour que Doubao, Kimi, DeepSeek et Wenxin puissent le lire et le citer.',
      },
    ],
  },
];

const pluginBuckets = [
  {
    eyebrow: 'Première option',
    title: 'Trouver une équivalence',
    body: 'Le réflexe par défaut, dans la majorité des cas. Google Analytics laisse la place à Baidu Tongji. reCAPTCHA cède à un captcha local. Google Maps devient Amap. Côté rédaction, la transition reste invisible.',
  },
  {
    eyebrow: 'Quand le contexte le permet',
    title: 'La désinstaller',
    body: 'Si l’extension n’a aucune utilité pour un public chinois, nous la désinstallons. Le site s’allège, gagne en rapidité, et offre moins de prise aux attaques.',
  },
  {
    eyebrow: 'Dernier recours',
    title: 'Modifier le code de l’extension',
    body: 'Extension critique, aucune équivalence disponible : nous patchons le code. Un appel API redirigé via un proxy, une URL de CDN codée en dur substituée. Uniquement quand la licence l’autorise.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hébergement' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hébergement' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hébergement' },
  { name: 'Baidu', cn: '百度', role: 'Recherche et SEO' },
  { name: 'WeChat', cn: '微信', role: 'Auth et messagerie' },
  { name: 'Alipay', cn: '支付宝', role: 'Paiements' },
];

const elementorItems = [
  {
    label: 'Polices',
    body: 'Elementor charge Google Fonts par défaut, et l’appel échoue à résoudre en Chine. Nous auto-hébergeons les fontes, ou nous les remplaçons par des polices qui couvrent à la fois les glyphes latins et chinois.',
  },
  {
    label: 'Widgets et composants',
    body: 'Certains widgets appellent des services bloqués (Google Maps, YouTube, Facebook, reCAPTCHA). Nous les remplaçons par des équivalents chinois, ou par des composants conçus sur mesure.',
  },
  {
    label: 'Bibliothèques d’icônes et CDN',
    body: 'Les ressources externes sont rapatriées et servies localement depuis le serveur chinois.',
  },
  {
    label: 'Modèles',
    body: 'La plupart des modèles Elementor partent de présupposés qui ne tiennent pas en Chine. Nous les passons en revue un à un et nous les assainissons.',
  },
];

const faqs = [
  {
    id: 'wp-icp',
    question: 'Notre site WordPress a-t-il besoin d’une licence ICP pour fonctionner en Chine ?',
    answer: 'Hébergé en Chine continentale, oui. Hébergé à Hong Kong, non, mais le site y perdra en vitesse de manière mesurable, et Baidu le traitera comme étranger. Pour la plupart des marques étrangères sérieuses sur le marché chinois, la licence ICP justifie l’investissement.',
  },
  {
    id: 'wp-marketing-team',
    question: 'Notre équipe marketing pourra-t-elle continuer à mettre à jour le site WordPress ?',
    answer: 'Oui. WordPress reste WordPress. L’interface d’administration ne bouge pas, le circuit éditorial non plus, et les rôles utilisateurs continuent de se comporter comme à l’accoutumée. Les retouches que nous opérons en arrière-plan restent, pour l’essentiel, invisibles côté rédaction.',
  },
  {
    id: 'wp-vs-astro-speed',
    question: 'WordPress est-il plus lent qu’Astro en Chine ?',
    answer: 'En temps de chargement brut, oui, à conditions égales. WordPress est dynamique, Astro est statique. Dans la réalité, un site WordPress correctement réglé sur Aliyun, avec les bonnes couches de cache, atteint les seuils de performance attendus à la fois par les utilisateurs chinois et par Baidu. L’écart pèse davantage sur certains projets que sur d’autres.',
  },
  {
    id: 'wp-elementor-divi',
    question: 'Notre site Elementor ou Divi existant fonctionnera-t-il en Chine ?',
    answer: 'Probablement pas en l’état. Mais le rendre opérationnel reste à notre portée la plupart du temps. Nous retirons les dépendances Google, nous remplaçons les polices, et nous redirigeons les intégrations. La plupart des sites Elementor et Divi que nous reprenons tournent proprement derrière le Pare-feu au bout de quelques semaines.',
  },
  {
    id: 'wp-auto-updates',
    question: 'Et les mises à jour automatiques d’extensions depuis wordpress.org ?',
    answer: 'Elles échouent ou arrivent à expiration le plus souvent depuis la Chine, parce que le dépôt wordpress.org répond mal, voire pas du tout, sur les réseaux chinois. Nous faisons transiter les mises à jour par un proxy, ou nous programmons des fenêtres manuelles. Dans les deux cas, votre équipe n’a pas à s’en occuper au quotidien.',
  },
  {
    id: 'wp-multilingual',
    question: 'Peut-on garder WPML ou Polylang pour le multilingue ?',
    answer: 'Oui, les deux passent en Chine sans difficulté, une fois le reste du site assaini. WPML reste le choix le plus courant pour les sites à trois langues ou davantage, et pour les circuits de traduction complexes. Polylang, plus léger, convient parfaitement à deux ou trois langues. Nous avons beaucoup pratiqué l’un comme l’autre. Le choix tient bien plus à votre processus éditorial qu’à des contraintes propres à la Chine.',
  },
  {
    id: 'wp-woocommerce-china',
    question: 'WooCommerce convient-il pour vendre à des consommateurs chinois ?',
    answer: 'WooCommerce en lui-même tourne très bien. Le travail se concentre sur la couche du tunnel de commande. Le consommateur chinois règle via Alipay, WeChat Pay ou UnionPay, presque toujours sur mobile, presque toujours par scan de QR code. Nous greffons ces passerelles de paiement à l’aide d’extensions dédiées, puis nous redessinons le parcours d’achat pour coller à la façon dont les Chinois achètent vraiment. WooCommerce part du principe d’un paiement par carte bancaire ou via PayPal, hypothèse qui ne s’applique tout simplement pas en Chine.',
  },
  {
    id: 'wp-single-vs-dual',
    question: 'Peut-on faire tourner un seul site WordPress pour la Chine et le reste du monde ?',
    answer: 'Techniquement, oui, via WordPress Multisite ou une installation multilingue. Dans la pratique, nous recommandons le plus souvent deux installations WordPress distinctes : une à l’extérieur de la Chine, une sur un serveur chinois continental. La raison tient à la performance. Avec une seule installation mondiale, l’utilisateur chinois va chercher ses ressources sur des serveurs situés hors du Pare-feu, ce qui ruine l’intérêt de l’opération. Deux installations peuvent mutualiser les circuits éditoriaux quand c’est utile, et rester indépendantes quand il le faut.',
  },
  {
    id: 'wp-security-china',
    question: 'Comment sécuriser notre site WordPress en Chine ?',
    answer: 'Le durcissement WordPress standard tient toujours. Nous coupons l’édition de fichiers depuis l’admin, nous verrouillons XML-RPC, nous imposons la double authentification, et nous déployons un Web Application Firewall paramétré pour le cloud chinois. La rigueur supplémentaire propre à la Chine porte sur les mises à jour d’extensions : quand l’auto-update tombe en échec, le site peut rester bloqué sur une version vieillissante plus longtemps qu’une équipe occidentale n’en a l’habitude. Nous surveillons, et nous appliquons les correctifs selon un calendrier arrêté à l’avance.',
  },
  {
    id: 'wp-hosting-provider',
    question: 'Quel hébergeur WordPress convient le mieux pour la Chine ?',
    answer: 'Nous travaillons avec Aliyun, Tencent Cloud et Huawei Cloud selon les projets. Les trois disposent de licences continentales, les trois affichent de bonnes performances, et les trois portent correctement la pile WordPress. Aliyun reste le choix par défaut sur les sites marketing. Tencent Cloud se montre solide sur les projets qui s’intègrent à WeChat. Huawei Cloud revient plus souvent chez les clients déjà installés sur l’écosystème Huawei par ailleurs. Nous pilotons le compte d’hébergement, le dépôt ICP et les opérations serveur au quotidien, pour que vous n’ayez jamais à entrer dans un panneau de contrôle d’hébergement chinois par vous-même.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-wordpress-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">WordPress</li>
        </ol>
      </nav>

      <div class="grid grid-cols-12 gap-8 items-center pb-20 md:pb-28 lg:pb-36 pt-8 lg:pt-16">
        <div class="col-span-12 lg:col-span-7">
          <!-- WordPress logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[#21759b] to-[#1a5d7a] flex items-center justify-center shadow-[0_8px_30px_rgba(33,117,155,0.45)]">
              <svg class="w-8 h-8 text-white" viewBox="0 0 122.52 122.523" fill="currentColor" aria-label="WordPress logo">
                <path d="m8.708 61.26c0 20.802 12.089 38.779 29.619 47.298l-25.069-68.686c-2.916 6.536-4.55 13.769-4.55 21.388z"/>
                <path d="m96.74 58.608c0-6.495-2.333-10.993-4.334-14.494-2.664-4.329-5.161-7.995-5.161-12.324 0-4.831 3.664-9.328 8.825-9.328.233 0 .454.029.681.042-9.35-8.566-21.807-13.796-35.489-13.796-18.36 0-34.513 9.42-43.91 23.688 1.233.037 2.395.063 3.382.063 5.497 0 14.006-.667 14.006-.667 2.833-.167 3.167 3.994.337 4.329 0 0-2.847.335-6.015.501l19.138 56.925 11.501-34.493-8.188-22.434c-2.83-.166-5.511-.501-5.511-.501-2.832-.166-2.5-4.496.332-4.329 0 0 8.679.667 13.843.667 5.496 0 14.006-.667 14.006-.667 2.835-.167 3.168 3.994.337 4.329 0 0-2.853.335-6.015.501l18.992 56.494 5.242-17.517c2.272-7.269 4.001-12.49 4.001-16.989z"/>
                <path d="m62.184 65.857-15.768 45.819c4.708 1.384 9.687 2.141 14.846 2.141 6.12 0 11.989-1.058 17.452-2.979-.141-.225-.269-.464-.374-.724z"/>
                <path d="m107.376 36.046c.226 1.674.354 3.471.354 5.404 0 5.333-.996 11.328-3.996 18.824l-16.053 46.413c15.624-9.111 26.133-26.038 26.133-45.426.001-9.137-2.333-17.729-6.438-25.215z"/>
                <path d="m61.262 0c-33.779 0-61.262 27.481-61.262 61.26 0 33.783 27.483 61.263 61.262 61.263 33.778 0 61.265-27.48 61.265-61.263-.001-33.779-27.487-61.26-61.265-61.26zm0 119.715c-32.23 0-58.453-26.223-58.453-58.455 0-32.23 26.222-58.451 58.453-58.451 32.229 0 58.45 26.221 58.45 58.451 0 32.232-26.221 58.455-58.45 58.455z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#21759b]/15 border border-[#21759b]/30">
              <span class="text-xs font-semibold uppercase tracking-wider text-[#7cb8d4]">Technologie · WordPress</span>
            </div>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[72px] xl:text-[84px] font-medium font-[var(--font-heading)] text-white leading-[0.98] tracking-tight">
            WordPress en Chine.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Oui, ça tient.</span>
          </h1>
          <p class="mt-10 text-lg lg:text-xl text-white/65 max-w-xl leading-relaxed">
            La plupart de nos clients arrivent déjà avec WordPress. Reste à savoir si l’installation passe derrière le Pare-feu, et ce qu’il faut revoir pour qu’elle y reste.
          </p>
          <p class="mt-4 text-base text-white/45 max-w-xl leading-relaxed">
            Vingt ans d’expérience à Shanghai. Plus de cinquante sites internationaux mis en ligne.
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Échanger avec l’équipe</Button>
            <Button href="/fr/astro/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Astro en Chine</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with workspace image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Pourquoi ça tient
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Le moteur WordPress fonctionne en Chine.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            WordPress fonctionne en Chine. Le noyau, le code livré par wordpress.org, le circuit de publication standard : tout se comporte de la même manière sur un serveur shanghaien que sur un serveur londonien. Le wp-admin reste accessible sans VPN.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            L’écueil vient de ses dépendances par défaut. Les thèmes appellent Google Fonts. Les extensions interrogent des API situées hors du Pare-feu. Les bibliothèques se chargent depuis des CDN bloqués. Les contenus intégrés pointent vers YouTube. L’outil de mesure d’audience interroge Google.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Une fois ces dépendances retirées et remplacées par des équivalents chinois, le résultat reste un site WordPress, rapide, conforme, indexé par Baidu, et administrable par une équipe qui le connaît déjà.
          </p>
        </div>

        <!-- WordPress admin screenshot -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-12 lg:mt-0">
          <figure class="relative">
