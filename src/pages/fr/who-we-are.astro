    <script>
      // hub Studio interactive: pillars, magnetic button, Shanghai clock
      function initHubStudio() {
        // Pillar selection
        const pillars = document.querySelectorAll<HTMLElement>('[data-hub-pillar]');
        if (pillars.length && !pillars[0].dataset.hubBound) {
          pillars.forEach((p) => {
            p.dataset.hubBound = 'true';
            p.addEventListener('mouseenter', () => {
              pillars.forEach((o) => o.removeAttribute('data-active'));
              p.setAttribute('data-active', '');
            });
            p.addEventListener('focus', () => {
              pillars.forEach((o) => o.removeAttribute('data-active'));
              p.setAttribute('data-active', '');
            });
          });
        }

        // Magnetic CTA
        const magnets = document.querySelectorAll<HTMLElement>('[data-hub-magnet]');
        magnets.forEach((m) => {
          if (m.dataset.magBound === 'true') return;
          m.dataset.magBound = 'true';
          let raf = 0;
          m.addEventListener('mousemove', (e) => {
            const rect = m.getBoundingClientRect();
            const x = (e.clientX - rect.left - rect.width / 2) * 0.15;
            const y = (e.clientY - rect.top - rect.height / 2) * 0.15;
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(() => {
              m.style.transform = `translate3d(${x.toFixed(1)}px, ${y.toFixed(1)}px, 0) scale(1.02)`;
            });
          });
          m.addEventListener('mouseleave', () => {
            cancelAnimationFrame(raf);
            m.style.transform = 'translate3d(0,0,0) scale(1)';
          });
        });

        // Shanghai live clock
        const clocks = document.querySelectorAll<HTMLElement>('[data-hub-time]');
        function tick() {
          const now = new Date();
          const utcMs = now.getTime() + now.getTimezoneOffset() * 60000;
          const sh = new Date(utcMs + 8 * 3600000);
          const hh = String(sh.getHours()).padStart(2, '0');
          const mm = String(sh.getMinutes()).padStart(2, '0');
          clocks.forEach((c) => {
            c.textContent = `${hh}:${mm} 上海`;
          });
        }
        if (clocks.length && !clocks[0].dataset.clockBound) {
          clocks.forEach((c) => (c.dataset.clockBound = 'true'));
          tick();
          setInterval(tick, 30_000);
        }
      }

      initHubStudio();
      document.addEventListener('astro:page-load', initHubStudio);
      document.addEventListener('astro:after-swap', initHubStudio);
    </script>
