---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
---

<PageLayout
  title="Page introuvable | ChinaWebFoundry"
  description="Cette page n'existe pas ou a été déplacée."
  lang="fr"
>
  <section class="section-spacing">
    <Container class="text-center">
      <h1 class="text-6xl font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)] mb-4">404</h1>
      <p class="text-xl text-[var(--color-text-dark)] font-[var(--font-heading)] mb-2">Page introuvable</p>
      <p class="text-[var(--color-text-body)] mb-8">Cette page n'existe plus ou a changé d'adresse.</p>
      <Button href="/fr/" variant="primary" size="lg">Retour à l'accueil</Button>
    </Container>
  </section>
</PageLayout>
