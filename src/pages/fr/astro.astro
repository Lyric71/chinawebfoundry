---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'Astro en Chine | Sites statiques rapides pour le continent | ChinaWebFoundry';
const metaDescription = 'Astro est la voie la plus rapide pour publier un site marketing en Chine. Ce que c’est, quand l’utiliser, et les ajustements qui le font tenir derrière le Pare-feu.';

const stats = [
  { value: 100, suffix: '', label: 'Score Lighthouse type d’un site Astro, sans réglage manuel', source: 'Sitepins, Astro en 2026' },
  { value: 60, suffix: '%', label: 'des sites Astro passent les seuils « Good » des Core Web Vitals', source: 'Contre 38 % sur WordPress' },
  { value: 50, suffix: '%', label: 'de LCP en moins qu’un WordPress comparable, même hébergeur chinois', source: 'Mesures ChinaWebFoundry' },
];

const useCases = [
  {
    icon: 'rocket',
    title: 'Sites marketing et sites de marque',
    body: 'Sites de marque, pages produit, landing pages, microsites de campagne. La vitesse doit être excellente et le contenu bouge une fois par semaine ou moins. C’est exactement le terrain pour lequel Astro a été pensé, et là où l’avantage de performance saute aux yeux.',
    span: 'feature',
    badges: ['Sites de marque', 'Landing pages', 'Microsites'],
  },
  {
    icon: 'book',
    title: 'Documentation et bibliothèques de ressources',
    body: 'Starlight, le framework de documentation maison d’Astro, est ce qui se fait de plus solide dans l’écosystème. Pour la documentation technique, les bases de connaissances et les centres de ressources en Chine, le contenu reste rapide à charger et la navigation propre à suivre.',
    span: 'normal',
  },
  {
    icon: 'pen',
    title: 'Sites éditoriaux et blogs',
    body: 'Les Content Collections offrent un Markdown et un MDX typés, validés au build. Le flux de travail va plus vite que tout ce qu’on a connu sur WordPress, et le rendu est nettement plus léger sur les réseaux mobiles chinois.',
    span: 'normal',
  },
  {
    icon: 'languages',
    title: 'Sites marketing multilingues',
    body: 'Astro intègre nativement le routage i18n. Faire cohabiter le chinois avec l’anglais, le français, l’allemand ou le japonais se fait sans peine. Nous avons livré des sites Astro à dix langues ou plus, sans accroc.',
    span: 'normal',
  },
  {
    icon: 'zap',
    title: 'Sites où les Core Web Vitals dictent le budget',
    body: 'Quand l’achat média dépend de la vitesse de la landing page, ou que votre SEO dépend de l’indexation Baidu, Astro est le framework qui vous y emmène avec le moins de friction. Chargement sous la seconde sur un téléphone chinois milieu de gamme.',
    span: 'normal',
  },
  {
    icon: 'shield',
    title: 'Sites à forte exigence de sécurité',
    body: 'Du HTML statique, donc pas de base de données à attaquer, pas de PHP à exploiter, pas de connexion admin à forcer. Pour les marques déjà piratées par le passé, ou qui opèrent dans des secteurs régulés où la sécurité remonte au comité de direction, la surface d’attaque réduite pèse vraiment dans la balance.',
    span: 'wide',
    badges: ['Sans base de données', 'Sans runtime PHP', 'Sans login admin', 'Livraison statique'],
  },
];

const pickAstro = [
  'Le site est avant tout du contenu et du marketing',
  'La vitesse de page est une exigence chiffrée et non négociable',
  'L’équipe accepte un flux piloté par la tech, ou on branche un CMS headless',
  'Vous voulez réduire les coûts d’hébergement et de maintenance sur la durée',
  'La sécurité et une surface d’attaque réduite comptent plus que la souplesse éditoriale',
];

const pickWordPress = [
  'Votre équipe contenu publie tous les jours sans appeler un développeur',
  'Vous gérez du e-commerce avec des centaines ou des milliers de références via WooCommerce',
  'Vous dépendez d’extensions WordPress précises (adhésion, LMS, marketing automation)',
  'L’équipe marketing utilise Elementor ou Divi et n’a pas envie de migrer',
  'Le projet est très interactif (tableaux de bord connectés, fonctionnalités temps réel)',
];

const changeGroups = [
  {
    label: 'Frontend',
    accent: 'amber',
    items: [
      {
        icon: 'type',
        title: 'Polices',
        body: 'Les starters Astro chargent souvent depuis Google Fonts. Nous coupons le loader et hébergeons les polices nous-mêmes, ou nous les remplaçons par des polices compatibles chinois qui livrent le latin et le CJK dans un seul fichier.',
      },
      {
        icon: 'palette',
        title: 'Ressources externes et images',
        body: 'Certains thèmes Astro pointent vers des CDN occidentaux (jsdelivr, unpkg) pour les icônes ou les bibliothèques. Nous redirigeons tout vers un CDN chinois ou nous embarquons les ressources dans le build. Les images sont servies depuis Aliyun OSS ou Tencent COS dans des formats modernes.',
      },
      {
        icon: 'blocks',
        title: 'Scripts tiers',
        body: 'Tout ce qui ping un service bloqué est retiré ou remplacé. Cartes, polices, mesure d’audience, captchas et embeds reçoivent chacun un équivalent compatible Chine pendant le build, avant que le rendu statique ne parte en production.',
      },
    ],
  },
  {
    label: 'Intégrations et CMS',
    accent: 'orange',
    items: [
      {
        icon: 'plug',
        title: 'CMS headless, quand il faut',
        body: 'Quand l’équipe éditoriale a besoin d’une interface visuelle, on branche Storyblok, Sanity, Decap ou WordPress headless. Le CMS vit hors de Chine, le contenu se synchronise au build et le site statique vit sur un serveur continental.',
      },
      {
        icon: 'card',
        title: 'Formulaires et widgets',
        body: 'Les formulaires tournent en Astro Islands. Google reCAPTCHA devient un captcha chinois. Google Maps devient Baidu Map ou Amap. Les blocs interactifs continuent de fonctionner sans dépendance externe.',
      },
      {
        icon: 'chart',
        title: 'Analytics',
        body: 'Vercel Analytics ou Plausible cèdent la place à Baidu Tongji ou à un outil auto-hébergé. Les mêmes tableaux de bord dont l’équipe a besoin, sans aucun endpoint bloqué.',
      },
    ],
  },
  {
    label: 'Hébergement et build',
    accent: 'sky',
    items: [
      {
        icon: 'server',
        title: 'Hébergement',
        body: 'Serveur en Chine continentale, dépôt ICP valide sur le domaine. Aliyun, Tencent Cloud ou Huawei Cloud, devant un CDN chinois. Le CDN propre de Cloudflare donne de mauvais résultats sur le continent, donc nous n’y déployons pas.',
      },
      {
        icon: 'refresh',
        title: 'Pipeline de build',
        body: 'Le build tourne hors de Chine sur un pipeline CI (GitHub Actions, GitLab CI). Le rendu statique est poussé vers l’hébergeur chinois. Push sur main et le site se met à jour en quelques minutes.',
      },
      {
        icon: 'shield',
        title: 'Posture de sécurité',
        body: 'Pas de base de données, pas de runtime PHP, pas de login admin. Le travail de sécurité se déplace vers le pipeline de build et vers le bord du cloud chinois, plutôt que vers un runtime à patcher chaque semaine.',
      },
    ],
  },
  {
    label: 'Performance et SEO',
    accent: 'emerald',
    items: [
      {
        icon: 'zap',
        title: 'Performance',
        body: 'Du HTML statique sur un CDN continental, c’est dur à battre. On vise un premier rendu utile sous la seconde sur un téléphone chinois milieu de gamme, et on l’atteint la plupart du temps.',
      },
      {
        icon: 'search',
        title: 'Baidu et recherche IA',
        body: 'Baidu n’indexe pas comme Google, donc on cale les métadonnées proprement, on configure Baidu Webmaster Tools et on structure le site pour que Doubao, Kimi, DeepSeek et Wenxin puissent le lire et le citer. Des fichiers en clair dans Git rendent les données structurées et le llms.txt faciles à générer.',
      },
    ],
  },
];

const fitBuckets = [
  {
    eyebrow: 'Astro convient',
    title: 'Sites marketing à interactivité légère',
    body: 'Un site marketing avec une petite vitrine produit, un formulaire de contact ou quelques widgets interactifs : c’est exactement pour ça qu’Astro a été conçu. Pages statiques, chargements rapides, JavaScript uniquement là où il a sa raison d’être.',
  },
  {
    eyebrow: 'WordPress convient mieux',
    title: 'E-commerce et éditorial quotidien',
    body: 'Des milliers de références gérées au quotidien par une équipe non technique, des dépendances profondes à des extensions, des équipes marketing qui vivent dans un page builder. WooCommerce sur WordPress reste la bonne réponse dans la plupart des cas.',
  },
  {
    eyebrow: 'Tout autre outil',
    title: 'Expériences proches d’une application',
    body: 'Tableaux de bord connectés, collaboration en temps réel, espaces sociaux, tout ce qui ressemble plus à une application qu’à un site. Au-delà de cette ligne, Next.js ou Remix sont mieux adaptés qu’Astro.',
  },
];

const chinaStack = [
  { name: 'Aliyun', cn: '阿里云', role: 'Hébergement' },
  { name: 'Tencent Cloud', cn: '腾讯云', role: 'Hébergement' },
  { name: 'Huawei Cloud', cn: '华为云', role: 'Hébergement' },
  { name: 'Baidu', cn: '百度', role: 'Recherche et SEO' },
  { name: 'WeChat', cn: '微信', role: 'Auth et messagerie' },
  { name: 'Alipay', cn: '支付宝', role: 'Paiements' },
];

const faqs = [
  {
    id: 'astro-icp',
    question: 'Notre site Astro a-t-il besoin d’une licence ICP pour fonctionner en Chine ?',
    answer: 'S’il est hébergé en Chine continentale, oui. Si l’hébergement passe par Hong Kong ou Cloudflare, non, mais le site sera mesurément plus lent pour les utilisateurs continentaux et Baidu le traitera comme un site étranger. Pour les marques sérieuses sur le marché chinois, le dépôt ICP vaut le coup.',
  },
  {
    id: 'astro-marketing-team',
    question: 'L’équipe marketing pourra-t-elle continuer à mettre à jour le site ?',
    answer: 'Cela dépend de la configuration retenue. Avec Markdown et les Content Collections, les modifications passent par Git et requièrent un développeur ou un utilisateur technique à l’aise. Avec un CMS headless connecté (Storyblok, Sanity, Decap), l’équipe éditoriale a une interface visuelle et met le site à jour sans toucher au code. Nous choisissons le bon modèle selon la façon dont l’équipe travaille vraiment.',
  },
  {
    id: 'astro-vs-wp-speed',
    question: 'Astro est-il vraiment plus rapide que WordPress en Chine ?',
    answer: 'En chiffres bruts, oui. Astro livre du HTML statique avec quasiment zéro JavaScript, ce qui réduit les transferts, accélère le parsing et limite les allers-retours serveur. Nous avons mesuré 40 à 60 % de Largest Contentful Paint en moins sur Astro par rapport à un WordPress comparable, sur le même hébergeur chinois.',
  },
  {
    id: 'astro-headless-cms',
    question: 'Peut-on utiliser un CMS headless avec Astro ?',
    answer: 'Oui, c’est l’un des modèles les plus solides d’Astro. Nous avons livré des sites avec Storyblok, Sanity, Decap et WordPress headless. Le CMS vit hors de Chine, là où les rédacteurs travaillent sans soucis de VPN, le frontend statique vit sur un serveur continental, le contenu se synchronise au build. L’équipe éditoriale garde l’interface qu’elle connaît et l’audience chinoise reçoit un site rapide.',
  },
  {
    id: 'astro-ecommerce',
    question: 'Et le e-commerce sur Astro ?',
    answer: 'Pour les catalogues petits à moyens (moins de cinq cents références), Astro s’associe bien au commerce headless : Shopify Storefront, Snipcart ou Stripe Checkout pour les paiements internationaux, plus des intégrations sur mesure pour Alipay et WeChat Pay côté consommateurs chinois. Pour le gros e-commerce avec des milliers de références et une équipe non technique qui pilote l’inventaire au quotidien, WooCommerce sur WordPress reste la bonne réponse dans la plupart des cas.',
  },
  {
    id: 'astro-multilingual',
    question: 'Comment Astro gère-t-il le multilingue côté Chine ?',
    answer: 'Astro intègre nativement le routage i18n, ce qui rend la cohabitation du chinois avec l’anglais, le français ou n’importe quelle autre langue propre et structurée. URL, balises hreflang et sitemaps par langue fonctionnent dès le départ. Nous avons livré des sites Astro à dix langues ou plus.',
  },
  {
    id: 'astro-migrate-wp',
    question: 'Peut-on migrer notre WordPress existant vers Astro ?',
    answer: 'Oui, et nous le faisons régulièrement. Le contenu est exporté de WordPress, restructuré en Content Collections Astro ou redirigé vers un CMS headless, et le design est reconstruit pour la nouvelle pile. Le délai habituel se situe entre quatre et huit semaines. Le résultat : un site plus rapide et des coûts de fonctionnement plus bas, mais on perd l’interface admin WordPress, sauf si on la conserve en backend headless.',
  },
  {
    id: 'astro-hosting',
    question: 'Quel hébergement utilisez-vous pour Astro en Chine ?',
    answer: 'Nous hébergeons sur Aliyun, Tencent Cloud ou Huawei Cloud selon le projet. Le build tourne hors de Chine sur un pipeline CI, le rendu statique est poussé vers l’hébergeur chinois, devant un CDN continental. Nous gérons le compte d’hébergement, le dépôt ICP et le pipeline de déploiement, donc votre équipe n’a jamais à se connecter à un panneau d’hébergeur chinois.',
  },
  {
    id: 'astro-maintenance',
    question: 'Quelle maintenance demande un site Astro ?',
    answer: 'Beaucoup moins qu’un WordPress, et de loin. Pas de base de données à sauvegarder, pas d’extensions à mettre à jour, pas de versions PHP à upgrader, pas de patchs de sécurité à appliquer toutes les deux semaines. Le framework lui-même reçoit quelques mises à jour par an, les dépendances méritent une revue de temps en temps, et c’est à peu près tout. Pour la plupart des sites marketing, une passe trimestrielle suffit.',
  },
  {
    id: 'astro-cloudflare',
    question: 'Et le rachat d’Astro par Cloudflare, ça change quoi pour la Chine ?',
    answer: 'Oui et non. L’investissement plus profond de Cloudflare signifie qu’Astro est désormais soutenu par une infrastructure de trente milliards de dollars, ce qui rassure les clients inquiets de la viabilité long terme. Le framework reste sous licence MIT et déployable n’importe où, y compris chez les fournisseurs cloud chinois. Le CDN propre de Cloudflare donne de mauvais résultats sur le continent, mais les sites Astro se déploient très bien sur Aliyun ou Tencent Cloud sans rien perdre en fonctionnalités.',
  },
];

const accentClasses: Record<string, { bg: string; text: string; border: string }> = {
  amber: { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20' },
  orange: { bg: 'bg-[var(--color-brand-orange)]/15', text: 'text-[var(--color-brand-orange)]', border: 'border-[var(--color-brand-orange)]/25' },
  sky: { bg: 'bg-sky-500/10', text: 'text-sky-300', border: 'border-sky-500/20' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20' },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-astro-china-skyline.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Astro</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <!-- Astro logo brand mark -->
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--color-brand-orange)] to-[#EF4444] flex items-center justify-center shadow-[0_8px_30px_rgba(242,95,41,0.4)]">
              <svg class="h-8 w-auto text-white" viewBox="0 0 85 107" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Astro logo">
                <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z"/>
                <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-[var(--color-brand-orange)] ring-2 ring-[#0f0f12] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/25">
              <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">Framework · Astro</span>
            </div>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Astro en Chine.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Conçu pour la vitesse.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Le framework frontend moderne pour les sites portés par le contenu. Statique d’abord, JavaScript proche de zéro, et très tolérant aux réseaux mobiles chinois lents.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            Repris par Cloudflare depuis janvier 2026. Nous concevons aussi bien Astro que WordPress, donc nous savons dire lequel convient.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Parler à notre équipe</Button>
            <Button href="/fr/wordpress/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">WordPress en Chine</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">astro-china-build</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Lighthouse</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100 / 100</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">JS livré</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">~0 Ko</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Edge</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Aliyun</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Dépôt ICP</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Déposé</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {stats.map((stat, i) => (
          <div class:list={[
            'flex flex-col md:flex-row items-start md:items-center gap-5',
            i > 0 ? 'md:pl-10 md:border-l md:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="flex-1">
              <p class="text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                {stat.source}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Works: editorial split with code editor image -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Pourquoi ça marche
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Du HTML statique, sans bagarre avec le Pare-feu.
          </h2>
