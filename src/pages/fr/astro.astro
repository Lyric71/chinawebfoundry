---
import PageLayout from '../../layouts/PageLayout.astro';

const metaTitle = 'Astro';
const metaDescription = 'Astro';
---

<PageLayout title={metaTitle} description={metaDescription} lang="fr">
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <h1 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
        Astro
      </h1>
    </div>
  </section>
</PageLayout>
