---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import FAQItem from '../../components/pages/FAQItem.astro';
import ScrollEffects from '../../components/global/ScrollEffects.astro';

const metaTitle = 'WeChat en Chine | Mini Programs et sites H5 | ChinaWebFoundry';
const metaDescription = 'Mini Programs et sites H5 WeChat pour les marques étrangères en Chine. Stratégie, dépôt Tencent, développement, mise en ligne. Tout est mené depuis Shanghai.';

const compareRows = [
  { label: 'Là où ça vit', mp: 'À l’intérieur de WeChat, comme une appli native', h5: 'Dans le navigateur intégré à WeChat, et au-delà' },
  { label: 'WeChat Pay', mp: 'Oui, intégration complète', h5: 'Limité, suppose un compte officiel lié' },
  { label: 'API natives', mp: 'Caméra, géolocalisation, scan, identification', h5: 'Limité au navigateur' },
  { label: 'Délais de production', mp: '10 à 14 semaines', h5: '4 à 6 semaines' },
  { label: 'Cas d’usage', mp: 'Fidélité, e-commerce, service', h5: 'Campagnes, brochures, captation de prospects' },
];

const useCases = [
  {
    title: 'Programmes de fidélité',
    body: 'Le cas d’usage le plus fréquent chez les marques étrangères. Le Mini Program porte la carte, suit les points, délivre les récompenses. Starbucks Chine y fait tourner l’intégralité de son programme d’adhésion.',
  },
  {
    title: 'Expérience de marque',
    body: 'Pour le luxe, la beauté, l’art de vivre : un univers éditorial maîtrisé. Films de campagne, récit du fondateur, encyclopédies produit, localisateur de boutiques, essayage virtuel, le tout dans WeChat.',
  },
  {
    title: 'D2C et directs sur Channels',
    body: 'Vendre en direct sans verser de commission à Tmall ou JD. Mini Program couplé à WeChat Pay, alimenté par le trafic privé des groupes communautaires et les directs sur Channels.',
  },
  {
    title: 'Précommandes et lancements',
    body: 'Pour les sorties saisonnières ou les lancements, le tunnel de précommande reste à l’intérieur de WeChat. Pas de site externe à ouvrir, pas de friction, des conversions nettement plus élevées.',
  },
  {
    title: 'Service après-vente et CRM',
    body: 'SAV, garantie, prise de rendez-vous, support technique. Le client ne télécharge aucune appli et n’a aucun mot de passe à retenir.',
  },
  {
    title: 'Brochures et catalogues B2B',
    body: 'Un H5 ou un Mini Program catalogue rend plus de service qu’un PDF. Les commerciaux le partagent en conversation, les prospects le parcourent directement depuis le fil de discussion.',
  },
];

const faqs = [
  {
    id: 'mp-vs-h5',
    question: 'Mini Program ou H5, comment trancher ?',
    answer: 'Mini Program si vous avez besoin de WeChat Pay, d’un programme de fidélité, d’API natives ou d’un usage récurrent. H5 quand il s’agit d’une campagne courte ou d’un lien à partager hors de WeChat. La plupart des marques finissent par déployer les deux.',
  },
  {
    id: 'foreign-entity',
    question: 'Peut-on déposer un Mini Program sans entité chinoise ?',
    answer: 'Pas pour un Mini Program complet. Tencent exige une entité enregistrée en Chine continentale et une licence ICP. On orchestre l’enchaînement avec un partenaire local quand l’entité n’est pas encore en place.',
  },
  {
    id: 'timeline',
    question: 'Combien de temps pour mettre en ligne ?',
    answer: 'Mini Program e-commerce : 10 à 14 semaines, dépôt et certification inclus. Site H5 : 4 à 6 semaines. La phase la plus longue reste l’audit Tencent, à anticiper dès le brief.',
  },
  {
    id: 'maintenance',
    question: 'Et après la mise en ligne ?',
    answer: 'Supervision, mises à jour Tencent, ajustements du programme de fidélité, rafraîchissement des contenus, pilotage des campagnes Channels. Au forfait mensuel, depuis Shanghai.',
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <section class="relative bg-[#07090a] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-wechat-loyalty-consumer.webp" alt="Une jeune Chinoise dans un café de Shanghai utilise un Mini Program de fidélité de marque sur WeChat depuis son smartphone" class="absolute inset-0 w-full h-full object-cover object-right" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#07090a] via-[#07090a]/92 via-35% to-[#07090a]/10"></div>
      <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[#07090a] to-transparent"></div>
      <div class="absolute top-1/2 right-[20%] w-[500px] h-[500px] -translate-y-1/2 bg-emerald-500/12 rounded-full blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">WeChat</li>
        </ol>
      </nav>

      <div class="grid grid-cols-12 gap-8 items-center pb-24 md:pb-32 lg:pb-40 pt-8 lg:pt-16">
        <div class="col-span-12 lg:col-span-7 xl:col-span-7">
          <div class="flex items-center gap-4 mb-8">
            <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center shadow-[0_8px_30px_rgba(16,185,129,0.4)]">
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor" aria-label="WeChat logo">
                <path d="M8.691 2C4.768 2 1.5 4.667 1.5 8.052c0 1.952 1.099 3.687 2.815 4.9-.105.34-.504 1.563-.683 2.099-.234.683.402.456.402.456.235-.067 1.95-1.214 2.703-1.69.703.222 1.45.34 2.243.34.247 0 .49-.012.731-.033-.156-.494-.241-1.02-.241-1.566 0-3.146 2.987-5.703 6.661-5.703.085 0 .169.001.252.003C15.16 4.108 12.205 2 8.691 2zM6.087 6.65a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm5.118 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2zM22.5 14.36c0-2.802-2.71-5.082-6.057-5.082-3.451 0-6.057 2.28-6.057 5.082 0 2.804 2.606 5.082 6.057 5.082.66 0 1.297-.092 1.895-.262.62.39 2.034 1.343 2.232 1.4 0 0 .518.207.328-.42-.155-.46-.485-1.475-.572-1.748a4.86 4.86 0 0 0 2.174-4.052zm-7.857-.965a.842.842 0 1 1 0-1.683.842.842 0 0 1 0 1.683zm3.6 0a.842.842 0 1 1 0-1.683.842.842 0 0 1 0 1.683z"/>
              </svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 ring-2 ring-[#07090a] animate-pulse"></span>
            </div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/25">
              <span class="text-xs font-semibold uppercase tracking-wider text-emerald-300">Technologie · 微信</span>
            </div>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[72px] xl:text-[84px] font-medium font-[var(--font-heading)] text-white leading-[0.98] tracking-tight">
            WeChat, le système d’exploitation
            <span class="block mt-2 text-[var(--color-brand-orange)]">du quotidien chinois.</span>
          </h1>
          <p class="mt-10 text-lg lg:text-xl text-white/65 max-w-xl leading-relaxed">
            1,4 milliard de personnes ouvrent WeChat des dizaines de fois par jour. Conversations, paiements, cartes de fidélité, achats, lien à la marque : tout vit à l’intérieur d’une seule appli.
          </p>
          <p class="mt-4 text-base text-white/45 max-w-xl leading-relaxed">
            Nous concevons des Mini Programs et des sites H5 pour les marques étrangères. Vingt ans à Shanghai.
          </p>

          <div class="mt-12 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Parler à notre équipe</Button>
            <Button href="/fr/services/strategy-audit/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Démarrer par la stratégie</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative bg-white border-b border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding py-12 lg:py-14">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10 items-center">
        <div class="col-span-12 lg:col-span-5 lg:border-r lg:border-[var(--color-surface-border)] lg:pr-10">
          <div class="flex items-baseline gap-3">
            <span class="text-7xl lg:text-[120px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count="1.41" data-count-suffix="">0</span>
            <span class="text-4xl lg:text-6xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none">Md</span>
          </div>
          <p class="mt-4 text-lg text-[var(--color-text-dark)] font-medium leading-snug">
            d’utilisateurs actifs mensuels sur WeChat en 2025.
          </p>
          <p class="mt-1 text-sm text-[var(--color-text-muted)]">Résultats Tencent T4 2024.</p>
        </div>

        <div class="col-span-12 lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div>
            <div class="flex items-baseline gap-2">
              <span class="text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none tabular-nums" data-count="945" data-count-suffix="">0</span>
              <span class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none">M</span>
            </div>
            <p class="mt-3 text-sm text-[var(--color-text-body)] leading-snug">
              utilisateurs mensuels de Mini Programs
            </p>
            <p class="text-xs text-[var(--color-text-muted)] mt-1">QuestMobile, 2025</p>
          </div>
          <div>
            <div class="flex items-baseline gap-2">
              <span class="text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none tabular-nums" data-count="79" data-count-suffix="">0</span>
              <span class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-none">min</span>
            </div>
            <p class="mt-3 text-sm text-[var(--color-text-body)] leading-snug">
              passées dans WeChat par utilisateur chinois, chaque jour
            </p>
            <p class="text-xs text-[var(--color-text-muted)] mt-1">Rapport annuel QuestMobile</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-white">
    <div class="mx-auto max-w-[1200px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Mini Program ou H5</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Deux briques, deux usages, à choisir selon le projet.
        </h2>
      </div>

      <div class="overflow-x-auto rounded-2xl border border-[var(--color-surface-border)]">
        <table class="w-full text-left">
          <thead class="bg-[var(--color-surface-light)]">
            <tr>
              <th class="px-6 py-4 text-sm font-semibold text-[var(--color-text-muted)]"></th>
              <th class="px-6 py-4 text-sm font-semibold text-[var(--color-text-dark)]">Mini Program</th>
              <th class="px-6 py-4 text-sm font-semibold text-[var(--color-text-dark)]">Site H5</th>
            </tr>
          </thead>
          <tbody>
            {compareRows.map((row, i) => (
              <tr class:list={[i % 2 === 1 ? 'bg-[var(--color-surface-light)]/50' : 'bg-white']}>
                <td class="px-6 py-4 text-sm font-medium text-[var(--color-text-muted)]">{row.label}</td>
                <td class="px-6 py-4 text-sm text-[var(--color-text-body)]">{row.mp}</td>
                <td class="px-6 py-4 text-sm text-[var(--color-text-body)]">{row.h5}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="py-24 md:py-32 bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Cas d’usage</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Ce que nos clients confient à WeChat.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {useCases.map((u) => (
          <article class="bg-white rounded-2xl border border-[var(--color-surface-border)] p-7 transition-all duration-300 hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_20px_40px_-20px_rgba(0,0,0,0.18)] hover:-translate-y-1">
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3 leading-snug">
              {u.title}
            </h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">
              {u.body}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 md:py-32 bg-white">
    <div class="mx-auto max-w-[1100px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">FAQ</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Quatre questions qui reviennent.
        </h2>
      </div>

      <div data-faq-accordion>
        {faqs.map((faq) => (
          <FAQItem question={faq.question} id={faq.id}>
            <p>{faq.answer}</p>
          </FAQItem>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-[var(--color-surface-dark)]">
    <div class="mx-auto max-w-[1100px] section-padding text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.1] mb-6">
        Vous démarrez sur WeChat, ou vous reprenez en main un projet bloqué ?
      </h2>
      <p class="text-lg text-white/70 leading-relaxed mb-10 max-w-2xl mx-auto">
        Décrivez-nous le périmètre. Nous revenons sous 24 heures avec un cadrage clair et un calendrier réaliste.
      </p>
      <Button href="/fr/contact/" variant="primary" size="lg">Nous écrire</Button>
    </div>
  </section>

</PageLayout>
