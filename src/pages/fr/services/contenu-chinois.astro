// Trust phrases for the marquee
const marqueePhrases = [
  '荣誉资质', 'Honneurs',
  '企业历程', 'Histoire',
  '生产基地', 'Site',
  '质量认证', 'Qualité',
  '合作伙伴', 'Partenaires',
  '媒体报道', 'Médias',
  '新闻动态', 'Actualités',
  'Conforme 广告法',
  'Indexé Baidu',
  'Prêt pour l’IA',
];

const faqs = [
  {
    id: 'just-translate',
    question: 'Peut-on se contenter de traduire notre contenu anglais existant ?',
    answer: [
      "C’est techniquement possible, et beaucoup de marques étrangères tentent le coup. Le résultat tient rarement. La traduction donne des mots ; construire une marque en chinois réclame un jugement éditorial à chaque page. Le lecteur chinois s’en aperçoit dès le premier paragraphe, Baidu dès le premier passage de son robot. Si le budget ne couvre que la traduction, nous le disons franchement : mieux vaut attendre d’avoir les moyens de faire les choses bien.",
    ],
  },
  {
    id: 'translation-vs-transcreation',
    question: 'Quelle différence entre traduction, transcréation et ce que vous faites ?',
    answer: [
      "La traduction fait passer des mots d’une langue à l’autre. La transcréation réécrit le message pour la culture visée tout en gardant la voix de marque. Notre travail commence avant les deux : nous décidons d’abord ce que votre marque a à dire au public chinois, puis nous l’écrivons en chinois, depuis la page blanche.",
    ],
  },
  {
    id: 'rebuild-from-scratch',
    question: 'Faut-il tout reconstruire depuis zéro ?',
    answer: [
      "Pas toujours. Sur l’ensemble de nos missions, un tiers environ repart des pages cœur de marque et des pages produit déjà en place. Un autre tiers recommence vraiment de zéro. Le dernier garde une partie du contenu existant comme matière première et reconstruit autour. C’est la Stratégie et Audit menée en amont qui tranche, cas par cas.",
    ],
  },
  {
    id: 'who-writes',
    question: 'Qui écrit réellement le contenu ?',
    answer: [
      "Des éditeurs chinois natifs, basés à Shanghai. Mandarin langue maternelle, toute une carrière dans le contenu commercial, sans exception. Un rédacteur senior sur chaque texte, à chaque fois. Et chaque page passe par notre revue éditoriale interne avant d’arriver entre vos mains.",
    ],
  },
  {
    id: 'brand-voice',
    question: 'Pouvez-vous tenir notre voix de marque en chinois ?',
    answer: [
      "Oui, en la reconstruisant plutôt qu’en la décalquant. Nous partons de votre charte mondiale et d’un échantillon de vos meilleurs textes, puis nous rebâtissons la voix en chinois, avec les registres et les images qui lui correspondent. Le résultat se lit comme la même marque, dans une autre langue.",
    ],
  },
  {
    id: 'design-development',
    question: 'Où se situe le contenu par rapport au design et au développement ?',
    answer: [
      "Avant les deux. C’est l’architecture de l’information qui commande le design. Nous livrons d’abord l’architecture et la structure de contenu ; le design suit, le développement bâtit derrière. Inverser cet ordre est l’une des raisons les plus fréquentes pour lesquelles les sites de marques étrangères sonnent faux en Chine.",
    ],
