const stages = [
  {
    n: '01',
    cn: '调研',
    title: 'Découverte et recherche sectorielle',
    body: "Audit de trois à cinq concurrents directs, lecture de ce qui se dit dans la catégorie sur Baidu, Zhihu (知乎) et les sites professionnels qui comptent. À la clé, une stratégie de contenu écrite : ce que la marque doit dire, ce qu’elle doit éviter, et l’angle encore libre à occuper.",
    output: 'Stratégie écrite',
  },
  {
    n: '02',
    cn: '架构',
    title: 'Architecture de l’information',
    body: "Plan de site et hiérarchie de pages conçus pour le lecteur chinois, avec d’emblée les pages de confiance, les espaces éditoriaux et la structure d’URL attendue par Baidu. Le tout livré sous forme de document d’architecture, pour que le design et le développement sachent exactement quoi bâtir.",
    output: 'Document d’architecture + sitemap',
  },
  {
    n: '03',
    cn: '撰写',
    title: 'Rédaction en chinois natif',
    body: 'Place aux éditeurs chinois. Ils écrivent en mandarin à partir de la stratégie, dans votre voix de marque, reconstruite pour ce lecteur.',
