    cn: '官网内容',
    body: 'La colonne vertébrale de la marque.',
    items: ['Accueil', 'À propos', 'Récit de marque', 'Récit du fondateur', 'Équipe', 'Histoire', 'Honneurs', 'Qualité', 'Site', 'Partenaires', 'Contact'],
    feature: true,
  },
  {
    label: 'Contenu produit et catégorie',
