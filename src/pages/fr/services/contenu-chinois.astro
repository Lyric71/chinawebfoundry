const audiences = [
  {
    label: 'Marques qui se lancent en Chine pour la première fois',
    description: 'Des sociétés qui prennent leurs premières décisions de contenu en Chine : quoi dire, dans quel ordre, et quelle figure de marque incarner sur ce marché.',
    image: '/images/audiences/launching-chinese-website.webp',
  },
  {
    label: 'Marques qui relancent après un échec de traduction',
    description: 'Des sites étrangers dont les pages chinoises stagnent depuis deux ou trois ans, pendant que les positions Baidu s’érodent. Le vrai levier est du côté du contenu, bien avant le design.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marques avec un site chinois sans rythme éditorial',
    description: 'Des entreprises qui ont lancé un site puis n’ont jamais mis en route la machine éditoriale, et qui s’étonnent aujourd’hui d’avoir disparu des radars de Baidu.',
