---
import PageLayout from '../../../layouts/PageLayout.astro';
import { serviceSchema } from '../../../lib/schema';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

import { getEntry } from 'astro:content';
const service = (await getEntry('services-fr', 'chinese-content'))!;
const metaTitle = service.data.metaTitle;
const metaDescription = service.data.metaDescription;

// What to Write: 5 differences with paired "default vs reality" data
const differences = [
  {
    n: '01',
    cn: '信任',
    title: 'Les signaux de confiance ne sont plus les mêmes',
    body: "Le lecteur chinois réclame exactement ce que les équipes étrangères reléguent d’instinct : crédibilité du fondateur, année de création, lieu de production, certifications, partenaires, prix obtenus, clients connus, reprises dans la presse, taille de l’équipe. Devant un bandeau épuré, trois puces et beaucoup de blanc, il voit une page vide. Et il en déduit une marque petite, récente, ou qui cache quelque chose.",
    westernLabel: 'Bandeau à trois puces',
    westernSub: '« Bâtir mieux. Plus vite. Ensemble. »',
    chineseLabel: 'Panneau de confiance dense',
