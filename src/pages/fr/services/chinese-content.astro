---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

const metaTitle = 'Contenu chinois · quoi écrire, comment le structurer · ChinaWebFoundry';
const metaDescription = "Quoi écrire et comment structurer votre site chinois. Des éditeurs natifs chinois posent contenu, architecture et signaux de confiance avant la première ligne de code.";

// What to Write: 5 differences with paired "default vs reality" data
const differences = [
  {
    n: '01',
    cn: '信任',
    title: 'Les signaux de confiance changent de nature',
    body: "Les lecteurs chinois cherchent ce que les équipes étrangères sous-pondèrent : crédibilité du fondateur, année de création, lieu de production, certifications, partenariats, prix, clients référencés, couverture presse, taille de l’équipe. Un bandeau d’accueil épuré, trois puces et beaucoup de blanc, donne au lecteur chinois l’impression d’une page vide. Il en conclut que la marque est petite, jeune, ou qu’elle cache quelque chose.",
    westernLabel: 'Bandeau à trois puces',
    westernSub: '« Bâtir mieux. Plus vite. Ensemble. »',
    chineseLabel: 'Panneau de confiance dense',
    chineseSub: 'Création · Site · Partenaires · Prix · Médias',
  },
  {
    n: '02',
    cn: '决策',
    title: 'Le cadre de décision change',
    body: "La rhétorique occidentale ouvre sur l’aspiration. Le lecteur chinois achète sur une autre séquence : preuve concrète d’abord, crédibilité ensuite, aspiration à la fin. Même contenu, autre ordre, la lecture passe de plaquette commerciale à marque crédible.",
    westernLabel: 'Aspiration → preuve',
    westernSub: 'Vision, puis caractéristiques, puis cas',
    chineseLabel: 'Preuve → crédibilité → aspiration',
    chineseSub: 'Caractéristiques d’abord, partenaires ensuite, vision à la fin',
  },
  {
    n: '03',
    cn: '语言',
    title: 'La langue de la catégorie se réécrit en chinois',
    body: "Une liste de mots-clés SEO traduite passe à côté des formulations que les internautes chinois saisissent vraiment dans Baidu. On mène la recherche directement en chinois, depuis la page blanche, avant la première ligne rédigée.",
    westernLabel: 'Mots-clés traduits',
    westernSub: '« enterprise software solutions »',
    chineseLabel: 'Intention native',
    chineseSub: '企业级软件 / SaaS服务 / 数字化解决方案',
  },
  {
    n: '04',
    cn: '形式',
    title: 'Le format se densifie',
    body: "Long, dense, défilable. Les pages produit chinoises font régulièrement trois à cinq fois la longueur de leurs équivalents occidentaux. Côté chinois, la densité d’information rassure : elle se lit comme un signal de confiance que la marque assume.",
    westernLabel: 'Minimaliste, espaces blancs',
    westernSub: 'Une affirmation par défilement',
    chineseLabel: 'Long, dense',
    chineseSub: '3 à 5 fois la longueur de la page occidentale',
  },
  {
    n: '05',
    cn: '法律',
    title: 'La loi sur la publicité impose ses règles',
    body: "La loi chinoise sur la publicité (广告法) encadre des formulations que les marques étrangères emploient sans y penser. Les superlatifs du type « le meilleur » ou « le premier » (最, 第一, 最佳) tombent sous restriction. Les secteurs sensibles, médical, financier, alimentaire, cosmétique, ont chacun leurs règles propres. On écrit en conformité dès la première ligne.",
    westernLabel: 'Superlatifs partout',
    westernSub: '« Leader mondial. Premier de la classe. »',
    chineseLabel: 'Discours conforme à 广告法',
    chineseSub: 'Précis, sourcé, audité',
  },
];

// IA comparison data
const foreignIA = [
  { label: 'Accueil', primary: true },
  { label: 'À propos' },
  { label: 'Produits' },
  { label: 'Ressources' },
  { label: 'Contact' },
];

const chineseIA = [
  { label: '首页 / Accueil', primary: true },
  { label: 'Récit de marque', highlight: true },
  { label: 'Honneurs et distinctions 荣誉资质', highlight: true },
  { label: 'Histoire de l’entreprise 企业历程', highlight: true },
  { label: 'Secteurs / Solutions' },
  { label: 'Cas et clients', highlight: true },
  { label: 'Produits' },
  { label: 'Site de production 生产基地', highlight: true },
  { label: 'Partenaires 合作伙伴', highlight: true },
  { label: 'Actualités 新闻动态', highlight: true },
  { label: 'Contact' },
];

const structurePoints = [
  {
    n: '01',
    title: 'Une hiérarchie de pages que le lecteur chinois attend',
    body: "Les sites étrangers s’ouvrent sur Accueil, À propos, Produits, Ressources, Contact. Les sites chinois ouvrent souvent sur la crédibilité de la marque, puis l’éducation à la catégorie, puis la preuve, puis le produit. L’ordre épouse la manière dont un lecteur chinois aborde une marque qu’il ne connaît pas encore.",
  },
  {
    n: '02',
    title: 'Les pages de confiance que les marques étrangères oublient',
    body: "Honneurs et distinctions (荣誉资质). Histoire de l’entreprise (企业历程). Site de production ou bureau (生产基地). Certifications qualité (质量认证). Partenaires majeurs (合作伙伴). Mentions presse (媒体报道). Actualités (新闻动态). Standard sur les sites chinois, quasi systématiquement oublié par les sites étrangers qui entrent en Chine. On les intègre dès la conception.",
  },
  {
    n: '03',
    title: 'Une structure d’URL et de contenu compatible Baidu',
    body: "Baidu indexe le contenu original et structuré, fraîchement publié, sur un domaine principal unique. On conçoit des schémas d’URL lisibles par le crawler, un maillage interne qui distribue l’autorité, un rythme éditorial qui signale un site vivant.",
  },
  {
    n: '04',
    title: 'Une structure pensée pour la recherche IA',
    body: "Doubao, Kimi, DeepSeek et Wenxin lisent le contenu autrement que Baidu. Ils valorisent la structure factuelle nette, le balisage Schema, les fichiers llms.txt, et un contenu calé sur la manière dont un utilisateur formule sa question à voix haute. On écrit avec les deux couches en tête. Les marques qui posent les fondations en 2026 seront celles que les IA citent en 2027 et 2028.",
  },
  {
    n: '05',
    title: 'Une cadence éditoriale inscrite dans la structure',
    body: "Un site qui n’a rien publié depuis six mois sort des classements Baidu. L’architecture doit ménager des surfaces où le contenu pourra continuer d’arriver : une vraie section actualités, une base de connaissances, un blog éditorial, des récits clients. On bâtit ces espaces dès la mise en ligne, même si le contenu d’amorce reste léger.",
  },
];

const contentTypes = [
  {
    label: 'Contenu cœur du site',
    cn: '官网内容',
    body: 'La colonne vertébrale de la marque.',
    items: ['Accueil', 'À propos', 'Récit de marque', 'Récit du fondateur', 'Équipe', 'Histoire', 'Honneurs', 'Qualité', 'Site', 'Partenaires', 'Contact'],
    feature: true,
  },
  {
    label: 'Contenu produit et catégorie',
    cn: '产品内容',
    body: 'Pages produit longues, fiches techniques détaillées, scénarios d’usage.',
  },
  {
    label: 'Contenu éditorial et SEO',
    cn: '内容运营',
    body: 'Articles de blog, base de connaissances, analyses sectorielles, guides pratiques pour la visibilité Baidu et IA.',
  },
  {
    label: 'Contenu de preuve et de confiance',
    cn: '品牌背书',
    body: 'Études de cas, récits clients, fiches partenaires, annonces de prix, mentions presse.',
  },
  {
    label: 'Contenu de conversion',
    cn: '转化页面',
    body: 'Pages d’atterrissage payantes, aimants à prospects, livres blancs, formulaires de contact.',
  },
  {
    label: 'Contenu écosystème WeChat',
    cn: '微信生态',
    body: 'Mini-sites H5, contenu Mini Programmes, briefs d’articles pour Comptes officiels.',
  },
];

const stages = [
  {
    n: '01',
    cn: '调研',
    title: 'Découverte et recherche sectorielle',
    body: "On audite trois à cinq concurrents directs, plus les conversations de la catégorie sur Baidu, Zhihu (知乎) et les sites professionnels pertinents. Livrable : une stratégie de contenu écrite, qui nomme ce que la marque doit dire, ce qu’elle doit éviter, et où se loge l’angle libre.",
    output: 'Stratégie écrite',
  },
  {
    n: '02',
    cn: '架构',
    title: 'Architecture de l’information',
    body: "Plan de site et hiérarchie de pages pensés pour le lecteur chinois, avec les pages de confiance, les surfaces éditoriales et la structure d’URL Baidu déjà intégrées. Livré sous forme de document d’architecture, pour que design et développement sachent quoi bâtir.",
    output: 'Document d’architecture + sitemap',
  },
  {
    n: '03',
    cn: '撰写',
    title: 'Rédaction en chinois natif',
    body: 'Des éditeurs chinois prennent la plume. Ils écrivent en mandarin à partir de la stratégie, dans votre voix de marque, recomposée pour le lecteur chinois.',
    output: 'Premiers jets page par page',
  },
  {
    n: '04',
    cn: '迭代',
    title: 'Revue éditoriale et publication',
    body: "Chaque pièce passe par la revue interne : voix de marque, exactitude factuelle, structure SEO, conformité 广告法. Après publication, on suit la performance sur Baidu et sur les IA, et on retravaille les pages qui sous-performent. Publier puis oublier ne fonctionne pas en Chine.",
    output: 'Performance mensuelle + révisions',
  },
];

const audiences = [
  {
    label: 'Marques qui se lancent en Chine pour la première fois',
    description: 'Sociétés qui jouent leurs premières décisions de contenu : quoi dire, comment l’ordonner, quelle figure de marque incarner sur le marché chinois.',
    image: '/images/audiences/launching-chinese-website.webp',
  },
  {
    label: 'Marques qui relancent après un échec de traduction',
    description: 'Sites étrangers dont les pages chinoises sont restées en l’état deux ou trois ans, avec des positions Baidu qui dérivent. Le levier réel se trouve côté contenu, avant même de toucher au design.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marques avec un site chinois sans rythme éditorial',
    description: 'Entreprises qui ont lancé un site puis n’ont jamais mis en place la machine éditoriale, et qui se demandent pourquoi Baidu les a oubliées.',
    image: '/images/audiences/ongoing-chinese-editorial.webp',
  },
  {
    label: 'B2B avec profondeur technique',
    description: 'Industrie, sciences de la vie, pharmacie, services B2B. Besoin d’un contenu chinois long, factuellement précis, techniquement solide.',
    image: '/images/audiences/campaign-chinese-copy.webp',
  },
  {
    label: 'Luxe et marques premium',
    description: 'Marques pour lesquelles les signaux de confiance, le récit du fondateur, l’héritage et l’ancrage culturel pèsent dans la décision d’achat.',
    image: '/images/audiences/ecommerce-product-pages-china.webp',
  },
];

// Trust phrases for the marquee
const marqueePhrases = [
  '荣誉资质', 'Honneurs',
  '企业历程', 'Histoire',
  '生产基地', 'Site',
  '质量认证', 'Qualité',
  '合作伙伴', 'Partenaires',
  '媒体报道', 'Médias',
  '新闻动态', 'Actualités',
  'Conforme 广告法',
  'Indexé Baidu',
  'Prêt pour l’IA',
];

const faqs = [
  {
    id: 'just-translate',
    question: 'Peut-on simplement traduire notre contenu anglais existant ?',
    answer: [
      "Possible, et beaucoup de marques étrangères s’y essaient. Le résultat ne tient presque jamais. La traduction produit des mots ; bâtir une marque en chinois exige un jugement éditorial. Le lecteur chinois le voit dès le premier paragraphe. Baidu le voit dès le crawl. Si le budget ne couvre que la traduction, notre conseil honnête est d’attendre d’avoir les moyens de faire les choses correctement.",
    ],
  },
  {
    id: 'translation-vs-transcreation',
    question: 'Quelle différence entre traduction, transcréation et ce que vous faites ?',
    answer: [
      "La traduction convertit des mots d’une langue à l’autre. La transcréation réécrit le message pour la culture cible en gardant la voix de marque. Notre travail démarre en amont des deux. On commence par trancher ce que votre marque doit dire au public chinois, puis on l’écrit en chinois, depuis la page blanche.",
    ],
  },
  {
    id: 'rebuild-from-scratch',
    question: 'Faut-il tout reconstruire depuis zéro ?',
    answer: [
      "Pas toujours. Sur l’ensemble de nos missions, environ un tiers reprend les pages cœur de marque et les pages produit. Un autre tiers démarre vraiment de zéro. Le dernier tiers récupère une partie du contenu existant comme matière première et reconstruit autour. La Stratégie et Audit menée en amont tranche.",
    ],
  },
  {
    id: 'who-writes',
    question: 'Qui écrit réellement le contenu ?',
    answer: [
      "Des éditeurs natifs chinois basés à Shanghai. Des personnes dont le mandarin est la langue maternelle et qui ont fait carrière dans le contenu commercial. Rédacteurs seniors, sur chaque pièce, à chaque fois. Chaque page passe par une revue éditoriale interne avant de vous parvenir.",
    ],
  },
  {
    id: 'brand-voice',
    question: 'Pouvez-vous coller à notre voix de marque ?',
    answer: [
      "Oui, par reconstruction. On travaille à partir de votre charte mondiale et d’un échantillon de vos meilleurs contenus, puis on reconstruit la voix en chinois avec des registres et des figures équivalents. Le résultat se lit comme la même marque, dans une autre langue.",
    ],
  },
  {
    id: 'design-development',
    question: 'Où se situe le contenu vis-à-vis du design et du développement ?',
    answer: [
      "En amont des deux. L’architecture de l’information décide du design. On livre l’architecture et la structure de contenu d’abord, le design suit, le développement bâtit derrière. Inverser cet ordre est l’une des raisons les plus courantes pour lesquelles les sites de marques étrangères en Chine sentent le forçage.",
    ],
  },
  {
    id: 'baidu-seo',
    question: 'Comment cela s’articule avec le SEO Baidu ?',
    answer: [
      "Étroitement. Un SEO Baidu solide démarre par une carte de mots-clés bâtie directement en chinois, puis une architecture éditoriale calée sur l’intention de recherche, puis du contenu rédigé autour de ces sujets. Nos équipes contenu et SEO Baidu fonctionnent comme une seule. La plupart des clients prennent les deux en une seule mission.",
    ],
  },
  {
    id: 'ai-search',
    question: 'Et la visibilité sur les IA chinoises Doubao, Kimi, DeepSeek ?',
    answer: [
      "On structure le contenu pour les IA dès le départ. Réponses factuelles propres, balisage Schema, fichiers llms.txt, contenu calé sur la manière dont les utilisateurs chinois formulent leurs questions à voix haute. Les marques qui s’y prennent bien en 2026 seront celles que les IA citent en 2027.",
    ],
  },
  {
    id: 'ongoing-publishing',
    question: 'Pilotez-vous aussi la publication continue ou seulement le contenu de lancement ?',
    answer: [
      "Les deux, et nous recommandons la seconde voie. Lancer un site puis ne plus jamais y toucher reste la première cause de perte de visibilité Baidu chez les marques étrangères. La plupart de nos clients enchaînent du contenu de lancement vers un forfait éditorial mensuel.",
    ],
  },
  {
    id: 'cost',
    question: 'Quel coût ?',
    answer: [
      "Cela dépend du périmètre : refonte ou nouveau site, nombre de pages, cadence éditoriale, intégration ou non du SEO Baidu et de l’optimisation IA. Décrivez-nous le périmètre, nous revenons sous deux jours ouvrés avec un chiffre ferme.",
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-chinese-content.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <!-- Massive decorative Chinese character -->
    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">写</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <!-- Breadcrumbs -->
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Contenu chinois</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <!-- Text -->
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Contenu chinois</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Éditeurs natifs, Shanghai</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Quoi écrire.
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Comment le structurer.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">中文.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            La traduction donne des mots. Bâtir une marque en chinois exige un jugement éditorial. On tranche ce que votre marque doit dire en chinois, comment le site doit s’ordonner autour, et on l’écrit. <span class="text-white font-medium">Des éditeurs qui rédigent en mandarin.</span>
          </p>

          <!-- Stat row -->
          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">15</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Années d’édition</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">50</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Marques lancées</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">SH</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Équipe Shanghai</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Parler à l’équipe</Button>
            <Button href="#structure" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir comment on écrit</Button>
          </div>
        </div>

        <!-- Visual: layered comparison mockup -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Translated card (back, faded) -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Traduit</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">EN → ZH</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Position Baidu : en perte
              </div>
            </div>

            <!-- Native card (front, sharp) -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-green-500/15 border border-green-400/30">
                  <span class="w-1 h-1 rounded-full bg-green-400"></span>
                  <span class="text-[10px] font-mono text-green-300 uppercase tracking-wider">ZH natif</span>
                </span>
                <span class="ml-auto text-[10px] font-mono text-white/40">brand-cn.md</span>
              </div>

              <div class="space-y-3.5 font-[var(--font-heading)]">
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H1</span>
                  <span class="text-[15px] text-white font-medium">内容即品牌</span>
                </div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[11px] text-white/40 font-mono">H2</span>
                  <span class="text-[13px] text-white/85">荣誉资质 · 企业历程 · 生产基地</span>
