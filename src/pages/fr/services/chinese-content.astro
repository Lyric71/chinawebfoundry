---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import CaseStudyCards from '../../../components/ui/CaseStudyCards.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Contenu chinois pour sites WordPress | ChinaWebFoundry';
const metaDescription = 'Rédaction chinoise native, transcréation et pilotage éditorial pour WordPress en Chine. Du contenu optimisé Baidu, signé par des plumes locales. Agence implantée à Shanghai.';

const offerings = [
  {
    title: 'Stratégie de contenu pour la Chine',
    body: 'Avant qu\'un seul caractère ne soit écrit, nous devons identifier ce qui portera ses fruits. Cela passe par la recherche de mots-clés, pas par la traduction de votre liste anglaise. Les internautes chinois cherchent avec leurs formulations, leur argot, leurs raccourcis. Une fois sur deux, les termes les plus rentables n\'ont pas d\'équivalent anglais. Une fois les requêtes posées, nous bâtissons l\'architecture du contenu : quelles pages créer, comment les relier, ce que Baidu attend côté structure. Nous calons ensuite votre calendrier éditorial sur les temps forts commerciaux chinois. Tout le monde connaît le Nouvel An chinois, mais le Singles\' Day, le festival 618, la Mi-Automne, la Semaine dorée... c\'est là que le trafic explose. Mieux vaut un contenu prêt avant l\'ouverture de ces fenêtres, pas après. Nous analysons aussi vos concurrents. Que publient-ils pour le marché chinois ? Où sont les angles morts ? C\'est presque toujours là que se cachent les meilleures opportunités.',
  },
  {
    title: 'Rédaction chinoise native',
    body: 'Nos rédacteurs sont des locuteurs chinois natifs. Pas des généralistes bilingues, ni des traducteurs indépendants qui prennent des missions marketing entre deux contrats. Ce sont des plumes qui savent ce qui retient un lecteur à Shenzhen ou Hangzhou au-delà de la première ligne. Qui savent comment se bâtit la confiance sur une page produit chinoise, et en quoi elle diffère de sa jumelle occidentale. Qui écrivent avec la logique de classement Baidu en tête, parce qu\'un texte brillant que Baidu ne voit pas reste des mots perdus sur un serveur. Nous rédigeons des pages de site, des fiches produits, des articles de blog, des supports de campagne, des tribunes d\'expert. Tout ce dont votre site WordPress a besoin en chinois, nous le prenons en charge. Le cap reste le même : un contenu qui a l\'air né en chinois. Parce qu\'il l\'est.',
  },
  {
    title: 'Transcréation et localisation',
    body: 'Vous avez déjà des contenus en anglais ou dans une autre langue ? Nous ne les traduisons pas. La traduction livre des mots. La transcréation livre du sens. Nous conservons votre voix de marque et votre intention, mais reconstruisons le message de fond en comble pour qu\'il parle à un public chinois. Parfois, ce sont quelques ajustements de ton. D\'autres fois, il faut repenser une page entière parce que l\'idée sous-jacente ne se transpose tout simplement pas. Une plaisanterie qui cartonne à New York tombe à plat à Pékin. Un format d\'étude de cas qui convainc le B2B européen rebute le lecteur chinois. Nous savons où passent ces lignes. Et puis les détails qui pèsent plus qu\'on ne le croit : formats de date, affichage des devises, unités de mesure, structure des adresses, mentions légales réellement conformes aux exigences chinoises. Ces petites choses auxquelles on ne pense pas, jusqu\'au jour où un client à Canton les pointe du doigt.',
  },
  {
    title: 'Gestion éditoriale WordPress',
    body: 'Un beau contenu ne vaut pas grand-chose si votre équipe ne peut plus le maintenir après la livraison. Nous mettons donc aussi les tuyaux en place. Flux de travail multilingues avec WPML ou MultilingualPress, blocs Gutenberg paramétrés pour la publication en chinois, migration de contenu depuis votre plateforme d\'origine. Et nous formons votre équipe à gérer les mises à jour courantes en autonomie, sans qu\'il faille solliciter un développeur pour chaque article ou chaque ajustement de fiche produit.',
  },
];

const processSteps = [
  {
    title: 'Stratégie et recherche',
    body: 'Objectifs éditoriaux, analyse de mots-clés, audit concurrentiel, planification. Pas question de bâcler cette étape : une erreur ici compromet tout ce qui suit.',
  },
  {
    title: 'Production de contenu',
    body: 'Nos rédacteurs livrent des textes fidèles au ton de votre marque, calibrés pour les mots-clés Baidu retenus, mis en forme pour WordPress. Chaque pièce passe par une relecture éditoriale interne avant de vous être soumise. On n\'envoie pas de premiers jets en croisant les doigts.',
  },
  {
    title: 'Publication et optimisation',
    body: 'Feu vert donné, nous orchestrons la mise en ligne. Formatage dans le CMS, métadonnées, maillage interne, compression des images, attributs alt. Tout le périmètre.',
  },
  {
    title: 'Suivi et ajustements',
    body: 'Nous mesurons la performance éditoriale via Baidu Analytics et vous livrons des rapports sur le trafic, les classements, les indicateurs d\'engagement. Quand un contenu ne tient pas ses promesses, nous le retravaillons. Publier puis oublier : en Chine, ça ne marche pas.',
  },
];

const audiences = [
  { label: 'Lancement d\'un site chinois', description: 'Le volet contenu reste la grande inconnue de votre projet.', image: '/images/audiences/launching-chinese-website.webp' },
  { label: 'Traductions défraîchies', description: 'Un contenu traduit il y a longtemps, des classements Baidu qui stagnent ou reculent.', image: '/images/audiences/outdated-translated-content.webp' },
  { label: 'Textes de campagne', description: 'Équipe marketing qui prépare des campagnes ciblant les consommateurs chinois.', image: '/images/audiences/campaign-chinese-copy.webp' },
  { label: 'Pages produits', description: 'Équipe e-commerce qui a besoin de fiches produits rédigées dans les règles pour la Chine.', image: '/images/audiences/ecommerce-product-pages-china.webp' },
  { label: 'Éditorial au long cours', description: 'Publication régulière sur le blog, textes saisonniers, mises à jour produits, le tout piloté depuis WordPress.', image: '/images/audiences/ongoing-chinese-editorial.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0"><img src="/images/hero-chinese-content.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" /><div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div><div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div></div>
    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20"><ol class="flex items-center gap-2 text-sm text-white/40"><li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li><li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li><li class="before:content-['/'] before:mx-2 text-white/60">Contenu chinois</li></ol></nav>
      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Contenu chinois</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">Un contenu qui parle aux lecteurs chinois.<span class="block mt-2 text-[var(--color-brand-orange)]">Pas seulement en chinois.</span></h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">Rédaction native, transcréation et pilotage éditorial pour votre site WordPress. Calibré pour Baidu, ancré dans la culture locale, orchestré depuis votre CMS.</p>
          <div class="mt-10"><Button href="/fr/contact/" variant="primary" size="lg">Parler contenu avec nous</Button></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">En Chine, le contenu n'est pas une affaire de traduction</h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">L'erreur revient sans cesse. Une entreprise fait traduire son site anglais en chinois, met en ligne, puis attend. Le trafic ne vient pas. Les prospects non plus. On en conclut que le problème est technique. La plupart du temps, non. C'est le contenu qui cloche.</p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">Les consommateurs chinois ne lisent pas simplement dans une autre langue. Ils lisent autrement. Ce qui inspire confiance sur une page américaine n'a pas le même poids en Chine. La structure diffère, les attentes de ton diffèrent, les conventions de longueur de paragraphe ne se recoupent pas.</p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">Les mots-clés, c'est encore une autre histoire. Impossible de prendre un terme anglais à 10 000 recherches mensuelles sur Google, de le traduire en mandarin et d'espérer que Baidu vous récompense. Ce n'est pas comme ça que ça fonctionne ici.</p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">Pire encore, l'algorithme de Baidu pénalise activement les pages traduites. Il les rétrograde. Ce qu'il valorise : du contenu chinois original, publié à cadence régulière. Si votre site tourne avec des traductions vieilles d'un an ou deux que personne n'a réactualisées, Baidu a décroché depuis longtemps. C'est brutal, c'est la réalité.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Ce que nous proposons</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">Du contenu né en chinois</h2>
          <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed">Nous rédigeons du contenu original en chinois, depuis la Chine. Pas du contenu adapté, pas du contenu localisé depuis l'anglais. Écrit en chinois d'abord, pour des lecteurs chinois, avec les critères de classement Baidu intégrés dès la première ligne.</p>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {offerings.map((item) => (
              <div class="flex gap-5"><div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div><div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]"><h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">{item.title}</h3><p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item.body}</p></div></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Notre méthode</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">De la recherche aux résultats</h2>
      </div>
      <CaseStudyCards items={processSteps} />
    </div>
  </section>

  <WhoIsThisFor heading="À qui s'adresse cette page" audiences={audiences} />

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>
    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Passez à l'action</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">Vous voulez du contenu que les audiences chinoises liront vraiment ?</h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">Tout commence par une connaissance fine du marché et les bonnes personnes pour s'en occuper. Dites-nous ce que vous cherchez à accomplir en Chine et nous bâtirons un plan de contenu adapté à vos objectifs.</p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Lancer votre projet de contenu</Button>
        <Button href="/fr/services/baidu-seo/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Services SEO Baidu</Button>
      </div>
    </div>
  </section>
</PageLayout>
