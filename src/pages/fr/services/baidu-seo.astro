---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Référencement Baidu pour WordPress en Chine | ChinaWebFoundry';
const metaDescription = 'Nous optimisons les sites WordPress pour Baidu depuis la Chine. SEO technique, recherche de mots-clés chinois, stratégie de contenu et construction d\'autorité pour de vrais résultats.';

const services = [
  {
    title: 'SEO technique - Ce que Baidu exige vraiment',
    body: 'L\'essentiel de notre travail technique n\'a tout simplement pas d\'équivalent chez Google. Configuration et vérification du site dans les Outils Webmaster Baidu. Soumission de sitemaps dans les formats que Baidu privilégie. Optimisation de la vitesse mesurée depuis des serveurs en Chine continentale, parce qu\'un site rapide en Europe peut s\'avérer d\'une lenteur insoutenable derrière le Grand Pare-feu. Ergonomie mobile validée par les tests propres à Baidu, plus stricts que ceux de Google sur ce point. URL propres, canonicalisation rigoureuse et balises meta spécifiques à Baidu que la plupart des développeurs internationaux ignorent. Point décisif : un hébergement et une configuration ICP qui envoient les signaux de confiance sans lesquels Baidu ne prend tout simplement pas votre site au sérieux.',
  },
  {
    title: 'Recherche de mots-clés chinois - Pas de la traduction',
    body: 'C\'est sur ce terrain que les entreprises gaspillent le plus d\'argent. Elles prennent leur liste de mots-clés anglais, la font traduire et ciblent ces termes. Sauf que les internautes chinois ne cherchent pas de cette façon. Les formulations diffèrent, l\'intention derrière chaque requête n\'est pas la même, les schémas de longue traîne obéissent à une logique entièrement distincte. Nous menons la recherche de mots-clés de manière native, avec Baidu Index, Baidu Keyword Planner et l\'analyse concurrentielle de ce sur quoi vos rivaux chinois se positionnent réellement. C\'est un travail de recherche primaire, pas un exercice de traduction.',
  },
  {
    title: 'Optimisation on-page',
    body: 'Balises title et meta descriptions rédigées pour l\'affichage propre à Baidu, qui n\'a rien à voir avec celui de Google. Structure de titres que le robot Baidu sait interpréter. Maillage interne pensé pour ses schémas d\'indexation. Textes alternatifs en chinois. Contenu formaté pour les habitudes de lecture locales : paragraphes plus courts, hiérarchie visuelle différente, signaux de qualité que Baidu récompense spécifiquement.',
  },
  {
    title: 'Construire l\'autorité dans l\'écosystème web chinois',
    body: 'Votre profil de liens international ne vaut quasiment rien sur Baidu. L\'autorité en Chine se bâtit via les plateformes locales : Baidu Baike, Baidu Zhidao, Baidu Tieba, annuaires sectoriels, syndication de contenu sur les plateformes chinoises et signaux sociaux issus de WeChat et Weibo. Nous gérons l\'ensemble parce que nous travaillons déjà quotidiennement au sein de cet écosystème. Ce n\'est pas un projet secondaire pour nous.',
  },
  {
    title: 'Pilotage SEO en continu',
    body: 'Baidu modifie fréquemment son algorithme, souvent sans prévenir. L\'an dernier, plusieurs mises à jour ont redistribué les classements de catégories entières du jour au lendemain. Nous suivons vos positions chaque mois, observons les manoeuvres de vos concurrents, réagissons aux évolutions algorithmiques en temps réel et continuons de repérer de nouvelles occasions éditoriales. Abandonner le SEO Baidu après la phase initiale reste de loin l\'erreur la plus courante que nous constatons.',
  },
];

const googleDifferences = [
  'Baidu exige du contenu en chinois simplifié. Il ne le préfère pas, il le requiert pour tout positionnement sérieux.',
  'Un hébergement en Chine continentale n\'est pas un atout supplémentaire, c\'est un signal de classement majeur.',
  'La fraîcheur du contenu pèse bien plus lourd que sur Google.',
  'La frontière entre résultats payants et organiques est plus floue, les annonces occupant davantage d\'espace au-dessus de la ligne de flottaison.',
  'Le mobile n\'est pas une option. C\'est le mode par défaut pour l\'immense majorité des internautes chinois.',
];

const audiences = [
  { label: 'Zéro trafic organique', description: 'Entreprises dont le site WordPress en Chine ne génère aucun trafic naturel.', image: '/images/audiences/no-organic-traffic-china.webp' },
  { label: 'Lancement en Chine', description: 'Entreprises sur le point de mettre en ligne un nouveau site pour le marché chinois.', image: '/images/audiences/launching-chinese-market.webp' },
  { label: 'Réduire la dépendance au payant', description: 'Équipes marketing qui veulent moins dépendre de l\'acquisition payante en Chine.', image: '/images/audiences/reduce-paid-acquisition.webp' },
  { label: 'Experts SEO, novices Baidu', description: 'Professionnels du référencement qui maîtrisent Google mais ont besoin d\'une équipe terrain pour Baidu.', image: '/images/audiences/seo-pro-needs-baidu.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-seo.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Référencement Baidu</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Référencement Baidu
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Rendez-vous visible sur Baidu.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Parce que Google n'existe pas ici.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Nous faisons du référencement Baidu pour les sites WordPress. Optimisation technique, recherche de mots-clés chinois, stratégie de contenu, construction d'autorité. Le tout piloté depuis la Chine, par une équipe qui utilise Baidu chaque jour.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Demander un audit SEO Baidu</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">baidu-seo-audit</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Pages indexées Baidu</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">342 pages</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Mots-clés positionnés</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Top 10 : 28</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[65%] h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Trafic organique</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">+147 % MoM</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[80%] h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Statut ICP</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Vérifié</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Score mobile</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">96/100</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Le problème dont personne ne vous parle
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Le scénario est presque toujours le même. Une entreprise construit un bon site WordPress, le traduit parfois en chinois, le lance pour conquérir le marché chinois, puis... rien. Aucun trafic Baidu. Aucun positionnement. Parfois, le site n'est même pas indexé.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            La raison ne change guère : on a traité Baidu comme un Google en caractères chinois. Ce n'est pas le cas. Pas du tout.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Baidu possède son propre robot d'indexation, avec ses particularités et ses limites. Il pondère les facteurs de classement autrement. Il accorde une forte préférence aux sites hébergés en Chine continentale avec une licence ICP valide. Son rendu JavaScript a des années de retard sur celui de Google, ce qui signifie que le contenu chargé en JS pourrait tout aussi bien ne pas exister.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Quant à la recherche de mots-clés qui fonctionnait pour vos campagnes Google, elle est en grande partie inutilisable. Les comportements de recherche chinois suivent des schémas radicalement différents.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-surface-light)] to-white border border-[var(--color-surface-border)]">
            <div class="absolute inset-6 flex flex-col justify-center gap-6">
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-red-50 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">Stratégie SEO Google</div>
                  <div class="text-xs text-[var(--color-text-muted)]">Mots-clés traduits, liens internationaux, hébergement US</div>
                  <div class="mt-2 w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden">
                    <div class="w-[5%] h-full bg-red-400 rounded-full"></div>
                  </div>
                  <div class="text-xs text-red-400 mt-1">Visibilité Baidu : quasi nulle</div>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">Stratégie native Baidu</div>
                  <div class="text-xs text-[var(--color-text-muted)]">Mots-clés natifs, liens chinois, hébergement Chine, ICP vérifié</div>
                  <div class="mt-2 w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden">
                    <div class="w-[85%] h-full bg-green-500 rounded-full"></div>
                  </div>
                  <div class="text-xs text-green-500 mt-1">Visibilité Baidu : en progression</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Ce que nous faisons
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Nos interventions concrètes
          </h2>
          <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed">
            Nous résolvons ces problèmes depuis des années, en travaillant depuis la Chine avec les outils natifs de Baidu. Nous ne recyclons pas des recettes Google. Nous partons de Baidu et construisons à partir de là.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {services.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Google SEO Doesn't Transfer -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Différences fondamentales
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Pourquoi votre savoir-faire Google ne suffit pas
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <p class="text-base text-white/70 leading-relaxed mb-8">
            Quelques réalités qui prennent au dépourvu même les professionnels les plus chevronnés du référencement :
          </p>
          <div class="space-y-5">
            {googleDifferences.map((item) => (
              <div class="flex items-start gap-5 bg-white/[0.04] rounded-xl px-6 py-5 border border-white/10">
                <span class="inline-block mt-1 w-2 h-2 rounded-full bg-[var(--color-brand-orange)] flex-shrink-0"></span>
                <p class="text-[15px] text-white/70 leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui en a besoin" audiences={audiences} />

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Passez à l'action
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Le référencement Baidu ne se pilote pas depuis l'étranger
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Pas sérieusement, en tout cas. Laissez-nous réaliser un audit et vous montrer où vous en êtes, puis ce qu'il faudrait pour véritablement vous positionner.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Demander un audit SEO Baidu</Button>
        <Button href="/fr/services/chinese-content/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Services de contenu chinois</Button>
      </div>
    </div>
  </section>

</PageLayout>
