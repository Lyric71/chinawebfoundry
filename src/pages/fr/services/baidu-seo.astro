---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

const metaTitle = "Référencement Baidu | Se positionner sur le vrai moteur chinois | ChinaWebFoundry";
const metaDescription = "Référencement Baidu piloté depuis la Chine. Outils officiels Baidu, suivi des algorithmes (知心算法, 飓风算法 3.0), optimisation IA sur 文心X1 et DeepSeek.";

const whyDifferent = [
  {
    n: '01',
    cn: '算法',
    title: 'Baidu récompense d’autres choses',
    body: '知心算法 (Zhixin) reconnaît désormais plus de 200 relations sémantiques dans les requêtes en chinois. 飓风算法 3.0 sanctionne le contenu IA de faible qualité. La copie traduite mot pour mot perd vite des positions.',
    tag: 'Critères de classement',
    chips: ['知心算法', '飓风算法 3.0', 'Original ZH', 'Sémantique'],
  },
  {
    n: '02',
    cn: '蜘蛛',
    title: 'Le crawler de Baidu n’est pas celui de Google',
    body: "Baidu Spider rend le JavaScript avec des années de retard sur Googlebot : le contenu côté client passe souvent à la trappe. Le crawl mobile-first est exigé, le chargement sous trois secondes est un seuil dur, le HTTPS un signal positif.",
    tag: 'Crawl et rendu',
    chips: ['Baiduspider', 'Mobile-first', 'SSR / static', 'HTTPS'],
  },
  {
    n: '03',
    cn: '主机',
    title: 'L’emplacement de l’hébergement est un signal',
    body: 'Les sites sans dépôt ICP sont pénalisés dans l’index. Un hébergement continental surclasse un contenu identique hébergé à Hong Kong ou à l’étranger. Structurel, pas anecdotique.',
    tag: 'Infrastructure',
    chips: ['ICP', 'Continental', 'Aliyun', 'Tencent Cloud'],
  },
  {
    n: '04',
    cn: '推送',
    title: 'Le modèle de soumission est différent',
    body: "Baidu ne trouve pas votre contenu de lui-même. Il attend que vous lui poussiez les nouvelles URL via 主动推送 (Active Push) dans les minutes qui suivent la publication. Nous câblons le push dans le CMS.",
    tag: 'Soumission',
    chips: ['主动推送', '自动推送', 'Sitemap', '手工提交'],
  },
  {
    n: '05',
    cn: '关键词',
    title: 'La recherche de mots-clés se fait en chinois, depuis la page blanche',
    body: 'Ce que les internautes chinois cherchent réellement n’a presque rien à voir avec une liste de mots-clés anglais traduite. Nous travaillons avec 百度指数 (Baidu Index) et 百度关键词规划师 pour bâtir la cartographie.',
    tag: 'Découverte',
    chips: ['百度指数', '关键词规划师', '5118', 'Longue traîne'],
  },
];

const services = [
  {
    n: '01',
    title: 'SEO technique pour Baidu',
    body: 'Vérification du site sur 百度搜索资源平台. Les quatre méthodes de soumission d’URL configurées par ordre de priorité, plus 死链提交, 站点子链 et la vérification du crawl mobile-first. Vitesse mesurée depuis la Chine continentale.',
    bullets: [
      '主动推送 (Active Push) câblé dans le CMS pour la soumission en temps réel.',
      '自动推送 (Auto Push) en JS pour rattraper les URL visitées avant le déclenchement du hook CMS.',
      'Sitemap complet, rafraîchi automatiquement (50 000 URL / 10 Mo max par fichier).',
      '手工提交 en dernier recours pour les pages à forte valeur.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Contenu chinois natif, structuré pour Baidu',
    body: 'Baidu valorise 深度原创. 飓风算法 déclasse les pages minces ou copiées, 飓风算法 3.0 vise le contenu IA sans relecture humaine. Nous écrivons avec des éditeurs chinois natifs : long format, balisage Schema, réponses factuelles que les IA peuvent citer.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Optimisation pour la recherche IA (文心X1, DeepSeek, Doubao, Kimi)',
    body: "Plus de 20 % des résultats Baidu en 2025 contenaient une réponse générée par IA. Baidu intègre désormais 文心X1 et la recherche profonde DeepSeek directement dans la page de résultats. Nous structurons le contenu pour que ces moteurs lisent, comprennent et citent votre marque.",
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Autorité dans l’écosystème web chinois',
    body: "Vos backlinks internationaux ne pèsent presque rien sur Baidu. Les plateformes qui font bouger les classements : 百度百科, 百度知道, 百度贴吧, 知乎, 百家号, 百度爱采购, plus les portails B2B sectoriels et les signaux WeChat / Weibo. Nous bâtissons la présence et pilotons la syndication.",
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Optimisation continue et réponse aux algorithmes',
    body: "Baidu n’annonce pas la plupart de ses mises à jour, et les annonces officielles sont en chinois sur le blog 百度搜索资源平台. Douze mois à suivre les évolutions de 知心算法, 飓风算法 3.0 et l’intégration 文心X1 + DeepSeek. Chacune a redéfini ce qui gagne.",
    tag: 'p.30',
  },
];

const stages = [
  {
    n: '01',
    cn: '审计',
    title: 'Audit Baidu',
    body: 'Tests depuis la Chine continentale : indexation, santé du crawl Baiduspider, profondeur du contenu, signaux ICP et hébergement, plus position actuelle sur 50 à 100 mots-clés ciblés.',
    output: 'Rapport d’audit',
  },
  {
    n: '02',
    cn: '关键词',
    title: 'Cartographie des mots-clés',
    body: 'Recherche en chinois natif via 百度指数 et 关键词规划师. Cartographie avec étiquettes d’intention, volumes et brief de contenu par grappe.',
    output: 'Carte + briefs',
  },
  {
    n: '03',
    cn: '部署',
    title: 'Déploiement technique',
    body: 'Vérification du site, 主动推送 câblé dans le CMS, sitemaps, balisage Schema, optimisations mobile et vitesse, llms.txt et structure pour la recherche IA livrés ensemble.',
    output: 'Indexation en ligne',
  },
  {
    n: '04',
    cn: '权威',
    title: 'Autorité et contenu',
    body: 'Contenu chinois natif, plus syndication sur 百家号, 知乎, 百度知道 et les portails sectoriels pertinents. Fiches 百度百科 ajoutées quand la marque est prête.',
    output: 'Citations + progression',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Suivi et itération',
    body: "Suivi hebdomadaire des positions, rapport mensuel écrit, réaction aux mises à jour algorithmiques dans la même semaine. Baidu change ; l’équipe qui ne suit pas perd ses positions sans comprendre pourquoi.",
    output: 'Rapport mensuel',
  },
];

const stats = [
  { value: '24-72h', label: 'Indexation via 主动推送', sub: 'Nouvelles URL dans Baidu en heures, pas en semaines.' },
  { value: '11', label: 'Mises à jour algo suivies en 2025', sub: '知心算法, 飓风算法 3.0, intégration 文心X1.' },
  { value: '20%+', label: 'Pages Baidu avec réponse IA', sub: '文心X1 et DeepSeek désormais intégrés aux résultats.' },
];

const audiences = [
  {
    label: 'Marques étrangères invisibles sur Baidu',
    description: 'Sociétés dont le site chinois génère moins de cinquante visites organiques par mois depuis Baidu, alors qu’elles paient déjà des annonces sur les mêmes mots-clés.',
    image: '/images/audiences/no-organic-traffic-china.webp',
  },
  {
    label: 'Marques avec un contenu traduit, ancien',
    description: 'Sites étrangers dont les pages chinoises sont restées des traductions et n’ont pas bougé depuis le lancement.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marques qui se lancent depuis zéro',
    description: 'Entreprises qui veulent une visibilité Baidu dès le premier jour, intégrée au build, pas ajoutée trois mois après le lancement.',
    image: '/images/audiences/launching-chinese-market.webp',
  },
  {
    label: 'Marques sérieuses sur la recherche IA',
    description: 'Équipes qui voient les réponses IA s’afficher en haut des résultats Baidu et veulent y être citées plutôt que contournées.',
    image: '/images/audiences/seo-pro-needs-baidu.webp',
  },
];

const marqueePhrases = [
  '百度', 'Baidu',
  '主动推送', 'Active Push',
  '知心算法', '飓风算法 3.0',
  '文心X1', 'DeepSeek',
  '百家号', '知乎', '百度百科',
  'ICP déposé',
  'Hébergement continental',
  'Prêt pour l’IA',
];

const faqs = [
  {
    id: 'outside-china',
    question: 'Peut-on piloter le SEO Baidu depuis l’étranger ?',
    answer: [
      "Techniquement oui, mais avec de fortes limites. La vérification Baidu attend des numéros chinois, le tableau de bord est en chinois, la documentation n’est pas traduite, et beaucoup d’outils Baidu limitent ou bloquent les IP étrangères. La plupart des équipes étrangères qui s’y essaient abandonnent en un trimestre. Nous le pilotons depuis Shanghai parce que c’est là que le travail se fait vraiment.",
    ],
  },
  {
    id: 'how-long',
    question: 'Combien de temps avant de voir des résultats ?',
    answer: [
      'Mouvement sur la longue traîne en 6 à 10 semaines. Termes concurrentiels en 3 à 6 mois minimum. Vraie croissance organique sur une courbe de 6 à 12 mois. Indexation des nouveaux contenus via 主动推送 en 24 à 72 heures.',
    ],
  },
  {
    id: 'no-icp',
    question: 'Et si notre site n’a pas de dépôt ICP ?',
    answer: [
      'Il se positionnera, mais avec un handicap mesurable. Baidu traite les sites de Hong Kong et offshore comme étrangers, les crawle moins souvent et les classe sous les sites continentaux. Pour une marque sérieuse sur Baidu, l’ICP sur hébergement continental reste le bon choix.',
    ],
  },
  {
    id: 'baidu-ads',
    question: 'Pilotez-vous aussi Baidu Ads (SEM) ?',
    answer: [
      "Non, nous nous concentrons sur le SEO Baidu organique. Le payant est un autre métier, mené par d’autres équipes. Nous travaillons aux côtés des partenaires media et veillons à ce que le contenu SEO et les pages d’atterrissage payantes ne se tirent pas dans les pattes.",
    ],
  },
  {
    id: 'chinese-content',
    question: 'Comment cela s’articule avec le travail de contenu chinois ?',
    answer: [
      'Étroitement. Le SEO Baidu sans contenu chinois natif est un effort gâché. La plupart de nos clients prennent les deux en une seule mission, équipe contenu et équipe SEO travaillant sur la même cartographie de mots-clés et la même architecture éditoriale.',
    ],
  },
  {
    id: 'ai-search',
    question: 'Quid de la visibilité IA sur Doubao, Kimi, DeepSeek, 文心X1 ?',
    answer: [
      'De plus en plus le même chantier. Baidu intègre désormais 文心X1 et DeepSeek dans plus de 20 % de ses pages de résultats. Structurer le contenu pour les IA (réponses factuelles propres, balisage Schema, llms.txt, structure sémantique) recoupe largement la structure pour Baidu. Nous traitons les deux ensemble.',
    ],
  },
  {
    id: 'links',
    question: 'Faites-vous du netlinking ?',
    answer: [
      "Nous bâtissons l’autorité sur les plateformes chinoises (百度百科, 百度知道, 知乎, 百家号, 百度爱采购, portails B2B sectoriels) où la présence fait réellement bouger les classements Baidu. Acheter des backlinks génériques chez un broker occidental ne marche pas et fait courir un risque 飓风算法. L’autorité en Chine se gagne sur les plateformes chinoises, ou pas du tout.",
    ],
  },
  {
    id: 'measurement',
    question: 'Comment mesurez-vous le succès ?',
    answer: [
      'Inclusion dans l’index (nombre de pages indexées), positions sur mots-clés (suivi hebdomadaire), trafic organique Baidu (via 百度统计), attribution des conversions, part de visibilité face à trois à cinq concurrents nommés. Reporting mensuel avec une synthèse écrite, pas seulement un lien dashboard.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: 'Que faites-vous quand Baidu change son algorithme ?',
    answer: [
      "Nous suivons chaque semaine les annonces du 百度搜索资源平台 et réagissons dans la même semaine quand quelque chose de matériel sort. Sur les douze derniers mois : extensions de 知心算法, 飓风算法 3.0 contre le contenu IA, intégration 文心X1 dans les résultats, plus plusieurs ajustements mineurs.",
    ],
  },
  {
    id: 'cost',
    question: 'Quel coût ?',
    answer: [
      'Cela dépend du périmètre : taille du site, volume de contenu, intensité concurrentielle, et intégration ou non de la production de contenu chinois et de l’optimisation IA. Décrivez-nous le périmètre, nous renvoyons un vrai devis sous deux jours ouvrés.',
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-search-results.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Référencement Baidu</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Référencement Baidu</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Derrière le Pare-feu, à Shanghai</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Faites-vous trouver sur
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">百度.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Pas Google.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Baidu n’est pas Google en caractères chinois. Crawler différent, index différent, API de soumission différente, cycle algorithmique différent, et une couche de recherche IA (文心X1, DeepSeek) qui produit plus de vingt pour cent des résultats. <span class="text-white font-medium">Pilotage depuis Shanghai, sur les outils maison de Baidu.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">20</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Ans sur Baidu</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">200</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Relations 知心 suivies</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">72h</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Indexation via 主动推送</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Demander un audit Baidu</Button>
            <Button href="#what-we-do" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir les chantiers</Button>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- POURQUOI -->
  <section class="relative section-spacing overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0" data-reveal="left">
          <div class="relative inline-flex items-baseline">
            <span class="text-[10rem] lg:text-[14rem] font-medium font-[var(--font-heading)] leading-none bg-gradient-to-br from-[var(--color-brand-orange)] via-[#FF7E47] to-[#D94E1F] bg-clip-text text-transparent">50%</span>
          </div>
          <p class="mt-4 text-base text-[var(--color-text-muted)] max-w-sm">
            La part de marché de Baidu sur la recherche en Chine, devant Bing et Sogou. Google reste sous les 3 %.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-7" data-reveal="right">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)] mb-5">Pourquoi cela compte</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15] mb-6">
            Le moteur que votre public chinois utilise vraiment.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            La recette Google ne s’exporte pas. Baidu a sa propre console de soumission, ses propres algorithmes, sa propre culture du contenu, sa propre couche IA. Le chemin pour s’y faire référencer est différent de bout en bout.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            Nous travaillons depuis Shanghai, sur les outils officiels de Baidu, en chinois, et nous suivons chaque mise à jour algorithmique dans la semaine où elle sort.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- POURQUOI BAIDU EST DIFFÉRENT -->
  <section class="relative section-spacing bg-gradient-to-b from-[var(--color-surface-light)] to-white overflow-hidden">
    <span aria-hidden="true" class="absolute -top-24 right-[-2rem] text-[20rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.04] leading-none select-none pointer-events-none" data-parallax="0.15">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14 lg:mb-16" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">Cinq différences · 五大差异</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-5">
          Cinq raisons pour lesquelles Baidu n’est pas Google.
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Algorithme, crawler, hébergement, soumission, mots-clés. Sur chacun, le chemin diverge.
        </p>
      </div>

      <div class="space-y-5 lg:space-y-6">
        {whyDifferent.map((q, i) => (
          <article
            data-reveal
            data-reveal-delay={String(i * 60)}
            class="group relative grid grid-cols-1 lg:grid-cols-12 gap-0 rounded-3xl border border-[var(--color-surface-border)] bg-white overflow-hidden transition-all duration-500 hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_30px_70px_-30px_rgba(15,15,18,0.18)] hover:-translate-y-1"
          >
            <div class="lg:col-span-3 relative p-7 lg:p-8 bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white overflow-hidden">
              <span aria-hidden="true" class="absolute right-[-1.5rem] bottom-[-3rem] text-[14rem] font-medium font-[var(--font-heading)] text-white/[0.04] leading-none select-none pointer-events-none">{q.cn}</span>
              <div class="relative">
                <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-2">N° {q.n} / 05</div>
                <div class="text-5xl lg:text-6xl font-medium font-[var(--font-heading)] text-white leading-none mb-1.5">{q.cn}</div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)]/90 font-semibold">{q.tag}</div>
              </div>
            </div>

            <div class="lg:col-span-6 p-7 lg:p-9 flex flex-col justify-center">
              <h3 class="text-2xl lg:text-[26px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4">
                {q.title}
              </h3>
              <p class="text-[15px] lg:text-base text-[var(--color-text-body)] leading-relaxed">
                {q.body}
              </p>
            </div>

            <div class="lg:col-span-3 p-6 lg:p-7 bg-[var(--color-surface-light)] border-t lg:border-t-0 lg:border-l border-[var(--color-surface-border)] flex flex-col justify-center gap-3">
              <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)]">Ce qu’on travaille</div>
              <div class="flex flex-wrap gap-1.5">
                {q.chips.map((c) => (
                  <span class="text-[11px] font-mono px-2.5 py-1 rounded-md bg-white text-[var(--color-text-body)] border border-[var(--color-surface-border)]">{c}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CE QUE NOUS FAISONS -->
  <section id="what-we-do" class="relative section-spacing bg-white overflow-hidden scroll-mt-32">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-text-card-blue)]/10 border border-[var(--color-text-card-blue)]/20 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-card-blue)]">Ce que nous faisons · 做什么</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-5">
          Cinq chantiers, menés ensemble.
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Sautez l’un d’eux et la progression s’arrête.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5">
        {services.map((d, i) => (
          <div data-reveal data-reveal-delay={String(i * 80)} class="group relative rounded-2xl bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] p-6 lg:p-7 transition-all duration-300 hover:bg-white hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_18px_40px_-18px_rgba(15,15,18,0.18)] hover:-translate-y-1 overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"></div>
            <div class="flex items-start gap-5 relative">
              <div class="flex-shrink-0">
                <div class="text-3xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/80 leading-none">{d.n}</div>
                <div class="mt-2 w-8 h-px bg-[var(--color-surface-border)]"></div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between gap-3 mb-2">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
                    {d.title}
                  </h3>
                  <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-text-muted)] flex-shrink-0">{d.tag}</span>
                </div>
                <p class="text-sm text-[var(--color-text-body)] leading-relaxed">
                  {d.body}
                </p>
                {d.bullets && (
                  <ul class="mt-4 space-y-2">
                    {d.bullets.map((b) => (
                      <li class="flex gap-3 text-[13px] text-[var(--color-text-body)] leading-relaxed">
                        <span class="flex-shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DÉROULÉ -->
  <section class="relative section-spacing bg-[var(--color-surface-light)] overflow-hidden">
    <div class="absolute -bottom-32 -right-32 w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.06] blur-[140px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="text-center max-w-2xl mx-auto mb-14 lg:mb-16" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">Notre déroulé · 工作流程</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-4">
          Cinq étapes, du diagnostic à l’itération.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 lg:gap-5">
        {stages.map((s, i) => (
          <article data-reveal data-reveal-delay={String(i * 70)} class="group relative rounded-3xl bg-white border border-[var(--color-surface-border)] p-6 lg:p-7 transition-all duration-300 overflow-hidden hover:-translate-y-1.5 hover:shadow-[0_24px_50px_-22px_rgba(15,15,18,0.18)] hover:border-[var(--color-brand-orange)]/30">
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"></div>
            <span aria-hidden="true" class="absolute right-2 top-2 text-6xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.06] leading-none select-none pointer-events-none transition-all duration-500 group-hover:text-[var(--color-brand-orange)]/[0.12] group-hover:scale-110 origin-top-right">{s.cn}</span>

            <div class="relative">
              <div class="flex items-center gap-2 mb-5">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-[var(--color-text-dark)] text-white text-sm font-semibold font-[var(--font-heading)]">
                  {s.n}
                </span>
                <span class="text-[10px] font-mono uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Étape {i + 1} sur 5</span>
              </div>

              <h3 class="text-lg lg:text-[19px] font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-3">
                {s.title}
              </h3>
              <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-5">
                {s.body}
              </p>

              <div class="pt-4 border-t border-[var(--color-surface-border)]">
                <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1.5">Livrable</div>
                <div class="flex items-center gap-2 text-sm font-medium text-[var(--color-text-dark)]">
                  <svg class="w-4 h-4 text-[var(--color-brand-orange)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {s.output}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CHIFFRES -->
  <section class="relative section-spacing bg-white overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-5">
        {stats.map((s, i) => (
          <div class:list={['group relative rounded-3xl p-7 lg:p-8 transition-all duration-300 hover:-translate-y-1 overflow-hidden', i === 1 ? 'bg-gradient-to-br from-[var(--color-brand-orange)] to-[#D14A1F] text-white' : 'bg-[var(--color-surface-light)] border border-[var(--color-surface-border)]']}>
            <div class="relative">
              <div class:list={['text-[10px] font-mono uppercase tracking-[0.18em] mb-3', i === 1 ? 'text-white/75' : 'text-[var(--color-text-muted)]']}>{s.label}</div>
              <div class:list={['text-5xl lg:text-6xl font-medium font-[var(--font-heading)] leading-none mb-3', i === 1 ? 'text-white' : 'text-[var(--color-text-dark)]']}>
                {s.value}
              </div>
              <p class:list={['text-sm leading-relaxed', i === 1 ? 'text-white/90' : 'text-[var(--color-text-body)]']}>{s.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui nous mandate pour le SEO Baidu" audiences={audiences} background="light" />

  <!-- FAQ -->
  <section id="faq" class="section-spacing bg-white scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32" data-reveal="left">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">FAQ · 常见问题</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Dix questions sur le SEO Baidu
          </h2>
          <div class="mt-7">
            <Button href="/fr/contact/" variant="secondary" size="md">Poser une autre question</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6" data-reveal="right">
          <div data-faq-accordion>
            {faqs.map((faq) => (
              <FAQItem question={faq.question} id={faq.id}>
                {faq.answer.map((para) => (
                  <p class="mb-3 last:mb-0">{para}</p>
                ))}
              </FAQItem>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA + marquee -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="relative border-y border-white/10 bg-[#0f0f12] py-5 overflow-hidden">
      <div class="flex gap-10 animate-[marquee_45s_linear_infinite] whitespace-nowrap">
        {[...marqueePhrases, ...marqueePhrases, ...marqueePhrases].map((phrase) => (
          <span class="inline-flex items-center gap-3 text-base lg:text-lg font-medium text-white/40 hover:text-[var(--color-brand-orange)] transition-colors">
            {phrase}
            <span class="text-white/15">·</span>
          </span>
        ))}
      </div>
    </div>

    <div class="relative py-20 lg:py-28">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[var(--color-brand-orange)]/8 rounded-full blur-[140px] pointer-events-none"></div>
      <div class="relative mx-auto max-w-[1400px] section-padding text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] max-w-3xl mx-auto">
          Prêt à devenir trouvable sur Baidu ?
        </h2>
        <p class="mt-6 text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
          Décrivez-nous le périmètre. Nous renvoyons sous deux jours ouvrés un cadrage et un vrai chiffre.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
          <Button href="/fr/contact/" variant="primary" size="lg">Demander un audit Baidu</Button>
          <Button href="/fr/services/geo/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir GEO China</Button>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
