---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

const metaTitle = "Référencement Baidu | Se positionner sur le vrai moteur chinois | ChinaWebFoundry";
const metaDescription = "Référencement Baidu piloté depuis la Chine, sur les outils officiels du moteur. Suivi des algorithmes 知心算法 et 飓风算法 3.0, optimisation pour la recherche IA 文心X1 et DeepSeek.";

const whyDifferent = [
  {
    n: '01',
    cn: '算法',
    title: 'Baidu récompense d’autres choses',
    body: '知心算法 (Zhixin) reconnaît désormais plus de 200 relations sémantiques dans les requêtes en chinois. 飓风算法 3.0 sanctionne le contenu IA mal relu. La copie traduite mot pour mot perd vite ses positions.',
    tag: 'Critères de classement',
    chips: ['知心算法', '飓风算法 3.0', 'Original ZH', 'Sémantique'],
  },
  {
    n: '02',
    cn: '蜘蛛',
    title: 'Baidu Spider joue avec un autre rythme',
    body: "Baidu Spider rend le JavaScript avec plusieurs années de retard sur Googlebot : tout contenu chargé côté client passe souvent à la trappe. Le crawl en priorité mobile est exigé, le chargement sous trois secondes est un seuil dur, le HTTPS un signal positif.",
    tag: 'Crawl et rendu',
    chips: ['Baiduspider', 'Priorité mobile', 'SSR / static', 'HTTPS'],
  },
  {
    n: '03',
    cn: '主机',
    title: 'L’emplacement de l’hébergement est un signal',
    body: 'Les sites sans dépôt ICP sont pénalisés dans l’index. À contenu identique, un hébergement continental surclasse un site logé à Hong Kong ou à l’étranger. Un signal structurel, qui pèse sur chaque requête.',
    tag: 'Infrastructure',
    chips: ['ICP', 'Continental', 'Aliyun', 'Tencent Cloud'],
  },
  {
    n: '04',
    cn: '推送',
    title: 'Le modèle de soumission est différent',
    body: "Baidu ne trouve pas votre contenu tout seul. Il attend qu’on lui pousse les nouvelles URL via 主动推送 (Active Push) dans les minutes qui suivent la publication. On câble le push directement dans le CMS.",
    tag: 'Soumission',
    chips: ['主动推送', '自动推送', 'Sitemap', '手工提交'],
  },
  {
    n: '05',
    cn: '关键词',
    title: 'La recherche de mots-clés se fait en chinois, depuis la page blanche',
    body: 'Ce que les internautes chinois cherchent réellement n’a presque rien à voir avec une liste de mots-clés anglais traduite. On travaille avec 百度指数 (Baidu Index) et 百度关键词规划师 pour bâtir la cartographie depuis la page blanche.',
    tag: 'Découverte',
    chips: ['百度指数', '关键词规划师', '5118', 'Longue traîne'],
  },
];

const services = [
  {
    n: '01',
    title: 'SEO technique pour Baidu',
    body: 'Vérification du site sur 百度搜索资源平台. Les quatre méthodes de soumission d’URL configurées par ordre de priorité, plus 死链提交, 站点子链 et la vérification du crawl en priorité mobile. Vitesse mesurée depuis la Chine continentale.',
    bullets: [
      '主动推送 (Active Push) câblé dans le CMS pour la soumission en temps réel.',
      '自动推送 (Auto Push) en JS pour rattraper les URL visitées avant le déclenchement du hook CMS.',
      'Sitemap complet, rafraîchi automatiquement (50 000 URL / 10 Mo max par fichier).',
      '手工提交 en dernier recours pour les pages à forte valeur.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Contenu chinois natif, structuré pour Baidu',
    body: 'Baidu valorise 深度原创. 飓风算法 déclasse les pages minces ou copiées, 飓风算法 3.0 vise le contenu IA sans relecture humaine. On écrit avec des éditeurs natifs chinois : format long, balisage Schema, réponses factuelles que les IA peuvent citer.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Optimisation pour la recherche IA (文心X1, DeepSeek, Doubao, Kimi)',
    body: "Plus de 20 % des résultats Baidu en 2025 contenaient une réponse générée par IA. Baidu intègre désormais 文心X1 et la recherche profonde DeepSeek directement dans la page de résultats. On structure le contenu pour que ces moteurs le lisent, le comprennent, et nomment votre marque dans la réponse.",
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Autorité dans l’écosystème web chinois',
    body: "Vos backlinks internationaux ne pèsent presque rien sur Baidu. Les plateformes qui font réellement bouger les classements : 百度百科, 百度知道, 百度贴吧, 知乎, 百家号, 百度爱采购, plus les portails B2B sectoriels et les signaux WeChat / Weibo. On bâtit la présence et on pilote la syndication.",
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Optimisation continue et réponse aux algorithmes',
    body: "Baidu n’annonce pas la plupart de ses mises à jour, et celles qui sortent paraissent en chinois sur le blog 百度搜索资源平台. Sur les douze derniers mois, on a suivi les évolutions de 知心算法, de 飓风算法 3.0 et l’intégration de 文心X1 + DeepSeek. Chacune a redéfini ce qui gagne.",
    tag: 'p.30',
  },
];

const tools = [
  {
    name: '百度搜索资源平台',
    en: 'Plateforme webmaster Baidu',
    cn: '资源',
    body: 'La console webmaster officielle : vérification du site, soumission d’URL, sitemaps, rapports d’indexation, test mobile, signalement de liens morts, fil d’annonces algorithmiques.',
    feature: true,
    items: ['Vérification du site', 'API de push d’URL', 'Sitemap', 'Rapports d’indexation', 'Test mobile', '死链提交', 'Fil algo'],
  },
  {
    name: '百度统计',
    en: 'Baidu Tongji',
    cn: '统计',
    body: 'L’équivalent Baidu de Google Analytics. Indispensable pour toute mesure sérieuse côté Chine.',
  },
  {
    name: '百度指数',
    en: 'Baidu Index et Keyword Planner',
    cn: '指数',
    body: 'Le point de départ d’une vraie recherche de mots-clés en chinois, plutôt qu’une liste anglaise traduite. À utiliser avec 百度关键词规划师.',
  },
  {
    name: '5118 · 爱站 · 站长之家',
    en: 'Outils SEO chinois tiers',
    cn: '工具',
    body: 'Souvent une intelligence concurrentielle et un historique de positions plus profonds que les outils officiels.',
  },
  {
    name: 'API webmaster Baidu',
    en: 'Intégration Active Push',
    cn: '接口',
    body: 'Pour 主动推送, on câble directement dans le CMS plutôt que de passer par les tableaux de bord.',
  },
];

const stages = [
  {
    n: '01',
    cn: '审计',
    title: 'Audit Baidu',
    body: 'Tests depuis la Chine continentale : indexation, santé du crawl Baiduspider, profondeur du contenu, signaux ICP et hébergement, plus position actuelle sur 50 à 100 mots-clés ciblés.',
    output: 'Rapport d’audit',
  },
  {
    n: '02',
    cn: '关键词',
    title: 'Cartographie des mots-clés',
    body: 'Recherche en chinois natif via 百度指数 et 关键词规划师. Cartographie avec étiquettes d’intention, volumes et brief de contenu par grappe.',
    output: 'Carte + briefs',
  },
  {
    n: '03',
    cn: '部署',
    title: 'Déploiement technique',
    body: 'Vérification du site, 主动推送 câblé dans le CMS, sitemaps, balisage Schema, optimisations mobile et vitesse, llms.txt et structure pour la recherche IA livrés ensemble.',
    output: 'Indexation en ligne',
  },
  {
    n: '04',
    cn: '权威',
    title: 'Autorité et contenu',
    body: 'Contenu chinois natif, plus syndication sur 百家号, 知乎, 百度知道 et les portails sectoriels pertinents. Fiches 百度百科 ajoutées quand la marque est prête.',
    output: 'Citations + progression',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Suivi et itération',
    body: "Suivi hebdomadaire des positions, rapport mensuel écrit, réaction aux mises à jour algorithmiques dans la même semaine. Baidu change ; l’équipe qui ne suit pas perd ses positions sans comprendre pourquoi.",
    output: 'Rapport mensuel',
  },
];

const stats = [
  { value: '24-72h', label: 'Indexation via 主动推送', sub: 'Nouvelles URL dans Baidu en quelques heures, là où le crawl naturel demande des semaines.' },
  { value: '11', label: 'Mises à jour algo suivies en 2025', sub: '知心算法, 飓风算法 3.0, intégration 文心X1.' },
  { value: '20%+', label: 'Pages Baidu avec réponse IA', sub: '文心X1 et DeepSeek désormais intégrés aux résultats.' },
];

const audiences = [
  {
    label: 'Marques étrangères invisibles sur Baidu',
    description: 'Sociétés dont le site chinois génère moins de cinquante visites organiques par mois depuis Baidu, alors qu’elles paient déjà des annonces sur les mêmes mots-clés.',
    image: '/images/audiences/no-organic-traffic-china.webp',
  },
  {
    label: 'Marques avec un contenu traduit, ancien',
    description: 'Sites étrangers dont les pages chinoises sont restées de simples traductions et n’ont pas évolué depuis le lancement.',
    image: '/images/audiences/outdated-translated-content.webp',
  },
  {
    label: 'Marques qui se lancent depuis zéro',
    description: 'Entreprises qui veulent une visibilité Baidu dès le premier jour, intégrée à la conception du site et au calendrier de mise en ligne.',
    image: '/images/audiences/launching-chinese-market.webp',
  },
  {
    label: 'Marques sérieuses sur la recherche IA',
    description: 'Équipes qui voient les réponses IA s’afficher en haut des résultats Baidu et veulent que ces moteurs nomment leur marque dans la réponse.',
    image: '/images/audiences/seo-pro-needs-baidu.webp',
  },
];

const marqueePhrases = [
  '百度', 'Baidu',
  '主动推送', 'Active Push',
  '知心算法', '飓风算法 3.0',
  '文心X1', 'DeepSeek',
  '百家号', '知乎', '百度百科',
  'ICP déposé',
  'Hébergement continental',
  'Prêt pour l’IA',
];

const faqs = [
  {
    id: 'outside-china',
    question: 'Peut-on piloter le SEO Baidu depuis l’étranger ?',
    answer: [
      "Techniquement oui, mais avec de fortes limites. La vérification Baidu attend des numéros chinois, le tableau de bord est en chinois, la documentation n’est pas traduite, et beaucoup d’outils Baidu limitent ou bloquent les adresses IP étrangères. La plupart des équipes étrangères qui s’y essaient abandonnent en un trimestre. Nous pilotons depuis Shanghai parce que c’est là que le travail se fait vraiment.",
    ],
  },
  {
    id: 'how-long',
    question: 'Combien de temps avant de voir des résultats ?',
    answer: [
      'Mouvement sur la longue traîne en 6 à 10 semaines. Termes concurrentiels en 3 à 6 mois minimum. Vraie croissance organique sur une courbe de 6 à 12 mois. Indexation des nouveaux contenus via 主动推送 en 24 à 72 heures.',
    ],
  },
  {
    id: 'no-icp',
    question: 'Et si notre site n’a pas de dépôt ICP ?',
    answer: [
      'Il se positionnera, mais avec un handicap mesurable. Baidu traite les sites de Hong Kong et offshore comme étrangers, les crawle moins souvent, et les classe en dessous des sites continentaux. Pour une marque sérieuse sur Baidu, l’ICP sur hébergement continental reste le bon choix.',
    ],
  },
  {
    id: 'baidu-ads',
    question: 'Pilotez-vous aussi Baidu Ads (SEM) ?',
    answer: [
      "Non, nous nous concentrons sur le SEO Baidu organique. Le payant est un métier distinct, mené par d’autres équipes. Nous travaillons aux côtés des partenaires média et veillons à ce que le contenu SEO et les pages d’atterrissage payantes ne se tirent pas dans les pattes.",
    ],
  },
  {
    id: 'chinese-content',
    question: 'Comment cela s’articule avec le travail de contenu chinois ?',
    answer: [
      'Étroitement. Faire du SEO Baidu sans contenu chinois natif revient à creuser dans le vide. La plupart de nos clients prennent les deux en une seule mission, l’équipe contenu et l’équipe SEO travaillant sur la même cartographie de mots-clés et la même architecture éditoriale.',
    ],
  },
  {
    id: 'ai-search',
    question: 'Quid de la visibilité IA sur Doubao, Kimi, DeepSeek, 文心X1 ?',
    answer: [
      'De plus en plus le même chantier. Baidu intègre désormais 文心X1 et DeepSeek dans plus de 20 % de ses pages de résultats. Structurer le contenu pour les IA (réponses factuelles propres, balisage Schema, llms.txt, structure sémantique) recoupe largement la structure attendue par Baidu. On traite les deux ensemble.',
    ],
  },
  {
    id: 'links',
    question: 'Faites-vous du netlinking ?',
    answer: [
      "On bâtit l’autorité sur les plateformes chinoises (百度百科, 百度知道, 知乎, 百家号, 百度爱采购, portails B2B sectoriels) où la présence fait réellement bouger les classements Baidu. Acheter des backlinks génériques chez un courtier occidental ne marche pas et fait courir un risque 飓风算法. L’autorité en Chine se gagne sur les plateformes chinoises, ou pas du tout.",
    ],
  },
  {
    id: 'measurement',
    question: 'Comment mesurez-vous le succès ?',
    answer: [
      'Inclusion dans l’index (nombre de pages indexées), positions sur mots-clés (suivi hebdomadaire), trafic organique Baidu (via 百度统计), attribution des conversions, part de voix face à trois à cinq concurrents nommés. Restitution : synthèse mensuelle écrite, doublée d’un tableau de bord en direct.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: 'Que faites-vous quand Baidu change son algorithme ?',
    answer: [
      "On suit chaque semaine les annonces du 百度搜索资源平台 et on réagit dans la semaine quand quelque chose de matériel sort. Sur les douze derniers mois : extensions de 知心算法, 飓风算法 3.0 contre le contenu IA, intégration de 文心X1 dans les résultats, plus plusieurs ajustements mineurs.",
    ],
  },
  {
    id: 'cost',
    question: 'Quel coût ?',
    answer: [
      'Cela dépend du périmètre : taille du site, volume de contenu, intensité concurrentielle, intégration ou non de la production de contenu chinois et de l’optimisation IA. Décrivez-nous le périmètre, nous revenons sous deux jours ouvrés avec un chiffre ferme.',
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-baidu-search-results.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">索</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Référencement Baidu</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Référencement Baidu</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Derrière le Great Firewall, à Shanghai</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Faites-vous trouver sur
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">百度.</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">Là où la recherche chinoise commence.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Baidu joue avec son propre crawler, son propre index, sa propre API de soumission, son propre cycle algorithmique, et désormais une couche IA (文心X1, DeepSeek) qui rédige plus de vingt pour cent des résultats. <span class="text-white font-medium">Pilotage depuis Shanghai, sur les outils maison de Baidu.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">20</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Ans sur Baidu</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">200</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Relations 知心 suivies</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">72h</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Indexation via 主动推送</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Demander un audit Baidu</Button>
            <Button href="#what-we-do" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir les chantiers</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Sans dépôt</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">site hors continent</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Index : 4 / 312 pages
              </div>
            </div>

            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                </div>
                <span class="text-[10px] font-mono text-white/45 ml-2">百度搜索资源平台</span>
                <span class="ml-auto inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-green-500/15 border border-green-400/30">
                  <span class="w-1 h-1 rounded-full bg-green-400 animate-pulse"></span>
                  <span class="text-[9px] font-mono text-green-300 uppercase">En ligne</span>
                </span>
              </div>

              <div class="space-y-4">
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">主动推送 (Push actif)</span>
                    <span class="text-[10px] text-[var(--color-brand-orange)] font-mono">Branché</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden shimmer-bar">
                    <div class="h-full w-full bg-gradient-to-r from-[var(--color-brand-orange)] to-[#FF8956] rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">Pages indexées</span>
                    <span class="text-[10px] text-white/55 font-mono"><span data-counter>342</span> / 412</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[83%] bg-gradient-to-r from-[var(--color-brand-orange)]/80 to-[var(--color-brand-orange)]/30 rounded-full"></div>
                  </div>
                </div>
                <div>
