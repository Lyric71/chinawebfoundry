---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

const metaTitle = "GEO China | Optimisation pour les moteurs d’IA chinois";
const metaDescription = "Optimisation pour la recherche par IA en Chine. Nous faisons de votre marque la réponse que citent DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA.";

const engines = [
  {
    n: '01',
    cn: '深度',
    name: 'DeepSeek',
    enLabel: '深度求索',
    body: "Privilégie le contenu structuré, techniquement irréprochable, issu de sites officiels. Si votre site charge lentement depuis la Chine ou s’appuie sur des ressources bloquées par le Great Firewall (防火长城), DeepSeek ne vous voit tout simplement pas.",
    tag: 'Long format, structuré',
    chips: ['JSON-LD', 'SSR', 'Vitesse', 'Sans dépendances bloquées'],
  },
  {
    n: '02',
    cn: '豆包',
    name: 'Doubao',
    enLabel: '字节跳动',
    body: 'Le porte-étendard de ByteDance, qui puise massivement dans son propre écosystème : Toutiao (今日头条), Douyin (抖音), Baijiahao (百家号). Optimiser pour Doubao, c’est nourrir le graphe ByteDance en parallèle de votre site.',
    tag: 'Graphe ByteDance',
    chips: ['Toutiao', 'Douyin', 'Baijiahao', 'Syndication'],
  },
  {
    n: '03',
    cn: 'Kimi',
    name: 'Kimi',
    enLabel: 'Moonshot AI',
    body: 'Récompense l’analyse longue. Comparatifs, guides techniques, rapports de plusieurs milliers de mots assortis de tableaux propres. Le contenu marketing court y est ignoré.',
    tag: 'Profondeur et tableaux',
    chips: ['Comparatifs', 'Guides', 'Tableaux', 'Long format'],
  },
  {
    n: '04',
    cn: '元宝',
    name: 'Yuanbao',
    enLabel: '腾讯混元',
    body: "La porte d’entrée de Tencent vers l’écosystème WeChat (微信), et le seul assistant capable d’explorer les comptes officiels (公众号).",
    tag: 'WeChat-aware',
    chips: ['公众号', '视频号', 'Mini Program', 'WeCom'],
  },
  {
    n: '05',
    cn: '文心',
    name: 'Baidu IA',
    enLabel: '文心一言',
    body: 'Propulsé par ERNIE (文心一言). Privilégie les sources d’autorité : Baidu Baike (百度百科), portails gouvernementaux, balisage JSON-LD, présence soutenue sur Baijiahao et Baidu Zhidao (百度知道).',
    tag: 'Logique d’autorité',
    chips: ['百度百科', '百度知道', 'JSON-LD', 'Baijiahao'],
  },
];

const services = [
  {
    n: '01',
    title: 'Diagnostic de visibilité',
    body: 'Une matrice structurée de 80 à 150 requêtes lancées sur les cinq plateformes chinoises, depuis de vrais appareils à Shanghai, Pékin et Shenzhen, sur des réseaux résidentiels et professionnels, jamais sur VPN.',
    bullets: [
      'Taux de citation : à quelle fréquence votre marque apparaît dans les réponses pertinentes.',
      'Rang de recommandation : votre place quand le moteur énumère les options.',
      'Sentiment : tonalité de la mention, neutre, positive ou critique.',
    ],
    tag: 'p.04',
  },
  {
    n: '02',
    title: 'Audit des sources',
    body: 'Les moteurs d’IA récompensent la preuve vérifiable. Numéros de brevet, rapports de laboratoires indépendants, normes publiées : ce qu’on appelle du contenu T1. Le contenu marketing sans appui externe, c’est du T3, ignoré ou marqué comme peu fiable. On cartographie chaque affirmation de votre site et on reconstruit les points faibles avec des éléments de preuve que l’IA peut valider.',
    tag: 'p.10',
  },
  {
    n: '03',
    title: 'Architecture de contenu',
    body: 'Un article isolé ne déplace plus rien. On bâtit des grappes : un pilier central adossé à des FAQ, des comparatifs, des scénarios d’usage, des études de cas. Quel que soit l’angle de la question, votre site refait surface.',
    tag: 'p.16',
  },
  {
    n: '04',
    title: 'Diffusion multi-plateformes',
    body: 'Les moteurs recoupent une même marque sur les destinations de référence. On syndique sur Baijiahao (百家号), Zhihu (知乎), les portails sectoriels, et, quand c’est pertinent, sur les fiches Baidu Baike (百度百科).',
    tag: 'p.22',
  },
  {
    n: '05',
    title: 'Fondations techniques',
    body: "Balisage JSON-LD, robots.txt taillé pour Baiduspider, Sogouspider, ByteSpider, sitemaps XML, balises canoniques qui ne dispersent pas l’autorité entre les versions linguistiques. La plupart des sites internationaux se trompent sur ce point.",
    tag: 'p.28',
  },
  {
    n: '06',
    title: 'Pilotage continu',
    body: 'DeepSeek a publié quatre révisions majeures sur la seule année 2025. Ce qui marchait en février ne marchait plus en mai. On mesure chaque semaine et on ajuste avant que la baisse de citations ne se fasse sentir.',
    tag: 'p.34',
  },
];

const stages = [
  {
    n: '01',
    cn: '诊断',
    title: 'Diagnostic de visibilité',
    body: 'Lancement de la matrice de requêtes sur les cinq moteurs, depuis de vrais appareils à Shanghai, Pékin et Shenzhen. Livrable : un rapport de référence avec les écarts identifiés plateforme par plateforme.',
    output: 'Référentiel de citations',
  },
  {
    n: '02',
    cn: '证据',
    title: 'Audit des preuves et des sources',
    body: 'Chaque affirmation classée T1, T2 ou T3. Reconstruction des points faibles à partir de brevets, rapports de laboratoire, experts nommés et données structurées que les moteurs peuvent valider.',
    output: 'Cartographie des preuves',
  },
  {
    n: '03',
    cn: '内容',
    title: 'Grappes éditoriales',
    body: 'Pages piliers en chinois natif, FAQ, comparatifs, scénarios d’usage, études de cas. Conçues pour qu’aucun angle de question ne passe à côté de votre site.',
    output: 'Grappes en ligne',
  },
  {
    n: '04',
    cn: '分发',
    title: 'Syndication et structuration',
    body: '百家号, 知乎, 百度百科 (lorsque c’est mûr), portails sectoriels, plus le travail de balisage JSON-LD, robots.txt, llms.txt, canoniques et sitemaps livré dans la foulée.',
    output: 'Présence inter-plateformes',
  },
  {
    n: '05',
    cn: '迭代',
    title: 'Suivi et itération',
    body: 'Relance hebdomadaire de la matrice de requêtes sur les cinq moteurs. Ajustements avant que les mises à jour des modèles ne fassent chuter les citations. Rapport mensuel écrit.',
    output: 'Pilotage hebdomadaire',
  },
];

const evidenceTiers = [
  {
    label: 'T1',
    title: 'Preuves dures',
    body: 'Numéros de brevet, rapports de laboratoires indépendants, normes publiées, données officielles.',
    weight: 100,
    color: 'green',
    examples: ['Brevet CN10X', 'Rapport SGS', 'Norme GB/T', 'Données CNNIC'],
  },
  {
    label: 'T2',
    title: 'Reconnu par le secteur',
    body: 'Couverture presse spécialisée, rapports d’analystes, expert nommé, distinctions sectorielles.',
    weight: 60,
    color: 'amber',
    examples: ['36Kr', '艾瑞咨询', 'Expert nommé', 'Prix sectoriel'],
  },
  {
    label: 'T3',
    title: 'Texte marketing',
    body: 'Affirmations de marque sans appui externe. Ignorées ou signalées comme peu fiables.',
    weight: 15,
    color: 'red',
    examples: ['« Le meilleur »', '« Leader du marché »', 'Sans source', 'Slogan seul'],
  },
];

const stats = [
  { value: '600M+', label: 'Utilisateurs d’IA en Chine · 2026', sub: 'Décompte CNNIC des utilisateurs d’IA générative en Chine.' },
  { value: '20%+', label: 'Pages Baidu avec réponse IA', sub: '文心X1 et DeepSeek désormais intégrés aux résultats.' },
  { value: '4', label: 'Révisions de DeepSeek en 2025', sub: 'Ce qui marchait en février ne marchait plus en mai.' },
];

const audiences = [
  {
    label: 'Marques invisibles sur les IA chinoises',
    description: "Entreprises dont le nom n’apparaît jamais quand un acheteur interroge DeepSeek, Doubao ou Yuanbao sur leur catégorie, alors que les concurrents, eux, sont cités et liés.",
    image: '/images/audiences/audience-geo-invisible-on-ai.webp',
  },
  {
    label: 'Marques internationales qui s’implantent en Chine',
    description: 'Équipes qui veulent intégrer la visibilité IA au lancement, sans avoir à la rattraper six mois plus tard quand le trafic stagne.',
    image: '/images/audiences/audience-geo-launching-china-market.webp',
  },
  {
    label: 'Marques avec contenu mais sans preuve',
    description: 'Sites au contenu chinois soigné que les moteurs ignorent malgré tout, faute de sources vérifiables, de données structurées et de validation par tiers.',
    image: '/images/audiences/audience-geo-content-without-evidence.webp',
  },
  {
    label: 'Marques dont le trafic naturel s’aplatit',
    description: 'Équipes marketing qui voient leur trafic organique chinois plafonner à mesure que les acheteurs basculent sur la recherche par IA, et qui veulent désormais que les moteurs citent leur marque dans la réponse.',
    image: '/images/audiences/audience-geo-search-traffic-flat.webp',
  },
];

const marqueePhrases = [
  'GEO China',
  'DeepSeek', '深度求索',
  'Doubao', '豆包',
  'Kimi', '元宝',
  '文心一言',
  'Cité par les IA',
  'Preuves T1',
  'JSON-LD',
  'llms.txt',
  '百家号 · 知乎 · 百度百科',
];

const faqs = [
  {
    id: 'difference-from-seo',
    question: 'En quoi le GEO diffère-t-il du SEO Baidu ?',
    answer: [
      "Les deux se chevauchent, sans se confondre. Le SEO Baidu optimise la page de résultats, où l’internaute parcourt encore dix liens bleus avant de cliquer. Le GEO optimise les assistants d’IA qui lisent votre contenu et décident s’ils vous citent dans une réponse unique. Critères de classement, structure du contenu, mesures de réussite : tout diffère. La plupart de nos clients pilotent les deux ensemble, parce que les fondations éditoriales se recoupent largement.",
    ],
  },
  {
    id: 'platforms-covered',
    question: 'Quelles plateformes d’IA chinoises couvrez-vous concrètement ?',
    answer: [
      'DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝) et Baidu IA (propulsé par 文心一言). Ce sont les cinq qui pèsent réellement en Chine continentale aujourd’hui. ChatGPT, Perplexity, Google AI Overviews et Claude n’ont pas leur place ici : derrière le Great Firewall, leur portée est nulle.',
    ],
  },
  {
    id: 'measurement',
    question: 'Comment mesurez-vous le succès ?',
    answer: [
      'Trois indicateurs, suivis chaque mois. Taux de citation : à quelle fréquence votre marque apparaît dans les réponses à une matrice de requêtes figée. Rang de recommandation : votre place quand le moteur énumère les options. Sentiment : tonalité positive, neutre ou critique. Restitution sous forme de note écrite : quelques pages denses, lisibles d’une traite.',
    ],
  },
  {
    id: 'how-long',
    question: 'Combien de temps avant de voir les citations décoller ?',
    answer: [
      'Audit et fondations : 4 à 6 semaines. Production éditoriale et syndication : trois à quatre mois. Au sixième mois, la plupart des clients constatent une vraie progression sur au moins deux plateformes. La couverture pleine s’établit en général entre le neuvième et le douzième mois. Quiconque vous promet une part de citation IA en trente jours vend autre chose.',
    ],
  },
  {
    id: 'evidence-tiers',
    question: "T1, T2, T3 : qu’est-ce que c’est et pourquoi est-ce important ?",
    answer: [
      'Les moteurs d’IA pondèrent les sources selon la vérifiabilité des affirmations. T1 : contenu adossé à des preuves dures, brevets, rapports de laboratoire indépendants, normes publiées, données officielles. T2 : reconnu par le secteur mais secondaire, presse spécialisée, rapports d’analystes, experts nommés. T3 : texte marketing sans preuve externe, le genre que les moteurs ignorent ou signalent comme peu fiable. Nous classons chaque affirmation de votre site et reconstruisons les points faibles.',
    ],
  },
  {
    id: 'translated-content',
    question: 'Peut-on simplement traduire notre contenu anglais ?',
    answer: [
      "Non. Le contenu traduit sonne étranger pour les moteurs chinois, perd souvent les repères structurels qui leur servent à décider, et reflète rarement la manière dont les internautes chinois formulent réellement leurs questions. On travaille avec des éditeurs natifs chinois, qui réécrivent depuis la page blanche, en gardant intactes les affirmations sources et leurs preuves.",
    ],
  },
  {
    id: 'syndication',
    question: 'Où syndiquez-vous le contenu ?',
    answer: [
      'Baijiahao (百家号) pour la portée Baidu et Yuanbao, Zhihu (知乎) pour les signaux de crédibilité technique et B2B, Toutiao (今日头条) et Baijiahao pour les surfaces ByteDance et Doubao, et lorsque c’est pertinent, des fiches Baidu Baike (百度百科) officielles. Les portails sectoriels viennent compléter selon votre marché.',
    ],
  },
  {
    id: 'algorithm-changes',
    question: 'Que se passe-t-il quand les moteurs modifient leurs modèles ?',
    answer: [
      'Ils le font souvent. DeepSeek a publié quatre révisions majeures sur la seule année 2025. On suit les citations chaque semaine sur la même matrice de requêtes utilisée à l’audit, et on ajuste contenu, balisage et syndication avant que la modification ne se traduise par une chute. Les équipes qui ne surveillent pas ce point perdent leur visibilité sans comprendre pourquoi.',
    ],
  },
  {
    id: 'cost',
    question: "Combien coûte un programme GEO China ?",
    answer: [
      'Cela dépend du périmètre : nombre de gammes ou d’axes, profondeur du capital éditorial existant, plateformes à couvrir intégralement, intégration ou non de la production de contenu chinois et du SEO Baidu. Décrivez-nous le périmètre, nous revenons sous deux jours ouvrés avec un chiffre ferme.',
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-geo-beijing-ai-research.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[#4D6BFE]/15 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">答</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">GEO China</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">GEO China</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">5 moteurs, un seul programme</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Cité
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">par les IA</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">chinoises.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            L’optimisation pour les moteurs génératifs, à destination du marché chinois. Nous faisons de votre contenu la réponse que DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA jugent assez fiable pour la rendre aux internautes. <span class="text-white font-medium">Une seule réponse par question, votre marque dedans.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter>5</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Moteurs couverts</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">600M</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Utilisateurs d’IA en Chine</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">150</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Requêtes par audit</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Demander un audit IA</Button>
            <Button href="#engines" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir les cinq moteurs</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Non cité</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">le concurrent gagne</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Taux de citation : 0%
              </div>
            </div>

            <div data-tilt class="relative bg-white rounded-2xl shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)] overflow-hidden">
              <div class="flex items-center gap-2.5 px-5 py-3 bg-white border-b border-gray-100">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#4D6BFE] to-[#3a55e8] flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm5.5 11.5c-1.4.4-2.9.5-4.4.3-.4 1.6-.4 3.3 0 4.9-1.4-.6-2.6-1.5-3.5-2.7-1.5.4-3 .5-4.5.4 1-1.5 2.4-2.6 4-3.3-.6-1.4-1-3-1-4.6 1.4.6 2.7 1.6 3.6 2.8 1.5-.5 3.1-.6 4.6-.4-.7 1.4-1.7 2.6-3 3.5.6.4 1.3.7 2 .9.6.6 1.4 1.5 2.2 2.2z"/>
                  </svg>
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="text-sm font-semibold text-gray-900">DeepSeek</span>
                  <span class="text-[10px] text-gray-400">深度求索</span>
                </div>
                <div class="ml-auto flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                  <span class="text-[10px] text-gray-400">在线</span>
                </div>
              </div>

              <div class="px-5 py-4 space-y-4 bg-white">
                <div class="flex justify-end">
                  <div class="max-w-[85%] bg-[#F4F5F7] rounded-2xl rounded-tr-sm px-3.5 py-2.5">
                    <p class="text-[12.5px] text-gray-900 leading-relaxed">推荐几家专门服务国际品牌的中国 WordPress 建站代理商</p>
                  </div>
                </div>

                <div class="flex items-center gap-1.5">
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#EEF2FF] text-[#4D6BFE] text-[10px] font-medium">
                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    深度思考 R1
                  </span>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#ECFDF5] text-emerald-600 text-[10px] font-medium">
                    联网搜索
                  </span>
                </div>

                <p class="text-[10.5px] text-gray-400">已搜索 14 个网页 · 用时 3.2 秒</p>

                <div>
                  <p class="text-[12.5px] text-gray-700 leading-relaxed mb-3">
