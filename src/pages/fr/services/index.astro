---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';

const services = [
  {
    title: 'Stratégie et audit',
    tagline: 'Commencez par la clarté, pas par les suppositions.',
    description: 'Nous testons votre site depuis de vrais navigateurs à Pékin, Shanghai, Shenzhen et observons ce qui se passe réellement. Chaque ressource bloquée, chaque problème de conformité, le tout documenté avec une feuille de route exploitable.',
    link: '/fr/services/strategy-audit/',
    cta: 'Demander un audit Chine',
    icon: 'strategy',
    featured: true,
  },
  {
    title: 'Migration',
    tagline: 'Migrez vers la Chine sans perdre ce que vous avez construit.',
    description: 'Transfert complet du site derrière le Grand Pare-feu. Contenus, capital SEO, intégrations, tout y passe. Nous avons migré des sites depuis Drupal, Sitecore, Shopify et des architectures sur mesure parfois redoutables.',
    link: '/fr/services/china-migration/',
    cta: 'Lancer votre évaluation de migration',
    icon: 'migration',
    featured: true,
  },
  {
    title: 'Design UX/UI',
    tagline: 'Concevez pour la façon dont les Chinois naviguent réellement.',
    description: 'Mobile-first, mises en page denses, QR codes WeChat, badges de licence commerciale. La moitié paraît incongrue aux yeux occidentaux, mais convertit à Chongqing.',
    link: '/fr/services/ux-ui-design/',
    cta: 'Lancer votre projet design',
    icon: 'design',
    featured: false,
  },
  {
    title: 'Intégration technique',
    tagline: 'Votre stack complète, reconstruite pour le Grand Pare-feu.',
    description: 'Configuration serveur, nettoyage de thème, remplacement des dépendances bloquées, WeChat Pay, Alipay, Baidu Analytics. Le tout testé depuis des connexions réelles en Chine.',
    link: '/fr/services/technical-integration/',
    cta: 'Planifier une consultation technique',
    icon: 'technical',
    featured: false,
  },
  {
    title: 'Contenu chinois',
    tagline: 'Écrit en chinois natif. Pas traduit.',
    description: 'Nos rédacteurs sont des locuteurs natifs qui créent du contenu chinois original avec les facteurs de classement Baidu intégrés dès le départ. C\'est toute la différence.',
    link: '/fr/services/chinese-content/',
    cta: 'Parlez-nous de vos besoins en contenu',
    icon: 'content',
    featured: false,
  },
  {
    title: 'Référencement Baidu',
    tagline: 'Google n\'existe pas ici.',
    description: 'Crawler différent, signaux de classement différents, logique de mots-clés radicalement différente. Nous faisons du SEO Baidu depuis la Chine avec les propres outils de Baidu.',
    link: '/fr/services/baidu-seo/',
    cta: 'Demander un audit SEO Baidu',
    icon: 'seo',
    featured: false,
  },
  {
    title: 'Extensions et plugins',
    tagline: 'La plupart des plugins n\'ont pas été conçus pour la Chine. Les nôtres, si.',
    description: 'Environ 40 % des extensions WordPress populaires dépendent de Google. Polices, reCAPTCHA, Maps. Tout bloqué. Nous construisons des remplacements et corrigeons celles qui peuvent être sauvées.',
    link: '/fr/services/plugins-extensions/',
    cta: 'Demander une consultation plugins',
    icon: 'plugins',
    featured: false,
  },
  {
    title: 'Hébergement en Chine',
    tagline: 'Un mauvais hébergement ruine tout le reste.',
    description: 'Serveurs en Chine continentale, chargement en moins d\'une seconde, conformité ICP. Besoin de couvrir la Chine et le reste du monde ? Nous proposons une architecture double avec routage géographique.',
    link: '/fr/services/china-hosting/',
    cta: 'Explorer les options d\'hébergement',
    icon: 'hosting',
    featured: false,
  },
  {
    title: 'Maintenance et support',
    tagline: 'Quelqu\'un doit surveiller depuis l\'intérieur.',
    description: 'Une Google Font bloquée un mardi quelconque et votre page d\'accueil devient illisible pour tout Shanghai. Nous surveillons depuis les réseaux chinois pour que cela n\'arrive jamais.',
    link: '/fr/services/maintenance-support/',
    cta: 'Voir les formules de maintenance',
    icon: 'maintenance',
    featured: false,
  },
];

---

<PageLayout
  title="Services WordPress Chine | Agence en Chine | CWF"
  description="Agence WordPress complète en Chine. Stratégie, migration, design, référencement Baidu, hébergement, contenu, extensions et maintenance. Plus de 20 ans sur le terrain."
  heroPage={true}
  lang="fr"
>
  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero-services.webp"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-32 lg:pb-40">
      <div class="io-grid items-start gap-y-10">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Nos services
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.08]">
            WordPress pour la Chine.<br />Chaque couche, maîtrisée.
          </h1>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 lg:pt-10">
          <p class="text-lg text-white/60 leading-relaxed">
            Une seule agence, basée en Chine, couvrant tout ce dont votre site WordPress a besoin pour fonctionner derrière le Grand Pare-feu.
          </p>
          <div class="mt-8">
            <Button href="/fr/contact/" variant="primary" size="md">Dites-nous ce qu'il vous faut</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Services - Large Bento Cards -->
  <section class="py-20 md:py-28 lg:py-36">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="mb-16 lg:mb-20 max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Ce que nous faisons
        </p>
        <p class="text-lg lg:text-xl text-[var(--color-text-body)] leading-relaxed">
          La plupart des sites WordPress sont cassés en Chine. Extensions bloquées, pages qui ne finissent jamais de charger, Baidu incapable d'indexer quoi que ce soit. Nous résolvons ces problèmes depuis l'intérieur de la Chine depuis plus de 20 ans.
        </p>
      </div>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {services.map((service) => (
          <a
            href={service.link}
            class="group relative flex flex-col bg-white border border-[var(--color-surface-border)] rounded-2xl p-7 lg:p-8 no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
          >
            <div class="w-12 h-12 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center mb-5 group-hover:bg-[var(--color-brand-orange)]/20 transition-colors duration-300">
              {service.icon === 'strategy' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                </svg>
              )}
              {service.icon === 'migration' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
              )}
              {service.icon === 'design' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
                </svg>
              )}
              {service.icon === 'technical' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                </svg>
              )}
              {service.icon === 'content' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              )}
              {service.icon === 'seo' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
                </svg>
              )}
              {service.icon === 'plugins' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.491 48.491 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" />
                </svg>
              )}
              {service.icon === 'hosting' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
                </svg>
              )}
              {service.icon === 'maintenance' && (
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              )}
            </div>

            <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-2">
              {service.tagline}
            </p>
            <h2 class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-3">
              {service.title}
            </h2>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-6 flex-1">
              {service.description}
            </p>

            <span class="inline-flex items-center gap-2 text-sm font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] group-hover:gap-3 transition-all duration-200">
              {service.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Strip -->
  <section class="bg-[var(--color-surface-dark)] py-16 md:py-20">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <div>
          <div class="w-10 h-10 rounded-full bg-[var(--color-brand-orange)] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium font-[var(--font-heading)] text-white mb-2">Audit</h3>
          <p class="text-sm text-white/50 leading-relaxed">Nous testons votre site depuis l'intérieur de la Chine et documentons tout ce qui est cassé.</p>
        </div>
        <div>
          <div class="w-10 h-10 rounded-full bg-[var(--color-brand-orange)] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium font-[var(--font-heading)] text-white mb-2">Plan</h3>
          <p class="text-sm text-white/50 leading-relaxed">Feuille de route claire avec priorités, calendrier et sans mauvaises surprises.</p>
        </div>
        <div>
          <div class="w-10 h-10 rounded-full bg-[var(--color-brand-orange)] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.42 15.17l-5.1-5.1m0 0L11.42 4.97m-5.1 5.1H21M3 21h18" />
            </svg>
          </div>
          <h3 class="text-lg font-medium font-[var(--font-heading)] text-white mb-2">Construction</h3>
          <p class="text-sm text-white/50 leading-relaxed">Nous exécutons depuis la Chine en testant sur de vrais réseaux à chaque étape.</p>
        </div>
        <div>
          <div class="w-10 h-10 rounded-full bg-[var(--color-brand-orange)] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium font-[var(--font-heading)] text-white mb-2">Support</h3>
          <p class="text-sm text-white/50 leading-relaxed">Surveillance et maintenance continues depuis les réseaux chinois.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 md:py-32 lg:py-40">
    <div class="mx-auto max-w-[1400px] section-padding text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
        Déterminons ensemble ce qu'il vous faut en Chine
      </h2>
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed max-w-2xl mx-auto mb-10">
        Peut-être que votre site ne charge pas derrière le Grand Pare-feu. Peut-être que vous repoussez un lancement parce que le volet chinois semble trop complexe. Quoi qu'il en soit, dites-nous ce qui se passe et nous trouverons la solution ensemble.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Planifier un appel découverte</Button>
        <Button href="/fr/contact/" variant="secondary" size="lg">Obtenir une évaluation gratuite</Button>
      </div>
    </div>
  </section>
</PageLayout>
