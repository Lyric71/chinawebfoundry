---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';

// Définitions de phases et données de service tirées des pages individuelles
const phases = [
  {
    id: 'plan',
    label: 'Cadrer',
    cn: '策略',
    title: 'Décider quoi bâtir, avant de bâtir',
    blurb: 'Audit de l’existant. Cartographie de ce dont votre public chinois a réellement besoin. Une feuille de route qui mène à une vraie présence en Chine, dans le bon ordre.',
  },
  {
    id: 'build',
    label: 'Construire',
    cn: '搭建',
    title: 'Reconstruire la pile pour l’arrière du Pare-feu',
    blurb: 'Migration, design, intégration technique, extensions sur mesure. Chaque couche reconstruite et testée depuis de vraies connexions chinoises.',
  },
  {
    id: 'host',
    label: 'Héberger',
    cn: '主机',
    title: 'Un hébergement qui tient en Chine continentale',
    blurb: 'Chargement sous la seconde sur un téléphone à Shanghai. Dépôt ICP géré de bout en bout. Continental, Hong Kong ou dual-stack.',
  },
  {
    id: 'grow',
    label: 'Faire grandir',
    cn: '增长',
    title: 'Trouvable sur Baidu, cité par les IA chinoises',
    blurb: 'Contenu chinois natif, référencement Baidu piloté depuis la Chine, visibilité IA sur DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA.',
  },
  {
    id: 'run',
    label: 'Faire vivre',
    cn: '维护',
    title: 'Quelqu’un qui veille de l’intérieur, chaque semaine',
    blurb: 'Cadence éditoriale, suivi SEO et GEO, maintenance technique, hébergement. Une équipe, une facture, supervisée depuis Shanghai.',
  },
];

// Service phare : Stratégie et audit
const strategy = {
  title: 'Stratégie et audit',
  cn: '策略',
  tagline: 'Une feuille de route écrite, que vous emportez où vous voulez.',
  description: "Nous ouvrons votre site depuis de vrais navigateurs à Pékin, Shanghai et Shenzhen, et observons ce qui se passe vraiment. Positionnement de marque, visibilité de recherche, pile technologique, empreinte WeChat, conformité : nous cartographions le tout, puis écrivons la feuille de route qui mène au lancement, dans le bon ordre.",
  link: '/fr/services/strategy-audit/',
  cta: 'Démarrer par la stratégie',
  deliverables: [
    'Diagnostic de préparation Chine sur le contenu, l’UX, la recherche, la performance et la conformité',
    'Positionnement stratégique calibré sur les signaux de confiance chinois',
    'Architecture technologique : WordPress ou Astro, Mini Program ou H5, dual-stack',
    'Feuille de route séquencée, dépôt ICP placé sur le chemin critique',
  ],
  stats: [
    { value: '15+', label: 'ans à Shanghai' },
    { value: '50+', label: 'marques lancées' },
    { value: '3-4 sem.', label: 'jusqu’à livraison' },
  ],
};

// Services de la phase Construire
const buildServices = [
  {
    title: 'Migration Chine',
    cn: '迁移',
    tagline: 'Une vraie migration en Chine, c’est une relance complète.',
    description: "Nous relançons contenu, UX et hébergement ensemble. Signaux de confiance réécrits, mise en page repensée pour les habitudes de lecture chinoises, infrastructure déplacée sur des serveurs continentaux, dépôt ICP en parallèle.",
    link: '/fr/services/china-migration/',
    cta: 'Parler de votre migration',
    icon: 'migration',
    deliverables: [
      'Contenu réécrit en chinois par des éditeurs natifs',
      'UX repensée pour des pages plus denses et le navigateur WeChat',
      'Bascule sans coupure, retour en arrière possible sous 48 h',
      'Mapping d’URL et 301 pour préserver l’autorité SEO',
    ],
    stats: [
      { value: '50+', label: 'marques migrées' },
      { value: '6-10 sem.', label: 'fenêtre type' },
    ],
  },
  {
    title: 'Design UX et UI',
    cn: '设计',
    tagline: 'Concevoir pour la façon dont les Chinois naviguent vraiment.',
    description: "Mobile d’abord, mises en page denses, calées sur la manière dont les internautes chinois naviguent après WeChat, Taobao et Douyin. Les designs très aérés se lisent comme vides. Les signaux de confiance restent au-dessus de la ligne de flottaison.",
    link: '/fr/services/ux-ui-design/',
    cta: 'Démarrer un projet de design',
    icon: 'design',
    deliverables: [
      'Recherche utilisateur cartographiant les parcours Douyin, WeChat et Baidu',
      'Architecture de l’information bâtie pour des pages plus denses',
      'QR WeChat, ICP et licence d’entreprise au-dessus de la ligne',
      'QA sur UC Browser, QQ Browser et Chrome',
    ],
    stats: [
      { value: '70%+', label: 'trafic mobile en Chine' },
      { value: '6', label: 'navigateurs testés en natif' },
    ],
  },
  {
    title: 'Intégration technique',
    cn: '技术',
    tagline: 'Deux secondes en Occident en font quinze à Shenzhen.',
    description: "Configuration serveur, nettoyage du thème, remplacement des dépendances bloquées, WeChat Pay, Alipay, Baidu Tongji. Toute la pile reconstruite et testée depuis de vrais réseaux chinois, à Shanghai et à Shenzhen.",
    link: '/fr/services/technical-integration/',
    cta: 'Caler une consultation technique',
    icon: 'technical',
    deliverables: [
      'Optimisation Aliyun, Tencent ou Huawei selon le fournisseur',
      'WeChat Pay, Alipay, connexion WeChat, Baidu Tongji intégrés',
      'Google Fonts remplacées, jQuery rerouté, API bloquées remplacées',
      'Architecture PIPL et Loi sur la cybersécurité dès le premier jour',
    ],
    stats: [
      { value: '47', label: 'ressources bloquées par site' },
      { value: '2,1 s', label: 'chargement après corrections' },
    ],
  },
  {
    title: 'Extensions et plug-ins',
    cn: '插件',
    tagline: 'Des extensions WordPress taillées pour le Pare-feu.',
    description: "Environ 40 % des extensions WordPress populaires dépendent de Google. Toutes bloquées derrière le Pare-feu. Nous bâtissons celles qui marchent et réparons celles qui peuvent l’être.",
    link: '/fr/services/plugins-extensions/',
    cta: 'Demander une consultation',
    icon: 'plugins',
    deliverables: [
      'OAuth WeChat, ponts vers Mini Programs, liens compte officiel',
      'Alipay, WeChat Pay, UnionPay en extensions WooCommerce',
      'Sitemap Baidu, API push et outils de balises meta',
      'Blocs Gutenberg sur mesure : QR WeChat, Cartes Baidu, Bilibili',
    ],
    stats: [
      { value: '60 %', label: 'd’extensions réparables sur place' },
      { value: 'UC', label: 'Browser inclus dans le QA' },
    ],
  },
];

// Phase Héberger : carte hébergement phare
const hosting = {
  title: 'Hébergement Chine',
  cn: '主机',
  tagline: 'Sous licence ICP, rapide, géré.',
  description: "Votre site ne charge probablement pas en Chine. Dix à quinze secondes, c’est typique pour un site international. Trafic ralenti, CDN bloqués, Google Fonts qui ne se résolvent pas. Nous corrigeons à la couche infrastructure.",
  link: '/fr/services/china-hosting/',
  cta: 'Voir les options d’hébergement',
  options: [
    {
      name: 'Continental',
      timeframe: '6-10 semaines',
      bullets: ['Chargement sous la seconde sur les téléphones chinois', 'Requis pour l’effet Baidu', 'Licence ICP gérée de bout en bout'],
    },
    {
      name: 'Hong Kong',
      timeframe: '2-3 semaines',
      bullets: ['2 à 4 secondes depuis le continent', 'Sans ICP', 'Lancement rapide, effet Baidu faible'],
    },
    {
      name: 'Dual-stack',
      timeframe: '8-12 semaines',
      bullets: ['Mondial et Chine en parallèle', 'Un seul flux éditorial', 'Routage géographique en bordure'],
    },
  ],
  stats: [
    { value: '0,8 s', label: 'chargement médian continental' },
    { value: '99,97 %', label: 'disponibilité sur 30 jours' },
    { value: '100 %', label: 'taux de réussite ICP' },
  ],
};

// Services de la phase Faire grandir
const growServices = [
  {
    title: 'Contenu chinois',
    cn: '内容',
    tagline: 'Des éditeurs qui écrivent en chinois, dans votre voix de marque.',
    description: "Des rédacteurs chinois natifs reprennent vos messages dans l’ordre où le lecteur chinois décide vraiment : preuve d’abord, crédibilité ensuite, aspiration à la fin.",
    link: '/fr/services/chinese-content/',
    cta: 'Parler à l’équipe contenu',
    icon: 'content',
    deliverables: [
      'Stratégie éditoriale bâtie sur audit Baidu, Zhihu et sectoriel',
      'Pages de confiance que les sites occidentaux oublient : 荣誉资质, 企业历程, 生产基地',
      'Rédaction chinoise native dans votre voix de marque',
      'Discours conforme 广告法 pour le médical, la finance, l’alimentaire et le cosmétique',
    ],
    stats: [
      { value: '9 s', label: 'avant rebond sur copie traduite' },
      { value: '50+', label: 'marques lancées' },
    ],
  },
  {
    title: 'Référencement Baidu',
    cn: '百度',
    tagline: 'Baidu joue avec son crawler, son API et son cycle algorithmique.',
    description: "Crawler différent, API de soumission différente, algorithme différent. Un référencement Baidu piloté depuis la Chine, sur les outils maison de Baidu, par des spécialistes qui suivent 百度搜索资源平台 chaque semaine.",
    link: '/fr/services/baidu-seo/',
    cta: 'Demander un audit Baidu',
    icon: 'seo',
    deliverables: [
      'API 主动推送 câblée dans le CMS pour la soumission temps réel',
      'Recherche de mots-clés en chinois natif, depuis Baidu Index',
      'Travail d’autorité sur 百度百科, 百度知道 et 百家号',
      'Suivi hebdomadaire des mises à jour 知心算法 et 飓风算法',
    ],
    stats: [
      { value: '24-72 h', label: 'indexation via 主动推送' },
      { value: '6-10 sem.', label: 'mouvement longue traîne' },
    ],
  },
  {
    title: 'GEO China',
    cn: '智搜',
    tagline: 'Devenir la réponse que les IA chinoises citent.',
    description: "Optimisation pour les moteurs génératifs sur DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA. Cinq moteurs, cinq jeux de règles, un site qui doit tenir face aux cinq.",
    link: '/fr/services/geo/',
    cta: 'Demander un audit IA',
    icon: 'ai',
    deliverables: [
      'Matrice de 80 à 150 questions sur de vrais appareils, dans trois villes',
      'Audit T1 / T2 / T3 sur les niveaux de preuve face aux IA',
      'Contenu pilier avec FAQ, comparatifs et clusters de scénarios',
      'Syndication sur Baijiahao, Zhihu, Toutiao et Baidu Baike',
    ],
    stats: [
      { value: '600M+', label: 'utilisateurs IA en Chine' },
      { value: '6 mois', label: 'jusqu’aux premières citations' },
    ],
  },
];

// Phase Faire vivre : carte maintenance phare
const maintenance = {
  title: 'Maintenance et accompagnement',
  cn: '维护',
  tagline: 'Un site chinois en production a besoin d’un œil sur place.',
  description: "Lancer est facile. Baidu déclasse les sites qui s’arrêtent de publier. DeepSeek et Doubao mettent à jour leur logique d’ingestion toutes les quelques semaines. Une Google Font laissée dans le thème se retrouve bloquée mardi. Depuis Londres ou Chicago, tout semble aller.",
  link: '/fr/services/maintenance-support/',
  cta: 'Demander une proposition sur mesure',
  deliverables: [
    '2 à 4 pièces de contenu par mois, syndiquées sur Baijiahao et Zhihu',
    'Rapport mensuel de positions Baidu sur les 30 à 50 mots-clés clés',
    'Suivi GEO hebdomadaire sur DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA',
    'Mises à jour cœur, extensions et thème testées d’abord en staging',
    'Détection des blocages Pare-feu : CDN, polices et API corrigés en 14 min environ',
    'Réponse aux piratages : isoler, nettoyer, restaurer, durcir, post-mortem en 48 h',
  ],
  stats: [
    { value: '11', label: 'mises à jour algo Baidu en 2025' },
    { value: '14 min', label: 'détection à correction en moyenne' },
    { value: '99,9 %', label: 'SLA de disponibilité' },
  ],
};
---

<PageLayout
  title="Services web en Chine · ChinaWebFoundry, agence digitale à Shanghai"
  description="Agence digitale full-service en Chine. Stratégie, migration, design, référencement Baidu, GEO, hébergement, contenu et maintenance. WordPress, Astro, headless ou Mini Program, choisis selon le projet. 15+ ans sur le terrain."
  heroPage={true}
  lang="fr"
>
  <!-- ============== HERO ============== -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <video
        class="absolute inset-0 w-full h-full object-cover"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        poster="/images/hero-services.webp"
        aria-hidden="true"
      >
        <source src="/images/Video/greatWall%20AI%20video.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/92 via-[#0f0f12]/75 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-28 lg:pb-32">
      <div class="io-grid items-end gap-y-10">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Nos services
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.06]">
            Une présence chinoise,<br />conçue de bout en bout.
          </h1>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9">
          <p class="text-lg text-white/65 leading-relaxed">
            Une seule agence, basée en Chine, qui couvre chaque couche dont votre site a besoin pour se lancer, performer et rester visible derrière le Grand Pare-feu. Sur la pile que vous utilisez.
          </p>
          <div class="mt-7">
            <Button href="/fr/contact/" variant="primary" size="md">Dites-nous ce qu’il vous faut</Button>
          </div>
        </div>
      </div>
    </div>

    <!-- Pastilles de navigation par phase -->
    <div class="relative border-t border-white/10 bg-[#0f0f12]/60 backdrop-blur-sm">
      <div class="mx-auto max-w-[1400px] section-padding py-5">
        <nav class="flex flex-wrap items-center gap-x-2 gap-y-2 justify-center lg:justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-white/40 mr-2 hidden lg:inline">
            Aller à une phase
          </span>
          <div class="flex flex-wrap gap-2">
            {phases.map((phase) => (
              <a
                href={`#${phase.id}`}
                class="group inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/15 text-white/80 hover:border-[var(--color-brand-orange)] hover:text-white hover:bg-[var(--color-brand-orange)]/10 transition-all duration-200 text-sm font-medium font-[var(--font-button)] no-underline"
              >
                <span class="text-[var(--color-brand-orange)] text-xs font-normal">{phase.cn}</span>
                <span>{phase.label}</span>
              </a>
            ))}
          </div>
        </nav>
      </div>
    </div>
  </section>

  <!-- ============== INTRO ============== -->
  <section class="py-20 md:py-24 lg:py-28">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid gap-y-8">
        <div class="col-span-12 lg:col-span-5">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Ce que nous faisons
          </p>
          <h2 class="text-3xl lg:text-[40px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15]">
            La plupart des sites étrangers sont cassés en Chine.
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-6">
            Dépendances bloquées, pages qui ne finissent jamais de charger, Baidu incapable d’indexer quoi que ce soit, IA assistantes qui citent vos concurrents à votre place. Nous réparons tout ça depuis l’intérieur de la Chine, depuis 15 ans, à travers 10 services qui s’imbriquent.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Nous les avons regroupés en 5 phases de travail avec nous, pour que vous trouviez ce dont vous avez besoin sans lire 10 brochures.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== PHASE PLAN ============== -->
  <section id="plan" class="bg-[var(--color-surface-light)] py-20 md:py-24 lg:py-28 scroll-mt-20">
    <div class="mx-auto max-w-[1400px] section-padding">
      <!-- En-tête de phase -->
      <div class="flex items-baseline gap-4 mb-12 lg:mb-14 pb-6 border-b border-[var(--color-surface-border)]">
        <span class="text-2xl lg:text-3xl font-light text-[var(--color-brand-orange)] font-[var(--font-heading)]">{phases[0].cn}</span>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Phase un</p>
        <h2 class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
          {phases[0].label}
        </h2>
      </div>

      <!-- Carte phare Stratégie -->
      <a
        href={strategy.link}
        class="group block bg-white border border-[var(--color-surface-border)] rounded-3xl overflow-hidden no-underline transition-all duration-300 hover:shadow-[0_20px_50px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
      >
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-0">
          <!-- Gauche : texte -->
          <div class="lg:col-span-7 p-8 md:p-10 lg:p-14">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-xl font-light text-[var(--color-brand-orange)]">{strategy.cn}</span>
              <span class="h-px w-12 bg-[var(--color-brand-orange)]"></span>
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)]">
                {strategy.tagline}
              </p>
            </div>
            <h3 class="text-3xl lg:text-[40px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-5">
              {strategy.title}
            </h3>
            <p class="text-base lg:text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
              {strategy.description}
            </p>

            <!-- Livrables -->
            <ul class="space-y-3 mb-8">
              {strategy.deliverables.map((item) => (
                <li class="flex gap-3 text-[15px] text-[var(--color-text-body)]">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <span class="inline-flex items-center gap-2 text-base font-medium font-[var(--font-button)] text-[var(--color-brand-orange)] group-hover:gap-3 transition-all duration-200">
              {strategy.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>

          <!-- Droite : panneau de chiffres -->
          <div class="lg:col-span-5 bg-[var(--color-surface-dark)] p-8 md:p-10 lg:p-14 flex flex-col justify-center">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-orange)] mb-8">
              En chiffres
            </p>
            <div class="space-y-8">
              {strategy.stats.map((stat) => (
                <div class="border-b border-white/10 pb-6 last:border-0 last:pb-0">
                  <p class="text-4xl lg:text-5xl font-medium font-[var(--font-heading)] text-white mb-1">{stat.value}</p>
                  <p class="text-sm text-white/55">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============== PHASE BUILD ============== -->
  <section id="build" class="py-20 md:py-24 lg:py-28 scroll-mt-20">
    <div class="mx-auto max-w-[1400px] section-padding">
      <!-- En-tête de phase -->
      <div class="flex items-baseline gap-4 mb-12 lg:mb-14 pb-6 border-b border-[var(--color-surface-border)]">
        <span class="text-2xl lg:text-3xl font-light text-[var(--color-brand-orange)] font-[var(--font-heading)]">{phases[1].cn}</span>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Phase deux</p>
        <h2 class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
          {phases[1].label}
        </h2>
      </div>

      <!-- Grille 2x2 des services Construire -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7">
        {buildServices.map((service) => (
          <a
            href={service.link}
            class="group flex flex-col bg-white border border-[var(--color-surface-border)] rounded-2xl p-7 lg:p-9 no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(0,0,0,0.08)] hover:border-[var(--color-brand-orange)]/30"
          >
            <div class="flex items-start justify-between mb-6">
              <div class="w-12 h-12 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center group-hover:bg-[var(--color-brand-orange)]/20 transition-colors duration-300">
                {service.icon === 'migration' && (
                  <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                  </svg>
                )}
                {service.icon === 'design' && (
                  <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
