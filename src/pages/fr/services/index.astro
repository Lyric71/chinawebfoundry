---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';

const phases = [
  { id: 'plan', label: 'Cadrer', cn: '策略', title: 'Décider quoi bâtir, avant de bâtir', blurb: 'Audit de l’existant. Cartographie des besoins réels du public. Une feuille de route qui mène à une vraie présence chinoise, dans le bon ordre.' },
  { id: 'build', label: 'Construire', cn: '搭建', title: 'Reconstruire la pile pour la Chine', blurb: 'Migration, design, intégration technique, extensions sur mesure. Chaque couche reconstruite et testée depuis de vraies connexions chinoises.' },
  { id: 'host', label: 'Héberger', cn: '主机', title: 'Un hébergement qui tient en Chine continentale', blurb: 'Chargement sous la seconde sur un téléphone à Shanghai. ICP géré de bout en bout. Continental, Hong Kong ou dual-stack.' },
  { id: 'grow', label: 'Faire grandir', cn: '增长', title: 'Trouvable sur Baidu, cité par les IA chinoises', blurb: 'Contenu chinois natif, SEO Baidu depuis la Chine, visibilité IA sur DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA.' },
  { id: 'run', label: 'Faire vivre', cn: '维护', title: 'Quelqu’un qui veille de l’intérieur, chaque semaine', blurb: 'Cadence éditoriale, suivi SEO et GEO, maintenance technique, hébergement. Une équipe, une facture, depuis Shanghai.' },
];

const strategy = {
  title: 'Stratégie et audit',
  cn: '策略',
  tagline: 'Une feuille de route, pas une liste d’extensions.',
  description: "Nous tirons votre site depuis de vrais navigateurs à Pékin, Shanghai et Shenzhen, et regardons ce qui se passe vraiment. Positionnement, visibilité de recherche, pile technologique, empreinte WeChat, conformité : nous cartographions tout, puis écrivons la feuille de route qui mène au lancement, dans le bon ordre.",
  link: '/fr/services/strategy-audit/',
  cta: 'Démarrer par la stratégie',
  deliverables: [
    'Diagnostic de préparation : contenu, UX, recherche, performance, conformité',
    'Positionnement calibré sur les signaux de confiance chinois',
    'Architecture technologique : WordPress / Astro, Mini Program / H5, dual-stack',
    'Feuille de route séquencée, ICP placé sur le chemin critique',
  ],
  stats: [
    { value: '20+', label: 'ans à Shanghai' },
    { value: '50+', label: 'marques lancées' },
    { value: '3-4 sem.', label: 'jusqu’à livraison' },
  ],
};

const buildServices = [
  {
    title: 'Migration Chine',
    cn: '迁移',
    tagline: 'Une vraie migration est une relance, pas un copier-coller.',
    description: "Nous relançons contenu, UX et hébergement ensemble. Signaux de confiance réécrits, mise en page repensée pour les habitudes de lecture chinoises, infrastructure déplacée sur des serveurs continentaux, ICP déposé en parallèle.",
    link: '/fr/services/china-migration/',
    cta: 'Parler de votre migration',
    deliverables: [
      'Contenu réécrit, jamais traduit automatiquement',
      'UX repensée pour des pages plus denses et le navigateur WeChat',
      'Bascule sans coupure, retour en arrière possible 48 h',
      'Mapping d’URL et 301 pour préserver l’autorité SEO',
    ],
    stats: [{ value: '50+', label: 'marques migrées' }, { value: '6-10 sem.', label: 'fenêtre type' }],
  },
  {
    title: 'Design UX et UI',
    cn: '设计',
    tagline: 'Concevoir pour les internautes chinois, pas seulement en chinois.',
    description: "Mobile d’abord, mises en page denses, calées sur la manière dont les internautes chinois naviguent après WeChat, Taobao et Douyin. Les designs très aérés se lisent comme vides. Les signaux de confiance sont au-dessus de la ligne de flottaison.",
    link: '/fr/services/ux-ui-design/',
    cta: 'Démarrer un projet de design',
    deliverables: [
      'Recherche utilisateur sur les parcours Douyin, WeChat et Baidu',
      'Architecture de l’information bâtie pour des pages plus denses',
      'QR WeChat, ICP et licence d’entreprise au-dessus de la ligne',
      'QA UC Browser, QQ Browser, Chrome',
    ],
    stats: [{ value: '70%+', label: 'trafic mobile en Chine' }, { value: '6', label: 'navigateurs testés' }],
  },
  {
    title: 'Intégration technique',
    cn: '技术',
    tagline: 'Deux secondes en Occident, quinze à Shenzhen.',
    description: "Configuration serveur, nettoyage du thème, remplacement des dépendances bloquées, WeChat Pay, Alipay, Baidu Tongji. Toute la pile reconstruite et testée depuis de vrais réseaux chinois, sans VPN.",
    link: '/fr/services/technical-integration/',
    cta: 'Caler une consultation technique',
    deliverables: [
      'Optimisation Aliyun, Tencent ou Huawei selon le fournisseur',
      'WeChat Pay, Alipay, connexion WeChat, Baidu Tongji intégrés',
      'Google Fonts remplacées, jQuery rerouté, API bloquées remplacées',
      'Architecture PIPL et Loi sur la cybersécurité dès le premier jour',
    ],
    stats: [{ value: '47', label: 'ressources bloquées par site' }, { value: '2,1 s', label: 'chargement après corrections' }],
  },
  {
    title: 'Extensions et plug-ins',
    cn: '插件',
    tagline: 'La plupart des plug-ins n’ont jamais été pensés pour la Chine. Les nôtres oui.',
    description: "Environ 40 % des extensions WordPress populaires dépendent de Google. Toutes bloquées derrière le Pare-feu. Nous bâtissons celles qui marchent et réparons celles qui peuvent l’être.",
    link: '/fr/services/plugins-extensions/',
    cta: 'Demander une consultation',
    deliverables: [
      'OAuth WeChat, ponts vers Mini Programs, liens compte officiel',
      'Alipay, WeChat Pay, UnionPay en extensions WooCommerce',
      'Sitemap Baidu, API push et balises meta',
      'Blocs Gutenberg : QR WeChat, Cartes Baidu, Bilibili',
    ],
    stats: [{ value: '60 %', label: 'd’extensions réparables' }, { value: 'UC', label: 'Browser inclus dans le QA' }],
  },
];

const hosting = {
  title: 'Hébergement Chine',
  cn: '主机',
  tagline: 'Sous licence ICP, rapide, géré.',
  description: "Votre site ne charge probablement pas en Chine. Dix à quinze secondes, c’est typique pour un site international. Trafic ralenti, CDN bloqués, Google Fonts qui ne se résolvent pas. Nous corrigeons à la couche infrastructure.",
  link: '/fr/services/china-hosting/',
  cta: 'Voir les options',
  options: [
    { name: 'Continental', timeframe: '6-10 semaines', bullets: ['Chargement sous la seconde', 'Requis pour l’effet Baidu', 'ICP géré de bout en bout'] },
    { name: 'Hong Kong', timeframe: '2-3 semaines', bullets: ['2 à 4 secondes depuis le continent', 'Sans ICP', 'Lancement rapide, effet Baidu faible'] },
    { name: 'Dual-stack', timeframe: '8-12 semaines', bullets: ['Mondial + Chine en parallèle', 'Un seul flux éditorial', 'Routage géographique en bordure'] },
  ],
  stats: [{ value: '0,8 s', label: 'chargement médian continental' }, { value: '99,97 %', label: 'disponibilité 30 jours' }, { value: '100 %', label: 'taux de réussite ICP' }],
};

const growServices = [
  {
    title: 'Contenu chinois',
    cn: '内容',
    tagline: 'Des éditeurs, pas des traducteurs.',
    description: "Des rédacteurs chinois natifs reprennent vos messages dans l’ordre où le lecteur chinois décide vraiment : preuve d’abord, crédibilité ensuite, aspiration à la fin.",
    link: '/fr/services/chinese-content/',
    cta: 'Parler à l’équipe contenu',
    deliverables: [
      'Stratégie de contenu sur audit Baidu, Zhihu et sectoriel',
      'Pages de confiance que les sites occidentaux oublient : 荣誉资质, 企业历程, 生产基地',
      'Rédaction chinoise native dans votre voix de marque',
      'Discours conforme 广告法 pour médical, finance, alimentaire, cosmétique',
    ],
    stats: [{ value: '9 s', label: 'avant rebond sur copie traduite' }, { value: '50+', label: 'marques lancées' }],
  },
  {
    title: 'SEO Baidu',
    cn: '百度',
    tagline: 'Baidu n’est pas Google en caractères chinois.',
    description: "Crawler différent, API de soumission différente, algorithme différent. Un SEO Baidu piloté depuis la Chine, sur les outils maison de Baidu, par des spécialistes qui suivent 百度搜索资源平台 chaque semaine.",
    link: '/fr/services/baidu-seo/',
    cta: 'Demander un audit Baidu',
    deliverables: [
      'API 主动推送 câblée dans le CMS pour la soumission temps réel',
      'Recherche de mots-clés en chinois natif, pas traduite',
      'Travail d’autorité sur 百度百科, 百度知道, 百家号',
      'Suivi hebdomadaire des mises à jour 知心算法 et 飓风算法',
    ],
    stats: [{ value: '24-72 h', label: 'indexation via 主动推送' }, { value: '6-10 sem.', label: 'mouvement longue traîne' }],
  },
  {
    title: 'GEO China',
    cn: '智搜',
    tagline: 'Cité par l’IA, pas seulement trouvé.',
    description: "Optimisation pour les moteurs génératifs sur DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA. Cinq moteurs, cinq jeux de règles, un site qui doit tenir face aux cinq.",
    link: '/fr/services/geo/',
    cta: 'Demander un audit IA',
    deliverables: [
      'Matrice de 80 à 150 questions sur de vrais appareils dans trois villes',
      'Audit T1 / T2 / T3 sur les niveaux de preuve face aux IA',
      'Contenu pilier avec FAQ, comparatifs, scénarios',
      'Syndication sur Baijiahao, Zhihu, Toutiao, Baidu Baike',
    ],
    stats: [{ value: '600M+', label: 'utilisateurs IA en Chine' }, { value: '6 mois', label: 'jusqu’aux premières citations' }],
  },
];

const maintenance = {
  title: 'Maintenance et accompagnement',
  cn: '维护',
  tagline: 'Un site chinois en production a besoin d’un œil sur place.',
  description: "Lancer est facile. Baidu déclasse les sites qui s’arrêtent de publier. DeepSeek et Doubao mettent à jour leur ingestion toutes les quelques semaines. Une Google Font laissée dans le thème se retrouve bloquée mardi. Depuis Londres ou Chicago, tout semble aller.",
  link: '/fr/services/maintenance-support/',
  cta: 'Demander une proposition',
  deliverables: [
    'Deux à quatre pièces de contenu par mois, syndiquées sur Baijiahao et Zhihu',
    'Rapport mensuel de positions Baidu sur 30-50 mots-clés',
    'Suivi GEO hebdomadaire sur DeepSeek, Doubao, Kimi, Yuanbao, Baidu IA',
    'Mises à jour cœur, extensions et thème testées en staging d’abord',
    'Détection des blocages Pare-feu : CDN, polices, API corrigés en 14 min',
    'Réponse aux piratages : isoler, nettoyer, restaurer, durcir, post-mortem 48 h',
  ],
  stats: [{ value: '11', label: 'mises à jour algo Baidu en 2025' }, { value: '14 min', label: 'détection-correction' }, { value: '99,9 %', label: 'SLA' }],
};
---

<PageLayout
  title="Services web en Chine | Agence digitale chinoise | CWF"
  description="Agence digitale full-service en Chine. Stratégie, migration, design, SEO Baidu, GEO, hébergement, contenu et maintenance. WordPress, Astro, headless ou Mini Program, choisis selon le projet. 20+ ans sur le terrain."
  heroPage={true}
  lang="fr"
>

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <video class="absolute inset-0 w-full h-full object-cover" autoplay loop muted playsinline preload="auto" poster="/images/hero-services.webp" aria-hidden="true">
        <source src="/images/Video/greatWall%20AI%20video.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/92 via-[#0f0f12]/75 to-[#0f0f12]/30"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-28 lg:pb-32">
      <div class="io-grid items-end gap-y-10">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Nos services</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.06]">
            Une présence chinoise,<br />conçue de bout en bout.
          </h1>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9">
          <p class="text-lg text-white/65 leading-relaxed">
            Une seule agence, basée en Chine, qui couvre chaque couche dont votre site a besoin pour se lancer, performer et rester visible derrière le Pare-feu. Sur la pile que vous utilisez.
          </p>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-2 lg:grid-cols-5 gap-3 lg:gap-5">
        {phases.map((p) => (
          <a href={`#${p.id}`} class="group rounded-2xl border border-white/10 bg-white/[0.03] p-5 hover:bg-white/[0.06] transition-all no-underline">
            <div class="text-[10px] font-mono uppercase tracking-wider text-white/40">{p.label}</div>
            <div class="text-2xl font-medium font-[var(--font-heading)] text-white mt-1">{p.cn}</div>
            <p class="text-xs text-white/55 mt-3 leading-relaxed">{p.title}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PLAN -->
  <section id="plan" class="section-spacing bg-white scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Cadrer · 策略</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          {phases[0].title}
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">{phases[0].blurb}</p>
      </div>

      <article class="bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white rounded-3xl p-8 lg:p-12 overflow-hidden relative">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
          <div class="lg:col-span-7">
            <p class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-brand-orange)] mb-3">{strategy.cn} · Mission phare</p>
            <h3 class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] mb-3">{strategy.title}</h3>
            <p class="text-[var(--color-brand-orange)] font-medium mb-5">{strategy.tagline}</p>
            <p class="text-base text-white/75 leading-relaxed mb-6">{strategy.description}</p>
            <ul class="space-y-2 mb-7">
              {strategy.deliverables.map((d) => (
                <li class="flex gap-3 text-sm text-white/80"><span class="text-[var(--color-brand-orange)]">·</span><span>{d}</span></li>
              ))}
            </ul>
            <Button href={strategy.link} variant="primary" size="md">{strategy.cta}</Button>
          </div>
          <div class="lg:col-span-5 grid grid-cols-3 gap-3 content-start">
            {strategy.stats.map((s) => (
              <div class="rounded-xl bg-white/[0.06] border border-white/10 p-4">
                <div class="text-2xl font-medium font-[var(--font-heading)]">{s.value}</div>
                <div class="text-[10px] uppercase tracking-wider text-white/55 mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- BUILD -->
  <section id="build" class="section-spacing bg-[var(--color-surface-light)] scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Construire · 搭建</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          {phases[1].title}
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">{phases[1].blurb}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6">
        {buildServices.map((s) => (
          <article class="bg-white rounded-2xl p-7 lg:p-8 border border-[var(--color-surface-border)]">
            <div class="flex items-baseline justify-between mb-3">
              <h3 class="text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)]">{s.title}</h3>
              <span class="text-2xl text-[var(--color-brand-orange)]/60">{s.cn}</span>
            </div>
            <p class="text-[var(--color-brand-orange)] font-medium mb-4">{s.tagline}</p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-5">{s.description}</p>
            <ul class="space-y-2 mb-5">
              {s.deliverables.map((d) => (
                <li class="flex gap-2 text-sm text-[var(--color-text-body)]"><span class="text-[var(--color-brand-orange)]">·</span><span>{d}</span></li>
              ))}
            </ul>
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <a href={s.link} class="text-sm font-semibold text-[var(--color-brand-orange)] no-underline hover:underline">{s.cta} →</a>
              <div class="flex gap-3">
                {s.stats.map((st) => (
                  <div class="text-right">
                    <div class="text-base font-semibold text-[var(--color-text-dark)]">{st.value}</div>
                    <div class="text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider">{st.label}</div>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- HOST -->
  <section id="host" class="section-spacing bg-white scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Héberger · 主机</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          {phases[2].title}
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">{phases[2].blurb}</p>
      </div>

      <article class="bg-[var(--color-surface-light)] rounded-3xl p-8 lg:p-12 border border-[var(--color-surface-border)]">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
          <div class="lg:col-span-5">
            <h3 class="text-3xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{hosting.title}</h3>
            <p class="text-[var(--color-brand-orange)] font-medium mb-5">{hosting.tagline}</p>
            <p class="text-base text-[var(--color-text-body)] leading-relaxed mb-6">{hosting.description}</p>
            <Button href={hosting.link} variant="primary" size="md">{hosting.cta}</Button>
            <div class="grid grid-cols-3 gap-3 mt-7">
              {hosting.stats.map((s) => (
                <div>
                  <div class="text-xl font-semibold text-[var(--color-text-dark)]">{s.value}</div>
                  <div class="text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mt-1">{s.label}</div>
                </div>
              ))}
            </div>
          </div>
          <div class="lg:col-span-7 space-y-3">
            {hosting.options.map((o) => (
              <div class="bg-white rounded-xl p-5 border border-[var(--color-surface-border)]">
                <div class="flex items-baseline justify-between mb-3">
                  <h4 class="text-lg font-semibold text-[var(--color-text-dark)]">{o.name}</h4>
                  <span class="text-xs font-mono text-[var(--color-brand-orange)]">{o.timeframe}</span>
                </div>
                <ul class="space-y-1.5">
                  {o.bullets.map((b) => (
                    <li class="text-sm text-[var(--color-text-body)] flex gap-2"><span class="text-[var(--color-brand-orange)]">·</span><span>{b}</span></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- GROW -->
  <section id="grow" class="section-spacing bg-[var(--color-surface-light)] scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Faire grandir · 增长</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          {phases[3].title}
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">{phases[3].blurb}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {growServices.map((s) => (
          <article class="bg-white rounded-2xl p-7 border border-[var(--color-surface-border)] flex flex-col">
            <div class="flex items-baseline justify-between mb-3">
              <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)]">{s.title}</h3>
              <span class="text-xl text-[var(--color-brand-orange)]/60">{s.cn}</span>
            </div>
            <p class="text-sm text-[var(--color-brand-orange)] font-medium mb-4">{s.tagline}</p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-5">{s.description}</p>
            <ul class="space-y-2 mb-5 flex-1">
              {s.deliverables.map((d) => (
                <li class="flex gap-2 text-xs text-[var(--color-text-body)]"><span class="text-[var(--color-brand-orange)]">·</span><span>{d}</span></li>
              ))}
            </ul>
            <a href={s.link} class="text-sm font-semibold text-[var(--color-brand-orange)] no-underline hover:underline mt-auto">{s.cta} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- RUN -->
  <section id="run" class="section-spacing bg-white scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Faire vivre · 维护</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          {phases[4].title}
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">{phases[4].blurb}</p>
      </div>

      <article class="bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white rounded-3xl p-8 lg:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
          <div class="lg:col-span-7">
            <h3 class="text-3xl font-semibold font-[var(--font-heading)] mb-3">{maintenance.title}</h3>
            <p class="text-[var(--color-brand-orange)] font-medium mb-5">{maintenance.tagline}</p>
            <p class="text-base text-white/75 leading-relaxed mb-6">{maintenance.description}</p>
            <ul class="space-y-2 mb-7">
              {maintenance.deliverables.map((d) => (
                <li class="flex gap-2 text-sm text-white/80"><span class="text-[var(--color-brand-orange)]">·</span><span>{d}</span></li>
              ))}
            </ul>
            <Button href={maintenance.link} variant="primary" size="md">{maintenance.cta}</Button>
          </div>
          <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-3 content-start">
            {maintenance.stats.map((s) => (
              <div class="rounded-xl bg-white/[0.06] border border-white/10 p-4">
                <div class="text-2xl font-medium font-[var(--font-heading)]">{s.value}</div>
                <div class="text-[11px] uppercase tracking-wider text-white/55 mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[var(--color-surface-dark)]">
    <div class="mx-auto max-w-[1100px] section-padding text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.1] mb-6">
        Une présence chinoise pensée de bout en bout.
      </h2>
      <p class="text-lg text-white/70 leading-relaxed mb-10 max-w-2xl mx-auto">
        Décrivez-nous votre situation. Nous renvoyons sous deux jours ouvrés un cadrage qui couvre les couches qui vous concernent.
      </p>
      <Button href="/fr/contact/" variant="primary" size="lg">Parler de votre projet</Button>
    </div>
  </section>

</PageLayout>
