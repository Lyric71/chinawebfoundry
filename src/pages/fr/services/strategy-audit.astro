---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

const metaTitle = 'Stratégie et audit Chine | Feuille de route numérique';
const metaDescription = 'Trois à quatre semaines pour cadrer votre présence numérique en Chine. Site, WeChat, contenu, référencement, hébergement, dépôt ICP : le document écrit qui verrouille la suite.';

const questions = [
  {
    n: '01',
    cn: '品牌',
    title: 'Votre marque parle-t-elle vraiment au public chinois ?',
    body: "Lecture de votre marque depuis les yeux du consommateur chinois. Celui-ci traque des signaux de confiance que les marques étrangères négligent presque systématiquement : profil du fondateur, certifications obtenues, logos de partenaires, vocabulaire calé sur le discours institutionnel, prix décrochés, distinctions reconnues, caution d’un tiers crédible. Nous confrontons votre discours à celui des concurrents déjà implantés sur place, et nous posons les mots précis sur ce qui ne passe pas.",
    tag: 'Positionnement de marque',
    chips: ['Fondateur', 'Certifications', 'Partenaires', 'Prix', 'Médias'],
  },
  {
    n: '02',
    cn: '搜索',
    title: 'Où le public chinois vous trouve-t-il, concrètement ?',
    body: "Baidu garde encore près de la moitié des requêtes en Chine. Doubao, Kimi, DeepSeek et Wenxin se sont imposés comme premier réflexe chez une large part des moins de trente-cinq ans. La recherche WeChat fonctionne dans son écosystème, avec sa logique de classement propre. Nous dressons l’état réel de votre visibilité sur chacune de ces surfaces, en séparant les retards rattrapables en trois mois de ceux qui demanderont dix-huit.",
    tag: 'Surfaces de découverte',
    chips: ['Baidu', 'Doubao', 'Kimi', 'DeepSeek', 'Wenxin', 'Recherche WeChat'],
  },
  {
    n: '03',
    cn: '技术',
    title: 'Quelle technologie correspond vraiment à votre cas ?',
    body: "WordPress, Astro, architectures headless, Mini Program WeChat, H5, applications natives : chaque brique répond à un besoin précis, et la plupart des marques étrangères en assemblent deux ou trois. Nous examinons votre chaîne éditoriale, la composition de votre équipe, le volume de trafic visé, l’ambition e-commerce, puis nous tranchons sans détour quoi bâtir sur quelle pile. Y compris lorsque la recommandation oriente vers un chantier qui ne reviendra pas chez nous.",
    tag: 'Pile technologique',
    chips: ['WordPress', 'Astro', 'Headless', 'Mini Program', 'H5', 'Natif'],
  },
  {
    n: '04',
    cn: '微信',
    title: 'Quelle est votre stratégie WeChat ?',
    body: "Presque toutes les marques étrangères ont leur place à l’intérieur de WeChat. Presque aucune n’a réellement arbitré entre Mini Program, compte officiel, dispositif WeCom, présence sur Channels (视频号), ou un assemblage des quatre. Nous calibrons votre empreinte WeChat sur votre modèle économique et votre audience : les surfaces qui comptent vraiment, ce qui démarre en phase un, ce qui s’ajoute ensuite. Et cette question que la plupart des marques étrangères oublient : ne vaut-il pas mieux s’appuyer sur l’écosystème SaaS local (有赞, 微店, Meituan, 客如云, Aliyun) plutôt que tout faire bâtir sur mesure ?",
    tag: 'Écosystème WeChat',
    chips: ['Mini Program', 'Compte officiel', 'WeCom', '视频号', 'SaaS local'],
  },
  {
    n: '05',
    cn: '合规',
    title: 'Qu’est-ce qui relève réellement de la conformité ?',
    body: "ICP, MIIT, PIPL, loi sur la cybersécurité, loi sur la sécurité des données, enregistrement des Mini Program WeChat : chaque strate touche une marque étrangère présente sur le numérique chinois. Nous évaluons votre position actuelle, situons l’exposition réelle au risque, et listons les démarches à engager avec leur calendrier.",
    tag: 'Réglementaire',
    chips: ['ICP', 'MIIT', 'PIPL', 'CSL', 'DSL', 'Mini Program'],
  },
];

const deliverables = [
  {
    n: '01',
    title: 'Diagnostic de préparation Chine',
    body: "Une lecture franche de votre marque et de vos actifs en place. Contenu, UX, visibilité sur Baidu et sur les IA, performance technique, conformité, présence WeChat. Ce qui tient debout, ce qui plie, ce qui exige une refonte plutôt qu’un raccommodage.",
    pageRef: 'p.04',
  },
  {
    n: '02',
    title: 'Recommandation de positionnement',
    body: "La manière dont votre marque doit s’installer dans sa catégorie face au public chinois. Les signaux de confiance qui pèsent réellement sur la décision d’achat. Les partis pris de voix et de ton. Les territoires de contenu à investir. Les écarts à assumer par rapport au positionnement global, justification à l’appui.",
    pageRef: 'p.10',
  },
  {
    n: '03',
    title: 'Architecture technologique',
    body: "La pile retenue pour le site, l’environnement WeChat, la gestion de contenu, l’hébergement. WordPress ou Astro, Mini Program ou H5, double socle international plus Chine : chaque arbitrage tranché et argumenté.",
    pageRef: 'p.16',
  },
  {
    n: '04',
    title: 'Feuille de route séquencée',
    body: "Phase un (mise en ligne), phase deux (croissance et recherche), phase trois (montée en charge et IA). Pour chacune, son périmètre, ses dépendances, son calendrier, sa fourchette budgétaire. Le dépôt ICP est placé sur le chemin critique afin qu’il ne bloque jamais le lancement.",
    pageRef: 'p.22',
  },
  {
    n: '05',
    title: 'Carte de conformité',
    body: "ICP, MIIT, PIPL, résidence des données, vérification WeChat, enregistrement Mini Program. Ce qui vous concerne directement, ce qui vous laisse de côté, le délai propre à chaque démarche, et l’ordre dans lequel nous recommandons de les engager.",
    pageRef: 'p.30',
  },
  {
    n: '06',
    title: 'Dossier prêt pour le siège',
    body: "Le livrable le plus réclamé par les directions marque que nous accompagnons. Synthèse exécutive de deux pages, argumentaires écrits sur lesquels la maison mère reviendra inévitablement, tableaux comparatifs côte à côte qui expliquent pourquoi les choix chinois divergent des standards mondiaux.",
    pageRef: 'p.36',
  },
];

const stages = [
  {
    n: '01',
    cn: '启动',
    title: 'Lancement',
    body: "Une séance de travail avec vos équipes. Objectifs, audience visée, dispositif chinois en place s’il existe, questions que vous portez, contraintes politiques internes côté siège dont nous devons avoir connaissance avant tout démarrage.",
    output: 'Périmètre aligné',
  },
  {
    n: '02',
    cn: '调研',
    title: 'Découverte et tests',
    body: "Tests de votre site depuis la Chine continentale, audit de votre empreinte WeChat si elle existe, lecture critique du contenu en place, relevé de votre visibilité sur Baidu et sur les moteurs d’IA. De vrais navigateurs, de vrais téléphones chinois, en conditions réseau authentiques.",
    output: 'Constats du diagnostic',
  },
  {
    n: '03',
    cn: '对标',
    title: 'Revue concurrentielle',
    body: "Observation de trois à cinq concurrents directs déjà implantés en Chine, et cartographie de leurs dispositifs sur le site, dans WeChat, en contenu, en recherche. L’objectif : caler votre marque à la hauteur réelle du marché, sur l’état effectif de la catégorie.",
    output: 'Repère sectoriel',
  },
  {
    n: '04',
    cn: '策略',
    title: 'Atelier stratégique',
    body: "Atelier collectif avec votre équipe pour arrêter la direction avant rédaction. Les arbitrages co-tranchés avec vous résistent au temps. Ceux que nous prendrions à votre place s’effritent au bout de six mois.",
    output: 'Direction alignée',
  },
  {
    n: '05',
    cn: '交付',
    title: 'Livraison écrite',
    body: "Remise du document complet de feuille de route, doublée d’un appel de restitution de quatre-vingt-dix minutes pour parcourir ensemble constats et actions recommandées.",
    output: 'PDF + appel de 90 min',
  },
];

const audiences = [
  {
    label: 'Première entrée en Chine',
    description: 'Marques internationales qui ouvrent leur première véritable présence en Chine, et qui souhaitent verrouiller les bonnes décisions dès le départ.',
    image: '/images/audiences/first-time-china-entry.webp',
  },
  {
    label: 'Présence chinoise sous-performante',
    description: 'Marques dont le dispositif chinois déçoit, et dont la direction cherche à comprendre la cause. Cette dernière se loge presque toujours en amont, dans un cadrage stratégique défaillant.',
    image: '/images/audiences/underperforming-china-site.webp',
  },
  {
    label: 'Marques qui consolident un dispositif éclaté',
    description: 'Entreprises qui ont bâti leur présence chinoise par à-coups : un site, un Mini Program, un déploiement WeCom, trois prestataires qui s’ignorent, et qui réclament aujourd’hui un plan unifié.',
    image: '/images/audiences/multinational-china-entry.webp',
  },
  {
    label: 'Marques qui préparent une refonte ou une migration',
    description: 'Sociétés ayant déjà acté la nécessité d’une refonte ou d’une migration, et qui veulent poser un socle stratégique avant l’ouverture du chantier.',
    image: '/images/audiences/agency-migration-clients.webp',
  },
];

const marqueePhrases = [
  '策略', 'Stratégie',
  '路线图', 'Feuille de route',
  '审计', 'Audit',
  'Dépôt ICP',
  'Stratégie WeChat',
  'Visibilité Baidu',
  'Prêt pour l’IA',
  'Validé par le siège',
  'Phase 1 · 2 · 3',
  'Carte de conformité',
];

const faqs = [
  {
    id: 'mandatory',
    question: "L’étape stratégie est-elle vraiment indispensable ? Peut-on enchaîner directement sur la production ?",
    answer: [
      "Oui, indispensable, et ce n’est pas négociable chez nous. La raison tient en une phrase : nous avons vu trop de chantiers dérailler faute de cadrage en amont. Toutes les marques que nous avons mises en ligne en Chine sont passées par cette étape, y compris celles qui se croyaient déjà fixées sur la réponse. Dans ce groupe, environ un tiers arrivait convaincu d’avoir besoin d’une chose, repartait avec un plan différent, et c’est ce plan qui a tenu. Les deux autres tiers ont vu leurs intuitions confirmées, avec des dépendances correctement enchaînées, un budget tenable, la conformité cadrée avant qu’elle ne se transforme en point de blocage.",
      "Si une autre agence vous propose de sauter la phase stratégique pour foncer en production, vous achetez en réalité son pari : que votre situation ressemble à son dernier projet livré. Le pari l’emporte parfois. Le plus souvent, il se solde par plusieurs mois de reprise avant que personne ne s’en aperçoive.",
    ],
  },
  {
    id: 'build-after',
    question: 'Sommes-nous tenus de vous confier la suite après l’audit ?',
    answer: [
      "Non. L’audit et la feuille de route vous reviennent dans leur intégralité. La majorité de nos clients poursuit avec nous, par simple commodité, mais le document est le vôtre. Libre à vous de le confier à vos équipes internes, de le transmettre à une autre agence, ou de le mettre de côté jusqu’au jour où vous serez prêt.",
    ],
  },
  {
    id: 'remote',
    question: 'Travaillez-vous à distance ? Faut-il une équipe sur place ?',
    answer: [
      "Nous conduisons la mission à distance depuis notre bureau de Shanghai. Vous, vos équipes, vos décideurs : où il vous convient. La grande majorité de nos clients Stratégie et Audit sont en Europe, aux États-Unis ou au Royaume-Uni, parfois épaulés par une petite cellule sur place, le plus souvent sans aucun bureau local.",
    ],
  },
  {
    id: 'site-scan-difference',
    question: 'Quelle différence avec le scan gratuit du site Chine ?',
    answer: [
      "Le scan gratuit est un diagnostic automatisé qui passe votre site existant au crible des problèmes techniques visibles. Utile, gratuit, circonscrit au site lui-même. La Stratégie et Audit est une mission de fond qui sort largement de ce périmètre : positionnement de marque, dispositif WeChat, territoires de contenu, visibilité dans les recherches, séquencement, budget, et la feuille de route détaillée sur laquelle vos équipes vont réellement appuyer leurs décisions.",
    ],
  },
  {
    id: 'already-decided',
    question: 'Et si nous savons déjà ce que nous voulons construire ?',
    answer: [
      "Dans ce cas, nous ne serons sans doute pas le bon partenaire pour cette mission précise, et nous vous le dirons dès le premier appel. La Stratégie et Audit s’adresse aux marques qui souhaitent valider qu’elles construisent la bonne chose. Quand la décision est arrêtée, allez directement vers une de nos missions de production.",
    ],
  },
  {
    id: 'who-does-the-work',
    question: 'Qui fait réellement le travail ?',
    answer: [
      "Notre équipe stratégique senior à Shanghai, pilotée à chaque mission par un stratège de rang associé. Il s’appuie sur un analyste chinois en charge de la revue concurrentielle, et sur un rédacteur qui prépare la recommandation de positionnement. Vous travaillez directement avec ces personnes, du premier appel jusqu’à la remise du document.",
    ],
  },
  {
    id: 'audit-validity',
    question: 'Combien de temps l’audit reste-t-il valable ?',
    answer: [
      "Douze à dix-huit mois, dans les faits. Le numérique chinois bouge vite. La réglementation évolue, la recherche par IA peut basculer en l’espace de quelques mois, WeChat livre des nouveautés chaque trimestre. Le positionnement de marque et la lecture sectorielle, eux, tiennent plus longtemps. Si le chantier démarre dans les six mois, tout reste exploitable en l’état. Au-delà de deux ans, nous proposons une mise à jour avant le coup d’envoi.",
    ],
  },
  {
    id: 'evaluate-other-agencies',
    question: 'Pouvons-nous utiliser l’audit pour mettre d’autres agences en concurrence ?',
    answer: [
      "Oui, et plusieurs clients le font. La feuille de route est suffisamment précise sur le périmètre, les dépendances, le calendrier et les fourchettes budgétaires pour qu’on puisse la confier à d’autres agences afin qu’elles chiffrent à armes égales. Nous l’assumons sereinement. La plupart finissent par poursuivre avec nous, mais le document est conçu pour rester portable.",
    ],
  },
  {
    id: 'fine-as-is',
    question: 'Direz-vous que notre dispositif chinois actuel suffit, si c’est le cas ?',
    answer: [
      "Oui. Environ une mission Stratégie et Audit sur dix débouche sur ce verdict : le dispositif tient debout, une amélioration progressive suffira, la refonte serait du surinvestissement. Nous n’inventons pas de problèmes pour vendre une suite. Le document remis est alors plus court, avec une recommandation claire portant sur trois actions à mener sur les six mois suivants.",
    ],
  },
  {
    id: 'price-included',
    question: 'Qu’est-ce qui est compris dans le prix, et qu’est-ce qui ne l’est pas ?',
    answer: [
      "Inclus : séance de lancement, audit conduit depuis la Chine, revue concurrentielle, atelier stratégique, document de feuille de route, appel de restitution. Hors périmètre : mise en œuvre des recommandations, dépôt ICP, production de contenu, design, développement. Autant de missions distinctes qui prennent le relais après l’audit, chiffrées sur la base de ses recommandations.",
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-strategy-shenzhen-waimai.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-text-card-blue)]/20 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">策</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Stratégie et audit</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Stratégie et audit</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Équipe senior, Shanghai</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Avant de bâtir,
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">savoir quoi</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">bâtir.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            La mission Stratégie et Audit précède tout chantier. Trois à quatre semaines pour examiner votre dispositif, comprendre ce qu’attend réellement le public chinois, et poser noir sur blanc la séquence qui mène à une présence solide. <span class="text-white font-medium">Un document de cadrage, argumenté et chiffré.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">15</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Ans à Shanghai</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter data-counter-suffix="+">50</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Marques lancées</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">3-4 sem.</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Jusqu’à la livraison</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Démarrer par la stratégie</Button>
            <Button href="#engagement" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir le déroulé de la mission</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg] transition-transform duration-500 hover:rotate-[-4deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Audit seul</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">périmètre étroit</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Marque, WeChat, recherche : exclus
              </div>
            </div>

            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-green-500/15 border border-green-400/30">
                  <span class="w-1 h-1 rounded-full bg-green-400"></span>
                  <span class="text-[10px] font-mono text-green-300 uppercase tracking-wider">Feuille de route complète</span>
                </span>
                <span class="ml-auto text-[10px] font-mono text-white/40">feuille-de-route-chine.pdf</span>
              </div>

              <div class="space-y-4">
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">Phase 1 · Mise en ligne</span>
                    <span class="text-[10px] text-[var(--color-brand-orange)] font-mono">Sem. 1-12</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-full bg-gradient-to-r from-[var(--color-brand-orange)] to-[#FF8956] rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">Phase 2 · Croissance et recherche</span>
                    <span class="text-[10px] text-white/45 font-mono">Mois 4-9</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[65%] bg-gradient-to-r from-[var(--color-brand-orange)]/70 to-[var(--color-brand-orange)]/30 rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/85 font-medium">Phase 3 · IA et passage à l’échelle</span>
                    <span class="text-[10px] text-white/45 font-mono">An 2+</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[35%] bg-gradient-to-r from-[var(--color-brand-orange)]/40 to-transparent rounded-full"></div>
                  </div>
                </div>
              </div>

