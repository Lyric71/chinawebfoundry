---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Stratégie et audit WordPress pour la Chine | ChinaWebFoundry';
const metaDescription = 'Audit complet de votre site WordPress pour la Chine. Nous identifions les blocages, préparons votre licence ICP et livrons une feuille de route priorisée.';

const auditItems = [
  { title: 'Tests de vitesse depuis la Chine', body: 'Sessions de navigation réelles depuis quatre grandes métropoles. La plupart des sites dépassent quinze secondes de chargement. Certains n\'aboutissent tout simplement jamais.', icon: 'speed' },
  { title: 'Chasse aux ressources bloquées', body: 'Chaque extension, police, script et appel API passé au crible face au Grand Pare-feu. Nous signalons ce qui est coupé et ce qui tourne en mode dégradé.', icon: 'shield' },
  { title: 'Revue de conformité', body: 'SSL, traitement des données et hébergement évalués à l\'aune de la Loi sur la cybersécurité, de la PIPL et de la Loi sur la sécurité des données.', icon: 'compliance' },
  { title: 'Expérience utilisateur chinoise', body: 'Votre site sur un Xiaomi avec QQ Browser : rendu typographique, navigation, adaptation mobile.', icon: 'mobile' },
  { title: 'Bilan de santé SEO Baidu', body: 'Indexation, sitemaps, compatibilité Outils Webmaster Baidu, alignement avec les intentions de recherche. Vos classements Google ne comptent pas ici.', icon: 'search' },
  { title: 'Audit d\'infrastructure', body: 'Hébergement, DNS, CDN et performance de la base de données. Votre stack WordPress tiendra-t-elle en environnement chinois ?', icon: 'server' },
];

const roadmapItems = [
  { title: 'Stratégie d\'entrée sur le marché', body: 'Hébergement continental, Hong Kong avec CDN, ou WeChat et Xiaohongshu ? Nous cartographions chaque option avec ses vrais arbitrages, sans embellir.' },
  { title: 'Parcours licence ICP', body: 'Type de dépôt, structure d\'entité, éligibilité du fournisseur, délais réalistes. Se tromper ici, c\'est perdre des mois.' },
  { title: 'Architecture technique', body: 'Hébergement, CDN, DNS pour les résolveurs chinois et une stack WordPress éprouvée en conditions réelles sur le terrain.' },
  { title: 'Contenu et SEO Baidu', body: 'Quoi publier en priorité, comment le structurer pour Baidu Spider et les règles d\'indexation mobile-first.' },
  { title: 'Liste de substitution des extensions', body: 'Google Analytics vers Baidu Tongji. Maps vers Amap. reCAPTCHA vers Tencent Captcha. Sans oublier la correspondance CRM et ERP.' },
  { title: 'Calendrier et budget', body: 'Des jalons phasés calés sur des délais réalistes, pas sur des voeux pieux.' },
];

const audiences = [
  { label: 'Première entrée en Chine', description: 'Votre site WordPress doit tenir debout derrière le Grand Pare-feu.', image: '/images/audiences/first-time-china-entry.webp' },
  { label: 'Sous-performance sur place', description: 'Chargements poussifs, visibilité Baidu en berne, ou rendus cassés sur les navigateurs du continent.', image: '/images/audiences/underperforming-china-site.webp' },
  { label: 'Équipes de campagne', description: 'Besoin d\'une page d\'atterrissage rapide et conforme pour les audiences chinoises.', image: '/images/audiences/campaign-team-china.webp' },
  { label: 'Direction technique', description: 'Besoin d\'un état des lieux précis des exigences ICP, MIIT et infrastructure.', image: '/images/audiences/technical-leadership-icp.webp' },
  { label: 'E-commerce et B2B', description: 'Des clients chinois perdus parce que le tunnel de paiement casse derrière le Grand Pare-feu.', image: '/images/audiences/ecommerce-china-checkout.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0"><img src="/images/hero-strategy-audit.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" /><div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div><div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div></div>
    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20"><ol class="flex items-center gap-2 text-sm text-white/40"><li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li><li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li><li class="before:content-['/'] before:mx-2 text-white/60">Stratégie et audit</li></ol></nav>
      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Tout projet démarre ici</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">Entrez en Chine en confiance.<span class="block mt-2 text-[var(--color-brand-orange)]">Commencez par la stratégie.</span></h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">Nous confrontons votre site WordPress aux contraintes techniques réelles de la Chine, puis traçons la route pour performer derrière le Grand Pare-feu.</p>
          <div class="mt-10"><Button href="/fr/contact/" variant="primary" size="lg">Caler un appel découverte</Button></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">La plupart des sites WordPress ne franchissent pas le Grand Pare-feu</h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">Les Google Fonts ne s'affichent pas, reCAPTCHA tourne dans le vide, les vidéos YouTube restent noires. Nous testons depuis Pékin, Shanghai, Shenzhen et Chengdu sur de vrais navigateurs, puis bâtissons la feuille de route : quoi corriger, quoi remplacer, quoi construire de zéro.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">L'audit</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">Audit WordPress : votre site est-il prêt pour la Chine ?</h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">Nous chiffrons ce que chaque problème vous coûte en vitesse, en positions Baidu et en conversions.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {auditItems.map((item) => (
          <div class="bg-white border border-[var(--color-surface-border)] rounded-xl p-7 transition-all duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]">
            <div class="w-12 h-12 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3">{item.title}</h3>
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">La feuille de route</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">Une feuille de route stratégique</h2>
          <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed mb-8">L'audit pose le diagnostic. La feuille de route trace le chemin.</p>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {roadmapItems.map((item) => (
              <div class="flex gap-5"><div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div><div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]"><h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">{item.title}</h3><p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item.body}</p></div></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Pour les équipes qui prennent la Chine au sérieux" audiences={audiences} />

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>
    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Passez à l'action</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">Prêt à voir comment votre site se comporte en Chine ?</h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">Nous testons depuis la Chine continentale et vous livrons un plan d'action concret.</p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Caler un appel découverte</Button>
        <Button href="/fr/contact/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Télécharger notre guide du marché chinois</Button>
      </div>
    </div>
  </section>
</PageLayout>
