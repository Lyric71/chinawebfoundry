---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Migration Chine | Contenu, UX, hébergement reconstruits | ChinaWebFoundry';
const metaDescription = 'Migration complète vers la Chine continentale : contenu réécrit pour le public local, UX ajustée, hébergement déplacé. Dépôt ICP géré, prêt pour Baidu. Équipe à Shanghai.';

const layers = [
  {
    label: 'Contenu',
    title: 'Un contenu réécrit pour le public chinois',
    body: 'Nos rédacteurs natifs chinois reprennent vos messages à la lumière des signaux de confiance que le lecteur cherche en premier, ceux que les versions traduites laissent presque toujours en chemin.',
    iconPath: 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10',
  },
  {
    label: 'UX',
    title: 'Une UX repensée pour les habitudes locales',
    body: 'Les internautes chinois ne lisent pas une page comme un public occidental. Priorité au mobile, densité d’information plus forte, navigateur WeChat testé en conditions réelles, signaux de confiance posés dans l’ordre attendu. L’identité de marque, elle, ne bouge pas.',
    iconPath: 'M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3',
  },
  {
    label: 'Hébergement',
    title: 'Une infrastructure déplacée en Chine',
    body: 'Dépôt ICP pris en charge de bout en bout. Hébergement chez Aliyun, Tencent ou Huawei Cloud. Dépendances bloquées remplacées une à une. Outils webmaster Baidu branchés dès la mise en ligne.',
    iconPath: 'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z',
  },
];

interface Scenario {
  timeline: string;
  title: string;
  lead: string;
  body: string;
  fit: string[];
  diagram: 'single' | 'swap' | 'parallel';
}

const scenarios: Scenario[] = [
  {
    timeline: '6 à 10 semaines',
    title: 'Migration de votre site existant',
    lead: 'Un seul site mondial, repensé pour le marché chinois.',
    body: 'Contenu réécrit, UX ajustée, hébergement déplacé sur un serveur continental conforme. Le site mondial reste exactement là où il est, sur la pile que vous connaissez déjà.',
    fit: [
      'Un site mondial qui fonctionne déjà',
      'Une présence chinoise qui doit enfin décoller',
      'WordPress, headless ou autre architecture',
    ],
    diagram: 'single',
  },
  {
    timeline: '8 à 14 semaines',
    title: 'Changer de CMS pendant la migration',
    lead: 'Changer de plateforme et entrer en Chine dans la même fenêtre de tir.',
    body: 'On profite de la migration pour réparer ce qui clochait déjà sur l’ancien site, avant d’y poser la couche chinoise. Drupal, Sitecore, AEM, Webflow, Shopify ou développement sur mesure.',
    fit: [
      'Le CMS actuel coûte cher à maintenir',
      'Mener un seul chantier au lieu de deux séparés',
      'La refonte était déjà au programme',
    ],
    diagram: 'swap',
  },
  {
    timeline: '10 à 16 semaines',
    title: 'Deux sites en parallèle',
    lead: 'Un site mondial et un site Chine, alimentés par une même chaîne éditoriale.',
    body: 'Une seule équipe pilote le flux. Deux publics très différents disposent chacun du site qui leur parle vraiment.',
    fit: [
      'La marque mondiale et la marque Chine ont des vies différentes',
      'Vous voulez garder la main des deux côtés',
      'Vous pouvez ressourcer les deux équipes',
    ],
    diagram: 'parallel',
  },
];

const phases = [
  {
    label: 'Phase 1',
    title: 'Découvrir',
    steps: [
      {
        title: 'Découverte et audit',
        body: 'Audit écrit du site, de la marque, de la catégorie et de la concurrence chinoise. On distingue ce qui peut rester en place de ce qui demande à être refait. Deux à trois semaines.',
      },
      {
        title: 'Architecture de migration',
        body: 'Hébergement, CDN, DNS, structure de contenu, plan de redirections. Pensée pour la performance en Chine continentale dès la mise en service. Une semaine.',
      },
    ],
  },
  {
    label: 'Phase 2',
    title: 'Bâtir',
    steps: [
      {
        title: 'Réécriture et transfert du contenu',
        body: 'Nos rédacteurs natifs chinois réécrivent ce qui le mérite, transposent le reste, et préservent l’autorité SEO grâce à un plan de correspondance d’URL bâti à la main.',
      },
      {
        title: 'Localisation UX et UI',
        body: 'Gabarits relus au regard des habitudes de lecture chinoises, ajustés là où ils flanchent. L’identité de marque ne change pas, l’interface, elle, se localise.',
      },
      {
        title: 'Remplacement des intégrations',
        body: 'Google Analytics, YouTube, pixels Facebook : remplacés par Baidu Tongji, Youku ou Bilibili, et leurs équivalents côté WeChat ou Weibo. Chaque dépendance passée au crible.',
      },
      {
        title: 'Optimisations techniques et performance',
        body: 'Polices et CDN bloqués remplacés. Certificat SSL adapté à la Chine. Ressources allégées pour les réseaux continentaux. SEO Baidu intégré dans la foulée.',
      },
    ],
  },
  {
    label: 'Phase 3',
    title: 'Lancer',
    steps: [
      {
        title: 'Tests depuis la Chine',
        body: 'Connexions réelles, sans VPN. Vitesse mesurée, fonctionnalités vérifiées, QQ et UC Browser, Android milieu de gamme. Les conditions dans lesquelles votre public lit réellement.',
      },
      {
        title: 'Bascule sans coupure',
        body: 'Lancement planifié à l’heure près. DNS pilotés en direct, retour en arrière garanti pendant quarante-huit heures. Astreinte sur les premières semaines.',
      },
    ],
  },
];

const migrationItems = [
