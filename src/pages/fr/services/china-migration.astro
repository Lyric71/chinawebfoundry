---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Migration Chine | Contenu, UX, hébergement reconstruits | ChinaWebFoundry';
const metaDescription = 'Faites entrer votre site en Chine. Contenu, UX et hébergement reconstruits pour le public chinois. Licence ICP, prêt pour Baidu. Équipe à Shanghai.';

const layers = [
  {
    label: 'Contenu',
    title: 'Un contenu réécrit pour le public chinois',
    body: 'Nos rédacteurs chinois natifs reprennent vos messages au prisme des signaux de confiance, des marqueurs de crédibilité et des preuves sociales que le lecteur chinois cherche en premier.',
  },
  {
    label: 'UX',
    title: 'Une UX repensée pour les habitudes locales',
    body: 'Les internautes chinois ne lisent pas une page comme les Occidentaux. Mobile d’abord, information plus dense, navigateur WeChat éprouvé, signaux de confiance dans l’ordre attendu. Identité de marque préservée.',
  },
  {
    label: 'Hébergement',
    title: 'Une infrastructure déplacée en Chine',
    body: 'Dépôt ICP géré de bout en bout. Hébergement sur Aliyun, Tencent ou Huawei Cloud, dépendances bloquées remplacées, outils webmaster Baidu connectés dès le premier jour.',
  },
];

const scenarios = [
  {
    timeline: '6 à 10 semaines',
    title: 'Migration de votre site existant',
    lead: 'Un site mondial unique, repensé pour le marché chinois.',
    body: 'Contenu réécrit, UX ajustée, hébergement déplacé sur un serveur continental conforme. Votre site mondial reste exactement là où il est, sur la pile que vous utilisez.',
    fit: ['Vous avez déjà un site mondial qui fonctionne', 'Vous voulez une présence chinoise qui prenne enfin', 'WordPress, headless ou autre pile'],
  },
  {
    timeline: '8 à 14 semaines',
    title: 'Changer de CMS pendant la migration',
    lead: 'Remplacer la plateforme et entrer en Chine en une seule fenêtre.',
    body: 'Nous profitons de la migration pour corriger ce qui clochait déjà sur l’ancien site, avant d’y ajouter la couche chinoise. Drupal, Sitecore, AEM, Webflow, Shopify ou sur mesure.',
    fit: ['Le CMS actuel est pénible à maintenir', 'Vous voulez un projet, pas deux', 'Vous reconstruisiez de toute façon'],
  },
  {
    timeline: '10 à 16 semaines',
    title: 'Deux sites en parallèle',
    lead: 'Un site mondial et un site Chine, avec un même pipeline éditorial.',
    body: 'Une équipe pilote le flux. Deux audiences très différentes ont chacune le site qui leur correspond.',
    fit: ['La marque mondiale et la marque Chine vivent différemment', 'Vous voulez le contrôle des deux côtés', 'Vous pouvez doter les deux équipes'],
  },
];

const phases = [
  {
    label: 'Phase 1',
    title: 'Découvrir',
    steps: [
      { title: 'Découverte et audit', body: 'Audit écrit du site, de la marque, de la catégorie et de la concurrence chinoise. Nous nommons ce qui se garde, ce qui se reconstruit. Deux à trois semaines.' },
      { title: 'Architecture de migration', body: 'Hébergement, CDN, DNS, structure de contenu, plan de redirections. Conçue pour la performance chinoise dès le premier jour. Une semaine.' },
    ],
  },
  {
    label: 'Phase 2',
    title: 'Bâtir',
    steps: [
      { title: 'Réécriture et transfert du contenu', body: 'Nos rédacteurs chinois natifs réécrivent ce qui le mérite, transcrient le reste, et préservent l’autorité SEO via un mapping d’URL fait à la main.' },
      { title: 'Localisation UX et UI', body: 'Templates relus à l’aune des habitudes de lecture chinoises et ajustés là où ils ne tiennent pas. L’identité reste, l’interface se localise.' },
      { title: 'Remplacement des intégrations', body: 'Google Analytics, YouTube, pixels Facebook remplacés par Baidu Tongji, Youku ou Bilibili, équivalents WeChat ou Weibo. Chaque dépendance vérifiée.' },
      { title: 'Optimisations techniques', body: 'Polices et CDN bloqués remplacés. SSL adapté à la Chine. Assets calibrés pour les réseaux continentaux. SEO Baidu intégré.' },
    ],
  },
  {
    label: 'Phase 3',
    title: 'Lancer',
    steps: [
      { title: 'Tests depuis la Chine', body: 'Connexions réelles, sans VPN. Vitesse, fonctionnalités, QQ et UC Browser, Android milieu de gamme. La manière dont votre public lit vraiment.' },
      { title: 'Bascule sans coupure', body: 'Lancement planifié à l’heure près. DNS pilotés en direct, retour en arrière possible pendant 48 heures. Astreinte sur les premières semaines.' },
    ],
  },
];

const migrationItems = [
  { label: 'Pages et articles', body: 'Contenu, mise en forme, médias intégrés, métadonnées.' },
  { label: 'Médiathèque', body: 'Images, vidéos, documents, ré-optimisés pour la diffusion en Chine.' },
  { label: 'Données SEO', body: 'Titres meta, descriptions, URLs, redirections, sitemaps.' },
  { label: 'Champs et taxonomies', body: 'Custom post types, catégories, étiquettes, données structurées.' },
  { label: 'Données e-commerce', body: 'Produits, commandes, fiches clients, configuration des paiements.' },
  { label: 'Comptes utilisateurs', body: 'Rôles, profils et permissions.' },
  { label: 'Intégrations', body: 'CRM, analytics, outils marketing, adaptés ou remplacés pour la pile chinoise.' },
  { label: 'Design et identité', body: 'L’identité visuelle reste intacte. UX ajustée là où les habitudes chinoises l’imposent.' },
];

const challenges = [
  {
    title: 'URLs historiques et autorité SEO',
    body: 'Vous avez bâti vos positions sur le site mondial pendant des années. Une migration ratée fait tout perdre du jour au lendemain. Nous mappons les URL à la main pour toutes les pages qui comptent, posons les 301 propres et préservons un maximum de visibilité organique.',
  },
  {
    title: 'La couche Pare-feu',
    body: 'Bloque les services Google, la plupart des CDN occidentaux, plusieurs plateformes sociales et une longue liste de dépendances externes que votre site utilise presque certainement. Chacune doit être remplacée.',
  },
  {
    title: 'Licence ICP',
    body: 'Héberger sur un serveur chinois exige un dépôt gouvernemental appelé ICP, ou Bei’an. Dossier en chinois, règles qui varient par province, vingt jours ouvrés au minimum. Nous portons le dossier pour vous.',
  },
  {
    title: 'Lois sur la résidence des données',
    body: 'Sous la Loi sur la cybersécurité chinoise et la PIPL, certaines données utilisateurs doivent être stockées sur le continent. L’architecture doit le prévoir dès le premier jour, pas trois mois après le lancement.',
  },
];

const audiences = [
  { label: 'Marques internationales qui entrent en Chine', description: 'Sociétés qui lancent leur première vraie présence chinoise, après des années passées sur un site mondial traduit.', image: '/images/audiences/multinational-china-entry.webp' },
  { label: 'Marques qui relancent un site qui n’a pas pris', description: 'Le site chinois est en ligne mais n’a jamais performé. Le rebond est élevé, le pipeline plat, le siège demande pourquoi. La migration est en réalité une relance.', image: '/images/audiences/agency-migration-clients.webp' },
  { label: 'Marques e-commerce', description: 'Lancer une boutique chinoise avec les bonnes intégrations de paiement, logistique et service client dès le premier jour.', image: '/images/audiences/ecommerce-china-store.webp' },
  { label: 'Médias et édition', description: 'Organisations qui veulent toucher le public chinois, pas via un miroir traduit.', image: '/images/audiences/media-publishing-china.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-migration.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Migration Chine</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Migration Chine</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Faites entrer votre site en Chine.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Sérieusement.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Une migration en Chine, c’est une relance complète. Nous déplaçons contenu, design et hébergement d’un seul tenant, pour que le site mis en ligne tourne pour le public chinois.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-xl leading-relaxed">
            15 ans à Shanghai. Plus de 50 marques internationales migrées, aucune cassée en route.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Démarrer la migration</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Les trois couches</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Trois couches reconstruites en parallèle.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {layers.map((l) => (
          <article class="bg-[var(--color-surface-light)] rounded-2xl p-7 lg:p-8 border border-[var(--color-surface-border)]">
            <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-3">{l.label}</p>
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-4">{l.title}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{l.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Trois scénarios</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Quel chemin pour votre projet ?
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-6">
        {scenarios.map((s) => (
          <article class="bg-white rounded-2xl p-7 lg:p-8 border border-[var(--color-surface-border)] flex flex-col">
            <div class="text-[11px] font-mono uppercase tracking-wider text-[var(--color-brand-orange)] mb-3">{s.timeline}</div>
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug mb-2">{s.title}</h3>
            <p class="text-sm font-medium text-[var(--color-brand-orange)] mb-4">{s.lead}</p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-5 flex-1">{s.body}</p>
            <div class="pt-5 border-t border-[var(--color-surface-border)]">
              <div class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-2">Profils</div>
              <ul class="space-y-1.5">
                {s.fit.map((item) => (
                  <li class="flex gap-2 text-xs text-[var(--color-text-body)]">
                    <span class="text-[var(--color-brand-orange)] flex-shrink-0">·</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Le déroulé</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Trois phases, du diagnostic à la mise en ligne.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {phases.map((p) => (
          <div class="bg-[var(--color-surface-light)] rounded-2xl p-7 border border-[var(--color-surface-border)]">
            <p class="text-[11px] font-mono uppercase tracking-wider text-[var(--color-brand-orange)] mb-2">{p.label}</p>
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-5">{p.title}</h3>
            <ul class="space-y-4">
              {p.steps.map((step) => (
                <li>
                  <p class="text-sm font-semibold text-[var(--color-text-dark)] mb-1">{step.title}</p>
                  <p class="text-xs text-[var(--color-text-body)] leading-relaxed">{step.body}</p>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Ce qui suit</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Ce que nous portons d’une rive à l’autre.
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {migrationItems.map((m) => (
          <div class="bg-white rounded-xl p-5 border border-[var(--color-surface-border)]">
            <p class="text-sm font-semibold text-[var(--color-text-dark)] mb-1">{m.label}</p>
            <p class="text-xs text-[var(--color-text-body)] leading-relaxed">{m.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Les vrais obstacles</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Les quatre points où la plupart des projets échouent.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {challenges.map((c) => (
          <article class="bg-[var(--color-surface-light)] rounded-2xl p-7 border border-[var(--color-surface-border)]">
            <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{c.title}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui nous mandate pour la migration Chine" audiences={audiences} background="light" />

  <section class="py-20 md:py-28 bg-[var(--color-surface-dark)]">
    <div class="mx-auto max-w-[1100px] section-padding text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.1] mb-6">
        Prêt à faire entrer votre site en Chine ?
      </h2>
      <p class="text-lg text-white/70 leading-relaxed mb-10 max-w-2xl mx-auto">
        Décrivez-nous le périmètre. Nous renvoyons sous deux jours ouvrés un cadrage et un calendrier.
      </p>
      <Button href="/fr/contact/" variant="primary" size="lg">Démarrer</Button>
    </div>
  </section>

</PageLayout>
