const challenges = [
  {
    title: 'URL historiques et autorité SEO',
    body: 'Vous avez bâti vos positions sur le site mondial pendant des années. Une migration ratée efface tout du jour au lendemain. On aligne les URL à la main pour toutes les pages qui comptent, on pose des 301 propres, et on préserve l’essentiel de la visibilité organique.',
    iconPath: 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
  },
  {
    title: 'Le Great Firewall',
    body: 'Il coupe les services Google, la quasi-totalité des CDN occidentaux, plusieurs plateformes sociales, et une liste interminable de dépendances que votre site utilise presque sans le savoir. Chacune doit être remplacée.',
