---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import CaseStudyCards from '../../../components/ui/CaseStudyCards.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Migration WordPress vers la Chine | ChinaWebFoundry';
const metaDescription = 'Transférez votre site WordPress en Chine ou basculez depuis n\'importe quel CMS vers une infrastructure WordPress pensée pour le continent. Zéro interruption, zéro perte de données, conformité garantie.';

const scenarios = [
  {
    title: 'WordPress vers WordPress optimisé pour la Chine',
    body: 'Votre site WordPress tourne sans accroc partout dans le monde. Sauf derrière le Grand Pare-feu, où il rame, génère des erreurs ou refuse purement et simplement de s\'afficher. Nous le transférons sur un hébergement conforme aux exigences chinoises, remplaçons chaque ressource bloquée et ramenons les performances au niveau attendu. Votre site global, lui, ne bouge pas d\'un iota.',
    image: '/images/migration-wordpress-china-optimised.webp',
  },
  {
    title: 'Autre CMS vers WordPress pour la Chine',
    body: 'Drupal, Sitecore, Adobe Experience Manager, Webflow, Shopify ou un développement maison vieux de dix ans que plus personne n\'ose toucher. Nous assurons le transfert intégral du contenu vers WordPress, avec une reconstruction pensée pour la Chine dès la première ligne de code. Correspondance des URL, préservation du référencement et refonte de la mise en page quand l\'originale ne parle pas au public chinois.',
    image: '/images/migration-cms-to-wordpress-china.webp',
  },
  {
    title: 'Site global vers architecture à double volet',
    body: 'Certaines entreprises ont besoin de faire coexister un site mondial et une version chinoise distincte. Nous bâtissons une architecture à double volet où les deux versions partagent les mêmes processus éditoriaux, tout en proposant à chaque public exactement ce qu\'il attend. Une seule équipe gère le contenu. Deux marchés radicalement différents sont servis comme il se doit.',
    image: '/images/migration-dual-stack-global-china.webp',
  },
];

const processSteps = [
  {
    title: 'Analyse et diagnostic',
    body: 'Tout démarre par un audit complet. Plateforme, volume de contenu, intégrations tierces, architecture technique. Nous passons chaque élément au crible et identifions tout ce qui est bloqué, incompatible ou non conforme. Cette phase se déroule avant qu\'une seule ligne de code ne soit touchée.',
  },
  {
    title: 'Conception de l\'architecture de migration',
    body: 'Le plan directeur. Environnement d\'hébergement en Chine, stratégie CDN, configuration DNS, structure du contenu. L\'ensemble est pensé autour de la performance sur le continent dès le départ, pas rafistolé après coup.',
  },
  {
    title: 'Transfert du contenu et des données',
    body: 'La totalité de votre contenu est transférée. Pages, articles, fichiers multimédias, métadonnées, champs personnalisés, données utilisateurs, catalogues produits si vous gérez du e-commerce. Nous cartographions minutieusement les structures d\'URL pour ne rien sacrifier du capital SEO que vous avez mis des années à construire.',
  },
  {
    title: 'Remplacement des intégrations',
    body: 'Google Analytics cède la place à Baidu Analytics. Les lecteurs YouTube sont remplacés par Youku ou Bilibili. Les pixels de suivi Facebook deviennent WeChat ou Weibo. Chaque dépendance tierce est passée au peigne fin. Si elle est bloquée en Chine, nous trouvons l\'alternative locale qui fonctionne et nous l\'intégrons.',
  },
  {
    title: 'Optimisation spécifique à la Chine',
    body: 'Polices bloquées, CDN inaccessibles, tout est remplacé. Le SSL est configuré pour la compatibilité avec les navigateurs chinois. Les ressources sont optimisées pour les conditions réseau locales. Le référencement technique Baidu est intégré à chaque étape du processus.',
  },
  {
    title: 'Tests depuis le territoire chinois',
    body: 'Des tests grandeur nature, depuis de véritables connexions en Chine continentale. Pas de proxy via Hong Kong. Nous vérifions les temps de chargement, le bon fonctionnement, la compatibilité multi-navigateurs (y compris QQ Browser et UC Browser) et les performances mobiles sur des appareils réellement utilisés en Chine.',
  },
  {
    title: 'Lancement sans coupure',
    body: 'La bascule est planifiée à l\'heure près. Zéro interruption de service. La propagation DNS est pilotée avec précision. Une surveillance en temps réel tourne pendant toute la fenêtre de transition, jusqu\'à confirmation que tout est stable.',
  },
  {
    title: 'Accompagnement post-migration',
    body: 'Surveillance des performances, résolution des incidents, ajustements au fil de l\'eau. L\'essentiel des difficultés se manifeste dans les deux ou trois premières semaines. Nous restons mobilisés pendant toute cette période.',
  },
];

const migrationItems = [
  { label: 'Pages et articles', body: 'Contenu, mise en forme, médias intégrés, métadonnées' },
  { label: 'Bibliothèque de médias', body: 'Images, vidéos, documents, le tout ré-optimisé pour la diffusion en Chine' },
  { label: 'Données SEO', body: 'Titres, descriptions, URL, redirections, sitemaps' },
  { label: 'Champs et taxonomies personnalisés', body: 'ACF, types de contenu sur mesure, catégories, étiquettes' },
  { label: 'Données e-commerce', body: 'Produits, commandes, fichiers clients (WooCommerce)' },
  { label: 'Comptes utilisateurs', body: 'Rôles, profils et permissions' },
  { label: 'Intégrations', body: 'CRM, outils d\'analyse, outils marketing, adaptés ou remplacés' },
  { label: 'Identité visuelle', body: 'Votre image de marque reste intacte, avec des ajustements pour l\'expérience utilisateur chinoise là où c\'est pertinent' },
];

const challenges = [
  {
    title: 'Le Grand Pare-feu',
    body: 'Il bloque les services Google, la quasi-totalité des CDN occidentaux, les réseaux sociaux et une longue liste de ressources externes dont votre site dépend presque à coup sûr. Chaque dépendance doit être vérifiée et remplacée. Notre équipe gère cette réalité au quotidien, depuis la Chine.',
  },
  {
    title: 'L\'obtention de la licence ICP',
    body: 'Votre site doit être hébergé sur une infrastructure approuvée par les autorités, avec un enregistrement de domaine en bonne et due forme. Nous accompagnons nos clients à chaque étape de cette procédure, car soyons francs, elle est particulièrement déroutante pour qui ne l\'a jamais traversée.',
  },
  {
    title: 'Les lois sur la localisation des données',
    body: 'En vertu de la loi chinoise sur la cybersécurité et de la PIPL, certaines données utilisateurs doivent être stockées sur le territoire continental. Votre architecture doit intégrer cette contrainte dès sa conception, pas trois mois après le lancement.',
  },
  {
    title: 'Les exigences de performance',
    body: 'Les internautes chinois veulent des pages rapides. Et Baidu pénalise les sites lents encore plus sévèrement que Google. Notre équipe technique sur place s\'assure que votre site migré atteint effectivement ces seuils de performance.',
  },
];

const audiences = [
  { label: 'Multinationales', description: 'Qui s\'implantent en Chine ou renforcent leur présence WordPress sur le continent.', image: '/images/audiences/multinational-china-entry.webp' },
  { label: 'Marques e-commerce', description: 'Qui lancent une boutique en ligne prête pour le marché chinois, bâtie sur WordPress.', image: '/images/audiences/ecommerce-china-store.webp' },
  { label: 'Médias et édition', description: 'Organisations qui doivent atteindre efficacement le public chinois.', image: '/images/audiences/media-publishing-china.webp' },
  { label: 'Agences', description: 'Qui pilotent des migrations WordPress vers la Chine pour le compte de leurs propres clients.', image: '/images/audiences/agency-migration-clients.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-migration.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>
    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Migration vers la Chine</li>
        </ol>
      </nav>
      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Migration WordPress</p>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Migration WordPress vers la Chine,
            <span class="block mt-2 text-[var(--color-brand-orange)]">dans les règles de l'art.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Transférez votre site WordPress en Chine ou basculez depuis n'importe quel CMS vers une infrastructure WordPress pensée pour le continent. Zéro interruption, zéro perte de données, conformité garantie.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Discuter de votre projet de migration</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">migration-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Transfert du contenu</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">100 %</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Ressources bloquées</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">0 / 47</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Temps de chargement Chine</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">2,1 s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[15%] h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Conformité ICP</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Déposé</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Transférer un site en Chine n'a rien d'une migration ordinaire
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Le Grand Pare-feu bloque la moitié des services dont votre site dépend. L'hébergement doit se conformer aux règles de licence ICP, un dispositif que la plupart des équipes de développement occidentales n'ont jamais rencontré. Les internautes chinois sont notoirement impatients face aux pages lentes. Et si Baidu ne parvient pas à explorer correctement votre site, vous êtes tout simplement invisible.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Nous traitons ces problématiques chaque semaine, depuis nos bureaux en Chine. Que vous soyez déjà sous WordPress ou que vous migriez depuis un CMS totalement différent, l'objectif reste le même : un site qui fonctionne véritablement sur le continent. Pas « à peu près ». Pas « derrière un VPN ». Un site qui charge vite, passe les contrôles de conformité et atteint les personnes que vous cherchez à toucher.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-surface-light)] to-white border border-[var(--color-surface-border)]">
            <div class="absolute inset-6 flex flex-col justify-center gap-4">
              <div class="flex items-center gap-3">
                <div class="w-16 h-16 rounded-xl bg-[var(--color-surface-border)]/60 flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" /></svg>
                </div>
                <div>
                  <div class="h-3 w-24 bg-[var(--color-surface-border)] rounded mb-2"></div>
                  <div class="h-2 w-16 bg-[var(--color-surface-border)]/60 rounded"></div>
                </div>
              </div>
              <div class="flex justify-center">
                <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-16 h-16 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div>
                  <div class="h-3 w-28 bg-[var(--color-brand-orange)]/20 rounded mb-2"></div>
                  <div class="h-2 w-20 bg-[var(--color-brand-orange)]/10 rounded"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Migration Scenarios -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Scénarios de migration
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Trois voies d'accès au marché chinois
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
          Chaque migration part d'un contexte différent. Voici comment nous abordons chacune d'entre elles.
        </p>
      </div>

      <CaseStudyCards items={scenarios} />
    </div>
  </section>

  <!-- Process Section -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Notre processus de migration
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Huit étapes vers un site pleinement opérationnel en Chine
          </h2>
          <p class="mt-4 text-lg text-[var(--color-text-body)] leading-relaxed">
            Chaque étape est conçue autour de la performance et de la conformité sur le continent, dès le premier jour.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {processSteps.map((step) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {step.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {step.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Gets Migrated -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Ce qui est transféré
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Rien n'est laissé de côté
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12">
            {migrationItems.map((item, i) => (
              <div class:list={[
                'py-6',
                i < migrationItems.length - 2 ? 'border-b border-white/10' : '',
                i === migrationItems.length - 2 ? 'border-b border-white/10 sm:border-b-0' : '',
              ]}>
                <div>
                  <div>
                    <h3 class="text-base font-semibold font-[var(--font-heading)] text-white mb-1">
                      {item.label}
                    </h3>
                    <p class="text-sm text-white/50 leading-relaxed">
                      {item.body}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why China Migration Is Different -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Pourquoi c'est différent
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Ce qui rend la migration WordPress vers la Chine si particulière
        </h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-0 divider-list">
        {challenges.map((item) => (
          <div class="flex gap-6 lg:gap-10 py-8 lg:py-10 items-start">
            <div class="hidden sm:block w-1 flex-shrink-0 self-stretch rounded-full bg-[var(--color-brand-orange)]/20"></div>
            <div class="flex-1">
              <h3 class="text-xl lg:text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-3">
                {item.title}
              </h3>
              <p class="text-base text-[var(--color-text-body)] leading-relaxed max-w-2xl">
                {item.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Pensé pour les équipes qui s'installent en Chine" audiences={audiences} background="light" />

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Lancez votre migration
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Vous envisagez de transférer votre site WordPress en Chine ?
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Chaque projet de migration est unique. Décrivez-nous votre situation actuelle, vos objectifs et vos échéances. Notre équipe en Chine élaborera la bonne approche avec vous.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Lancer votre diagnostic de migration</Button>
        <Button href="/fr/services/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir nos services</Button>
      </div>
    </div>
  </section>

</PageLayout>
