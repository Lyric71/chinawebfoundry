const audiences = [
  { label: 'Marques internationales qui entrent en Chine', description: 'Sociétés qui ouvrent leur première vraie présence chinoise, après des années à n’avoir qu’une version traduite du site mondial.', image: '/images/audiences/multinational-china-entry.webp' },
  { label: 'Marques qui relancent un site qui n’a pas pris', description: 'Le site chinois existe mais n’a jamais décollé. Taux de rebond élevé, carnet vide, siège qui demande des comptes. La migration est, en fait, une relance complète.', image: '/images/audiences/agency-migration-clients.webp' },
  { label: 'Marques e-commerce', description: 'Lancer une boutique chinoise avec les bonnes connexions paiement, logistique et service client posées dès la mise en ligne.', image: '/images/audiences/ecommerce-china-store.webp' },
  { label: 'Médias et édition', description: 'Organisations qui visent le public chinois directement, avec un dispositif éditorial conçu pour lui.', image: '/images/audiences/media-publishing-china.webp' },
