---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import CaseStudyCards from '../../../components/ui/CaseStudyCards.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Extensions WordPress pour la Chine, développées sur mesure';
const metaDescription = 'Extensions WordPress bâties pour la Chine : intégrations WeChat, Alipay, référencement Baidu et correctifs ciblés pour les sites derrière le Grand Pare-feu. Agence basée en Chine.';

const buildItems = [
  {
    title: 'Intégration WeChat',
    body: 'Connexion OAuth, liaison aux comptes officiels, passerelles Mini Programs, QR codes, WeChat Pay. En Chine, WeChat n\'est pas une option. C\'est le canal par lequel les gens vous trouvent, jaugent votre sérieux et vous règlent. Tout transite par là.',
  },
  {
    title: 'Passerelles de paiement',
    body: 'Alipay, WeChat Pay et UnionPay, sous forme d\'extensions WooCommerce ou de modules autonomes selon votre architecture. Se louper sur ce volet n\'a rien d\'anodin. Les acheteurs chinois quittent le site à la seconde où le tunnel de paiement leur paraît insolite. Nous l\'avons constaté chez nos clients plus souvent qu\'on ne voudrait l\'admettre.',
  },
  {
    title: 'Référencement Baidu',
    body: 'Génération de sitemaps pour Baidu Spider, intégration de l\'API push, balises meta que Baidu lit véritablement. La plupart croient que Yoast ou RankMath suffisent. Faux. Ces outils sont pensés pour Google. Baidu joue selon ses propres règles.',
  },
  {
    title: 'Analytics et partage social',
    body: 'Baidu Tongji prend le relais de Google Analytics, CNZZ bouche les trous. Pour le partage, nous branchons WeChat, Weibo, QQ, Douyin, RED. Les plateformes où les Chinois passent vraiment leur temps, pas celles vers lesquelles vos boutons de partage actuels pointent probablement.',
  },
];

const fixItems = [
  'Google Fonts remplacées par des polices auto-hébergées',
  'reCAPTCHA remplacé par une solution qui tourne en Chine',
  'Appels CDN bloqués redirigés vers des alternatives chinoises',
  'Requêtes API acheminées via des couches proxy ou basculées sur des services locaux',
  'Boutons de partage social recâblés vers WeChat, Weibo, QQ, Douyin',
  'Extensions de paiement basculées de Stripe et PayPal vers Alipay et WeChat Pay',
];

const gutenbergBlocks = [
  'Blocs QR code WeChat',
  'Baidu Maps à la place de Google Maps',
  'Lecteurs vidéo Youku, Bilibili, Tencent Video',
  'Formulaires avec validation de numéro chinois et champ WeChat ID',
  'Blocs produits branchés aux passerelles de paiement locales',
];

const audiences = [
  { label: 'Fonctionnalités manquantes', description: 'Entreprises qui ont besoin de briques WordPress que le marché n\'a jamais pensées pour la Chine.', image: '/images/audiences/wordpress-features-china.webp' },
  { label: 'Paiement WeChat et Alipay', description: 'Marques e-commerce qui intègrent Alipay ou WeChat Pay dans leur tunnel d\'achat.', image: '/images/audiences/ecommerce-wechat-alipay.webp' },
  { label: 'Équipes techniques', description: 'Développeurs qui veulent des extensions pensées pour la Chine, signées par des pros qui travaillent chaque jour dans cet environnement.', image: '/images/audiences/dev-team-china-plugins.webp' },
  { label: 'Agences', description: 'Agences qui bâtissent des sites pour la Chine au nom de leurs propres clients et cherchent un travail d\'extension fiable.', image: '/images/audiences/agency-china-clients.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-plugins-extensions.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Extensions et plugins</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Extensions et plugins
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Des extensions WordPress sur mesure
            <span class="block mt-2 text-[var(--color-brand-orange)]">taillées pour le marché chinois</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            La plupart des extensions WordPress n'ont jamais été pensées pour tourner en Chine. Nous développons celles qui marchent.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Consulter nos développeurs</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">plugin-audit</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Google Fonts</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">Bloqué</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">reCAPTCHA v3</span>
                  <span class="text-sm font-semibold text-red-400 font-mono">Bloqué</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Stripe Checkout</span>
                  <span class="text-sm font-semibold text-yellow-400 font-mono">Inutilisable</span>
                </div>
                <div class="w-full h-px bg-white/10 my-1"></div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">WeChat Pay</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Sur mesure</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">SEO Baidu</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Sur mesure</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Passerelle Alipay</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Sur mesure</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-8">
          40 % des extensions WordPress populaires dépendent de Google. Toutes bloquées en Chine.
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
          Ce que personne ne vous signale à temps : près de 40 % des extensions WordPress les plus répandues dépendent de Google, d'une manière ou d'une autre. Polices, reCAPTCHA, Maps, Analytics. Tout bloqué en Chine. Votre site se charge avec des trous béants.
        </p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
          Et le problème ne s'arrête pas à Google. Les boutons de partage pointent vers Facebook et Instagram, inaccessibles ici. Les extensions de paiement s'appuient sur Stripe ou PayPal, que les consommateurs chinois n'utilisent pas. Les ressources sont appelées depuis des CDN que le Grand Pare-feu refuse net de charger. Cette pile d'extensions que vous avez passé des mois à assembler ? Bon courage à Shenzhen.
        </p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Nous démêlons ce type de situations depuis des années. En clair : nous développons des extensions WordPress taillées pour l'internet chinois, et nous rafistolons celles qui cassent derrière le Grand Pare-feu.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Build -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Ce que nous développons
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Les mêmes besoins reviennent, client après client
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {buildItems.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fixing What's Already There -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Corriger l'existant
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Tout ne mérite pas une refonte totale
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Certaines agences vous orienteront systématiquement vers du développement 100 % sur mesure : ce n'est pas toujours la réponse honnête. Notre démarche habituelle consiste à auditer toute votre pile d'extensions, repérer chaque dépendance qui flanchera derrière le Grand Pare-feu, puis les corriger une par une.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Votre équipe continue de travailler avec les outils qu'elle connaît. Cela pèse, en pratique, bien plus qu'on ne l'imagine.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="bg-white rounded-2xl p-8 border border-[var(--color-surface-border)]">
            <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
              Corrections courantes
            </p>
            <div class="space-y-4">
              {fixItems.map((item) => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[var(--color-brand-orange)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="mt-6 bg-[var(--color-surface-light)] rounded-xl p-6 border-l-4 border-[var(--color-brand-orange)]">
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed italic">
              La plupart des clients débarquent persuadés qu'il faut tout arracher et repartir de zéro. Dans les faits, environ 60 % de leurs extensions existantes n'ont besoin que de retouches ciblées pour tourner correctement en Chine. Un gain de temps et d'argent considérable.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Gutenberg Blocks -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Blocs Gutenberg sur mesure
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
          Même éditeur, nouvelles possibilités
        </h2>
        <p class="mt-6 text-base text-[var(--color-text-body)] leading-relaxed">
          Le même éditeur WordPress que votre équipe éditoriale maîtrise déjà. Simplement, les blocs parlent désormais à un public chinois.
        </p>
      </div>

      <CaseStudyCards items={gutenbergBlocks.map(block => ({ title: block }))} />
    </div>
  </section>

  <!-- How We Build -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Notre approche technique
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Bâti pour durer, bâti pour la Chine
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
              <h3 class="text-lg font-semibold text-white mb-2">Standards WordPress</h3>
              <p class="text-base text-white/70 leading-relaxed">
                Tout respecte les standards de dev WordPress. Documenté avec assez de rigueur pour que votre équipe, ou un autre développeur plus tard, puisse assurer la maintenance sans avoir à nous solliciter à chaque ajustement.
              </p>
            </div>
            <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
              <h3 class="text-lg font-semibold text-white mb-2">Performance d'abord</h3>
              <p class="text-base text-white/70 leading-relaxed">
                L'environnement d'hébergement chinois est sensiblement moins indulgent que celui auquel vous êtes habitué. Chaque requête superflue en base de données, chaque appel HTTP inutile pèse plus lourd quand votre serveur vit derrière le Grand Pare-feu. Un code qui file aux États-Unis peut ramper à Shanghai.
              </p>
            </div>
            <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
              <h3 class="text-lg font-semibold text-white mb-2">Sécurité dès le premier jour</h3>
              <p class="text-base text-white/70 leading-relaxed">
                Validation, assainissement des données, vérification des nonces : les fondamentaux, pas greffés après coup. Nous testons dans des environnements de pré-production hébergés en Chine, sur des navigateurs chinois. UC Browser reste massivement utilisé ici, et les rendus divergent d'une manière qui vous surprendra.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- After Launch -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
          Après le lancement
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
          Une extension, cela ne se construit pas une bonne fois pour toutes
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
          WordPress publie ses mises à jour, PHP change de version, une autre extension de votre pile déploie un correctif et casse soudain quelque chose de totalement indépendant. Nous assurons le suivi au quotidien : corrections de compatibilité, mises à jour de sécurité, nouvelles fonctionnalités au rythme où votre présence chinoise grandit.
        </p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Et nous gardons un oeil sur les performances, pour que rien ne se dégrade en douce pendant que votre équipe a la tête ailleurs.
        </p>
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui nous sollicite pour les extensions" audiences={audiences} footnote="Si les extensions standard ne résolvent pas votre problème en Chine, venez nous en parler. Nous développerons ce qui manque." background="light" />

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Lancez-vous
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Vous avez un besoin précis en tête ?
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Décrivez-nous ce qui ne fonctionne pas ou ce que vous aimeriez voir exister. Nous trouverons la solution.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Demander une consultation extensions</Button>
        <Button href="/fr/services/maintenance-support/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Maintenance continue</Button>
      </div>
    </div>
  </section>

</PageLayout>
