---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import CaseStudyCards from '../../../components/ui/CaseStudyCards.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Extensions WordPress pour la Chine | Développement sur mesure';
const metaDescription = 'Extensions WordPress sur mesure pour la Chine. Intégrations WeChat, Alipay, SEO Baidu et corrections d\'extensions pour les sites derrière le Grand Pare-feu. Agence basée en Chine.';

const buildItems = [
  { title: 'Intégration WeChat', body: 'Connexion OAuth, comptes officiels, passerelles Mini Programs, QR codes, WeChat Pay. Si vous faites des affaires en Chine, WeChat n\'est pas optionnel. C\'est la façon dont les gens vous trouvent, vérifient que vous êtes sérieux et vous paient.' },
  { title: 'Passerelles de paiement', body: 'Alipay, WeChat Pay et UnionPay en tant qu\'extensions WooCommerce ou modules autonomes selon la configuration. Mal configurer cela n\'est pas anodin. Les acheteurs chinois quittent le site dès que le processus de paiement leur semble inhabituel ou peu familier.' },
  { title: 'Outils SEO Baidu', body: 'Génération de sitemaps pour Baidu Spider, intégration de l\'API push, balises meta que Baidu lit et prend réellement en compte. La plupart des gens pensent que Yoast ou RankMath les couvrent. Ce n\'est pas le cas. Ces outils sont construits autour du fonctionnement de Google.' },
  { title: 'Analytics et partage social', body: 'Baidu Tongji remplace Google Analytics, CNZZ comble les lacunes. Pour le partage, nous connectons WeChat, Weibo, QQ, Douyin, RED. Les plateformes que les gens en Chine utilisent réellement.' },
];

const audiences = [
  { label: 'Fonctionnalités manquantes', description: 'Entreprises ayant besoin de fonctionnalités WordPress que le marché n\'a tout simplement pas construites pour la Chine.', image: '/images/audiences/wordpress-features-china.webp' },
  { label: 'Checkout WeChat et Alipay', description: 'Marques e-commerce intégrant Alipay ou WeChat Pay au checkout.', image: '/images/audiences/ecommerce-wechat-alipay.webp' },
  { label: 'Équipes de développement', description: 'Équipes dev qui veulent des extensions Chine créées par des gens qui travaillent quotidiennement dans cet environnement.', image: '/images/audiences/dev-team-china-plugins.webp' },
  { label: 'Agences', description: 'Agences qui construisent des sites Chine pour leurs propres clients et ont besoin d\'un travail d\'extension fiable.', image: '/images/audiences/agency-china-clients.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0"><img src="/images/hero-plugins-extensions.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" /><div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div><div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div></div>
    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20"><ol class="flex items-center gap-2 text-sm text-white/40"><li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li><li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li><li class="before:content-['/'] before:mx-2 text-white/60">Extensions et plugins</li></ol></nav>
      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Extensions et plugins</p>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">Extensions WordPress sur mesure<span class="block mt-2 text-[var(--color-brand-orange)]">conçues pour le marché chinois</span></h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">La plupart des extensions WordPress n'ont jamais été conçues pour fonctionner en Chine. Nous construisons celles qui fonctionnent.</p>
          <div class="mt-10"><Button href="/fr/contact/" variant="primary" size="lg">Demander une consultation plugins</Button></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-8">Environ 40 % des extensions WordPress populaires dépendent de Google. Toutes bloquées en Chine.</h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">Voici ce que personne ne vous dit assez tôt : environ 40 % des extensions WordPress populaires dépendent de Google d'une manière ou d'une autre. Polices, reCAPTCHA, Maps, Analytics. Tout bloqué en Chine. Votre site se charge tout simplement avec des trous.</p>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">Nous démêlons ce type de situation depuis des années. En résumé, nous construisons des extensions WordPress sur mesure pour l'internet chinois, et nous corrigeons celles qui cassent derrière le Grand Pare-feu.</p>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Ce que nous construisons</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">Les mêmes besoins récurrents, chaque nouveau client</h2>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {buildItems.map((item) => (
              <div class="flex gap-5"><div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div><div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]"><h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">{item.title}</h3><p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item.body}</p></div></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui nous contacte pour les extensions" audiences={audiences} footnote="Si les extensions standard ne résolvent pas votre problème en Chine, venez nous parler. Nous construirons ce qui manque." background="light" />

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>
    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Lancez-vous</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">Vous avez quelque chose de précis en tête ?</h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">Dites-nous ce qui ne fonctionne pas ou ce que vous aimeriez voir exister. Nous trouverons la solution.</p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Demander une consultation plugins</Button>
        <Button href="/fr/services/maintenance-support/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Maintenance continue</Button>
      </div>
    </div>
  </section>
</PageLayout>
