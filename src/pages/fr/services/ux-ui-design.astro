        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-6">
        <!-- PANNEAU COULEUR -->
        <div class="rounded-2xl bg-white border border-[var(--color-surface-border)] p-7 lg:p-8">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-sm font-mono uppercase tracking-wider text-[var(--color-text-muted)]">/ Couleur</h3>
            <span class="text-[11px] font-mono text-[var(--color-text-muted)]/60">5 / tokens</span>
