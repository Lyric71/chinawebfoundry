---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Design UX et UI pour WordPress en Chine | ChinaWebFoundry';
const metaDescription = 'Nous concevons des sites WordPress qui parlent au public chinois. Adaptés culturellement, mobile-first, par une équipe basée en Chine, vingt ans d’ancrage local.';

const stats = [
  { value: '70%+', label: 'Trafic mobile en Chine' },
  { value: '6', label: 'Navigateurs testés' },
  { value: 'WeChat', label: 'Intégration native' },
  { value: 'ICP', label: 'Conforme par conception' },
];

const services = [
  {
    title: 'Recherche utilisateur',
    body: 'Nous cartographions la manière dont votre public navigue réellement en Chine, mesurons concurrents locaux et internationaux, et concevons des parcours qui partent d’où partent les internautes chinois : Douyin, WeChat ou Baidu.',
    tag: 'Recherche',
  },
  {
    title: 'Architecture de l’information',
    body: 'Le public chinois préfère les pages denses. Plus de liens visibles, plus de texte, plus d’options dès le départ. Nous structurons le contenu à la profondeur attendue, sans le rendre illisible pour le siège.',
    tag: 'IA',
  },
  {
    title: 'Design visuel',
    body: 'Mises en page mobile-first pour les appareils que les Chinois utilisent vraiment. Couleur symbolique, typographie qui respecte les caractères, signaux de confiance (QR WeChat, ICP, licence d’entreprise) que les consommateurs chinois vérifient avant d’agir.',
    tag: 'UI',
  },
  {
    title: 'Système de design Gutenberg',
    body: 'Nous concevons directement dans Gutenberg. Blocs personnalisés que votre équipe contenu utilise sans développeur, composants de cohérence visuelle, templates modifiables sans compétence technique.',
    tag: 'Système',
  },
];

const processSteps = [
  { phase: '01', title: 'Découverte et brief', body: 'Alignement sur les guidelines de marque, les objectifs et le public que vous cherchez à atteindre en Chine.' },
  { phase: '02', title: 'Recherche et benchmarking', body: 'Paysage concurrentiel, schémas d’usage locaux, principes de design. La phase de devoirs.' },
  { phase: '03', title: 'Wireframing', body: 'Structure de pages et flux confrontés aux attentes des internautes chinois. Reprendre un wireframe coûte moins qu’un mockup léché.' },
  { phase: '04', title: 'Design visuel et itération', body: 'Mockups haute fidélité et tours de retour jusqu’à ce que le design tienne pour la marque mondiale et pour le marché chinois.' },
  { phase: '05', title: 'Système et passation', body: 'Composants, guidelines de style et specs d’interaction emballés pour que votre équipe dev développe sans deviner.' },
  { phase: '06', title: 'QA et validation', body: 'Tests sur les navigateurs et appareils chinois. Un site superbe à Londres peut s’effondrer sur UC Browser ou QQ Browser, encore très utilisés en Chine.' },
];

const intelligence = [
  { claim: 'La couleur porte un sens', body: 'Le rouge évoque la chance et l’énergie. L’or, le premium. Le blanc seul porte un poids funéraire ; nous l’associons toujours à des accents forts.' },
  { claim: 'La densité signale la confiance', body: 'Les pages denses au-dessus de la ligne de flottaison rassurent l’internaute chinois. Les designs très aérés peuvent se lire comme vides, inachevés ou évasifs.' },
  { claim: 'La confiance vit aux marges', body: 'Numéro ICP, licence d’entreprise, badges officiels. Le pied de page est conventionnel. Les QR codes au-dessus de la ligne ancrent la crédibilité.' },
  { claim: 'WeChat fait partie de la plomberie', body: 'QR codes, liens vers Mini Programs, points de partage, identifiants service client. Infrastructure de base, pas options.' },
  { claim: 'La typographie pèse', body: 'PingFang SC, Noto Sans SC ou Source Han s’associent à Inter ou aux piles système. L’interlettrage et l’interligne diffèrent du latin.' },
  { claim: 'La nav du bas, c’est le bouton « accueil »', body: 'La barre de navigation collante en bas est le bouton « accueil » du web mobile chinois. Cinq cibles tactiles, toujours visibles, toujours atteignables au pouce.' },
];

const audiences = [
  { label: 'Démarrer depuis zéro', description: 'Vous bâtissez un site WordPress pour la Chine et voulez poser le bon design dès le départ.', image: '/images/audiences/building-site-china-design.webp' },
  { label: 'Site live qui ne performe pas', description: 'Votre site chinois est en ligne mais ne convertit pas, et vous soupçonnez le design.', image: '/images/audiences/live-site-not-performing.webp' },
  { label: 'Pages de campagne', description: 'Vos équipes marketing ont besoin de pages pour des consommateurs chinois, sans effet de traduction.', image: '/images/audiences/campaign-chinese-consumers.webp' },
  { label: 'Adapter un design global', description: 'Vous avez un design system mondial solide et cherchez quelqu’un qui sait l’adapter pour la Chine.', image: '/images/audiences/global-design-adapt-china.webp' },
];

const marqueeWords = [
  '移动优先', 'Mobile d’abord',
  '微信', 'WeChat',
  '百度', 'Baidu',
  '抖音', 'Douyin',
  '备案', 'Dépôt ICP',
  'Gutenberg',
  '中文排版', 'Typographie ZH',
  '信任信号', 'Signaux de confiance',
  '色彩文化', 'Couleur culturelle',
  '密度优先', 'Densité d’abord',
  'PingFang SC',
  'UC · QQ · Chrome',
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <section class="relative bg-[#0a0a0d] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(242,95,41,0.08),transparent_50%)]"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Design UX et UI</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 lg:pb-32">
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">UX / UI · 设计</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Concevoir <span class="italic font-light text-white/80">pour</span><br/>
            les internautes chinois.
            <span class="block mt-3 text-[var(--color-brand-orange)]">Pas seulement en chinois.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            Des expériences WordPress qui sonnent natives. Pertinentes culturellement, mobile-first, façonnées autour des plateformes qui font tourner l’internet chinois.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/fr/contact/" variant="primary" size="lg">Démarrer un projet de design</Button>
          </div>

          <div class="mt-12 grid grid-cols-2 sm:grid-cols-4 gap-6">
            {stats.map((s) => (
              <div>
                <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">{s.value}</div>
                <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Notre prestation</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Quatre chantiers, une seule discipline.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {services.map((s) => (
          <article class="rounded-2xl bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] p-7">
            <p class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-2">{s.tag}</p>
            <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{s.title}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Le déroulé</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Six étapes, du brief au QA.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {processSteps.map((p) => (
          <article class="rounded-2xl bg-white border border-[var(--color-surface-border)] p-6">
            <div class="text-3xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/80 leading-none mb-3">{p.phase}</div>
            <h3 class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-2">{p.title}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Six convictions</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Ce que nous tenons pour acquis sur l’UX chinoise.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {intelligence.map((it) => (
          <article class="rounded-2xl bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] p-7">
            <h3 class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{it.claim}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{it.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Pour qui nous concevons" audiences={audiences} background="light" />

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="relative border-y border-white/10 bg-[#0f0f12] py-5 overflow-hidden">
      <div class="flex gap-10 animate-[marquee_45s_linear_infinite] whitespace-nowrap">
        {[...marqueeWords, ...marqueeWords, ...marqueeWords].map((phrase) => (
          <span class="inline-flex items-center gap-3 text-base lg:text-lg font-medium text-white/40">
            {phrase}
            <span class="text-white/15">·</span>
          </span>
        ))}
      </div>
    </div>

    <div class="relative py-20 lg:py-28">
      <div class="relative mx-auto max-w-[1400px] section-padding text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.1] mb-6 max-w-3xl mx-auto">
          Un design pensé pour la Chine, dès la première intention.
        </h2>
        <p class="text-lg text-white/65 leading-relaxed mb-10 max-w-2xl mx-auto">
          Décrivez-nous le périmètre. Nous renvoyons sous deux jours ouvrés un cadrage et un calendrier.
        </p>
        <Button href="/fr/contact/" variant="primary" size="lg">Démarrer un projet</Button>
      </div>
    </div>
  </section>

</PageLayout>
