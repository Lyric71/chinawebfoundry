---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Design UX et UI pour WordPress en Chine | ChinaWebFoundry';
const metaDescription = 'Nous concevons des sites WordPress qui s’adressent réellement au public chinois. Pensés mobile d’abord, ancrés culturellement, livrés par une équipe installée en Chine depuis vingt ans.';

const stats = [
  { value: '70%+', label: 'Trafic mobile en Chine' },
  { value: '6', label: 'Navigateurs testés' },
  { value: 'WeChat', label: 'Intégration native' },
  { value: 'ICP', label: 'Conforme dès la conception' },
];

const services = [
  {
    title: 'Recherche utilisateur',
    body: 'Nous cartographions la manière dont votre public navigue réellement en Chine, nous mesurons les concurrents locaux et internationaux, et nous concevons des parcours qui s’amorcent là où l’internaute chinois commence sa journée : Douyin, WeChat ou Baidu.',
    icon: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607Z',
    tag: 'Recherche',
  },
  {
    title: 'Architecture de l’information',
    body: 'Le lecteur chinois marque sa préférence pour les pages denses. Davantage de liens visibles, davantage de texte, davantage d’options dès le premier écran. Nous structurons le contenu à la profondeur attendue, sans le rendre illisible aux yeux du siège.',
    icon: 'M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5',
    tag: 'Architecture',
  },
  {
    title: 'Design visuel',
    body: 'Mises en page pensées d’abord pour le mobile, sur les appareils réellement utilisés en Chine. Couleur symbolique, typographie respectueuse des caractères, signaux de confiance (QR WeChat, numéro ICP, licence d’entreprise) que les consommateurs chinois vérifient avant de passer à l’action.',
    icon: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
    tag: 'UI',
  },
  {
    title: 'Système de design Gutenberg',
    body: 'Nous concevons directement dans Gutenberg. Blocs personnalisés manipulés par vos équipes contenu sans dépendre d’un développeur, composants de cohérence visuelle, gabarits modifiables sans la moindre compétence technique.',
    icon: 'M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3',
    tag: 'Système',
  },
];

const processSteps = [
  { phase: '01', title: 'Cadrage initial', body: 'Cadrage à partir de votre charte de marque, des objectifs visés et du public que vous comptez toucher en Chine.' },
  { phase: '02', title: 'Recherche et veille concurrentielle', body: 'Cartographie de la concurrence, schémas d’usage locaux, principes de design propres au marché. La phase de fondations, à laquelle nous consacrons le temps qu’elle réclame.' },
  { phase: '03', title: 'Maquettes filaires', body: 'Structure des pages et parcours confrontés aux attentes des internautes chinois. Reprendre une maquette filaire coûte sans commune mesure moins cher qu’une maquette finalisée.' },
  { phase: '04', title: 'Design visuel et itérations', body: 'Maquettes haute fidélité et cycles de retours jusqu’à ce que le design tienne à la fois pour la marque mondiale et pour le marché chinois.' },
  { phase: '05', title: 'Système et passation', body: 'Composants, règles de style et spécifications d’interaction réunis dans un même livrable, pour que vos développeurs avancent sans avoir à deviner.' },
  { phase: '06', title: 'Recette et validation', body: 'Tests sur les navigateurs et appareils chinois. Un site somptueux à Londres peut s’effondrer sur UC Browser ou QQ Browser, encore très répandus sur le continent.' },
];

const colours = [
  { name: 'Rouge propice', hex: '#E11D2E', meaning: 'Chance, énergie, action' },
  { name: 'Orange de marque', hex: '#F25F29', meaning: 'Vitalité, accent' },
  { name: 'Vert de validation', hex: '#52C41A', meaning: 'Validation, WeChat' },
  { name: 'Encre', hex: '#1F1F1F', meaning: 'Titres, ancrage' },
  { name: 'Nuage', hex: '#FAFAFA', meaning: 'Arrière-plan, jamais isolé' },
];

const typeScale = [
  { label: 'H1', size: '32', cn: '中文标题', en: 'Titre principal' },
  { label: 'H2', size: '24', cn: '副标题', en: 'Sous-titre de section' },
  { label: 'Body', size: '16', cn: '正文段落', en: 'Paragraphe courant' },
  { label: 'Caption', size: '12', cn: '辅助说明', en: 'Légende ou méta' },
];

const spacingTokens = [
  { name: '4 · XS', width: 'w-2' },
  { name: '8 · S', width: 'w-4' },
  { name: '16 · M', width: 'w-8' },
  { name: '24 · L', width: 'w-12' },
  { name: '32 · XL', width: 'w-16' },
  { name: '48 · 2XL', width: 'w-24' },
];

const intelligence = [
  {
    claim: 'La couleur véhicule un sens',
    body: 'Le rouge évoque la chance et l’énergie. L’or, le haut de gamme. Le blanc, livré à lui-même, charrie une lourdeur funéraire : nous l’associons systématiquement à des accents marqués.',
    visual: 'colour',
  },
  {
    claim: 'La densité signale la confiance',
    body: 'Les pages denses au-dessus de la ligne de flottaison rassurent l’internaute chinois. Les designs très aérés se lisent souvent comme inaboutis, parfois même évasifs.',
    visual: 'density',
  },
  {
    claim: 'La confiance se loge aux marges',
    body: 'Numéro ICP, licence d’entreprise, badges officiels. Le pied de page demeure l’emplacement conventionnel. Les QR codes placés au-dessus de la ligne de flottaison renforcent considérablement la crédibilité perçue.',
    visual: 'trust',
  },
  {
    claim: 'WeChat relève de l’infrastructure',
    body: 'QR codes, liens vers Mini Programs, points de partage, identifiants service client. À traiter comme un socle d’infrastructure du site, au même rang que la navigation principale.',
    visual: 'wechat',
  },
  {
    claim: 'La typographie compte autant que les mots',
    body: 'PingFang SC, Noto Sans SC ou Source Han s’associent à Inter ou aux piles système. L’interlettrage et l’interligne obéissent à des règles distinctes de celles des langues latines.',
    visual: 'type',
  },
  {
    claim: 'La barre du bas tient lieu de bouton d’accueil',
    body: 'La barre de navigation collée en bas joue, sur le Web mobile chinois, le rôle d’un bouton d’accueil universel. Cinq cibles tactiles, en permanence visibles, en permanence atteignables au pouce.',
    visual: 'nav',
  },
];

const audiences = [
  { label: 'Démarrer depuis zéro', description: 'Vous bâtissez un site WordPress pour la Chine et entendez poser le bon design dès le départ.', image: '/images/audiences/building-site-china-design.webp' },
  { label: 'Un site en ligne qui peine à convertir', description: 'Votre site chinois fonctionne, mais les conversions ne suivent pas. Vous soupçonnez le design d’en être la cause.', image: '/images/audiences/live-site-not-performing.webp' },
  { label: 'Pages de campagne', description: 'Vos équipes marketing ont besoin de pages calibrées pour les consommateurs chinois, débarrassées de cet effet « page traduite » qui saute immédiatement aux yeux.', image: '/images/audiences/campaign-chinese-consumers.webp' },
  { label: 'Adapter un design international', description: 'Vous disposez d’un système de design international solide et cherchez l’interlocuteur capable de le transposer au marché chinois.', image: '/images/audiences/global-design-adapt-china.webp' },
];

const marqueeWords = [
  '移动优先', 'Mobile d’abord',
  '微信', 'WeChat',
  '百度', 'Baidu',
  '抖音', 'Douyin',
  '备案', 'Dépôt ICP',
  'Gutenberg',
  '中文排版', 'Typographie chinoise',
  '信任信号', 'Signaux de confiance',
  '色彩文化', 'Couleur culturelle',
  '密度优先', 'Densité d’abord',
  'PingFang SC',
  'UC · QQ · Chrome',
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <!-- HERO: composition éditoriale avec maquette mobile -->
  <section class="relative bg-[#0a0a0d] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px]"></div>
      <div class="absolute -bottom-40 right-1/3 w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/5 blur-[100px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(242,95,41,0.08),transparent_50%)]"></div>
      <!-- grille discrète -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Design UX et UI</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 lg:pb-32">
        <!-- Texte -->
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)]"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">UX / UI · 设计</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Concevoir <span class="italic font-light text-white/80">pour</span><br/>
            la manière dont les Chinois
            <span class="block mt-3 text-[var(--color-brand-orange)]">naviguent au quotidien.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            Des expériences WordPress qui sonnent natives à l’oreille du lecteur chinois. Ancrées culturellement, pensées mobile d’abord, façonnées autour des plateformes qui font tourner l’Internet en Chine.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/fr/contact/" variant="primary" size="lg">Engager un projet de design</Button>
            <a href="#notre-prestation" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              Découvrir le système
              <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <!-- Visuel : maquette mobile encadrée comme un artboard -->
        <div class="col-span-12 lg:col-span-5 mt-16 lg:mt-0">
          <div class="relative">
            <div class="absolute -inset-8 bg-[var(--color-brand-orange)]/15 rounded-[40px] blur-3xl -z-10"></div>

            <!-- Étiquette artboard -->
            <div class="flex items-center justify-between mb-3 px-1">
              <div class="flex items-center gap-2 text-[11px] font-mono text-white/40">
                <span class="w-1.5 h-1.5 rounded-sm bg-[var(--color-brand-orange)]"></span>
                <span>home-mobile.fig</span>
              </div>
              <div class="text-[11px] font-mono text-white/30">375 × 812</div>
            </div>

            <div class="relative rounded-3xl overflow-hidden border border-white/10 bg-gradient-to-br from-white/[0.04] to-transparent">
              <img
                src="/images/ux-design-china-mobile-wordpress-mockup.webp"
                alt="Page d’accueil mobile WordPress conçue pour le public chinois, avec accents rouges, QR code WeChat et numéro ICP"
                class="w-full h-auto block"
                loading="eager"
                decoding="async"
              />
            </div>

            <!-- Pastille flottante : Mobile d’abord -->
            <div class="hidden sm:flex absolute -left-6 top-20 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <span class="w-2 h-2 rounded-full bg-green-400"></span>
              <span class="text-xs font-medium text-white">Mobile d’abord</span>
            </div>

            <!-- Pastille flottante : signaux de confiance -->
            <div class="hidden sm:flex absolute -right-4 bottom-24 items-center gap-2.5 rounded-full bg-white/[0.08] backdrop-blur-md border border-white/15 px-4 py-2 shadow-2xl">
              <svg class="w-3.5 h-3.5 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              <span class="text-xs font-medium text-white">WeChat + ICP</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BANDEAU VOCABULAIRE -->
  <section aria-hidden="true" class="bg-[#0a0a0d] border-y border-white/5 overflow-hidden py-5">
    <div class="marquee-mask">
      <div class="marquee-track flex items-center gap-10 whitespace-nowrap">
        {[...marqueeWords, ...marqueeWords].map((word, i) => (
          <div class="flex items-center gap-10 flex-shrink-0">
            <span class={`text-base font-medium ${i % 2 === 0 ? 'text-white/40' : 'text-white/70'}`}>{word}</span>
            <span class="w-1 h-1 rounded-full bg-[var(--color-brand-orange)]/60 flex-shrink-0"></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BANDEAU CHIFFRES -->
  <section class="bg-white border-b border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-[var(--color-surface-border)] py-10 lg:py-12 -mx-4 sm:-mx-6 lg:-mx-8">
        {stats.map((stat) => (
          <div class="px-4 sm:px-6 lg:px-8">
            <div class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] tracking-tight leading-none">
              {stat.value}
            </div>
            <div class="mt-3 text-sm text-[var(--color-text-muted)]">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LE PROBLÈME -->
  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-12 lg:mb-0">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Le problème
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] mb-8 tracking-tight">
            Pourquoi le design occidental<br/>
            <span class="text-[var(--color-text-muted)]">s’effondre en Chine.</span>
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Une entreprise fait tourner son site WordPress chez elle, le déploie en Chine, et le taux de rebond s’envole. Techniquement, le site demeure irréprochable, mais quelque chose sonne faux à qui le consulte depuis Shanghai ou Chengdu.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            Les internautes chinois n’ont pas grandi sur le même Web. Leur manière de naviguer, le volume d’informations qu’ils s’attendent à embrasser d’un seul coup d’œil, tout cela porte l’empreinte de WeChat, de Taobao et de Douyin.
          </p>
          <blockquote class="border-l-2 border-[var(--color-brand-orange)] pl-6 py-1">
            <p class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
              Un langage visuel qui convertit à Chicago demande à être repensé pour parler à Chongqing.
            </p>
          </blockquote>
        </div>

        <div class="col-span-12 lg:col-span-6">
          <div class="relative">
            <div class="rounded-2xl overflow-hidden border border-[var(--color-surface-border)] shadow-xl shadow-black/5">
              <img
                src="/images/ux-design-china-vs-western-mobile-comparison.webp"
                alt="Deux téléphones côte à côte : à gauche, un site occidental épuré ; à droite, un site chinois dense, avec QR WeChat et signaux de confiance"
                class="w-full h-auto block"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="mt-5 grid grid-cols-2 gap-4 text-center">
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Style occidental</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Aéré, faible engagement</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)] mb-1">Style chinois</div>
                <div class="text-sm font-medium text-[var(--color-text-dark)]">Dense, performant à la conversion</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GRILLE DES CONVICTIONS UX CHINE -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-20">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Savoir de terrain
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1] tracking-tight">
            Six leçons que la Chine<br/>nous a transmises sur le design.
          </h2>
        </div>
        <p class="text-base text-[var(--color-text-muted)] max-w-md font-mono uppercase tracking-wider text-xs">
          A.01 à A.06 / Heuristiques UX Chine
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {intelligence.map((card, idx) => (
          <article class="group relative rounded-2xl bg-white border border-[var(--color-surface-border)] overflow-hidden hover:border-[var(--color-brand-orange)]/40 hover:shadow-xl hover:shadow-black/5 transition-all duration-300">
            <!-- Zone d’artefact visuel -->
            <div class="relative h-44 bg-gradient-to-br from-[var(--color-surface-light)] to-white border-b border-[var(--color-surface-border)] overflow-hidden">
              <div class="absolute top-3 left-4 text-[11px] font-mono text-[var(--color-text-muted)] uppercase tracking-wider">
                A.0{idx + 1}
              </div>

              {card.visual === 'colour' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-end gap-1">
                    <div class="w-12 h-20 rounded-md bg-[#E11D2E] shadow-md"></div>
                    <div class="w-12 h-16 rounded-md bg-[#F25F29] shadow-md"></div>
                    <div class="w-12 h-12 rounded-md bg-[#D4AF37] shadow-md"></div>
                    <div class="w-12 h-8 rounded-md bg-[#52C41A] shadow-md"></div>
                  </div>
                </div>
              )}

              {card.visual === 'density' && (
                <div class="absolute inset-0 flex items-center justify-center px-8">
                  <div class="w-full max-w-[180px] space-y-1.5">
                    <div class="h-3 bg-[var(--color-brand-orange)]/80 rounded-sm"></div>
                    <div class="grid grid-cols-3 gap-1.5">
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-8 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm"></div>
                    <div class="h-3 bg-[var(--color-text-dark)]/20 rounded-sm w-3/4"></div>
                    <div class="grid grid-cols-2 gap-1.5">
                      <div class="h-6 bg-[var(--color-brand-orange)]/30 rounded-sm"></div>
                      <div class="h-6 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'trust' && (
                <div class="absolute inset-0 flex items-center justify-center px-6">
                  <div class="flex items-center gap-2.5">
                    <div class="px-3 py-2 rounded-md border border-[var(--color-surface-border)] bg-white text-[10px] font-mono text-[var(--color-text-body)]">
                      ICP 沪B2-2024<br/>0123456号
                    </div>
                    <div class="w-12 h-12 rounded-md bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center text-white text-[10px] font-bold">营业<br/>执照</div>
                    <div class="w-10 h-10 rounded-md bg-[#52C41A] flex items-center justify-center">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'wechat' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative w-24 h-24 bg-white rounded-xl border border-[var(--color-surface-border)] p-2">
                    <div class="grid grid-cols-7 gap-px h-full w-full">
                      {Array.from({ length: 49 }).map((_, i) => {
                        const filled = [0,1,2,3,5,6,8,12,14,15,18,20,22,24,28,29,30,32,34,36,40,42,43,44,46,47,48].includes(i);
                        return <div class={filled ? 'bg-[var(--color-text-dark)] rounded-[1px]' : ''}></div>;
                      })}
                    </div>
                    <div class="absolute -bottom-2 -right-2 w-7 h-7 rounded-full bg-[#52C41A] border-2 border-white flex items-center justify-center">
                      <span class="text-white text-[9px] font-bold">微信</span>
                    </div>
                  </div>
                </div>
              )}

              {card.visual === 'type' && (
                <div class="absolute inset-0 flex items-center justify-center gap-3 px-6">
                  <span class="text-[80px] leading-none font-medium text-[var(--color-text-dark)]">中</span>
                  <div class="h-16 w-px bg-[var(--color-surface-border)]"></div>
                  <span class="text-[72px] leading-none font-light text-[var(--color-text-dark)] italic">Aa</span>
                </div>
              )}

              {card.visual === 'nav' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative w-20 h-32 rounded-xl border-2 border-[var(--color-text-dark)]/30 bg-white p-1.5 flex flex-col">
                    <div class="flex-1 space-y-1">
                      <div class="h-1.5 bg-[var(--color-text-dark)]/15 rounded-sm"></div>
                      <div class="h-3 bg-[var(--color-text-dark)]/10 rounded-sm"></div>
                      <div class="h-1.5 bg-[var(--color-text-dark)]/15 rounded-sm w-3/4"></div>
                      <div class="h-3 bg-[var(--color-brand-orange)]/30 rounded-sm"></div>
                    </div>
                    <div class="mt-1 flex items-center justify-around bg-[var(--color-brand-orange)]/10 rounded-md px-1 py-1.5 border-t border-[var(--color-brand-orange)]/30">
