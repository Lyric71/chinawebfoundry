---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Maintenance et accompagnement | Faire vivre votre site chinois';
const metaDescription = 'Mises à jour de contenu, suivi SEO et GEO, maintenance technique et hébergement pour votre site chinois. Une seule équipe. Depuis l’intérieur du Pare-feu.';

const includedItems = [
  { n: '01', cn: '内容', title: 'Mises à jour éditoriales', body: "Deux à quatre pièces par mois pour les clients actifs : un article long format compatible Baidu (1 500 à 2 500 caractères chinois), une étude de cas ou mise à jour produit, une à deux brèves d’actualité. Tout est rédigé en chinois natif, jamais traduit. Nous syndiquons les meilleures pièces sur Baijiahao (百家号), Zhihu (知乎) et Sohu Hao (搜狐号), que les IA traitent comme signaux de vérification.", tag: 'Contenu', chips: ['百家号', '知乎', '搜狐号', 'ZH natif', '双11 / 618 / 春节'] },
  { n: '02', cn: '搜索', title: 'Suivi SEO Baidu', body: "Rapport mensuel de positions sur vos 30 à 50 mots-clés prioritaires, contrôle d’indexation sur 100+ URL via 百度搜索资源平台, deux à trois correctifs techniques par mois selon ce que disent les chiffres. Nous poussons chaque nouveau contenu via les outils de soumission Baidu le jour de la publication, corrigeons les erreurs de crawl, reconstruisons ce qui sort de l’index.", tag: 'SEO Baidu', chips: ['Rang', '主动推送', 'Index', 'Réponse algo'] },
  { n: '03', cn: '智能', title: 'Suivi GEO', body: "Contrôles de visibilité hebdomadaires sur DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝) et Baidu IA (百度AI), avec une matrice de 40 requêtes fixes par client couvrant marque, catégorie, scénario et concurrence. Les rapports donnent taux de citation, rang de recommandation, sentiment, plus la liste des ajustements à pousser dans le mois.", tag: 'Recherche IA', chips: ['DeepSeek', 'Doubao', 'Kimi', '元宝', '文心X1'] },
  { n: '04', cn: '技术', title: 'Maintenance technique', body: "Mises à jour cœur WordPress, extensions et thèmes testées en staging avant production. Sauvegardes off-site quotidiennes conservées 30 jours. Scan de sécurité Wordfence ou Sucuri en continu. Contrôles de disponibilité toutes les 5 minutes depuis des serveurs en Chine. Nettoyage trimestriel de la base. Renouvellement des SSL compatibles Chine via Aliyun (阿里云) ou autorités locales.", tag: 'Technique', chips: ['Mises à jour', 'Backups', 'Sécurité', 'Uptime', 'SSL'] },
  { n: '05', cn: '防火', title: 'La couche Pare-feu', body: "Nous surveillons en temps réel le comportement du Grand Pare-feu. Quand un CDN, une bibliothèque de polices ou une API externe se retrouve bloqué, nous basculons sur un équivalent compatible. Délai moyen entre détection et déploiement : 14 minutes. Nous retestons connexion WeChat (微信), Alipay (支付宝), WeChat Pay (微信支付) et analytics (Baidu Tongji ou 51la) à chaque cycle de mise à jour.", tag: 'Pare-feu', chips: ['CDN', 'Polices', 'WeChat', 'Alipay', 'Analytics'] },
  { n: '06', cn: '主机', title: 'Hébergement', body: "Serveurs sous licence ICP (ICP备案) sur Aliyun, Tencent Cloud (腾讯云) ou Huawei Cloud (华为云), gérés de bout en bout. Optimisation lors des pics de trafic. Renouvellements Bei’an (备案) suivis sur la console MIIT pour qu’aucun ne tombe. SLA de 99,9 % avec délais documentés : 30 minutes pour les incidents critiques, 4 heures pour les tickets standards.", tag: 'Hébergement', chips: ['ICP 备案', 'Aliyun', 'Tencent', 'Huawei', '99,9% SLA'] },
  { n: '07', cn: '修复', title: 'Dépannage', body: "Quand quelque chose casse, l’équipe en Chine prend la main immédiatement. Bugs, conflits d’extension, incidents de sécurité, erreurs sur Alipay ou WeChat Pay. En cas de piratage : isoler, nettoyer, restaurer, durcir, post-mortem sous 48 heures.", tag: 'Incident', chips: ['Bugs', 'Conflits', 'Piratage', '48h post-mortem'] },
];

const insightItems = [
  { n: '01', cn: '变', title: 'Le numérique chinois bouge plus vite', body: "L’algorithme Baidu a changé onze fois en 2025. DeepSeek a publié quatre révisions majeures de modèle. Doubao a remanié son ingestion de contenu au moins une fois par mois. Le rythme ne ralentit pas." },
  { n: '02', cn: '退', title: 'Les sites laissés en l’état se dégradent', body: "Les sites lancés correctement et laissés intacts un an finissent presque toujours invisibles au neuvième mois. La dégradation est progressive, puis soudaine." },
  { n: '03', cn: '增', title: 'Les sites maintenus composent', body: "Les sites qui publient un contenu frais régulier, suivent leurs citations IA chaque semaine et gardent la pile technique propre composent leurs gains. Les positions montent, les mentions IA s’accumulent, le coût pour rester visible baisse." },
  { n: '04', cn: '盲', title: 'Les agences étrangères passent à côté', body: "Les agences internationales ne voient pas la plupart des modes d’échec sans VPN. Depuis Londres ou Chicago, tout semble aller bien, jusqu’au moment où ce n’est plus le cas." },
];

const stats = [
  { value: '14 min', label: 'Détection-déploiement moyen', sub: 'Quand une police, un CDN ou une API se trouve bloqué.' },
  { value: '99,9 %', label: 'SLA de disponibilité', sub: 'Réponse en 30 minutes sur les incidents critiques.' },
  { value: '40', label: 'Requêtes IA par semaine', sub: 'Suivi des citations sur 5 moteurs, hebdomadaire.' },
];

const audiences = [
  { label: 'Pas d’équipe locale', description: 'Sociétés avec un site chinois en ligne mais sans équipe sur place, qui ont besoin de soutien expert sans tout monter en interne.', image: '/images/audiences/wordpress-china-no-local-team.webp' },
  { label: 'Marketing d’abord', description: 'Équipes marketing qui préfèrent travailler sur les campagnes que pourchasser des extensions cassées sur neuf fuseaux horaires.', image: '/images/audiences/marketing-not-debugging.webp' },
  { label: 'IT sans Chinese hire', description: 'Équipes IT qui ont besoin d’expertise Chine mais ne peuvent justifier un poste plein temps à l’organigramme.', image: '/images/audiences/it-team-china-expertise.webp' },
  { label: 'E-commerce en Chine', description: 'Activités e-commerce sur WooCommerce ou Shopify avec passerelles de paiement chinoises et logistique locale.', image: '/images/audiences/woocommerce-china-payments.webp' },
];

const marqueePhrases = [
  '维护', 'Maintenance',
  '内容', 'GEO', 'SEO',
  'ICP 备案',
  'Aliyun · Tencent Cloud',
  'Wordfence',
  'WeChat Pay',
  'Alipay',
  '99,9% disponibilité',
  'Veille 24/7',
  'Une équipe · une facture',
];

const faqs = [
  { id: 'why-not-internal', question: 'Pourquoi ne pas confier ça à notre IT interne ?', answer: ["Ils peuvent, en théorie. En pratique, les équipes internes perdent presque toujours la visibilité côté Chine, parce qu’elles n’atteignent pas les tableaux de bord (百度站长资源, console Aliyun, plateforme WeChat) sans VPN, et que les alertes sont en chinois. La plupart de nos clients gardent leur IT pour le global et nous prennent comme bureau Chine."] },
  { id: 'pricing', question: 'Comment sont tarifés les forfaits ?', answer: ["Forfaits mensuels à partir de 1 200 USD, calibrés sur ce que votre site nécessite vraiment. Le montant dépend du volume de trafic, de la cadence éditoriale, du nombre de moteurs IA suivis et de l’intégration ou non de l’hébergement. Décrivez-nous votre situation, nous renvoyons un vrai devis sous deux jours ouvrés."] },
  { id: 'response-time', question: 'À quelle vitesse réagissez-vous aux incidents ?', answer: ["Incidents critiques (site down, paiement, piratage) : 30 minutes entre l’alerte et la première action, 24/7. Tickets standards (conflit d’extension, modification de contenu, question dashboard) : 4 heures ouvrées. Tous les délais sont écrits dans le SLA."] },
  { id: 'content-cadence', question: 'Combien de contenu sortez-vous par mois ?', answer: ["Deux à quatre pièces sur un forfait actif : un article long format Baidu, une étude de cas ou mise à jour produit, une à deux brèves. La cadence monte autour des fenêtres de campagne : 双11, 618, 春节."] },
  { id: 'baidu-and-geo', question: 'Le SEO Baidu et le GEO sont-ils inclus ou séparés ?', answer: ["Les deux sont inclus dans le forfait pour les clients actifs. Rapport mensuel de positions Baidu et contrôle d’indexation, suivi hebdomadaire des citations IA sur DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA. Les chantiers structurels lourds (refonte de cartographie de mots-clés, grappes de contenu) sont des projets séparés."] },
  { id: 'hosting', question: 'Doit-on déplacer notre hébergement chez vous ?', answer: ["Non. Nous travaillons avec ce que vous avez sur Aliyun, Tencent Cloud ou Huawei Cloud. Si l’hébergement entre dans le forfait, nous gérons tout, y compris les renouvellements 备案 sur la console MIIT. Sinon, nous coordonnons avec celui qui le gère."] },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12] via-[#0f0f12] to-[#1a1a2e]"></div>
    <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/10 blur-[120px]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Maintenance et accompagnement</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 lg:pb-32">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Maintenance et accompagnement</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Faire vivre votre site chinois.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Mois après mois.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Contenu, SEO Baidu, GEO sur les cinq moteurs d’IA chinois, maintenance technique et hébergement, dans un seul forfait mensuel piloté depuis Shanghai.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Demander un forfait</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Inclus</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Sept chantiers menés ensemble.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6">
        {includedItems.map((it) => (
          <article class="bg-[var(--color-surface-light)] rounded-2xl p-7 border border-[var(--color-surface-border)]">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-2xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/80">{it.n}</span>
                <span class="text-2xl text-[var(--color-brand-orange)]/60">{it.cn}</span>
              </div>
              <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-text-muted)]">{it.tag}</span>
            </div>
            <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{it.title}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-4">{it.body}</p>
            <div class="flex flex-wrap gap-1.5">
              {it.chips.map((c) => (
                <span class="text-[11px] font-mono px-2.5 py-1 rounded-md bg-white text-[var(--color-text-body)] border border-[var(--color-surface-border)]">{c}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Pourquoi le forfait</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Quatre raisons concrètes.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {insightItems.map((it) => (
          <article class="bg-white rounded-2xl p-7 border border-[var(--color-surface-border)]">
            <div class="text-3xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/80 mb-3">{it.cn}</div>
            <h3 class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{it.title}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{it.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-5">
        {stats.map((s, i) => (
          <div class:list={['rounded-3xl p-7 lg:p-8', i === 1 ? 'bg-gradient-to-br from-[var(--color-brand-orange)] to-[#D14A1F] text-white' : 'bg-[var(--color-surface-light)] border border-[var(--color-surface-border)]']}>
            <div class:list={['text-[10px] font-mono uppercase tracking-[0.18em] mb-3', i === 1 ? 'text-white/75' : 'text-[var(--color-text-muted)]']}>{s.label}</div>
            <div class:list={['text-5xl lg:text-6xl font-medium font-[var(--font-heading)] leading-none mb-3', i === 1 ? 'text-white' : 'text-[var(--color-text-dark)]']}>
              {s.value}
            </div>
            <p class:list={['text-sm leading-relaxed', i === 1 ? 'text-white/90' : 'text-[var(--color-text-body)]']}>{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Pour qui ce forfait" audiences={audiences} background="light" />

  <section id="faq" class="section-spacing bg-white">
    <div class="mx-auto max-w-[1100px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">FAQ</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Six questions sur le forfait.
        </h2>
      </div>
      <div data-faq-accordion>
        {faqs.map((faq) => (
          <FAQItem question={faq.question} id={faq.id}>
            {faq.answer.map((p) => <p class="mb-3 last:mb-0">{p}</p>)}
          </FAQItem>
        ))}
      </div>
    </div>
  </section>

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="relative border-y border-white/10 bg-[#0f0f12] py-5 overflow-hidden">
      <div class="flex gap-10 animate-[marquee_45s_linear_infinite] whitespace-nowrap">
        {[...marqueePhrases, ...marqueePhrases, ...marqueePhrases].map((phrase) => (
          <span class="inline-flex items-center gap-3 text-base lg:text-lg font-medium text-white/40">
            {phrase}
            <span class="text-white/15">·</span>
          </span>
        ))}
      </div>
    </div>

    <div class="relative py-20 lg:py-28">
      <div class="relative mx-auto max-w-[1100px] section-padding text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.1] mb-6">
          Une équipe, une facture, un site qui tient.
        </h2>
        <p class="text-lg text-white/65 leading-relaxed mb-10 max-w-2xl mx-auto">
          Décrivez-nous votre situation. Nous renvoyons sous deux jours ouvrés un forfait calibré.
        </p>
        <Button href="/fr/contact/" variant="primary" size="lg">Demander un forfait</Button>
      </div>
    </div>
  </section>

</PageLayout>
