---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/pages/ScrollEffects.astro';

const metaTitle = 'Maintenance et accompagnement | Faire vivre votre site chinois';
const metaDescription = 'Mises à jour de contenu, suivi SEO et GEO, maintenance technique et hébergement pour votre site chinois. Une seule équipe, basée à l’intérieur du Great Firewall.';

const includedItems = [
  {
    n: '01',
    cn: '内容',
    title: 'Mises à jour éditoriales',
    body: "Deux à quatre pièces par mois pour les clients actifs : un article au format long compatible Baidu (1 500 à 2 500 caractères chinois), une étude de cas ou mise à jour produit, une à deux brèves d’actualité. Tout est rédigé en chinois natif, jamais traduit. On syndique les meilleures pièces sur Baijiahao (百家号), Zhihu (知乎) et Sohu Hao (搜狐号), que les IA traitent comme signaux de vérification.",
    tag: 'Contenu',
    chips: ['百家号', '知乎', '搜狐号', 'ZH natif', '双11 / 618 / 春节'],
  },
  {
    n: '02',
    cn: '搜索',
    title: 'Suivi SEO Baidu',
    body: "Rapport mensuel de positions sur vos 30 à 50 mots-clés prioritaires, contrôle d’indexation sur plus de 100 URL via 百度搜索资源平台, deux à trois correctifs techniques par mois selon ce que disent les chiffres. On pousse chaque nouveau contenu via les outils de soumission Baidu le jour de la publication, on corrige les erreurs de crawl, on reconstruit ce qui sort de l’index.",
    tag: 'SEO Baidu',
    chips: ['Rang', '主动推送', 'Index', 'Réponse algo'],
  },
  {
    n: '03',
    cn: '智能',
    title: 'Suivi GEO',
    body: "Contrôles de visibilité hebdomadaires sur DeepSeek (深度求索), Doubao (豆包), Kimi, Yuanbao (元宝) et Baidu IA (百度AI), avec une matrice de 40 requêtes fixes par client couvrant marque, catégorie, scénario et concurrence. Les rapports donnent taux de citation, rang de recommandation, sentiment, plus la liste des ajustements à pousser dans le mois.",
    tag: 'Recherche IA',
    chips: ['DeepSeek', 'Doubao', 'Kimi', '元宝', '文心X1'],
  },
  {
    n: '04',
    cn: '技术',
    title: 'Maintenance technique',
    body: "Mises à jour du cœur WordPress, des extensions et des thèmes testées en préproduction avant passage en ligne. Sauvegardes quotidiennes hors site, conservées 30 jours. Scan de sécurité Wordfence ou Sucuri en continu. Contrôles de disponibilité toutes les 5 minutes depuis des serveurs en Chine. Nettoyage trimestriel de la base. Renouvellement des SSL compatibles Chine via Aliyun (阿里云) ou autorités locales.",
    tag: 'Technique',
    chips: ['Mises à jour', 'Sauvegardes', 'Sécurité', 'Disponibilité', 'SSL'],
  },
  {
    n: '05',
    cn: '防火',
    title: 'La couche Great Firewall',
    body: "On surveille en temps réel le comportement du Great Firewall. Quand un CDN, une bibliothèque de polices ou une API externe se retrouve bloqué, on bascule sur un équivalent compatible. Délai moyen entre détection et déploiement : 14 minutes. On reteste les connexions WeChat (微信), Alipay (支付宝), WeChat Pay (微信支付) et la mesure d’audience (Baidu Tongji ou 51la) à chaque cycle de mise à jour.",
    tag: 'Great Firewall',
    chips: ['CDN', 'Polices', 'WeChat', 'Alipay', 'Mesure d’audience'],
  },
  {
    n: '06',
    cn: '主机',
    title: 'Hébergement',
    body: "Serveurs sous licence ICP (ICP备案) chez Aliyun, Tencent Cloud (腾讯云) ou Huawei Cloud (华为云), gérés de bout en bout. Optimisation lors des pics de trafic. Renouvellements Bei’an (备案) suivis sur la console MIIT pour qu’aucun ne passe à la trappe. SLA de 99,9 % avec délais documentés : 30 minutes pour les incidents critiques, 4 heures pour les tickets standards.",
    tag: 'Hébergement',
    chips: ['ICP 备案', 'Aliyun', 'Tencent', 'Huawei', '99,9% SLA'],
  },
  {
    n: '07',
    cn: '修复',
    title: 'Dépannage',
    body: "Quand quelque chose casse, l’équipe en Chine prend la main immédiatement. Bugs, conflits d’extension, incidents de sécurité, erreurs sur Alipay ou WeChat Pay. En cas de piratage : isoler, nettoyer, restaurer, durcir, post-mortem sous 48 heures.",
    tag: 'Incident',
    chips: ['Bugs', 'Conflits', 'Piratage', '48h post-mortem'],
  },
];

const insightItems = [
  {
    n: '01',
    cn: '变',
    title: 'Le numérique chinois bouge plus vite',
    body: "L’algorithme Baidu a changé onze fois en 2025. DeepSeek a publié quatre révisions majeures de modèle. Doubao a remanié son ingestion de contenu au moins une fois par mois. Le rythme ne ralentit pas.",
  },
  {
    n: '02',
    cn: '退',
    title: 'Les sites laissés en l’état se dégradent',
    body: "Les sites lancés correctement et laissés intacts un an finissent presque toujours invisibles au neuvième mois. La dégradation est progressive, puis soudaine.",
  },
  {
    n: '03',
    cn: '增',
    title: 'Les sites maintenus composent',
    body: "Les sites qui publient un contenu frais régulier, suivent leurs citations IA chaque semaine et gardent la pile technique propre composent leurs gains. Les positions montent, les mentions IA s’accumulent, le coût pour rester visible baisse.",
  },
  {
    n: '04',
    cn: '盲',
    title: 'Les agences étrangères passent à côté',
    body: "Les agences internationales ne voient pas la plupart des modes d’échec sans VPN. Depuis Londres ou Chicago, tout semble aller bien, jusqu’au moment où ce n’est plus le cas.",
  },
];

const stats = [
  { value: '14 min', label: 'Détection-déploiement moyen', sub: 'Quand une police, un CDN ou une API se trouve bloqué.' },
  { value: '99,9 %', label: 'SLA de disponibilité', sub: 'Réponse en 30 minutes sur les incidents critiques.' },
  { value: '40', label: 'Requêtes IA par semaine', sub: 'Suivi des citations sur 5 moteurs, hebdomadaire.' },
];

const audiences = [
  { label: 'Pas d’équipe locale', description: 'Sociétés avec un site chinois en ligne mais sans équipe sur place, qui ont besoin de soutien expert sans tout monter en interne.', image: '/images/audiences/wordpress-china-no-local-team.webp' },
  { label: 'Marketing d’abord', description: 'Équipes marketing qui préfèrent travailler sur les campagnes plutôt que de pourchasser des extensions cassées à neuf fuseaux horaires de distance.', image: '/images/audiences/marketing-not-debugging.webp' },
  { label: 'IT sans expert Chine en interne', description: 'Équipes IT qui ont besoin d’expertise Chine mais ne peuvent pas justifier un poste à temps plein à l’organigramme.', image: '/images/audiences/it-team-china-expertise.webp' },
  { label: 'E-commerce en Chine', description: 'Activités e-commerce sur WooCommerce ou Shopify avec passerelles de paiement chinoises et logistique locale.', image: '/images/audiences/woocommerce-china-payments.webp' },
];

const marqueePhrases = [
  '维护', 'Maintenance',
  '内容', 'GEO', 'SEO',
  'ICP 备案',
  'Aliyun · Tencent Cloud',
  'Wordfence',
  'WeChat Pay',
  'Alipay',
  '99,9% disponibilité',
  'Veille 24/7',
  'Une équipe · une facture',
];

const faqs = [
  {
    id: 'why-not-internal',
    question: 'Pourquoi ne pas confier ça à notre IT interne ?',
    answer: [
      "Elles peuvent, en théorie. En pratique, les équipes internes perdent presque toujours la visibilité côté Chine : elles n’atteignent pas les tableaux de bord (百度站长资源, console Aliyun, plateforme WeChat) sans VPN, et les alertes arrivent en chinois. La plupart de nos clients gardent leur IT pour le global et nous prennent comme bureau Chine.",
    ],
  },
  {
    id: 'pricing',
    question: 'Comment sont tarifés les forfaits ?',
    answer: [
      "Forfaits mensuels à partir de 1 200 USD, ajustés aux besoins réels du site. Le montant dépend du volume de trafic, de la cadence éditoriale, du nombre de moteurs IA suivis, de l’intégration ou non de l’hébergement. Décrivez-nous votre situation, nous revenons sous deux jours ouvrés avec un chiffre précis.",
    ],
  },
  {
    id: 'response-time',
    question: 'À quelle vitesse réagissez-vous aux incidents ?',
    answer: [
      "Incidents critiques (site hors ligne, paiement, piratage) : 30 minutes entre l’alerte et la première action, 24/7. Tickets standards (conflit d’extension, modification de contenu, question sur un tableau de bord) : 4 heures ouvrées. Tous les délais sont écrits dans le SLA.",
    ],
  },
  {
    id: 'content-cadence',
    question: 'Combien de contenu sortez-vous par mois ?',
    answer: [
      "Deux à quatre pièces sur un forfait actif : un article au format long pour Baidu (1 500 à 2 500 caractères chinois), une étude de cas ou mise à jour produit, une à deux brèves. La cadence monte autour des fenêtres de campagne : 双11, 618, 春节.",
    ],
  },
  {
    id: 'baidu-and-geo',
    question: 'Le SEO Baidu et le GEO sont-ils inclus ou séparés ?',
    answer: [
      "Les deux sont inclus dans le forfait pour les clients actifs. Rapport mensuel de positions Baidu et contrôle d’indexation, suivi hebdomadaire des citations IA sur DeepSeek, Doubao, Kimi, Yuanbao et Baidu IA. Les chantiers structurels lourds, refonte de cartographie de mots-clés ou grappes de contenu, restent des missions à part.",
    ],
  },
  {
    id: 'hosting',
    question: 'Doit-on déplacer notre hébergement chez vous ?',
    answer: [
      "Non. On travaille avec ce que vous avez chez Aliyun, Tencent Cloud ou Huawei Cloud. Si l’hébergement entre dans le forfait, on gère tout, renouvellements 备案 sur la console MIIT compris. Sinon, on coordonne avec celui qui le pilote.",
    ],
  },
  {
    id: 'firewall',
    question: 'Que se passe-t-il quand le Great Firewall bloque quelque chose ?',
    answer: [
      "On surveille le comportement en temps réel et on bascule vers des équivalents compatibles Chine quand un CDN, une bibliothèque de polices ou une API externe ne résout plus. Délai moyen : 14 minutes entre détection et déploiement. Chaque trimestre, on reteste les connexions WeChat, Alipay, WeChat Pay et Baidu Tongji, parce que les régressions y sont silencieuses.",
    ],
  },
  {
    id: 'reporting',
    question: 'À quoi ressemble le reporting ?',
    answer: [
      "Synthèse écrite mensuelle couvrant le contenu publié, les mouvements de positions Baidu, le suivi des citations GEO, le travail technique réalisé, les incidents résolus et les priorités recommandées pour le mois suivant. Plus un tableau de bord en direct, consultable à tout moment.",
    ],
  },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-maintenance-beijing-team-office.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/85 to-[#0f0f12]/60"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-emerald-500/10 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[28rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">维</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Maintenance et accompagnement</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Maintenance &amp; accompagnement</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">Derrière le Great Firewall, 24h/24</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            Faire vivre votre site chinois.
            <span class="block mt-1.5">
              <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Mois après</span>
              <span class="text-white/95 font-[var(--font-heading)] ml-1">mois.</span>
            </span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            Contenu, SEO Baidu, suivi GEO sur les cinq moteurs d’IA chinois, maintenance technique, hébergement. Tout est porté par une équipe qui opère depuis l’intérieur du Great Firewall, chaque jour. <span class="text-white font-medium">Une équipe. Une facture. Aucun renvoi de balle à neuf fuseaux horaires.</span>
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-emerald-400/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">99,9<span class="text-base text-white/60">%</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">SLA disponibilité</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white"><span data-counter>14</span><span class="text-base text-white/60">min</span></div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Détection → déploiement</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">24/7</div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Veille côté Chine</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Parler à notre équipe</Button>
            <Button href="#whats-included" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Voir ce qui est inclus</Button>
          </div>
        </div>

        <!-- Visuel : tableau de bord en couches -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative">
            <!-- Arrière : maquette du site « laissé en l’état » -->
            <div class="absolute -top-6 -left-4 right-12 bottom-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono text-red-300/70 uppercase tracking-wider">Sans suivi · 9 mois</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">sans équipe</span>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
                <div class="h-2 w-2/3 rounded bg-white/5"></div>
              </div>
              <div class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-mono text-red-300/70">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                Position Baidu : en perte
              </div>
            </div>

            <!-- Avant : tableau de bord live -->
            <div data-tilt class="relative rounded-2xl bg-gradient-to-br from-white/[0.09] via-white/[0.06] to-white/[0.03] backdrop-blur-md border border-white/15 p-6 lg:p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
              <div class="flex items-center gap-2 mb-5">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                </div>
                <span class="text-[10px] font-mono text-white/45 ml-2">statut-site · live</span>
                <span class="ml-auto inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-emerald-500/15 border border-emerald-400/30">
                  <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
                  <span class="text-[9px] font-mono text-emerald-300 uppercase">Sain</span>
                </span>
              </div>

              <div class="space-y-3.5">
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Veille Great Firewall</span>
                  <span class="text-[12px] font-mono text-emerald-300">RAS</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Cadence contenu</span>
                  <span class="text-[12px] font-mono text-emerald-300">3 / mois</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-white/75">Index Baidu</span>
                  <span class="text-[12px] font-mono text-emerald-300">Sain</span>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/75">Citations IA (sem.)</span>
                    <span class="text-[12px] font-mono text-[var(--color-brand-orange)]">+<span data-counter data-counter-suffix="%">12</span></span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden shimmer-bar">
                    <div class="h-full w-[72%] bg-gradient-to-r from-[var(--color-brand-orange)] to-[#FF8956] rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-[13px] text-white/75">Disponibilité · 30j</span>
                    <span class="text-[12px] font-mono text-emerald-300">99,98%</span>
                  </div>
                  <div class="h-1 rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full w-[99%] bg-gradient-to-r from-emerald-400 to-emerald-300 rounded-full"></div>
                  </div>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-white/10 grid grid-cols-3 gap-2">
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">Sauvegardes</div>
                  <div class="text-xs font-mono text-emerald-300">À jour</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">ICP 备案</div>
                  <div class="text-xs font-mono text-white/70">2027</div>
                </div>
                <div>
                  <div class="text-[9px] text-white/40 uppercase tracking-wider mb-0.5">SSL</div>
                  <div class="text-xs font-mono text-emerald-300">Valide</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- POURQUOI : énoncé fort -->
  <section class="relative section-spacing overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-5 mb-10 lg:mb-0" data-reveal="left">
          <div class="relative inline-flex items-baseline">
            <span class="text-[10rem] lg:text-[14rem] font-medium font-[var(--font-heading)] leading-none bg-gradient-to-br from-[var(--color-brand-orange)] via-[#FF7E47] to-[#D94E1F] bg-clip-text text-transparent" data-counter data-counter-duration="1800">9</span>
            <span class="text-3xl lg:text-4xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] ml-2">mois</span>
          </div>
          <p class="mt-4 text-base text-[var(--color-text-muted)] max-w-sm">
            Temps moyen avant qu’un site chinois lancé puis abandonné ne disparaisse des radars. Dégradation progressive, puis sortie brutale des positions.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-7" data-reveal="right">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-orange)] mb-5">Pourquoi ça compte</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.15] mb-6">
            Le lancement, c’est la partie facile.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Un site chinois ne se lance pas pour qu’on l’oublie ensuite. Baidu fait reculer les sites qui cessent de publier. Les moteurs d’IA changent leur logique de crawl toutes les quelques semaines. Une Google Font oubliée par votre développeur dans le thème se retrouve bloquée un mardi sans prévenir, et la page d’accueil casse pour tous les visiteurs à Shanghai, Shenzhen et Pékin.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-8">
            Depuis votre bureau à Londres ou Chicago, tout semble aller bien jusqu’au moment où ça cesse. On porte la veille, le contenu, le travail de référencement et la couche technique dans un même engagement.
          </p>

          <div class="flex flex-wrap items-center gap-2.5">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-brand-orange)] text-white text-sm font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
              Veille
            </span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Publication</span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Maintenance</span>
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[var(--color-surface-border)] text-[var(--color-text-dark)] text-sm font-medium">Composition</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CE QUI EST INCLUS : cartes comparatives -->
  <section id="whats-included" class="relative section-spacing bg-gradient-to-b from-[var(--color-surface-light)] to-white overflow-hidden scroll-mt-32">
    <span aria-hidden="true" class="absolute -top-24 right-[-2rem] text-[20rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.04] leading-none select-none pointer-events-none" data-parallax="0.15">守</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14 lg:mb-16" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">Ce qui est inclus · 服务内容</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08] mb-5">
          Sept chantiers. Un seul forfait.
        </h2>
        <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
          Les trois premiers gardent le site visible. Les trois suivants le tiennent debout. Le dernier rattrape ce qui passe entre les mailles.
        </p>
      </div>

      <div class="space-y-5 lg:space-y-6">
        {includedItems.map((q, i) => (
          <article
            data-reveal
            data-reveal-delay={String(i * 50)}
            data-cursor-spotlight
            class:list={[
              'group relative grid grid-cols-1 lg:grid-cols-12 gap-0 rounded-3xl border border-[var(--color-surface-border)] bg-white overflow-hidden transition-all duration-500',
              'hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_30px_70px_-30px_rgba(15,15,18,0.18)] hover:-translate-y-1',
            ]}
          >
            <div class="lg:col-span-3 relative p-7 lg:p-8 bg-gradient-to-br from-[var(--color-text-dark)] to-[#0f0f12] text-white overflow-hidden">
              <span aria-hidden="true" class="absolute right-[-1.5rem] bottom-[-3rem] text-[14rem] font-medium font-[var(--font-heading)] text-white/[0.04] leading-none select-none pointer-events-none transition-transform duration-700 group-hover:scale-110 origin-bottom-right">{q.cn}</span>
              <div class="relative">
                <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-2">No. {q.n} / 07</div>
                <div class="text-5xl lg:text-6xl font-medium font-[var(--font-heading)] text-white leading-none mb-1.5">{q.cn}</div>
                <div class="text-xs uppercase tracking-wider text-[var(--color-brand-orange)]/90 font-semibold">{q.tag}</div>
              </div>
            </div>

            <div class="lg:col-span-6 p-7 lg:p-9 flex flex-col justify-center">
              <h3 class="text-2xl lg:text-[26px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-4">
                {q.title}
              </h3>
              <p class="text-[15px] lg:text-base text-[var(--color-text-body)] leading-relaxed">
                {q.body}
              </p>
            </div>

            <div class="lg:col-span-3 p-6 lg:p-7 bg-[var(--color-surface-light)] border-t lg:border-t-0 lg:border-l border-[var(--color-surface-border)] flex flex-col justify-center gap-3">
              <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)]">Stack / surfaces</div>
              <div class="flex flex-wrap gap-1.5">
                {q.chips.map((c) => (
                  <span class="text-[11px] font-mono px-2.5 py-1 rounded-md bg-white text-[var(--color-text-body)] border border-[var(--color-surface-border)]">{c}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- POURQUOI EN CONTINU : 4 constats en cartes bento -->
  <section class="relative section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(white_1px,transparent_1px)] [background-size:36px_36px] opacity-[0.025]"></div>
    <div class="absolute -top-32 left-[15%] w-[500px] h-[500px] rounded-full bg-[var(--color-brand-orange)]/[0.08] blur-[140px] pointer-events-none" data-float></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-5">
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Pourquoi en continu · 为什么要持续</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] mb-5">
          Les sites laissés en l’état deviennent invisibles.
        </h2>
        <p class="text-lg text-white/65 leading-relaxed">
          Les sites maintenus composent leurs gains. L’écart entre les deux se creuse vite.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5">
        {insightItems.map((p, i) => (
          <div
            data-reveal
            data-reveal-delay={String(i * 80)}
            class:list={[
              'group relative rounded-3xl bg-white/[0.03] border border-white/10 p-7 lg:p-8 overflow-hidden transition-all duration-300',
              'hover:bg-white/[0.06] hover:border-white/20 hover:-translate-y-0.5',
            ]}
          >
            <span aria-hidden="true" class="absolute -right-3 -bottom-6 text-[8rem] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/[0.06] leading-none select-none pointer-events-none transition-all duration-500 group-hover:text-[var(--color-brand-orange)]/[0.12] group-hover:scale-110 origin-bottom-right">{p.cn}</span>
            <div class="relative">
              <div class="flex items-center gap-3 mb-5">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-[var(--color-brand-orange)]/15 text-[var(--color-brand-orange)] text-sm font-semibold font-[var(--font-heading)]">
                  {p.n}
                </span>
                <span class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40">Constat {p.n} sur 04</span>
              </div>
              <h3 class="text-xl font-semibold font-[var(--font-heading)] text-white leading-tight mb-3">
                {p.title}
              </h3>
              <p class="text-base text-white/65 leading-relaxed">
                {p.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHIFFRES -->
  <section class="relative section-spacing bg-white overflow-hidden">
    <div class="absolute inset-0 [background-image:radial-gradient(var(--color-text-dark)_1px,transparent_1px)] [background-size:32px_32px] opacity-[0.04]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start mb-12">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-text-card-blue)]/10 border border-[var(--color-text-card-blue)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-card-blue)]">Chiffres du service · 数据</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
            Les chiffres tenus, chaque mois.
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-4 lg:mt-0" data-reveal data-reveal-delay="80">
          <p class="text-base text-[var(--color-text-body)] leading-relaxed">
            Inscrits dans le SLA. Visibles dans le tableau de bord en direct. Repris chaque mois dans une synthèse écrite.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-5">
        {stats.map((s, i) => (
          <div
            data-reveal
            data-reveal-delay={String(i * 90)}
            class:list={[
              'group relative rounded-3xl p-7 lg:p-8 transition-all duration-300 hover:-translate-y-1 overflow-hidden',
              i === 1
                ? 'bg-gradient-to-br from-[var(--color-brand-orange)] to-[#D14A1F] text-white hover:shadow-[0_24px_50px_-22px_rgba(242,95,41,0.4)]'
                : 'bg-[var(--color-surface-light)] border border-[var(--color-surface-border)] hover:shadow-[0_24px_50px_-22px_rgba(15,15,18,0.18)] hover:border-[var(--color-brand-orange)]/30',
            ]}
          >
            {i === 1 && <span aria-hidden="true" class="absolute -right-4 -bottom-8 text-[10rem] font-medium font-[var(--font-heading)] text-white/[0.08] leading-none select-none pointer-events-none">守</span>}
            <div class="relative">
              <div class:list={['text-[10px] font-mono uppercase tracking-[0.18em] mb-3', i === 1 ? 'text-white/75' : 'text-[var(--color-text-muted)]']}>{s.label}</div>
              <div class:list={['text-5xl lg:text-6xl font-medium font-[var(--font-heading)] leading-none mb-3', i === 1 ? 'text-white' : 'text-[var(--color-text-dark)]']}>
                {s.value}
              </div>
              <p class:list={['text-sm leading-relaxed', i === 1 ? 'text-white/90' : 'text-[var(--color-text-body)]']}>{s.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- POUR QUI -->
  <WhoIsThisFor heading="Qui nous contacte" audiences={audiences} background="light" />

  <!-- FAQ -->
  <section id="faq" class="section-spacing bg-white scroll-mt-32">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32" data-reveal="left">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-brand-orange)]/10 border border-[var(--color-brand-orange)]/20 mb-5">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)]">FAQ · 常见问题</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Huit questions qu’on nous pose sur la maintenance et l’accompagnement
          </h2>
          <p class="mt-6 text-base text-[var(--color-text-body)] leading-relaxed">
            Cliquez sur une question pour la déplier. Si la vôtre n’y est pas, posez-la-nous directement.
          </p>
          <div class="mt-7">
            <Button href="/fr/contact/" variant="secondary" size="md">Poser une autre question</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6" data-reveal="right">
          <div data-faq-accordion>
            {faqs.map((faq) => (
              <FAQItem question={faq.question} id={faq.id}>
                {faq.answer.map((para) => (
                  <p class="mb-3 last:mb-0">{para}</p>
                ))}
              </FAQItem>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA avec marquee -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="relative border-y border-white/10 bg-[#0f0f12] py-5 overflow-hidden">
      <div class="flex gap-10 animate-[marquee_45s_linear_infinite] whitespace-nowrap">
        {[...marqueePhrases, ...marqueePhrases, ...marqueePhrases].map((phrase) => (
          <span class="inline-flex items-center gap-3 text-base lg:text-lg font-medium text-white/40 hover:text-[var(--color-brand-orange)] transition-colors">
            {phrase}
            <span class="text-white/15">·</span>
          </span>
        ))}
      </div>
      <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#0f0f12] to-transparent pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#0f0f12] to-transparent pointer-events-none"></div>
    </div>

    <div class="relative py-20 lg:py-28">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[var(--color-brand-orange)]/10 rounded-full blur-[140px] pointer-events-none"></div>
      <span aria-hidden="true" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[24rem] lg:text-[30rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none">维</span>

      <div class="relative mx-auto max-w-[1400px] section-padding text-center" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/85">Ne le laissez pas filer</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[52px] font-medium font-[var(--font-heading)] text-white leading-[1.08] max-w-3xl mx-auto">
          Vous avez fait le plus dur. Ne le laissez pas filer.
        </h2>
        <p class="mt-6 text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
          Décrivez-nous votre situation. On revient avec un plan couvrant cadence éditoriale, actions SEO et GEO, maintenance technique et hébergement. Forfaits mensuels à partir de 1 200 USD, ajustés aux besoins réels du site.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
          <Button href="/fr/contact/" variant="primary" size="lg">Proposition sur mesure</Button>
          <Button href="/fr/services/china-hosting/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Options d’hébergement</Button>
          <Button href="/fr/services/baidu-seo/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">SEO Baidu</Button>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
