---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Maintenance et support WordPress en Chine | ChinaWebFoundry';
const metaDescription = 'Maintenance WordPress depuis la Chine : surveillance du Grand Pare-feu, suivi SEO Baidu, sécurité, sauvegardes et support réactif par une équipe qui opère depuis le territoire chinois.';

const includedItems = [
  {
    title: 'Maintenance préventive',
    body: 'Mises à jour du coeur WordPress, des extensions et des thèmes, testées en pré-production avant tout passage en ligne. Sauvegardes quotidiennes stockées hors site. Scans de sécurité en continu, 24 heures sur 24. Contrôles de disponibilité toutes les cinq minutes depuis des serveurs physiquement situés en Chine. Nettoyage régulier de la base de données. Surveillance et renouvellement SSL pour les configurations compatibles avec le marché chinois.',
    note: 'N\'importe quelle agence sérieuse propose une version de ces prestations. La différence, c\'est que nous vérifions tout depuis derrière le Grand Pare-feu. Pas depuis un centre de données en Virginie.',
  },
  {
    title: 'La couche Chine',
    body: 'Nous surveillons le comportement du Grand Pare-feu en temps réel. Quand un CDN, une bibliothèque de polices ou une API se retrouve bloqué, nous le détectons et mettons en place un remplacement compatible avant que vos statistiques ne révèlent les dégâts. Nous suivons les signaux de classement de Baidu et ajustons le référencement technique dès que les paramètres évoluent. Après chaque cycle de mise à jour, nous vérifions manuellement vos intégrations chinoises. Connexion WeChat, Alipay, outils d\'analyse locaux. Pour nous assurer que rien ne s\'est silencieusement cassé.',
    note: 'Votre agence habituelle ne peut tout simplement pas assurer cette partie. Elle aurait besoin d\'un VPN ne serait-ce que pour constater l\'existence du problème.',
  },
  {
    title: 'Dépannage',
    body: 'Quand quelque chose casse, notre équipe en Chine s\'en occupe sans délai. Pas question d\'attendre une demi-journée que quelqu\'un à l\'autre bout de la planète consulte ses courriels. Corrections de bogues, conflits d\'extensions, incidents de sécurité, problèmes de paiement WooCommerce avec Alipay ou WeChat Pay.',
    note: 'En cas de piratage : isolement, nettoyage, restauration, durcissement. Puis un véritable post-mortem pour que cela ne se reproduise pas.',
  },
  {
    title: 'Évolution du site',
    body: 'Nouvelles pages, modifications de design, demandes de fonctionnalités, ajustements SEO Baidu, nouvelles intégrations. Tout est géré dans le cadre de vos heures de support mensuelles. Nos recommandations s\'appuient sur des données de performance réelles collectées auprès d\'utilisateurs chinois, pas sur des articles de bonnes pratiques rédigés par quelqu\'un qui n\'a jamais eu affaire à Baidu.',
    note: '',
  },
];

const insightItems = [
  'Une seule ressource bloquée par le Grand Pare-feu peut faire sauter la mise en page de votre site pour l\'ensemble des visiteurs en Chine. Depuis vos bureaux à Paris ou Lyon, tout semble normal. Vous ne le saurez pas tant que quelqu\'un ne vous le signalera pas.',
  'Baidu récompense les sites techniquement bien entretenus. Négligez la maintenance pendant deux mois et votre positionnement s\'en ressentira. Les regagner prend beaucoup plus de temps que les conserver n\'en aurait demandé.',
  'WordPress hébergé en Chine fait face à des menaces de sécurité aux schémas spécifiquement régionaux. Des vecteurs d\'attaque pour lesquels vos extensions de sécurité occidentales n\'ont pas été conçues.',
  'Votre équipe informatique peut lancer des diagnostics depuis n\'importe où. Elle ne peut toujours pas voir ce qu\'un utilisateur à Canton vit réellement. Nous, si. Parce que nous sommes ici.',
];

const audiences = [
  { label: 'Pas d\'équipe sur place', description: 'Entreprises avec un site WordPress actif en Chine qui ont besoin d\'un support expert sans constituer une équipe locale.', image: '/images/audiences/wordpress-china-no-local-team.webp' },
  { label: 'Priorité au marketing', description: 'Directions marketing qui préfèrent se concentrer sur leurs campagnes plutôt que déboguer des conflits d\'extensions sur neuf fuseaux horaires.', image: '/images/audiences/marketing-not-debugging.webp' },
  { label: 'IT sans recrutement Chine', description: 'Équipes informatiques qui ont besoin d\'expertise WordPress en Chine mais ne peuvent pas justifier un poste à temps plein.', image: '/images/audiences/it-team-china-expertise.webp' },
  { label: 'WooCommerce en Chine', description: 'Entreprises e-commerce sous WooCommerce avec passerelles de paiement chinoises et logistique locale.', image: '/images/audiences/woocommerce-china-payments.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <!-- Hero -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-maintenance-support.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Maintenance et support</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">
            Maintenance et support
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Votre site WordPress en Chine a besoin de quelqu'un
            <span class="block mt-2 text-[var(--color-brand-orange)]">qui le surveille de l'intérieur</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Maintenance et support continus par une équipe qui opère véritablement derrière le Grand Pare-feu. Nous détectons les problèmes que votre équipe informatique internationale ne peut pas voir.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Parler à notre équipe</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">maintenance-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Statut pare-feu</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">RAS</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Dernière vérification</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">il y a 2h</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Scan de sécurité</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Validé</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Disponibilité (30 j)</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">99,98 %</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Sauvegardes</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">À jour</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Index Baidu</span>
                  <span class="text-sm font-semibold text-green-400 font-mono">Sain</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
            Une police Google est bloquée. Votre page d'accueil s'effondre. Personne dans vos bureaux ne s'en aperçoit.
          </h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Nous voyons cela plus souvent qu'on ne le souhaiterait. Le Grand Pare-feu bloque une police Google un mardi quelconque. Votre page d'accueil se désagrège pour tous les visiteurs à Shanghai, Shenzhen, Pékin. Votre équipe à Paris ? Aucune idée. De son côté, tout s'affiche normalement.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">
            Ce n'est pas un discours alarmiste. C'est juste la réalité du terrain. WordPress en Chine exige une vigilance permanente de la part de quelqu'un capable de voir ce que vos visiteurs chinois voient réellement. Le Grand Pare-feu ne prévient pas avant de bloquer quelque chose. Baidu remanie son algorithme et votre positionnement chute avant que quiconque ne s'en rende compte.
          </p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
            Une mise à jour d'extension qui passe sans encombre sur un hébergement américain ? Elle peut provoquer un problème totalement différent sur des serveurs chinois. Notre équipe travaille depuis la Chine. Nous testons depuis les réseaux chinois. Quand quelque chose casse à 3 heures du matin chez vous, nous sommes déjà dessus.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-surface-light)] to-white border border-[var(--color-surface-border)]">
            <div class="absolute inset-6 flex flex-col justify-center gap-6">
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-red-50 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">fonts.googleapis.com</div>
                  <div class="w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden">
                    <div class="w-full h-full bg-red-400 rounded-full"></div>
                  </div>
                  <div class="text-xs text-red-500 mt-1 font-medium">Bloqué par le Grand Pare-feu</div>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">Police de remplacement auto-hébergée</div>
                  <div class="w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden">
                    <div class="w-[12%] h-full bg-green-500 rounded-full"></div>
                  </div>
                  <div class="text-xs text-green-600 mt-1 font-medium">Remplacement effectué en 14 minutes</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Ce qui est inclus
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">
            Ce que nous faisons concrètement pour votre site
          </h2>
          <p class="mt-6 text-base text-[var(--color-text-body)] leading-relaxed">
            C'est là que la plupart des prestataires de maintenance WordPress ne peuvent tout simplement pas vous aider. Nous couvrons les fondamentaux et le travail spécifique à la Chine que personne d'autre ne peut assurer.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {includedItems.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">
                    {item.title}
                  </h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                    {item.body}
                  </p>
                  {item.note && (
                    <p class="mt-3 text-sm text-[var(--color-text-muted)] italic leading-relaxed">
                      {item.note}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Matters -->
  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
            Pourquoi c'est important
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">
            Plus que vous ne l'imaginez
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            {insightItems.map((item) => (
              <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6">
                <p class="text-base text-white/70 leading-relaxed">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui nous contacte pour la maintenance" audiences={audiences} background="light" />

  <!-- CTA -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">
        Lancez-vous
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">
        Le plus dur est fait. Ne laissez pas tout se dégrader maintenant.
      </h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Vous avez déjà accompli le travail de lancement d'un site WordPress pour la Chine. Ne laissez pas tout s'effriter parce que personne ne surveille depuis l'intérieur. Choisissez une formule, ou décrivez-nous simplement ce dont vous avez besoin.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Demander une proposition sur mesure</Button>
        <Button href="/fr/services/china-hosting/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Explorer les options d'hébergement</Button>
      </div>
    </div>
  </section>

</PageLayout>
