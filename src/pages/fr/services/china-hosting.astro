---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/global/ScrollEffects.astro';

const metaTitle = 'Hébergement Chine | Performance, licence ICP, infogérance';
const metaDescription = 'Un hébergement calibré pour la Chine continentale. Dépôt ICP instruit de bout en bout, CDN intégré, supervision opérée depuis Shanghai. Compatible WordPress, Astro et architectures headless.';

const proofStats = [
  { value: '0,8', suffix: ' s', label: 'Temps de chargement médian depuis le continent', sub: 'Mesuré sur smartphone chinois milieu de gamme, réseau Shanghai' },
  { value: '99,97', suffix: '%', label: 'Disponibilité observée sur les sites que nous hébergeons', sub: 'Moyenne glissante sur les 30 derniers jours' },
  { value: '100', suffix: '%', label: "Taux d'aboutissement des dossiers ICP", sub: 'Aucun dossier instruit par nos soins resté sur le carreau' },
  { value: '20', suffix: '+', label: 'Années de présence à Shanghai', sub: 'Même équipe, même bureau, depuis 2005' },
];

const sectionLinks = [
  { id: 'problem', label: 'Le constat' },
  { id: 'options', label: "Options d’hébergement" },
  { id: 'included', label: 'Prestations incluses' },
  { id: 'icp', label: 'Licence ICP' },
  { id: 'compliance', label: 'Conformité' },
  { id: 'timeline', label: 'Calendrier' },
  { id: 'performance', label: 'Performance' },
  { id: 'faq', label: 'FAQ' },
];

const hostingOptions = [
  {
    id: 'mainland',
    name: 'Chine continentale',
    tag: 'ICP requis',
    tagline: 'Serveurs à Pékin, Shanghai, Shenzhen ou Canton.',
    headline: 'L’option de référence. Chargements sous la seconde, levier Baidu à plein régime.',
    body: 'Votre site tourne sur des serveurs implantés en Chine continentale. Selon le profil du projet, le déploiement se fait chez Aliyun, Tencent Cloud ou Huawei Cloud. Trois fournisseurs que nous pratiquons depuis des années, dont nous connaissons les forces respectives à la virgule près.',
    detail: 'Les pages s’affichent sous la seconde. Baidu favorise nettement les sites sous licence ICP hébergés sur le continent, ce qui change la donne dès que le référencement entre en ligne de compte. Le dépôt ICP, nous l’instruisons également en interne. C’est typiquement l’étape sur laquelle les marques étrangères s’enlisent quand elles avancent sans relais local.',
    fit: 'Marques installées sur le marché chinois, projets à fort enjeu de référencement Baidu, plateformes e-commerce, sites qui collectent des données auprès d’utilisateurs chinois.',
    image: '/images/hosting-china-cdn-map.webp',
    imageAlt: 'Carte stylisée de la Chine continentale avec des nœuds de centres de données à Pékin, Shanghai, Shenzhen et Canton reliés par un maillage CDN',
    accent: 'orange',
    metrics: [
      { label: 'Chargement', value: '< 1 s' },
      { label: 'ICP', value: 'Requis' },
      { label: 'Effet Baidu', value: 'Fort' },
      { label: 'Mise en ligne', value: '6 à 10 sem.' },
    ],
  },
  {
    id: 'hong-kong',
    name: 'Hong Kong',
    tag: 'Sans ICP',
    tagline: 'Mise en ligne rapide, sans formalité administrative chinoise.',
    headline: 'Une passerelle vers le continent, en service immédiat.',
    body: 'Sans licence ICP en main, Hong Kong reste l’option la plus rapide à mettre en service. Aucun dossier à instruire, déploiement direct. Avec un CDN bien dimensionné et un cache calibré, les visiteurs chinois reçoivent la page en 2 à 4 secondes. Face à un site servi depuis Francfort ou la Virginie, le saut qualitatif est considérable.',
    detail: 'Cette configuration sert souvent de palier intermédiaire, le temps d’obtenir la licence ICP ou de décider d’une implantation pleine et entière sur le marché chinois. Certains clients de longue date sont restés à Hong Kong pendant des années sans jamais en éprouver les limites.',
    fit: 'Lancements rapides, solutions provisoires, projets pour lesquels la licence ICP n’est pas accessible immédiatement, marques en phase de test avant un engagement plus durable.',
    image: '/images/hosting-hong-kong-bridge.webp',
    imageAlt: 'Skyline de Hong Kong à l’heure bleue depuis Victoria Harbour, avec des traînées lumineuses orange traversant l’eau vers la Chine continentale',
    accent: 'sky',
    metrics: [
      { label: 'Chargement', value: '2 à 4 s' },
      { label: 'ICP', value: 'Pas requis' },
      { label: 'Effet Baidu', value: 'Faible' },
      { label: 'Mise en ligne', value: '2 à 3 sem.' },
    ],
  },
  {
    id: 'dual-stack',
    name: 'Dual-stack',
    tag: 'Mondial + Chine',
    tagline: 'Le continent pour les visiteurs chinois. Votre infrastructure mondiale pour le reste.',
    headline: 'Une marque, deux architectures, performance équivalente des deux côtés.',
    body: 'Certaines marques ne peuvent pas concentrer leurs investissements numériques sur la seule Chine. Le site doit fonctionner partout, avec le même niveau de service. Dans cette configuration, nous mettons en place un dispositif partagé : les visiteurs chinois sont routés vers un serveur continental, le reste du monde demeure servi par votre infrastructure existante.',
    detail: 'Le routage est piloté par le DNS, sans intervention manuelle. Un back-end unique alimente les deux faces, le contenu se synchronise automatiquement. Le site continental porte son propre dépôt ICP, le site international reste là où il opère déjà. Nous prenons en charge l’ensemble dans une même mission, et la rédaction ne pilote qu’un seul flux éditorial.',
    fit: 'Marques internationales dotées d’une véritable audience chinoise, plateformes e-commerce multinationales, sites pour lesquels la performance compte autant en Chine qu’en dehors.',
    image: '/images/hosting-dual-stack-globe.webp',
    imageAlt: 'Illustration 3D isométrique d’un globe avec deux grappes de serveurs lumineux (orange sur la Chine, cyan sur l’Occident) et des chemins de routage qui répartissent le trafic selon la géographie',
    accent: 'emerald',
    metrics: [
      { label: 'Chargement', value: '< 1 s en CN' },
      { label: 'ICP', value: 'Requis (CN)' },
      { label: 'Effet Baidu', value: 'Fort' },
      { label: 'Mise en ligne', value: '8 à 12 sem.' },
    ],
  },
];

const includedItems = [
  {
    icon: 'server',
    title: 'Mise en place et optimisation serveur',
    body: 'Serveur calibré pour votre pile applicative, certificat SSL adapté à l’environnement chinois, pare-feu et protection DDoS configurés au regard des contraintes du Grand Pare-feu.',
  },
  {
    icon: 'cdn',
    title: 'CDN Chine intégré',
    body: 'CDN Aliyun ou Tencent Cloud déployé en bonne et due forme. Vos fichiers statiques sont servis depuis des nœuds situés au plus près des visiteurs, à Shanghai ou Chengdu, sans détour par le Pacifique.',
  },
  {
    icon: 'monitor',
    title: 'Supervision depuis la Chine',
    body: 'La plupart des sondes mesurent la performance depuis l’extérieur du Grand Pare-feu, ce qui livre des tableaux de bord trompeurs. Notre supervision est conduite depuis la Chine, en condition réelle. Un point technique en apparence, qui modifie radicalement la lecture des indicateurs.',
  },
  {
    icon: 'backup',
    title: 'Sauvegardes quotidiennes et plan de reprise',
    body: 'Sauvegardes automatiques quotidiennes, stockage déporté, restauration à un instant donné, plan de reprise d’activité documenté. Parce qu’aucun système ne tient indéfiniment sans incident.',
  },
  {
    icon: 'document',
    title: 'Dépôt ICP instruit de bout en bout',
    body: 'Constitution du dossier, dépôt, échanges avec l’autorité provinciale jusqu’à la délivrance de la licence. À aucun moment vous n’ouvrez une console d’hébergement chinoise ni ne déchiffrez un formulaire en mandarin.',
  },
  {
    icon: 'wrench',
    title: 'Exploitation au long cours',
    body: 'Correctifs serveur, mises à jour de sécurité, dimensionnement à la hausse : tout reste à notre charge. Le site continue de tourner sans intervention de vos équipes.',
  },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Sites éditoriaux',
    timing: '20 jours ouvrés et plus',
    body: 'Site institutionnel, blog éditorial, vitrine en ligne : tout ce qui n’engage aucune transaction marchande. C’est le dépôt le plus fréquent chez les marques étrangères qui s’implantent en Chine.',
    docs: ['Immatriculation de la société', 'Attestation de propriété du nom de domaine', 'Pièce d’identité du responsable de la publication', 'Entité juridique enregistrée en Chine'],
  },
  {
    code: '经营许可证',
    name: 'Licence commerciale ICP',
    type: 'Activité marchande',
    timing: '2 à 3 mois',
    body: 'Sites transactionnels, plateformes e-commerce, services payants : tout ce qui implique un acte commercial. La procédure est plus longue, le dossier plus volumineux, l’instruction par l’autorité provinciale plus poussée.',
    docs: ['L’ensemble des pièces exigées pour le Bei\'an', 'Justification du périmètre d’activité', 'Vérification du capital social', 'Déclaration de finalité commerciale du site'],
  },
];

const complianceLaws = [
  {
    abbr: 'PIPL',
    name: 'Loi sur la protection des informations personnelles',
    body: 'Encadre la collecte, le stockage et le transfert des données personnelles des résidents chinois. Le texte chinois qui se rapproche le plus du RGPD européen.',
  },
  {
    abbr: 'CSL',
    name: 'Loi sur la cybersécurité',
    body: 'Texte fondateur du dispositif chinois, en vigueur depuis 2017. Il fixe les obligations des opérateurs de réseau, des infrastructures dites critiques et les règles de résidence des données.',
  },
  {
    abbr: 'DSL',
    name: 'Loi sur la sécurité des données',
    body: 'Classe les données par degré de sensibilité et impose un niveau de protection proportionné. Elle s’applique notamment au stockage et aux transferts transfrontaliers concernant les utilisateurs chinois.',
  },
];

const timelines = [
  {
    label: 'Hong Kong',
    title: 'Lancement Hong Kong',
    duration: '2 à 3 semaines',
    accent: 'sky',
    phases: [
      { name: 'Préparation', width: '40%' },
      { name: 'Configuration', width: '40%' },
      { name: 'Mise en ligne', width: '20%' },
    ],
    note: 'Sans dépôt ICP à instruire. C’est le calendrier le plus court pour ouvrir une présence en ligne à destination du marché chinois.',
  },
  {
    label: 'Chine continentale',
    title: 'Lancement continental',
    duration: '6 à 10 semaines',
    accent: 'orange',
    phases: [
      { name: 'Dépôt ICP', width: '50%' },
      { name: 'Développement (en parallèle)', width: '35%' },
      { name: 'Bascule', width: '15%' },
    ],
    note: 'Le dépôt ICP commande tout le calendrier. Il est lancé dès le premier jour, le développement est mené en parallèle pour ne pas perdre de temps.',
  },
  {
    label: 'Dual-stack',
    title: 'Lancement dual-stack',
    duration: '8 à 12 semaines',
    accent: 'emerald',
    phases: [
      { name: 'Architecture', width: '25%' },
      { name: 'Volet Chine + ICP', width: '45%' },
      { name: 'Routage + bascule', width: '30%' },
    ],
    note: 'Le calendrier dépend de la configuration mondiale en place. Le volet continental, lui, donne la cadence générale.',
  },
];

const performanceRows = [
  { location: 'États-Unis ou Europe', loadTime: 8, loadLabel: '8 à 15 secondes, voire au-delà', icp: 'Non', baiduBoost: 'Aucun', highlight: false },
  { location: 'Hong Kong', loadTime: 2.5, loadLabel: '2 à 4 secondes', icp: 'Non', baiduBoost: 'Faible', highlight: false },
  { location: 'Chine continentale', loadTime: 0.8, loadLabel: 'Sous la seconde', icp: 'Oui', baiduBoost: 'Fort', highlight: true },
];

const audiences = [
  { label: 'Lancement en Chine', description: 'Entreprises internationales qui ouvrent un nouveau site à destination du marché chinois.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Site lent depuis le continent', description: 'Entreprises dont le site actuel met 10 à 15 secondes à se charger pour les visiteurs venus de Chine continentale.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'Premier dépôt ICP', description: 'Équipes confrontées au dépôt ICP pour la première fois, et qui buttent sur la complexité du dossier ou son instruction administrative.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'E-commerce en règle', description: 'Marques en quête d’un hébergement performant, conforme à la réglementation chinoise et compatible avec les solutions de paiement locales.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];

const faqs = [
  {
    id: 'mainland-or-hk',
    question: 'Faut-il impérativement héberger sur le continent, ou peut-on rester à Hong Kong ?',
    answer: 'Hong Kong reste une option viable, en particulier pour un lancement transitoire. Reste que Baidu traite les sites hongkongais comme étrangers, avec une pénalité de classement bien réelle. Pour les marques qui s’installent en Chine sur le long terme, l’hébergement continental sous licence ICP demeure la voie la plus efficace.',
  },
  {
    id: 'aliyun-overseas',
    question: 'Une licence ICP reste-t-elle exigée sur la région internationale d’Aliyun ?',
    answer: 'Oui, dès lors que vous visez les serveurs continentaux d’Aliyun. L’opérateur dispose également de zones à Hong Kong et à Singapour, exemptes de licence ICP. Mais vous renoncez alors à la performance continentale et au gain de classement sur Baidu.',
  },
  {
    id: 'cost',
    question: 'Combien coûte un hébergement Chine ?',
    answer: 'Le coût dépend du trafic, du volume de stockage et du niveau d’infogérance retenu. La plupart des sites institutionnels rentrent dans une fourchette mensuelle stable, en pratique inférieure à un hébergement WordPress infogéré équivalent en Europe ou aux États-Unis. Communiquez-nous le périmètre, nous établissons un devis détaillé sous 2 jours ouvrés.',
  },
  {
    id: 'add-china',
    question: 'Peut-on conserver l’hébergement mondial existant et y adjoindre un volet Chine ?',
    answer: 'Oui, c’est précisément la logique du dispositif dual-stack. Votre site international reste à sa place, les visiteurs chinois sont redirigés vers un serveur continental, et les deux faces partagent les flux éditoriaux lorsque c’est pertinent.',
  },
  {
    id: 'providers',
    question: 'Avec quels fournisseurs travaillez-vous concrètement ?',
    answer: 'Aliyun, Tencent Cloud et Huawei Cloud, nos trois fournisseurs de référence. Aliyun s’impose le plus souvent pour les sites institutionnels, Tencent Cloud convient mieux aux projets profondément intégrés à WeChat, et Huawei Cloud revient régulièrement chez les clients déjà équipés en Huawei sur le reste de leur infrastructure.',
  },
  {
    id: 'icp-rejection',
    question: 'Que se passe-t-il si la demande d’ICP est rejetée ?',
    answer: 'Le rejet survient parfois, surtout lors d’un premier dépôt par une entité étrangère. Dans la grande majorité des cas, l’origine est une pièce manquante ou une incohérence dans l’immatriculation de la société. Nous instruisons alors une nouvelle soumission. À ce jour, l’ensemble des dossiers que nous avons portés ont fini par aboutir.',
  },
  {
    id: 'astro-headless',
    question: 'Peut-on héberger un site Astro ou headless en Chine ?',
    answer: 'Oui. Le build s’exécute hors de Chine sur un pipeline d’intégration continue, le rendu statique est poussé vers un serveur continental, et le site atteint des temps de chargement parmi les meilleurs de notre portefeuille. C’est une configuration que nous déployons régulièrement, sur Astro comme sur WordPress en mode headless.',
  },
  {
    id: 'data-privacy',
    question: 'L’hébergement continental est-il conforme aux lois chinoises sur la vie privée ?',
    answer: 'Pour les sites qui collectent des données auprès d’utilisateurs chinois, oui. Un hébergement continental sur un compte Aliyun ou Tencent Cloud correctement paramétré reste la voie la plus claire pour respecter la PIPL, la loi sur la cybersécurité et la loi sur la sécurité des données. L’architecture est conçue pour que les données personnelles ne quittent pas le territoire chinois.',
  },
  {
    id: 'hosting-panel',
    question: 'Faut-il administrer soi-même le panneau d’hébergement chinois ?',
    answer: 'Non. Nous tenons le compte d’hébergement, instruisons le dépôt ICP et assurons l’exploitation au quotidien. À aucun moment vous ne vous connectez à une interface en chinois ni ne déchiffrez un formulaire administratif. Vous recevez un site qui fonctionne et un rapport mensuel synthétique.',
  },
  {
    id: 'scaling',
    question: 'Que se passe-t-il quand le trafic monte ou que le site grossit ?',
    answer: 'L’hébergement est redimensionné en conséquence. Aliyun, Tencent et Huawei autorisent tous une montée en charge souple sur les formules que nous utilisons. Nous prenons en charge la mise à l’échelle, l’équilibrage de charge et les ajustements d’architecture nécessaires pour suivre l’évolution du trafic.',
  },
];

const accentMap: Record<string, { dot: string; bg: string; text: string; border: string; bar: string }> = {
  orange: {
    dot: 'bg-[var(--color-brand-orange)]',
    bg: 'bg-[var(--color-brand-orange)]/10',
    text: 'text-[var(--color-brand-orange)]',
    border: 'border-[var(--color-brand-orange)]/25',
    bar: 'bg-[var(--color-brand-orange)]',
  },
  sky: {
    dot: 'bg-sky-500',
    bg: 'bg-sky-500/10',
    text: 'text-sky-600',
    border: 'border-sky-500/25',
    bar: 'bg-sky-500',
  },
  emerald: {
    dot: 'bg-emerald-500',
    bg: 'bg-emerald-500/10',
    text: 'text-emerald-600',
    border: 'border-emerald-500/25',
    bar: 'bg-emerald-500',
  },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-hosting.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/95 via-[#0f0f12]/75 to-[#0f0f12]/35"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Hébergement Chine</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">Hébergement Chine · 中国主机</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-white leading-[1.05] tracking-tight">
            Un hébergement à la hauteur
            <span class="block mt-2 text-[var(--color-brand-orange)]">de la Chine continentale.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            Nous concevons et opérons un hébergement taillé pour l’internet chinois. Pages rapides, dépôt ICP instruit de bout en bout, CDN intégré, supervision conduite depuis la Chine. Quelle que soit la pile technique sur laquelle votre site tourne.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-[560px] leading-relaxed">
            Plus de 15 ans à Shanghai. 100 % d’aboutissement sur les dossiers ICP à ce jour.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/fr/contact/" variant="primary" size="lg">Demander une recommandation</Button>
            <a href="#options" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              Comparer les trois formules
              <span class="inline-block transition-transform group-hover:translate-y-0.5">↓</span>
            </a>
          </div>
        </div>

        <!-- Visual: server status card -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">statut-hébergement</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Emplacement serveur</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Shanghai</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Chargement (Chine)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">0,8 s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[8%] h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Disponibilité (30 j)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">99,97 %</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Statut ICP</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Actif</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Nœuds CDN</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">24 actifs</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/8 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
        {proofStats.map((stat, i) => (
          <div class:list={[
            'flex flex-col gap-3',
            i > 0 ? 'lg:pl-8 lg:border-l lg:border-[var(--color-surface-border)]' : '',
          ]}>
