---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import CaseStudyCards from '../../../components/ui/CaseStudyCards.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Hébergement WordPress en Chine : rapide, conforme ICP';
const metaDescription = 'Un hébergement WordPress taillé pour la Chine continentale. Serveurs, licence ICP, CDN et supervision pris en charge : votre site charge vite derrière le Grand Pare-feu.';

const includedItems = [
  {
    title: 'Configuration et optimisation serveur',
    body: 'Nous paramétrons votre environnement d\'hébergement sur mesure pour WordPress. Réglage fin de PHP et MySQL, OPcache, optimisation des requêtes, gestion mémoire. Certificats SSL compatibles avec les navigateurs chinois. Pare-feu serveur, détection d\'intrusion, protection DDoS. Du classique, mais calibré pour les conditions réelles du terrain chinois, qui diffèrent sensiblement de ce à quoi vous êtes habitué.',
  },
  {
    title: 'CDN chinois',
    body: 'Nous branchons Alibaba Cloud CDN, Tencent Cloud CDN ou la solution la mieux adaptée à votre projet. Vos images, vos scripts et vos fichiers statiques sont servis depuis des noeuds proches de vos visiteurs. Fini le détour par le Pacifique.',
  },
  {
    title: 'Supervision depuis la Chine',
    body: 'Le point qui surprend tout le monde : la plupart des outils de monitoring testent votre site depuis l\'extérieur du Grand Pare-feu. Tableau de bord au vert, pendant que vos vrais visiteurs à Shenzhen regardent tourner un sablier. Nous supervisons depuis la Chine. Un détail en apparence, qui change absolument tout.',
  },
  {
    title: 'Sauvegardes quotidiennes',
    body: 'Automatisées chaque nuit, stockées hors site. En cas d\'incident, nous restaurons le site à un instant précis. Nous tenons aussi à jour un plan de reprise documenté, parce qu\'une panne finit toujours par arriver et qu\'il vaut mieux avoir un protocole sous la main.',
  },
];

const hostingOptions = [
  {
    title: 'Hébergement Chine continentale (ICP requis)',
    body: 'La formule idéale. Votre site tourne sur des serveurs implantés à Pékin, Shanghai, Shenzhen ou Canton. Nous travaillons avec Alibaba Cloud, Tencent Cloud et Huawei Cloud. Des années de pratique nous ont donné la maîtrise de ces environnements, jusqu\'aux moindres paramètres.',
    details: 'Temps de chargement sous la seconde. Baidu réserve un bonus de classement notable aux sites dotés d\'une licence ICP et hébergés sur des serveurs locaux, un avantage majeur dès que le référencement naturel pèse dans votre stratégie chinoise. Nous pilotons aussi l\'intégralité du dépôt ICP : croyez-nous, c\'est précisément là que la plupart des entreprises s\'ensablent sans aide sur place.',
  },
  {
    title: 'Hébergement Hong Kong (sans ICP)',
    body: 'Pas encore de licence ICP ? Hong Kong vous met en ligne bien plus vite. Aucun dépôt requis. Avec un bon CDN et un cache bien réglé, comptez 2 à 4 secondes de chargement en Chine continentale. Moins rapide qu\'un hébergement continental, soit, mais comparé à un site servi depuis Francfort ou la Virginie, c\'est une autre planète.',
    details: 'Nous utilisons souvent cette formule comme solution transitoire, le temps que nos clients décrochent leur ICP.',
  },
  {
    title: 'Architecture double (dual-stack)',
    body: 'Certains clients ne peuvent pas se concentrer uniquement sur la Chine et oublier le reste du monde. Leur site doit performer partout. Pour ces cas-là, nous déployons une architecture scindée : les visiteurs en Chine tapent sur les serveurs locaux, tous les autres passent par votre infrastructure mondiale existante.',
    details: 'Le DNS gère le routage en coulisses. Un seul back-end WordPress alimente les deux environnements, le contenu se synchronise tout seul.',
  },
];

const performanceRows = [
  { location: 'États-Unis ou Europe', loadTime: '8 à 15 secondes, voire plus', icp: 'Non', baiduBoost: 'Aucun' },
  { location: 'Hong Kong', loadTime: '2 à 4 secondes', icp: 'Non', baiduBoost: 'Marginal' },
  { location: 'Chine continentale', loadTime: 'Moins d\'une seconde', icp: 'Oui', baiduBoost: 'Déterminant' },
];

const audiences = [
  { label: 'Nouveau site pour la Chine', description: 'Entreprises internationales qui lancent un site neuf destiné au marché chinois.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Lenteur depuis le continent', description: 'Entreprises dont le site existant rame lamentablement pour les visiteurs en Chine continentale.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'Premier dépôt ICP', description: 'Équipes qui affrontent pour la première fois le labyrinthe administratif de l\'ICP.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'E-commerce conforme', description: 'Marques en ligne qui cherchent un hébergement à la fois rapide et en règle avec la réglementation chinoise.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-hosting.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d'Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Hébergement en Chine</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Hébergement en Chine</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Un hébergement WordPress qui tient la route
            <span class="block mt-2 text-[var(--color-brand-orange)]">en Chine continentale</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Nous déployons et pilotons un hébergement conçu pour l'internet chinois. Chargement éclair, accompagnement ICP, CDN paramétré, conformité complète. Nous absorbons la complexité pour que votre site tourne, point final.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/fr/contact/" variant="primary" size="lg">Découvrir les options d'hébergement</Button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">hosting-status</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between"><span class="text-sm text-white/50">Localisation serveur</span><span class="text-sm font-semibold text-green-400 font-mono">Shanghai</span></div>
                <div class="flex items-center justify-between pt-2"><span class="text-sm text-white/50">Temps de chargement (Chine)</span><span class="text-sm font-semibold text-green-400 font-mono">0,8s</span></div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden"><div class="w-[8%] h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div></div>
                <div class="flex items-center justify-between pt-2"><span class="text-sm text-white/50">Disponibilité (30j)</span><span class="text-sm font-semibold text-green-400 font-mono">99,97 %</span></div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden"><div class="w-full h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full"></div></div>
                <div class="flex items-center justify-between pt-2"><span class="text-sm text-white/50">Statut ICP</span><span class="text-sm font-semibold text-green-400 font-mono">Actif</span></div>
                <div class="flex items-center justify-between pt-2"><span class="text-sm text-white/50">Noeuds CDN</span><span class="text-sm font-semibold text-green-400 font-mono">24 actifs</span></div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/5 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-center">
        <div class="col-span-12 lg:col-span-6 mb-10 lg:mb-0">
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">Votre site ne charge probablement pas en Chine</h2>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">Essayez de l'ouvrir depuis Shanghai. Vous fixez un écran blanc pendant dix secondes. Quinze. Parfois rien du tout.</p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed mb-5">C'est le Grand Pare-feu. Il ralentit et bloque le trafic venu des serveurs étrangers. Les Google Fonts restent fantômes. Les poignées de main SSL expirent en route. Le CDN que vous payez ? Bridé, ou tout simplement coupé.</p>
          <p class="text-lg text-[var(--color-text-body)] leading-relaxed">Nous travaillons sur le terrain depuis plus de vingt ans et c'est, de loin, le problème le plus répandu chez les entreprises internationales. Votre site file comme un TGV à New York. À Pékin, il est quasi hors service.</p>
        </div>
        <div class="col-span-12 lg:col-span-5 lg:col-start-8">
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-[var(--color-surface-light)] to-white border border-[var(--color-surface-border)]">
            <div class="absolute inset-3 sm:inset-6 flex flex-col justify-center gap-4 sm:gap-6">
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-red-50 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">Serveur US/EU</div>
                  <div class="w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden"><div class="w-[85%] h-full bg-red-400 rounded-full"></div></div>
                  <div class="text-xs text-[var(--color-text-muted)] mt-1">12,4s de chargement</div>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-[var(--color-brand-orange)]/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[var(--color-brand-orange)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[var(--color-text-dark)] mb-1">Serveur Chine</div>
                  <div class="w-full h-2 bg-[var(--color-surface-border)] rounded-full overflow-hidden"><div class="w-[8%] h-full bg-green-500 rounded-full"></div></div>
                  <div class="text-xs text-[var(--color-text-muted)] mt-1">0,8s de chargement</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Options d'hébergement</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">Trois manières d'héberger votre site WordPress</h2>
      </div>
      <CaseStudyCards items={hostingOptions} />
    </div>
  </section>

  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-5 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Ce qui est compris</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">Compris dans chaque formule</h2>
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-6">
            {includedItems.map((item) => (
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-2.5 h-2.5 mt-2 rounded-full bg-[var(--color-brand-orange)]"></div>
                <div class="flex-1 pb-6 border-b border-[var(--color-surface-border)]">
                  <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">{item.title}</h3>
                  <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">{item.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start">
        <div class="col-span-12 lg:col-span-4 mb-12 lg:mb-0 lg:sticky lg:top-32">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Licence ICP</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight">Le passage obligé que personne n'aime</h2>
        </div>
        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <div class="space-y-6">
            <p class="text-base text-white/70 leading-relaxed">Pour héberger votre site sur des serveurs en Chine continentale, l'ICP est incontournable. Pas de raccourci, pas d'exception. Sans licence, l'hébergeur met le site hors ligne. Et il ne vous prévient pas : il s'éteint, fin de la discussion.</p>
            <p class="text-base text-white/70 leading-relaxed">Il en existe deux. L'ICP Bei'an (备案) couvre les sites informatifs : site vitrine, blog, pages institutionnelles. Si le vôtre traite des transactions ou une activité commerciale, il vous faudra la licence complète (经营许可证), dont le parcours est nettement plus long.</p>
            <p class="text-base text-white/70 leading-relaxed">Nous prenons tout en charge. Identifier le type applicable, réunir les pièces (enregistrement commercial, certificats de domaine, pièce d'identité du responsable), déposer le dossier, relancer quand la procédure s'enlise. Comptez deux à quatre semaines pour un Bei'an. Deux à trois mois pour une licence commerciale, parfois davantage.</p>
            <p class="text-base text-white/70 leading-relaxed">Un point capital : il faut disposer d'une entité commerciale immatriculée en Chine pour lancer la démarche. Si vous n'en avez pas, pas de panique : nous vous orientons vers les solutions de repli.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Performance</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight">Où vos serveurs tournent change tout</h2>
      </div>
      <div class="max-w-4xl mx-auto">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b-2 border-[var(--color-surface-border)]">
                <th class="py-4 pr-6 text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">Lieu d'hébergement</th>
                <th class="py-4 pr-6 text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">Temps de chargement en Chine</th>
                <th class="py-4 pr-6 text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">ICP requis ?</th>
                <th class="py-4 text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">Bonus SEO Baidu</th>
              </tr>
            </thead>
            <tbody>
              {performanceRows.map((row, i) => (
                <tr class:list={['border-b border-[var(--color-surface-border)]', i === performanceRows.length - 1 ? 'bg-[var(--color-brand-orange)]/5' : '']}>
                  <td class="py-4 pr-6 text-base font-medium text-[var(--color-text-dark)]">{row.location}</td>
                  <td class:list={['py-4 pr-6 text-base font-semibold', i === performanceRows.length - 1 ? 'text-[var(--color-brand-orange)]' : 'text-[var(--color-text-body)]']}>{row.loadTime}</td>
                  <td class="py-4 pr-6 text-base text-[var(--color-text-body)]">{row.icp}</td>
                  <td class:list={['py-4 text-base font-semibold', i === performanceRows.length - 1 ? 'text-[var(--color-brand-orange)]' : 'text-[var(--color-text-body)]']}>{row.baiduBoost}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-8 text-base text-[var(--color-text-body)] leading-relaxed text-center max-w-2xl mx-auto">
          Douze secondes de chargement, ce n'est pas un site lent. C'est un site que personne ne verra. Les internautes chinois attendent des pages véloces et claquent la porte dès qu'elles rament.
        </p>
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui nous sollicite pour l'hébergement" audiences={audiences} footnote="Pas besoin de comprendre la mécanique technique de tout cela. C'est notre métier. Notre équipe est implantée en Chine, nous faisons ce travail depuis plus de vingt ans, et nous prenons tout en charge pour que vous puissiez vous consacrer à l'essentiel de votre activité." background="light" />

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden py-24 lg:py-32">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-brand-orange)]/5 rounded-full blur-3xl"></div>
    <div class="relative mx-auto max-w-[1400px] section-padding text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-4">Passez à l'action</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-tight max-w-3xl mx-auto">Parlons de votre configuration</h2>
      <p class="mt-6 text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">Chaque projet a ses singularités : votre calendrier, votre avancée ICP, votre public cible, votre enveloppe budgétaire. Racontez-nous votre situation et nous vous livrerons une recommandation d'hébergement taillée sur mesure. Pas de propositions passe-partout.</p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/fr/contact/" variant="primary" size="lg">Obtenir une recommandation d'hébergement</Button>
        <Button href="/fr/services/china-migration/" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">En savoir plus sur la licence ICP</Button>
      </div>
    </div>
  </section>

</PageLayout>
