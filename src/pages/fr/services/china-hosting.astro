---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';
import ScrollEffects from '../../../components/global/ScrollEffects.astro';

const metaTitle = 'Hébergement Chine | Rapide, sous licence ICP, géré';
const metaDescription = 'Un hébergement qui tient vraiment en Chine continentale. Dépôt ICP géré de bout en bout, CDN configuré, supervision depuis Shanghai. Compatible WordPress, Astro ou architectures headless.';

const proofStats = [
  { value: '0,8', suffix: ' s', label: 'Temps de chargement médian sur serveur continental', sub: 'Téléphone chinois milieu de gamme, connexion Shanghai' },
  { value: '99,97', suffix: '%', label: 'Disponibilité sur les sites que nous hébergeons', sub: 'Moyenne glissante sur 30 jours' },
  { value: '100', suffix: '%', label: 'Taux de réussite des dépôts ICP', sub: 'Tous nos dossiers ont fini par passer' },
  { value: '20', suffix: '+', label: 'Ans de présence à Shanghai', sub: 'Même équipe, même ville, depuis 2005' },
];

const sectionLinks = [
  { id: 'problem', label: 'Le problème' },
  { id: 'options', label: 'Options d’hébergement' },
  { id: 'included', label: 'Inclus' },
  { id: 'icp', label: 'Licence ICP' },
  { id: 'compliance', label: 'Conformité données' },
  { id: 'timeline', label: 'Calendrier' },
  { id: 'performance', label: 'Performance' },
  { id: 'faq', label: 'FAQ' },
];

const hostingOptions = [
  {
    id: 'mainland',
    name: 'Chine continentale',
    tag: 'ICP requis',
    tagline: 'Serveurs à Pékin, Shanghai, Shenzhen ou Canton.',
    headline: 'La vraie option. Chargements sous la seconde, plein effet Baidu.',
    body: 'Votre site vit sur des serveurs implantés en Chine continentale. Selon le projet, on déploie chez Aliyun, Tencent Cloud ou Huawei Cloud. On travaille avec les trois depuis des années et on sait précisément ce que chacun apporte.',
    detail: 'Les temps de chargement passent sous la seconde. Baidu accorde un coup de pouce sensible aux sites titulaires d’une licence ICP hébergés sur le continent, et cela pèse fort dès que le SEO entre dans la stratégie. Le dépôt ICP, on le porte aussi de bout en bout. Honnêtement, c’est sur cette étape que la plupart des marques étrangères se retrouvent coincées sans appui local.',
    fit: 'Marques engagées sur le marché chinois, projets ambitieux sur Baidu, e-commerce, sites qui collectent des données d’utilisateurs chinois.',
    image: '/images/hosting-china-cdn-map.webp',
    imageAlt: 'Carte stylisée de la Chine continentale avec des nœuds de centres de données à Pékin, Shanghai, Shenzhen et Canton reliés par un maillage CDN',
    accent: 'orange',
    metrics: [
      { label: 'Chargement', value: '< 1 s' },
      { label: 'ICP', value: 'Requis' },
      { label: 'Effet Baidu', value: 'Fort' },
      { label: 'Mise en ligne', value: '6 à 10 sem.' },
    ],
  },
  {
    id: 'hong-kong',
    name: 'Hong Kong',
    tag: 'Sans ICP',
    tagline: 'Mise en ligne rapide, sans dépôt gouvernemental.',
    headline: 'Un pont vers le continent. Rapide à mettre en route.',
    body: 'Pas encore de licence ICP ? Hong Kong met en ligne plus vite, sans dépôt à porter. Avec le bon CDN et un cache bien configuré, on tient 2 à 4 secondes de chargement en Chine continentale. Comparé à un site servi depuis Francfort ou la Virginie, c’est un autre monde.',
    detail: 'On utilise souvent cette option comme étape intermédiaire, le temps que le client obtienne son ICP ou décide de s’engager pleinement sur le marché. Certains clients de longue date sont restés sur Hong Kong sans jamais ressentir le besoin d’en partir.',
    fit: 'Lancements rapides, solutions transitoires, projets pour lesquels l’ICP n’est pas accessible tout de suite, marques qui testent le marché chinois avant de s’engager.',
    image: '/images/hosting-hong-kong-bridge.webp',
    imageAlt: 'Skyline de Hong Kong à l’heure bleue depuis Victoria Harbour, avec des traînées lumineuses orange traversant l’eau vers la Chine continentale',
    accent: 'sky',
    metrics: [
      { label: 'Chargement', value: '2 à 4 s' },
      { label: 'ICP', value: 'Pas requis' },
      { label: 'Effet Baidu', value: 'Faible' },
      { label: 'Mise en ligne', value: '2 à 3 sem.' },
    ],
  },
  {
    id: 'dual-stack',
    name: 'Dual-stack',
    tag: 'Mondial + Chine',
    tagline: 'Continental pour les visiteurs chinois. Pile mondiale existante pour le reste.',
    headline: 'Une marque, deux architectures, rapides des deux côtés.',
    body: 'Certains clients ne peuvent pas tout miser sur la Chine et oublier le reste du monde. Le site doit fonctionner partout, dans des conditions équivalentes. Pour ces cas, on monte un dispositif partagé : les visiteurs venus de Chine atterrissent sur un serveur continental, les autres restent sur votre infrastructure mondiale existante.',
    detail: 'Le DNS gère le routage automatiquement. Un seul back-end alimente les deux côtés, le contenu se synchronise. Le site Chine porte son propre dépôt ICP, le site mondial reste là où il vit déjà. On gère les deux faces dans la même mission, et l’équipe éditoriale ne suit qu’un seul flux.',
    fit: 'Marques globales avec une vraie audience chinoise, e-commerce multinational, sites pour lesquels ni la Chine ni le reste du monde ne peuvent être relégués au second plan.',
    image: '/images/hosting-dual-stack-globe.webp',
    imageAlt: 'Illustration 3D isométrique d’un globe avec deux grappes de serveurs lumineux (orange sur la Chine, cyan sur l’Occident) et des chemins de routage qui répartissent le trafic selon la géographie',
    accent: 'emerald',
    metrics: [
      { label: 'Chargement', value: '< 1 s en CN' },
      { label: 'ICP', value: 'Requis (CN)' },
      { label: 'Effet Baidu', value: 'Fort' },
      { label: 'Mise en ligne', value: '8 à 12 sem.' },
    ],
  },
];

const includedItems = [
  {
    icon: 'server',
    title: 'Mise en place et optimisation serveur',
    body: 'Hébergement calibré pour votre pile, certificat SSL compatible avec la Chine, pare-feu serveur et protection DDoS configurés pour la réalité du Grand Pare-feu.',
  },
  {
    icon: 'cdn',
    title: 'CDN Chine configuré',
    body: 'CDN Aliyun ou Tencent Cloud branché. Vos ressources statiques sont servies depuis des nœuds proches de vos utilisateurs à Shanghai ou Chengdu, sans rebondir par le Pacifique.',
  },
  {
    icon: 'monitor',
    title: 'Supervision depuis la Chine',
    body: 'La plupart des outils mesurent depuis l’extérieur du Grand Pare-feu, ce qui fait mentir les tableaux de bord. On supervise depuis l’intérieur. Petit détail en apparence, qui change tout en pratique.',
  },
  {
    icon: 'backup',
    title: 'Sauvegardes quotidiennes et plan de reprise',
    body: 'Sauvegardes automatiques quotidiennes, stockage hors site, restauration à un instant donné, plan de reprise documenté. Parce que les choses cassent, parfois.',
  },
  {
    icon: 'document',
    title: 'Dépôt ICP géré de bout en bout',
    body: 'Constitution du dossier, soumissions, va-et-vient avec l’autorité provinciale. Vous ne vous connectez jamais à une console d’hébergement chinoise et ne lisez aucun formulaire en chinois.',
  },
  {
    icon: 'wrench',
    title: 'Maintenance continue',
    body: 'Correctifs serveur, mises à jour de sécurité et montée en charge restent de notre côté. Le site continue de tourner sans que vous ayez à y penser.',
  },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Sites informationnels',
    timing: '20+ jours ouvrés',
    body: 'Site institutionnel, blog, plaquette en ligne : tout ce qui n’implique aucune transaction. Le dépôt le plus courant chez les marques étrangères qui se lancent en Chine.',
    docs: ['Immatriculation de l’entreprise', 'Certificat de domaine', 'Pièce d’identité de l’admin du site', 'Entité chinoise enregistrée'],
  },
  {
    code: '经营许可证',
    name: 'Licence commerciale ICP',
    type: 'Activité commerciale',
    timing: '2 à 3 mois',
    body: 'Sites transactionnels, e-commerce, services payants : tout ce qui relève du commerce. Procédure plus longue, plus de pièces à fournir, examen approfondi par l’autorité provinciale.',
    docs: ['Tout ce qui est requis pour le Bei\'an', 'Examen du périmètre d’activité', 'Vérification du capital', 'Déclaration de finalité commerciale'],
  },
];

const complianceLaws = [
  {
    abbr: 'PIPL',
    name: 'Loi sur la protection des informations personnelles',
    body: 'Encadre le traitement, le stockage et le transfert des données personnelles des résidents chinois. Le pendant chinois le plus proche du RGPD.',
  },
  {
    abbr: 'CSL',
    name: 'Loi sur la cybersécurité',
    body: 'Texte fondateur depuis 2017. Pose les règles pour les opérateurs de réseau, les infrastructures critiques et la résidence des données.',
  },
  {
    abbr: 'DSL',
    name: 'Loi sur la sécurité des données',
    body: 'Classe les données par niveau de sensibilité et impose une protection graduée. Touche le stockage et les transferts transfrontaliers de données d’utilisateurs chinois.',
  },
];

const timelines = [
  {
    label: 'Hong Kong',
    title: 'Lancement Hong Kong',
    duration: '2 à 3 semaines',
    accent: 'sky',
    phases: [
      { name: 'Préparation', width: '40%' },
      { name: 'Configuration', width: '40%' },
      { name: 'Mise en ligne', width: '20%' },
    ],
    note: 'Sans dépôt ICP. Le chemin le plus court pour ouvrir une présence en ligne destinée au marché chinois.',
  },
  {
    label: 'Chine continentale',
    title: 'Lancement continental',
    duration: '6 à 10 semaines',
    accent: 'orange',
    phases: [
      { name: 'Dépôt ICP', width: '50%' },
      { name: 'Build (parallèle)', width: '35%' },
      { name: 'Bascule', width: '15%' },
    ],
    note: 'L’ICP se trouve sur le chemin critique. On lance le dépôt dès le premier jour et on mène le reste de la construction en parallèle.',
  },
  {
    label: 'Dual-stack',
    title: 'Lancement dual-stack',
    duration: '8 à 12 semaines',
    accent: 'emerald',
    phases: [
      { name: 'Architecture', width: '25%' },
      { name: 'Côté CN + ICP', width: '45%' },
      { name: 'Routage + bascule', width: '30%' },
    ],
    note: 'Tout dépend de la configuration mondiale actuelle. La moitié continentale dicte le calendrier.',
  },
];

const performanceRows = [
  { location: 'États-Unis ou Europe', loadTime: 8, loadLabel: '8 à 15+ secondes', icp: 'Non', baiduBoost: 'Aucun', highlight: false },
  { location: 'Hong Kong', loadTime: 2.5, loadLabel: '2 à 4 secondes', icp: 'Non', baiduBoost: 'Faible', highlight: false },
  { location: 'Chine continentale', loadTime: 0.8, loadLabel: 'Sous la seconde', icp: 'Oui', baiduBoost: 'Fort', highlight: true },
];

const audiences = [
  { label: 'Lancement chinois', description: 'Sociétés internationales qui montent un site neuf pour le marché chinois.', image: '/images/audiences/new-site-for-china.webp' },
  { label: 'Site lent depuis le continent', description: 'Entreprises avec un site existant qui rame sévèrement pour les visiteurs venus de Chine continentale.', image: '/images/audiences/slow-site-mainland.webp' },
  { label: 'Premier ICP', description: 'Équipes qui affrontent le dépôt ICP pour la première fois et trouvent le dossier obscur ou enlisé.', image: '/images/audiences/icp-paperwork-first-time.webp' },
  { label: 'E-commerce conforme', description: 'Marques qui veulent un hébergement rapide, conforme à la réglementation chinoise et compatible avec l’écosystème de paiement local.', image: '/images/audiences/ecommerce-compliant-hosting.webp' },
];

const faqs = [
  {
    id: 'mainland-or-hk',
    question: 'On est obligé de passer par un hébergement continental, ou on peut rester à Hong Kong ?',
    answer: 'Hong Kong reste possible, surtout pour un lancement provisoire. Mais Baidu traite les sites de Hong Kong comme étrangers et la pénalité de classement existe vraiment. Pour les marques qui visent le marché chinois sur la durée, l’hébergement continental avec dépôt ICP est le bon choix.',
  },
  {
    id: 'aliyun-overseas',
    question: 'Faut-il un ICP si on héberge sur la région internationale d’Aliyun ?',
    answer: 'Oui, si vous voulez le site sur les serveurs continentaux d’Aliyun. Aliyun exploite aussi des serveurs à Hong Kong et à Singapour, qui n’exigent pas d’ICP, mais vous perdez la performance continentale et le coup de pouce Baidu.',
  },
  {
    id: 'cost',
    question: 'Combien coûte un hébergement Chine ?',
    answer: 'Cela dépend du trafic, du stockage et du niveau d’infogérance qu’on ajoute par-dessus. La plupart des sites marketing tombent dans une fourchette mensuelle prévisible, en pratique inférieure à un hébergement WordPress géré équivalent en Occident. Donnez-nous le périmètre et nous renvoyons un devis réel sous deux jours ouvrés.',
  },
  {
    id: 'add-china',
    question: 'On peut garder notre hébergement mondial actuel et juste y greffer la Chine ?',
    answer: 'Oui, c’est exactement le dispositif dual-stack. Votre site mondial reste où il est, les visiteurs chinois sont routés vers un serveur continental, et les deux partagent les flux éditoriaux quand cela fait sens.',
  },
  {
    id: 'providers',
    question: 'Quels fournisseurs utilisez-vous concrètement ?',
    answer: 'Aliyun, Tencent Cloud et Huawei Cloud, nos trois piliers. Aliyun reste le choix par défaut pour les sites marketing, Tencent Cloud excelle sur les sites profondément intégrés à WeChat, et Huawei Cloud revient plus souvent chez les clients qui utilisent déjà Huawei ailleurs dans leur infrastructure.',
  },
  {
    id: 'icp-rejection',
    question: 'Que se passe-t-il si la demande d’ICP est rejetée ?',
    answer: 'Cela arrive, surtout sur un premier dépôt étranger. C’est généralement un problème de pièces ou un détail manquant dans l’immatriculation de l’entreprise. On gère la nouvelle soumission. Tous les ICP que nous avons déposés ont fini par passer.',
  },
  {
    id: 'astro-headless',
    question: 'Peut-on héberger un site Astro ou headless en Chine ?',
    answer: 'Oui. Le build tourne hors de Chine sur un pipeline CI, la sortie statique est poussée vers un serveur continental, et le site se charge aussi vite que tout ce que nous avons livré. On le fait régulièrement avec Astro et avec des configurations WordPress en headless.',
  },
  {
    id: 'data-privacy',
    question: 'L’hébergement continental est-il conforme aux lois chinoises sur la vie privée ?',
    answer: 'Pour les sites qui collectent des données auprès d’utilisateurs chinois, oui. Un hébergement continental sur un compte Aliyun ou Tencent Cloud correctement configuré est le chemin le plus propre pour respecter la PIPL, la Loi sur la cybersécurité et la Loi sur la sécurité des données. On configure l’architecture pour que les données personnelles restent dans le pays.',
  },
  {
    id: 'hosting-panel',
    question: 'Faut-il gérer soi-même le panneau d’hébergement chinois ?',
    answer: 'Non. On opère le compte d’hébergement, le dépôt ICP et le travail serveur au quotidien. Vous ne vous connectez à rien en chinois, vous ne lisez aucun formulaire incompréhensible. Vous récupérez juste un site qui tient et un rapport mensuel.',
  },
  {
    id: 'scaling',
    question: 'Que se passe-t-il quand le trafic monte ou que le site grossit ?',
    answer: 'On dimensionne l’hébergement à la hausse. Aliyun, Tencent et Huawei prennent tous en charge la mise à l’échelle souple sur les offres que nous utilisons. On gère le redimensionnement, l’équilibrage de charge et les changements d’architecture nécessaires pour suivre.',
  },
];

const accentMap: Record<string, { dot: string; bg: string; text: string; border: string; bar: string }> = {
  orange: {
    dot: 'bg-[var(--color-brand-orange)]',
    bg: 'bg-[var(--color-brand-orange)]/10',
    text: 'text-[var(--color-brand-orange)]',
    border: 'border-[var(--color-brand-orange)]/25',
    bar: 'bg-[var(--color-brand-orange)]',
  },
  sky: {
    dot: 'bg-sky-500',
    bg: 'bg-sky-500/10',
    text: 'text-sky-600',
    border: 'border-sky-500/25',
    bar: 'bg-sky-500',
  },
  emerald: {
    dot: 'bg-emerald-500',
    bg: 'bg-emerald-500/10',
    text: 'text-emerald-600',
    border: 'border-emerald-500/25',
    bar: 'bg-emerald-500',
  },
};
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-china-hosting.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/95 via-[#0f0f12]/75 to-[#0f0f12]/35"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-16 md:pb-20">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/#OurServices" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Hébergement Chine</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">Hébergement Chine · 中国主机</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[64px] font-medium font-[var(--font-heading)] text-white leading-[1.05] tracking-tight">
            Un hébergement qui tient
            <span class="block mt-2 text-[var(--color-brand-orange)]">en Chine continentale.</span>
          </h1>

          <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-[560px] leading-relaxed">
            On monte et on opère un hébergement taillé pour l’internet chinois. Chargements rapides, dépôt ICP géré de bout en bout, CDN configuré, supervision depuis l’intérieur de la Chine. Quelle que soit la pile sur laquelle tourne votre site.
          </p>
          <p class="mt-4 text-base text-white/40 max-w-[560px] leading-relaxed">
            15+ ans à Shanghai. 100 % de réussite sur les ICP à ce jour.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-5">
            <Button href="/fr/contact/" variant="primary" size="lg">Voir les hébergements</Button>
            <a href="#options" class="group inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors">
              Comparer les trois formules
              <span class="inline-block transition-transform group-hover:translate-y-0.5">↓</span>
            </a>
          </div>
        </div>

        <!-- Visual: server status card -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9 mt-12 lg:mt-0">
          <div class="relative">
            <div class="bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-xs text-white/30 ml-2 font-mono">statut-hébergement</span>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-white/50">Emplacement serveur</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Shanghai</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Chargement (Chine)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">0,8 s</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-[8%] h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Disponibilité (30 j)</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">99,97 %</span>
                </div>
                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Statut ICP</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">Actif</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                  <span class="text-sm text-white/50">Nœuds CDN</span>
                  <span class="text-sm font-semibold text-emerald-400 font-mono">24 actifs</span>
                </div>
              </div>
            </div>
            <div class="absolute -inset-4 bg-[var(--color-brand-orange)]/8 rounded-3xl blur-2xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="border-y border-[var(--color-surface-border)] bg-white">
    <div class="mx-auto max-w-[1400px] section-padding py-14 lg:py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
        {proofStats.map((stat, i) => (
          <div class:list={[
            'flex flex-col gap-3',
            i > 0 ? 'lg:pl-8 lg:border-l lg:border-[var(--color-surface-border)]' : '',
          ]}>
            <div class="text-5xl lg:text-[60px] font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)] leading-none tabular-nums" data-count={stat.value} data-count-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div>
              <p class="text-sm lg:text-base text-[var(--color-text-dark)] leading-snug font-medium">
                {stat.label}
              </p>
              <p class="mt-1 text-xs lg:text-sm text-[var(--color-text-muted)]">
                {stat.sub}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STICKY SUB-NAV: jump to section -->
  <nav aria-label="Sections de la page" class="sticky top-[64px] lg:top-[72px] z-30 bg-white/85 backdrop-blur-md border-b border-[var(--color-surface-border)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="overflow-x-auto -mx-1">
        <ul class="flex items-center gap-1 py-3 px-1 whitespace-nowrap">
          {sectionLinks.map((link) => (
            <li>
