---
import PageLayout from '../../../layouts/PageLayout.astro';
import Button from '../../../components/ui/Button.astro';
import FAQItem from '../../../components/pages/FAQItem.astro';
import WhoIsThisFor from '../../../components/pages/WhoIsThisFor.astro';

const metaTitle = 'Hébergement Chine | Rapide, sous licence ICP, géré';
const metaDescription = 'Un hébergement qui tient en Chine continentale. Dépôt ICP géré, CDN configuré, supervision depuis Shanghai. WordPress, Astro ou headless.';

const proofStats = [
  { value: '0,8', suffix: ' s', label: 'Temps de chargement médian sur serveur continental', sub: 'Téléphone chinois milieu de gamme, connexion Shanghai' },
  { value: '99,97', suffix: '%', label: 'Disponibilité sur les sites que nous hébergeons', sub: 'Moyenne glissante sur 30 jours' },
  { value: '100', suffix: '%', label: 'Taux de réussite des dépôts ICP', sub: 'Tous nos dossiers ont fini par passer' },
  { value: '20', suffix: '+', label: 'Ans de présence à Shanghai', sub: 'Même équipe, même ville, depuis 2005' },
];

const hostingOptions = [
  {
    name: 'Chine continentale',
    tag: 'ICP requis',
    tagline: 'Serveurs à Pékin, Shanghai, Shenzhen ou Canton.',
    headline: 'La vraie option. Chargements sous la seconde, plein effet Baidu.',
    body: 'Votre site vit sur des serveurs en Chine continentale. Selon le projet, nous déployons sur Aliyun, Tencent Cloud ou Huawei Cloud. Nous travaillons avec les trois depuis des années, nous savons précisément ce que chacun apporte.',
    detail: 'Les temps de chargement passent sous la seconde. Baidu accorde un coup de pouce sensible aux sites qui détiennent une licence ICP sur serveur local, ce qui pèse beaucoup si le SEO fait partie de votre stratégie. Nous portons aussi le dépôt ICP de bout en bout.',
    fit: 'Marques engagées sur le marché chinois, projets sérieux sur Baidu, e-commerce, sites qui collectent des données utilisateurs chinois.',
    metrics: [
      { label: 'Chargement', value: '< 1 s' },
      { label: 'ICP', value: 'Requis' },
      { label: 'Effet Baidu', value: 'Fort' },
      { label: 'Mise en ligne', value: '6 à 10 sem.' },
    ],
  },
  {
    name: 'Hong Kong',
    tag: 'Sans ICP',
    tagline: 'Mise en ligne rapide, sans dépôt gouvernemental.',
    headline: 'Un pont vers le continent. Rapide à mettre en route.',
    body: 'Pas encore de licence ICP ? Hong Kong met en ligne plus vite. Sans dépôt. Avec le bon CDN et un cache bien configuré, on parle de deux à quatre secondes de chargement en Chine continentale. Moins rapide que le continental, mais sans commune mesure avec un site servi depuis Francfort ou la Virginie.',
    detail: 'Nous utilisons souvent cette solution comme transition, le temps que les clients obtiennent leur ICP ou décident de s’engager pleinement. Certains clients de longue date sont restés sur Hong Kong sans jamais ressentir le besoin de bouger.',
    fit: 'Lancements rapides, solutions transitoires, projets qui ne peuvent pas obtenir l’ICP tout de suite, marques qui testent le marché.',
    metrics: [
      { label: 'Chargement', value: '2 à 4 s' },
      { label: 'ICP', value: 'Pas requis' },
      { label: 'Effet Baidu', value: 'Faible' },
      { label: 'Mise en ligne', value: '2 à 3 sem.' },
    ],
  },
  {
    name: 'Dual-stack',
    tag: 'Mondial + Chine',
    tagline: 'Continental pour les visiteurs chinois. Pile mondiale pour les autres.',
    headline: 'Une marque, deux architectures, sans compromis.',
    body: 'Certains clients ne peuvent pas tout sacrifier à la Chine. Le site doit fonctionner partout. Pour ces situations, nous montons un partage : les visiteurs depuis la Chine atterrissent sur un serveur continental, les autres restent sur votre dispositif mondial existant.',
    detail: 'Le DNS gère le routage automatiquement. Un seul backend nourrit les deux côtés, le contenu se synchronise. Le site Chine a son ICP propre, le site mondial reste là où il est. Une seule équipe, un seul flux éditorial.',
    fit: 'Marques globales avec une vraie audience chinoise, e-commerce multinational, sites où ni la Chine ni le reste du monde ne peuvent être déprioritisés.',
    metrics: [
      { label: 'Chargement', value: '< 1 s en CN' },
      { label: 'ICP', value: 'Requis (CN)' },
      { label: 'Effet Baidu', value: 'Fort' },
      { label: 'Mise en ligne', value: '8 à 12 sem.' },
    ],
  },
];

const includedItems = [
  { title: 'Mise en place et optimisation serveur', body: 'Hébergement calibré pour votre pile, SSL compatible Chine, pare-feu serveur et protection DDoS configurés pour la réalité derrière le Pare-feu.' },
  { title: 'CDN Chine configuré', body: 'CDN Aliyun ou Tencent Cloud branché. Vos assets sont servis depuis Shanghai ou Chengdu, sans rebondir sur le Pacifique.' },
  { title: 'Supervision depuis la Chine', body: 'La plupart des outils mesurent depuis l’extérieur du Pare-feu, donc les dashboards mentent. Nous surveillons depuis l’intérieur. Détail en apparence, change tout en pratique.' },
  { title: 'Sauvegardes et reprise', body: 'Sauvegardes automatiques quotidiennes, stockage hors site, point-in-time recovery, plan de reprise documenté. Les choses cassent, parfois.' },
  { title: 'Dépôt ICP géré de bout en bout', body: 'Dossier, soumissions, va-et-vient avec l’autorité provinciale. Vous ne vous connectez jamais à une console chinoise, ne lisez jamais un formulaire en chinois.' },
  { title: 'Maintenance continue', body: 'Patches serveur, mises à jour de sécurité, montée en charge, à notre charge. Le site continue de tourner sans que vous ayez à y penser.' },
];

const icpTypes = [
  {
    code: '备案',
    name: 'ICP Bei\'an',
    type: 'Sites informationnels',
    timing: '20+ jours ouvrés',
    body: 'Site corporate, blog, plaquette : tout ce qui n’implique pas de transaction. Le dépôt le plus courant pour les marques étrangères qui se lancent en Chine.',
    docs: ['Immatriculation entreprise', 'Certificat de domaine', 'Pièce d’identité de l’admin', 'Entité chinoise enregistrée'],
  },
  {
    code: '经营许可证',
    name: 'Licence commerciale ICP',
    type: 'Activité commerciale',
    timing: '2 à 3 mois',
    body: 'Sites avec transactions, e-commerce, services payants : tout ce qui est commercial. Procédure plus longue, plus de pièces, examen approfondi de l’autorité provinciale.',
    docs: ['Tout ce qui est requis pour le Bei\'an', 'Examen du périmètre d’activité', 'Vérification du capital', 'Déclaration de finalité commerciale'],
  },
];

const complianceLaws = [
  { abbr: 'PIPL', name: 'Loi sur la protection des informations personnelles', body: 'Encadre le traitement, le stockage et le transfert des données personnelles des résidents chinois. L’équivalent chinois le plus proche du RGPD.' },
  { abbr: 'CSL', name: 'Loi sur la cybersécurité', body: 'Texte fondateur depuis 2017. Pose les règles pour les opérateurs de réseau, les infrastructures critiques et la résidence des données.' },
  { abbr: 'DSL', name: 'Loi sur la sécurité des données', body: 'Classifie les données par sensibilité et impose une protection graduée. Affecte le stockage et les transferts transfrontaliers de données utilisateur chinois.' },
];

const timelines = [
  { label: 'Hong Kong', title: 'Lancement Hong Kong', duration: '2 à 3 semaines', note: 'Pas de dépôt ICP. Le chemin le plus court vers une présence en ligne pour le marché chinois.' },
  { label: 'Continental', title: 'Lancement continental', duration: '6 à 10 semaines', note: 'L’ICP est sur le chemin critique. Nous le démarrons dès le premier jour et menons le reste en parallèle.' },
  { label: 'Dual-stack', title: 'Lancement dual-stack', duration: '8 à 12 semaines', note: 'Dépend de la configuration mondiale actuelle. La moitié continentale dicte le calendrier.' },
];

const audiences = [
  { label: 'Marques qui se lancent en Chine', description: 'Sociétés qui mettent en ligne leur première vraie présence chinoise et veulent l’infrastructure dès le départ.', image: '/images/audiences/launching-chinese-market.webp' },
  { label: 'Sites qui rament', description: 'Sites en place mais lents en Chine, mal indexés par Baidu, ou qui dépendent d’un hébergeur étranger qui ne tient pas.', image: '/images/audiences/live-site-not-performing.webp' },
  { label: 'E-commerce et collecte de données', description: 'Activités qui nécessitent l’ICP commercial et la résidence des données utilisateurs chinois sur le continent.', image: '/images/audiences/ecommerce-china-store.webp' },
  { label: 'Marques globales avec une vraie audience chinoise', description: 'Multinationales qui veulent garder leur dispositif global et ajouter une moitié continentale conforme.', image: '/images/audiences/multinational-china-entry.webp' },
];

const faqs = [
  { id: 'icp-needed', question: 'Avons-nous besoin d’un ICP ?', answer: ['Oui pour héberger sur le continent. Non pour Hong Kong. Si vous comptez sur Baidu pour le trafic organique, l’ICP fait une vraie différence : Baidu favorise les sites avec ICP sur serveur continental, et le crawl est plus régulier. Nous portons le dossier pour vous.'] },
  { id: 'no-chinese-entity', question: 'Et si nous n’avons pas d’entité chinoise ?', answer: ['Pas d’ICP sans entité chinoise enregistrée. Hong Kong reste possible et donne une bonne expérience pour la majorité des projets B2B. Si vous voulez l’ICP, nous pouvons vous orienter vers des partenaires qui montent l’entité.'] },
  { id: 'how-fast', question: 'Combien de temps pour mettre en ligne ?', answer: ['Hong Kong : 2 à 3 semaines. Continental avec ICP : 6 à 10 semaines en moyenne, le dépôt ICP étant sur le chemin critique. Dual-stack : 8 à 12 semaines.'] },
  { id: 'wordpress-fit', question: 'Vous gérez WordPress sur tous les fournisseurs chinois ?', answer: ['Oui. Aliyun, Tencent Cloud et Huawei Cloud, tous configurés pour WordPress. Cache, CDN, sauvegardes, sécurité : la pile complète, calibrée pour la Chine.'] },
  { id: 'data-residency', question: 'Que faire de la résidence des données ?', answer: ['Sous PIPL et CSL, les données utilisateurs chinois doivent rester sur le continent. Nous concevons l’architecture pour respecter cela dès le premier jour, et non trois mois après le lancement.'] },
  { id: 'monitoring', question: 'Comment savoir si le site tient en Chine ?', answer: ['Supervision active depuis nos sondes en Chine continentale. Métriques de chargement réelles, alertes en cas d’incident, rapport mensuel écrit, plus un dashboard live consultable à toute heure.'] },
];
---

<PageLayout title={metaTitle} description={metaDescription} heroPage={true} lang="fr">

  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12] via-[#0f0f12] to-[#1a1a2e]"></div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Fil d’Ariane" class="pt-20 pb-12">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/fr/" class="hover:text-white/70 transition-colors no-underline">Accueil</a></li>
          <li class="before:content-['/'] before:mx-2"><a href="/fr/services/" class="hover:text-white/70 transition-colors no-underline">Services</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Hébergement Chine</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 lg:pb-32">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-6">Hébergement Chine</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-white leading-[1.07]">
            Un hébergement qui tient en Chine.
            <span class="block mt-2 text-[var(--color-brand-orange)]">Sans appeler le siège.</span>
          </h1>
          <p class="mt-8 text-lg text-white/60 max-w-xl leading-relaxed">
            Continental sous licence ICP, ou Hong Kong en pont, ou dual-stack. Nous montons l’hébergement, posons le dépôt, branchons le CDN, et nous supervisons l’ensemble depuis Shanghai.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/fr/contact/" variant="primary" size="lg">Démarrer un hébergement</Button>
          </div>
          <div class="mt-12 grid grid-cols-2 lg:grid-cols-4 gap-6">
            {proofStats.map((s) => (
              <div>
                <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">{s.value}{s.suffix}</div>
                <div class="text-[11px] text-white/55 mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Trois options</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Continental, Hong Kong, ou les deux.
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-6">
        {hostingOptions.map((o) => (
          <article class="bg-[var(--color-surface-light)] rounded-2xl p-7 lg:p-8 border border-[var(--color-surface-border)] flex flex-col">
            <div class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-2">{o.tag}</div>
            <h3 class="text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-2">{o.name}</h3>
            <p class="text-sm font-medium text-[var(--color-brand-orange)] mb-4">{o.tagline}</p>
            <p class="text-base font-medium text-[var(--color-text-dark)] leading-snug mb-3">{o.headline}</p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-3">{o.body}</p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-5">{o.detail}</p>
            <div class="grid grid-cols-2 gap-3 mb-5">
              {o.metrics.map((m) => (
                <div class="rounded-lg bg-white p-3 border border-[var(--color-surface-border)]">
                  <div class="text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider">{m.label}</div>
                  <div class="text-sm font-semibold text-[var(--color-text-dark)] mt-0.5">{m.value}</div>
                </div>
              ))}
            </div>
            <p class="text-xs text-[var(--color-text-muted)] italic mt-auto">Pour : {o.fit}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Inclus</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Six choses dans le forfait, à chaque fois.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {includedItems.map((it) => (
          <article class="bg-white rounded-2xl p-6 border border-[var(--color-surface-border)]">
            <h3 class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{it.title}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{it.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Le dépôt ICP</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Deux types de licence, deux calendriers.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {icpTypes.map((t) => (
          <article class="bg-[var(--color-surface-light)] rounded-2xl p-7 border border-[var(--color-surface-border)]">
            <div class="text-3xl font-medium font-[var(--font-heading)] text-[var(--color-brand-orange)]/80 mb-3">{t.code}</div>
            <h3 class="text-xl font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-1">{t.name}</h3>
            <p class="text-sm text-[var(--color-text-muted)] mb-4">{t.type} · {t.timing}</p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed mb-5">{t.body}</p>
            <div class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-2">Pièces requises</div>
            <ul class="space-y-1.5">
              {t.docs.map((d) => (
                <li class="text-xs text-[var(--color-text-body)] flex gap-2">
                  <span class="text-[var(--color-brand-orange)]">·</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Conformité</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Trois lois qui encadrent les données chinoises.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {complianceLaws.map((l) => (
          <article class="bg-white rounded-2xl p-7 border border-[var(--color-surface-border)]">
            <div class="text-2xl font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)] mb-2">{l.abbr}</div>
            <h3 class="text-base font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{l.name}</h3>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{l.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">Calendrier</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Trois chemins, trois calendriers.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {timelines.map((t) => (
          <article class="bg-[var(--color-surface-light)] rounded-2xl p-7 border border-[var(--color-surface-border)]">
            <div class="text-[11px] font-mono uppercase tracking-wider text-[var(--color-brand-orange)] mb-2">{t.label}</div>
            <h3 class="text-lg font-semibold font-[var(--font-heading)] text-[var(--color-text-dark)] mb-1">{t.title}</h3>
            <p class="text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">{t.duration}</p>
            <p class="text-sm text-[var(--color-text-body)] leading-relaxed">{t.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <WhoIsThisFor heading="Qui nous mandate pour l’hébergement" audiences={audiences} background="light" />

  <section id="faq" class="section-spacing bg-white">
    <div class="mx-auto max-w-[1100px] section-padding">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">FAQ</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]">
          Six questions sur l’hébergement.
        </h2>
      </div>

      <div data-faq-accordion>
        {faqs.map((faq) => (
          <FAQItem question={faq.question} id={faq.id}>
            {faq.answer.map((p) => <p class="mb-3 last:mb-0">{p}</p>)}
          </FAQItem>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[var(--color-surface-dark)]">
    <div class="mx-auto max-w-[1100px] section-padding text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.1] mb-6">
        Prêts à mettre votre site en ligne en Chine ?
      </h2>
      <p class="text-lg text-white/70 leading-relaxed mb-10 max-w-2xl mx-auto">
        Décrivez-nous le périmètre. Nous renvoyons sous deux jours ouvrés un cadrage et un calendrier.
      </p>
      <Button href="/fr/contact/" variant="primary" size="lg">Démarrer</Button>
    </div>
  </section>

</PageLayout>
