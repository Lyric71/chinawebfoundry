---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQAccordion from '../components/pages/FAQAccordion.astro';
import { getCollection } from 'astro:content';

const teamMembers = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);

const departments = [
  {
    title: 'WordPress Engineering',
    subtitle: '5+ years China-focused experience per engineer',
    description: 'Senior developers specialising in multisite/multilingual architectures, headless WordPress, plugin governance, CI/CD pipelines, and performance tuning specifically for China\u2019s network conditions.',
  },
  {
    title: 'Infrastructure & DevOps',
    subtitle: 'Alibaba Cloud, Tencent Cloud, and Private Server Operations',
    description: 'Engineers managing our own servers and cloud deployments with expertise in CDN optimisation, caching, observability, disaster recovery, and cost-performance tuning for mainland China.',
  },
  {
    title: 'Chinese UX/UI Design',
    subtitle: 'Purely Local Design Team',
    description: 'Designers who build for actual Chinese user expectations including WeChat/Alipay integrations, mobile-first layouts, payment UX, and navigation patterns that feel native to Chinese users.',
  },
  {
    title: 'Chinese Copywriting & Localisation',
    subtitle: 'Beyond Translation',
    description: 'Native copywriters who rewrite English content with culturally relevant tone, local search intent alignment, and SEO optimisation so it reads naturally in Chinese and persuades local audiences.',
  },
  {
    title: 'Baidu SEO & China Search Optimisation',
    subtitle: 'Native Baidu Expertise',
    description: 'SEO specialists who optimise for Baidu\u2019s unique ranking factors, crawlability requirements, and Chinese search behaviour \u2014 not Western SEO practices translated to China.',
  },
  {
    title: 'Security & Compliance',
    subtitle: 'WordPress Hardening and Local Regulatory Guidance',
    description: 'Specialists implementing WAF, plugin audits, encrypted backups, vulnerability management, and providing guidance on ICP/\u5907\u6848 licensing and data residency requirements.',
  },
  {
    title: 'Project Management & Client Success',
    subtitle: 'Bilingual PMs Who Bridge Global and China Teams',
    description: 'Project managers running sprints, tracking progress, managing risks, and ensuring clear communication with defined acceptance criteria, continuous delivery, and monthly reporting.',
  },
];

const values = [
  {
    title: 'China-First Execution, Not Adaptation',
    description: 'We don\u2019t retrofit Western solutions for China. We build from a China-native perspective \u2014 knowing the infrastructure, the user behaviours, the regulatory landscape, and the platforms that matter. Our work is designed to succeed in China from day one.',
  },
  {
    title: 'Measurable Outcomes Over Buzzwords',
    description: 'We define success in metrics you can verify: Core Web Vitals from mainland China, crawlability on Baidu, uptime, localised content performance. Every deliverable ties to a measurable commitment.',
  },
  {
    title: 'Transparency & Accountability',
    description: 'We work with clear roadmaps, acceptance criteria, and risk logs. You know what\u2019s being built, why, and when. If something blocks progress, you hear it from us first \u2014 with a mitigation plan already in motion.',
  },
  {
    title: 'Long-Term Partnership',
    description: 'Launching a WordPress site in China isn\u2019t a one-time event. We\u2019re structured for ongoing optimisation, security, performance monitoring, and continuous improvement. We succeed when your China presence thrives over time.',
  },
];
---

<PageLayout
  title="Who We Are | ChinaWebFoundry \u2014 WordPress China Agency"
  description="Meet the China-based team behind ChinaWebFoundry. 30+ specialists in WordPress engineering, Baidu SEO, Chinese UX, and infrastructure \u2014 built for China delivery."
  heroPage={true}
>
  <!-- Hero intro -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero-who-we-are.webp"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f12]/90 via-[#0f0f12]/70 to-[#0f0f12]/30"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f0f12]/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding pt-32 lg:pt-40 pb-24 md:pb-32 lg:pb-40">
      <div class="io-grid items-start gap-y-10">
        <div class="col-span-12 lg:col-span-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Who We Are
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.08]">
            Grounded Locally, Built for Global Standards
          </h1>
        </div>
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 lg:pt-10">
          <p class="text-lg text-white/60 leading-relaxed">
            If you're outside China but need a WordPress presence inside China, we bridge that gap. We speak both languages - literally and technically.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team departments: split layout with divider list -->
  <section class="py-24 md:py-32 lg:py-40 bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start gap-y-16">
        <!-- Left: heading + CTA -->
        <div class="col-span-12 lg:col-span-5 lg:sticky lg:top-24">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Our Team
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
            Built for China Delivery
          </h2>
          <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed">
            We're a cross-functional, bilingual team organised around one goal: making WordPress work reliably and performantly for the Chinese market.
          </p>
          <div class="mt-10">
            <Button href="/contact/" variant="primary" size="md">Work with us</Button>
          </div>
        </div>

        <!-- Right: department list with dividers -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="divider-list border-t border-[var(--color-surface-border)]">
            {departments.map((dept) => (
              <div class="py-8">
                <h3 class="text-xl sm:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-snug">
                  {dept.title}
                </h3>
                <p class="mt-1 text-sm font-medium text-[var(--color-brand-orange)]">
                  {dept.subtitle}
                </p>
                <p class="mt-3 text-base text-[var(--color-text-body)] leading-relaxed">
                  {dept.description}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="py-24 md:py-32 lg:py-40">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start gap-y-16">
        <div class="col-span-12 lg:col-span-5">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Leadership
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
            Meet the people behind ChinaWebFoundry
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-12">
            {teamMembers.map((member) => (
              <div class="flex flex-col sm:flex-row gap-6 items-start">
                {member.data.linkedin ? (
                  <a href={member.data.linkedin} target="_blank" rel="noopener noreferrer" class="flex-shrink-0">
                    <img
                      src={member.data.photo}
                      alt={`Photo of ${member.data.name}`}
                      class="w-32 h-32 rounded-full object-cover"
                      width="128"
                      height="128"
                      loading="lazy"
                    />
                  </a>
                ) : (
                  <img
                    src={member.data.photo}
                    alt={`Photo of ${member.data.name}`}
                    class="w-32 h-32 rounded-full object-cover flex-shrink-0"
                    width="128"
                    height="128"
                    loading="lazy"
                  />
                )}
                <div>
                  <h3 class="text-xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)]">
                    {member.data.name}
                  </h3>
                  <p class="text-sm font-medium text-[var(--color-brand-orange)] mt-1">
                    {member.data.role}
                  </p>
                  <p class="mt-3 text-base text-[var(--color-text-body)] leading-relaxed">
                    {member.data.bio}
                  </p>
                  {(member.data.linkedin || member.data.substack) && (
                    <div class="flex items-center gap-4 mt-3">
                      {member.data.linkedin && (
                        <a href={member.data.linkedin} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] transition-colors" aria-label={`${member.data.name} on LinkedIn`}>
                          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                          </svg>
                        </a>
                      )}
                      {member.data.substack && (
                        <a href={member.data.substack} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-orange)] transition-colors" aria-label={`${member.data.name} on Substack`}>
                          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
                          </svg>
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values: dark section -->
  <section class="relative bg-[var(--color-surface-dark)] py-24 md:py-32 lg:py-40 overflow-hidden">
    <!-- Subtle background decoration -->
    <div class="absolute inset-0 opacity-[0.04]">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-white to-transparent"></div>
      <div class="absolute bottom-0 left-1/4 w-96 h-96 rounded-full bg-[var(--color-brand-orange)]" style="filter: blur(120px);"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start gap-y-16">
        <!-- Left: heading -->
        <div class="col-span-12 lg:col-span-5">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            Our Values
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-white leading-[1.1]">
            The Principles That Guide Every Project We Deliver
          </h2>
        </div>

        <!-- Right: values list -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <div class="space-y-10">
            {values.map((v) => (
              <div>
                <h3 class="text-xl sm:text-2xl font-medium font-[var(--font-heading)] text-white leading-snug">
                  {v.title}
                </h3>
                <p class="mt-3 text-base text-white/60 leading-relaxed">
                  {v.description}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ: split layout -->
  <section class="py-24 md:py-32 lg:py-40">
    <div class="mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start gap-y-16">
        <div class="col-span-12 lg:col-span-5 lg:sticky lg:top-24">
          <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-brand-orange)] mb-5">
            FAQ
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.08]">
            Common questions about working with our team
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-6 lg:col-start-7">
          <FAQAccordion />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32 lg:py-40 bg-[var(--color-surface-light)]">
    <div class="mx-auto max-w-[1400px] section-padding text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-tight mb-6">
        Want to work with us?
      </h2>
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed max-w-xl mx-auto mb-10">
        We'd love to hear about your project. Get in touch and we'll respond within 24 hours.
      </p>
      <Button href="/contact/" variant="primary" size="lg">Contact Us</Button>
    </div>
  </section>
</PageLayout>
