---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQItem from '../components/pages/FAQItem.astro';
import ScrollEffects from '../components/pages/ScrollEffects.astro';
import { getCollection } from 'astro:content';

const teamMembers = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);

const disciplines = [
  {
    title: 'Strategists',
    cn: '战略',
    icon: 'compass',
    accent: '#F25F29',
    description: 'Senior people who have built China go-to-market plans for global brands across luxury, consumer, B2B, SaaS, and professional services. Audit, positioning, roadmap. The work that decides whether the next twelve months pay off or get wasted.',
    chips: ['Audit', 'Positioning', 'Roadmap', 'GTM'],
  },
  {
    title: 'Content specialists',
    cn: '内容',
    icon: 'pen',
    accent: '#EF4444',
    description: 'Native Chinese copywriters who don’t translate, they rewrite. Articles built around real Baidu keyword research. Case studies written for AI engines to cite. Product pages structured for how Chinese buyers actually scan and decide.',
    chips: ['Native rewrite', 'Baidu intent', 'AI-citable', 'Product pages'],
  },
  {
    title: 'UX/UI designers',
    cn: '设计',
    icon: 'layers',
    accent: '#4D6BFE',
    description: 'Local team building for Chinese user expectations from the start. Mobile-first because over 80 percent of traffic is mobile. WeChat (微信) and Alipay (支付宝) flows that feel native. The trust signals that move conversions in China.',
    chips: ['Mobile-first', 'WeChat', 'Alipay', 'Trust signals'],
  },
  {
    title: 'Tech integrators',
    cn: '技术',
    icon: 'code',
    accent: '#10B981',
    description: 'Senior developers with five years or more of China-specific experience each. WordPress and Astro builds, headless setups, plugin governance, CI/CD tuned for Chinese network conditions. ICP-licensed (ICP备案) hosting on Aliyun, Tencent Cloud, or Huawei Cloud, end to end.',
    chips: ['WordPress', 'Astro', 'Headless', 'ICP hosting'],
  },
  {
    title: 'SEO and GEO experts',
    cn: '搜索',
    icon: 'search',
    accent: '#F59E0B',
    description: 'Baidu SEO specialists who optimise for how Baiduspider actually crawls. GEO specialists running weekly visibility checks across DeepSeek, Doubao, Kimi, Yuanbao, and Baidu AI, adjusting content and syndication as the models evolve.',
    chips: ['Baidu SEO', 'DeepSeek', 'Doubao', 'Yuanbao'],
  },
];

const ticker = [
  'Strategy', '战略',
  'Content', '内容',
  'Design', '设计',
  'Technology', '技术',
  'Hosting', 'ICP备案',
  'Baidu SEO', '百度',
  'GEO', 'AI search',
  'WeChat', '微信',
  'Alipay', '支付宝',
  'Aliyun', '阿里云',
  'Tencent Cloud', '腾讯云',
  'Huawei Cloud', '华为云',
  'DeepSeek', '深度求索',
  'Doubao', '豆包',
  'Kimi', 'Yuanbao',
];

const faqs = [
  {
    id: 'who-actually-works',
    question: 'Who actually works on our project?',
    answer: 'The team you meet at proposal stage is the team that does the work. Strategist, designer, developer, SEO lead all join kickoff. No bait and switch where seniors pitch and juniors deliver.',
  },
  {
    id: 'how-involved-week-to-week',
    question: 'How involved do we need to be week to week?',
    answer: 'Most clients commit two to three hours: a 45-minute weekly check-in, async review of work in progress, a longer monthly review. We don’t need approvals on every comma, but we do need a clear point of contact who can decide without escalating for two weeks.',
  },
  {
    id: 'time-difference-handling',
    question: 'How do you handle the time difference?',
    answer: 'Project managers overlap with European hours in the morning and North American teams in our evening. Weekly written updates land before you log on. Slack, Teams, Zoom, whatever you use.',
  },
  {
    id: 'strategy-execution-alignment',
    question: 'How do you make sure strategy doesn’t drift from execution?',
    answer: 'The person who writes the strategy briefs the writer, the designer, and the developer. No handoff documents that get reinterpreted six times. When strategy flexes, the change happens in one room, not across three agencies.',
  },
  {
    id: 'existing-team-or-agency',
    question: 'What if we already have an internal team or another agency?',
    answer: 'We work alongside in-house teams and other agencies often, especially when clients keep global brand teams in place while we handle China execution. Scope boundaries written up front, joint stand-ups when it helps.',
  },
  {
    id: 'keep-us-in-the-loop',
    question: 'How do you keep us in the loop?',
    answer: 'Weekly written update covering shipped, in-progress, blocked, and what we need from you. Shared dashboard with live metrics. A 45-minute call weekly, longer monthly. That’s it.',
  },
  {
    id: 'when-we-disagree',
    question: 'What happens when we disagree?',
    answer: 'We say it. If we think a brief will fail in China, we push back before work starts, with reasoning and an alternative. Better the uncomfortable conversation in week two than a failed deliverable in month six.',
  },
  {
    id: 'after-launch',
    question: 'What does the relationship look like after launch?',
    answer: 'Most clients move into an ongoing engagement: content, SEO and GEO follow-up, technical maintenance, hosting. Same team. No re-explaining your brand to a new account manager every quarter.',
  },
];
---

<PageLayout
  title="Who We Are | ChinaWebFoundry"
  description="Strategists, content specialists, UX/UI designers, tech integrators, SEO and GEO experts. One team, in China, for 20 years."
  heroPage={true}
>
  <ScrollEffects />

  <!-- HERO -->
  <section class="relative bg-[var(--color-surface-dark)] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero-who-we-are-office.webp"
        alt=""
        class="absolute inset-0 w-full h-full object-cover opacity-70"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f0f12]/95 via-[#0f0f12]/80 to-[#0f0f12]/55"></div>
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)]/15 blur-[120px] pointer-events-none" data-float="slow"></div>
      <div class="absolute -bottom-40 right-[5%] w-[520px] h-[520px] rounded-full bg-[#4D6BFE]/15 blur-[140px] pointer-events-none" data-float></div>
    </div>

    <span aria-hidden="true" class="absolute right-[-3rem] top-1/2 -translate-y-1/2 text-[26rem] lg:text-[32rem] font-medium font-[var(--font-heading)] text-white/[0.025] leading-none select-none pointer-events-none hidden md:block" data-parallax="0.1">团</span>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <nav aria-label="Breadcrumb" class="pt-20 pb-12 md:pb-16">
        <ol class="flex items-center gap-2 text-sm text-white/40">
          <li><a href="/" class="hover:text-white/70 transition-colors no-underline">Home</a></li>
          <li class="before:content-['/'] before:mx-2 text-white/60">Who We Are</li>
        </ol>
      </nav>

      <div class="io-grid items-center pb-20 md:pb-28 lg:pb-36">
        <div class="col-span-12 lg:col-span-7" data-reveal>
          <div class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full bg-white/[0.06] border border-white/15 backdrop-blur-sm mb-7">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-orange)] animate-pulse"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">Who We Are</span>
            <span class="text-white/30">·</span>
            <span class="text-[11px] font-medium text-white/55">5 disciplines, 1 team</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[68px] font-medium font-[var(--font-heading)] text-white leading-[1.02] tracking-tight">
            <span class="bg-gradient-to-r from-[var(--color-brand-orange)] via-[#FF7E47] to-[var(--color-brand-orange)] bg-clip-text text-transparent">Grounded locally.</span>
            <span class="block mt-1.5 text-white/95">Built for global standards.</span>
          </h1>

          <p class="mt-7 text-lg lg:text-xl text-white/70 max-w-2xl leading-relaxed">
            If you sit outside China but need a serious presence inside China, we close that gap. A full multidisciplinary team that has been doing this work, on the ground, for over <span class="text-white font-medium">twenty years</span>.
          </p>

          <div class="mt-10 grid grid-cols-3 gap-4 max-w-xl">
            <div class="border-l-2 border-[var(--color-brand-orange)]/60 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">
                <span data-counter data-counter-suffix="+">20</span>
              </div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Years in China</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">
                <span data-counter>5</span>
              </div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">Disciplines</div>
            </div>
            <div class="border-l-2 border-white/15 pl-4">
              <div class="text-2xl lg:text-3xl font-medium font-[var(--font-heading)] text-white">
                <span data-counter data-counter-suffix="%">100</span>
              </div>
              <div class="text-[11px] uppercase tracking-wider text-white/50 mt-1">In-house, in China</div>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="/contact/" variant="primary" size="lg">Work with us</Button>
            <Button href="#leadership" variant="ghost" size="lg" class="!text-white/70 hover:!text-white">Meet the team</Button>
          </div>
        </div>

        <!-- Right: layered floating discipline chips -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-14 lg:mt-0" data-reveal="right" data-reveal-delay="120">
          <div class="relative h-[420px]">
            <!-- Back card: client outside China -->
            <div class="absolute top-0 left-0 right-12 rounded-2xl bg-white/[0.03] backdrop-blur-sm border border-white/10 p-5 rotate-[-3deg]">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[10px] font-mono text-white/40 uppercase tracking-wider">You</span>
                <span class="ml-auto text-[10px] font-mono text-white/30">outside China</span>
              </div>
              <div class="space-y-2">
                <div class="h-2.5 w-3/4 rounded bg-white/10"></div>
                <div class="h-2 w-full rounded bg-white/5"></div>
                <div class="h-2 w-5/6 rounded bg-white/5"></div>
              </div>
            </div>

            <!-- Middle: connection line -->
            <div class="absolute top-[120px] left-1/2 -translate-x-1/2 w-px h-12 bg-gradient-to-b from-white/30 to-[var(--color-brand-orange)]/60"></div>

            <!-- Front card: stacked disciplines -->
            <div data-tilt class="absolute top-[160px] left-4 right-0 rounded-2xl bg-white shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)] overflow-hidden">
              <div class="flex items-center gap-2.5 px-5 py-3 bg-white border-b border-gray-100">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[var(--color-brand-orange)] to-[#FF7E47] flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-7m0 0V3m0 11h11m6 7v-7m0 0V3m0 11h-6"/></svg>
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="text-sm font-semibold text-gray-900">ChinaWebFoundry</span>
                  <span class="text-[10px] text-gray-400">在中国 · Shanghai</span>
                </div>
                <div class="ml-auto flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                  <span class="text-[10px] text-gray-400">在线</span>
                </div>
              </div>

              <div class="px-5 py-4 space-y-2.5 bg-white">
                {disciplines.map((d, i) => (
                  <div class="flex items-center gap-3" data-reveal data-reveal-delay={String(i * 80)}>
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style={`background-color: ${d.accent}15; color: ${d.accent}`}>
                      <span class="text-[11px] font-medium">{d.cn}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[12.5px] font-medium text-gray-900 truncate">{d.title}</div>
                    </div>
                    <svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                ))}
              </div>

              <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
                <span class="text-[10px] font-mono text-gray-500">One team. One brief. One Slack.</span>
                <span class="text-[10px] font-mono text-emerald-600">No handoff tax</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Marquee strip -->
    <div class="relative border-t border-white/[0.08] bg-[#0f0f12]/60 backdrop-blur-sm overflow-hidden">
      <div class="flex whitespace-nowrap py-4 gap-10" style="animation: marquee 50s linear infinite; width: 300%;">
        {[...ticker, ...ticker, ...ticker].map((item) => (
          <span class="text-sm text-white/40 font-medium tracking-wider flex items-center gap-10">
            <span>{item}</span>
            <span class="text-[var(--color-brand-orange)]/40">●</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- INTRO STATEMENT -->
  <section class="relative py-24 md:py-32 lg:py-40 bg-white overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.04]">
      <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-gradient-to-bl from-[var(--color-brand-orange)] to-transparent blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-[1100px] section-padding">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)] text-center mb-6" data-reveal>One team. One brief.</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[52px] text-center font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.1]" data-reveal data-reveal-delay="80">
        Not a tech agency that picked up some marketing.<br class="hidden sm:block" />
        Not a marketing agency that bolted on a developer.
      </h2>
      <p class="mt-8 text-xl text-center text-[var(--color-text-body)] max-w-3xl mx-auto leading-relaxed" data-reveal data-reveal-delay="160">
        We are a full team built around one job: making your website actually work for the China market. <span class="text-[var(--color-text-dark)] font-medium">Strategy, content, design, technology, and search</span> all under the same roof.
      </p>

      <div class="mt-16 grid grid-cols-2 md:grid-cols-5 gap-px bg-[var(--color-surface-border)] border border-[var(--color-surface-border)] rounded-2xl overflow-hidden" data-reveal data-reveal-delay="240">
        {disciplines.map((d) => (
          <div class="bg-white p-6 text-center hover:bg-[var(--color-surface-light)] transition-colors group">
            <div class="text-3xl font-medium font-[var(--font-heading)] mb-2 transition-transform group-hover:scale-110" style={`color: ${d.accent}`}>{d.cn}</div>
            <div class="text-xs uppercase tracking-wider text-[var(--color-text-muted)]">{d.title}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FIVE DISCIPLINES -->
  <section id="disciplines" class="relative py-24 md:py-32 lg:py-40 bg-[var(--color-surface-light)] overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.05] pointer-events-none">
      <div class="absolute top-1/4 left-0 w-96 h-96 rounded-full bg-[var(--color-brand-orange)] blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-96 h-96 rounded-full bg-[#4D6BFE] blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] section-padding">
      <div class="max-w-3xl mb-16 lg:mb-20" data-reveal>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)] mb-5">What We Do</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[56px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.05]">
          Five disciplines.<br />
          <span class="text-[var(--color-brand-orange)]">One team.</span>
        </h2>
        <p class="mt-6 text-lg text-[var(--color-text-body)] leading-relaxed max-w-2xl">
          Senior people in every seat. No outsourcing, no white-labelling, no offshore handoffs. The whole stack, in one office.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-5 auto-rows-fr">
        {disciplines.map((d, i) => (
          <article
            data-reveal
            data-reveal-delay={String(i * 90)}
            data-cursor-spotlight
            class:list={[
              'group relative bg-white rounded-2xl p-7 lg:p-8 border border-[var(--color-surface-border)] overflow-hidden transition-all duration-300 hover:border-[var(--color-brand-orange)]/30 hover:shadow-[0_30px_80px_-40px_rgba(0,0,0,0.25)] hover:-translate-y-1 flex flex-col',
              i === 0 && 'lg:col-span-7',
              i === 1 && 'lg:col-span-5',
              i === 2 && 'lg:col-span-4',
              i === 3 && 'lg:col-span-4',
              i === 4 && 'md:col-span-2 lg:col-span-4',
            ]}
          >
            <!-- decorative Chinese watermark -->
            <span aria-hidden="true" class="absolute -right-4 -top-4 text-[9rem] font-medium font-[var(--font-heading)] leading-none select-none pointer-events-none transition-transform duration-500 group-hover:scale-110 group-hover:-rotate-6" style={`color: ${d.accent}; opacity: 0.07`}>{d.cn}</span>

            <div class="relative flex flex-col flex-1">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style={`background-color: ${d.accent}15; color: ${d.accent}`}>
                {d.icon === 'compass' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 8l-2 5-5 2 2-5z"/></svg>
                )}
                {d.icon === 'pen' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 4l4 4-12 12H4v-4L16 4zM14 6l4 4"/></svg>
                )}
                {d.icon === 'layers' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l9 5-9 5-9-5 9-5zM3 13l9 5 9-5M3 18l9 5 9-5"/></svg>
                )}
                {d.icon === 'code' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7l-5 5 5 5M16 7l5 5-5 5M14 4l-4 16"/></svg>
                )}
                {d.icon === 'search' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path stroke-linecap="round" d="M21 21l-4.5-4.5"/></svg>
                )}
              </div>

              <h3 class="text-xl lg:text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] mb-3">
                {d.title}
              </h3>
              <p class="text-base text-[var(--color-text-body)] leading-relaxed mb-6 flex-1">
                {d.description}
              </p>

              <div class="flex flex-wrap gap-2 pt-5 border-t border-[var(--color-surface-border)]">
                {d.chips.map((chip) => (
                  <span class="text-[11px] font-medium px-2.5 py-1 rounded-full bg-[var(--color-surface-light)] text-[var(--color-text-body)] border border-[var(--color-surface-border)] group-hover:border-[var(--color-brand-orange)]/30 transition-colors">
                    {chip}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY THIS MIX WORKS -->
  <section class="relative bg-[var(--color-surface-dark)] py-24 md:py-32 lg:py-40 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.06]">
      <div class="absolute top-1/4 right-0 w-[600px] h-[600px] rounded-full bg-[var(--color-brand-orange)] blur-[160px]"></div>
      <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] rounded-full bg-[#4D6BFE] blur-[160px]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1400px] section-padding">
      <div class="io-grid items-start gap-y-16">
        <div class="col-span-12 lg:col-span-5" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-orange)] mb-5">Why It Works</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-medium font-[var(--font-heading)] text-white leading-[1.08]">
            No handoff tax<br />between disciplines.
          </h2>
          <p class="mt-6 text-lg text-white/65 leading-relaxed">
            Most agencies sell strategy, then hand execution to a different team that doesn’t have the local context. Slides look good, the work falls apart across months of back-and-forth.
          </p>
          <p class="mt-4 text-lg text-white/65 leading-relaxed">
            We built it so that doesn’t happen. The strategist briefs the writer directly. The designer co-builds the page with the developer. The SEO lead reviews content before it ships.
          </p>

          <div class="mt-10 grid grid-cols-2 gap-3 max-w-md">
            <div class="rounded-xl bg-red-500/[0.07] border border-red-500/20 p-4">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round"/></svg>
                <span class="text-[11px] font-mono uppercase tracking-wider text-red-300/80">Most agencies</span>
              </div>
              <p class="text-sm text-white/70 leading-snug">3 vendors, 6 handoffs, slides that look great</p>
            </div>
            <div class="rounded-xl bg-emerald-500/[0.07] border border-emerald-500/20 p-4">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span class="text-[11px] font-mono uppercase tracking-wider text-emerald-300/80">ChinaWebFoundry</span>
              </div>
              <p class="text-sm text-white/70 leading-snug">1 team, 0 handoffs, work that ships</p>
            </div>
          </div>
        </div>

        <!-- Right: connected disciplines diagram -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7" data-reveal="right" data-reveal-delay="120">
          <div class="relative aspect-square max-w-[520px] mx-auto">
