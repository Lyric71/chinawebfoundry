---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides
    .filter((guide) => guide.data.published)
    .map((guide) => ({
      params: { slug: guide.id },
      props: { guide },
    }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
---

<PageLayout
  title={`${guide.data.title} | China Web Guide | ChinaWebFoundry`}
  description={guide.data.summary}
>
  <article class="py-20 md:py-28">
    <div class="mx-auto max-w-[800px] section-padding">
      <!-- Header -->
      <div class="mb-12">
        <a
          href="/china-web-guide/"
          class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-brand-orange)] no-underline hover:gap-3 transition-all duration-200 mb-8"
        >
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
          Back to China Web Guide
        </a>
        <h1 class="text-3xl sm:text-4xl lg:text-[44px] font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] leading-[1.12] mb-4">
          {guide.data.title}
        </h1>
        <p class="text-lg text-[var(--color-brand-orange)] font-medium">
          {guide.data.subtitle}
        </p>
      </div>

      <!-- Visual -->
      {guide.data.visual && (
        <div class="aspect-[16/9] rounded-2xl overflow-hidden mb-12 bg-[var(--color-surface-light)]">
          <img
            src={guide.data.visual}
            alt=""
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-lg max-w-none
        prose-headings:font-[var(--font-heading)] prose-headings:text-[var(--color-text-dark)] prose-headings:font-medium
        prose-p:text-[var(--color-text-body)] prose-p:leading-relaxed
        prose-li:text-[var(--color-text-body)]
        prose-strong:text-[var(--color-text-dark)]
        prose-a:text-[var(--color-brand-orange)] prose-a:no-underline hover:prose-a:underline
      ">
        <Content />
      </div>

      <!-- Footer CTA -->
      <div class="mt-16 pt-12 border-t border-[var(--color-surface-border)]">
        <h2 class="text-2xl font-medium font-[var(--font-heading)] text-[var(--color-text-dark)] mb-4">
          Need help with this?
        </h2>
        <p class="text-[var(--color-text-body)] leading-relaxed mb-8">
          ChinaWebFoundry handles WordPress projects in China end to end. If any of this feels like more than you want to tackle alone, get in touch.
        </p>
        <Button href="/contact/" variant="primary" size="md">Talk to Us</Button>
      </div>
    </div>
  </article>
</PageLayout>
