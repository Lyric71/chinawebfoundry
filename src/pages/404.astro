---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout
  title="Page not found | ChinaWebFoundry"
  description="The page you are looking for is missing or has moved. Head back to the home page or browse our work and services for international brands in China."
>
  <section class="section-spacing">
    <Container class="text-center">
      <h1 class="text-6xl font-semibold font-[var(--font-heading)] text-[var(--color-brand-orange)] mb-4">404</h1>
      <p class="text-xl text-[var(--color-text-dark)] font-[var(--font-heading)] mb-2">Page not found</p>
      <p class="text-[var(--color-text-body)] mb-8">The page you are looking for does not exist or has been moved.</p>
      <Button href="/" variant="primary" size="lg">Back to Homepage</Button>
    </Container>
  </section>
</PageLayout>
